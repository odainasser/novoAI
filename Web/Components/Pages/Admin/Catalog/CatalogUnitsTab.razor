    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);

        // Start all requests in parallel
        var unitsTask = LoadUnits();
        var supportTask = Task.WhenAll(
            LoadUnitTypes(), LoadFilterProducts(), LoadFilterCategories(),
            LoadFilterSuppliers());

        // Wait for units first so the table renders immediately
        await unitsTask;

        // Let filter data finish loading in the background
        _ = FinishLoadingSupportDataAsync(supportTask);
    }

    private async Task FinishLoadingSupportDataAsync(Task supportTask)
    {
        try { await supportTask; } catch { }
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadUnitTypes() { try { unitTypes = await LookupService.GetLookupsByParentAsync("UNIT_TYPE"); } catch { } }
    private async Task LoadFilterProducts() { try { var r = await ProductService.GetAllProductsAsync(1, 1000); filterProducts = r.Items; } catch { } }
    private async Task LoadFilterCategories() { try { var r = await CategoryService.GetAllCategoriesAsync(1, 1000); filterCategories = r.Items; } catch { } }
    private async Task LoadFilterSuppliers() { try { var r = await SupplierService.GetAllSuppliersAsync(1, 1000); filterSuppliers = r.Items.ToList(); } catch { } }

    private async Task LoadUnits()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            ItemStatus? status = string.IsNullOrEmpty(selectedStatus) ? null : (ItemStatus)int.Parse(selectedStatus);
            Guid? unitTypeId = string.IsNullOrEmpty(selectedUnitTypeId) ? null : Guid.Parse(selectedUnitTypeId);
            Guid? productId = selectedProductId;
            Guid? categoryId = string.IsNullOrEmpty(selectedCategoryId) ? null : Guid.Parse(selectedCategoryId);
            Guid? supplierId = string.IsNullOrEmpty(selectedSupplierId) ? null : Guid.Parse(selectedSupplierId);
            var result = await UnitService.GetAllAsync(pageIndex, pageSize, search, productId, null, null, unitTypeId, categoryId, supplierId, status);
            units = result.Items;
            totalPages = result.TotalPages;
            totalCount = result.TotalCount;
            await LoadPendingRequestFlagsAsync();
        }
        catch (Exception ex) { errorMessage = Localizer["FailedToLoadUnits"] + $": {ex.Message}"; }
        finally { isLoading = false; }
    }

    private async Task LoadPendingRequestFlagsAsync()
    {
        unitIdsNeedingAction.Clear();
        if (!units.Any()) return;

        var visibleUnitIds = units.Select(u => u.Id).ToHashSet();
        var pendingRequests = new List<RequestDto>();
        try
        {
            var pending = await RequestService.GetAllRequestsAsync(
                1,
                1000,
                type: null,
                status: RequestStatus.Pending);
            pendingRequests = pending.Items;
        }
        catch
        {
            try
            {
                var pendingMine = await RequestService.GetMyRequestsAsync(
                    1,
                    1000,
                    search: null,
                    type: null,
                    status: RequestStatus.Pending);
                pendingRequests = pendingMine.Items;
            }
            catch
            {
                // Ignore request label loading errors to keep main list usable.
                return;
            }
        }

        foreach (var req in pendingRequests)
        {
            if (req.UnitId.HasValue && visibleUnitIds.Contains(req.UnitId.Value))
            {
                unitIdsNeedingAction.Add(req.UnitId.Value);
                continue;
            }

            var unitId = ExtractEntityIdFromRequest(req.NewDataJson, req.OldDataJson, "UnitId", "unitId", "Id", "id");
            if (unitId.HasValue && visibleUnitIds.Contains(unitId.Value))
                unitIdsNeedingAction.Add(unitId.Value);
        }
    }

    private static Guid? ExtractEntityIdFromRequest(string? newDataJson, string? oldDataJson, params string[] keys)
    {
        return ExtractGuid(newDataJson, keys) ?? ExtractGuid(oldDataJson, keys);
    }

    private static Guid? ExtractGuid(string? json, params string[] keys)
    {
        if (string.IsNullOrWhiteSpace(json)) return null;

        try
        {
            using var doc = JsonDocument.Parse(json);
            return ExtractGuidFromElement(doc.RootElement, keys);
        }
        catch
        {
            return null;
        }
    }

    private static Guid? ExtractGuidFromElement(JsonElement element, params string[] keys)
    {
        if (element.ValueKind == JsonValueKind.Object)
        {
            foreach (var prop in element.EnumerateObject())
            {
                if (keys.Contains(prop.Name, StringComparer.OrdinalIgnoreCase))
                {
                    if (prop.Value.ValueKind == JsonValueKind.String && Guid.TryParse(prop.Value.GetString(), out var parsed))
                        return parsed;
                }

                var nested = ExtractGuidFromElement(prop.Value, keys);
                if (nested.HasValue)
                    return nested;
            }
        }
        else if (element.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in element.EnumerateArray())
            {
                var nested = ExtractGuidFromElement(item, keys);
                if (nested.HasValue)
                    return nested;
            }
        }

        return null;
    }


