@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using Web.Components.Common
@using Web.Models.Enums
@using Web.Models.Requests
@using Web.Models.Units
@using Web.Models.Lookups
@using Web.Models.Suppliers
@using System.Globalization
@using System.Text.Json
@inject IUnitService UnitService
@inject IProductService ProductService
@inject ICategoryService CategoryService
@inject ILookupService LookupService
@inject IRequestService RequestService
@inject ISupplierService SupplierService
@inject Web.Services.IRequestService RequestService
@inject NavigationManager Navigation

<div class="flex justify-end mb-4">
    <AuthorizeView Policy="Permission:units.write">
        <Authorized>
            <button @onclick="NavigateToCreate"
                    class="btn-primary-action">
                <i class="bi bi-plus-circle"></i>
                <span>@Localizer["CreateUnit"]</span>
            </button>
        </Authorized>
    </AuthorizeView>
</div>

<!-- Filters -->
<div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
    <div class="flex flex-wrap items-center gap-3 p-4">
        <div class="flex-1 min-w-[200px]">
            <SearchInput @bind-Value="search" OnSearch="HandleSearch" Placeholder="@Localizer["SearchUnits"]" />
        </div>
        <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")">
            <i class="bi bi-funnel"></i>
            <span>@Localizer["Filters"]</span>
            @if (ActiveFilterCount > 0)
            {
                <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
            }
            <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
        </button>
        @if (HasActiveFilters())
        {
            <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <i class="bi bi-x-circle"></i>
                <span>@Localizer["ResetFilters"]</span>
            </button>
        }
    </div>

    @if (showFiltersPanel)
    {
        <div class="px-4 pb-4 pt-0 border-t border-gray-200">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 pt-4">
                <div>
                    <SearchableDropdown TItem="ProductDto" TValue="Guid?"
                                       Items="filterProducts"
                                       @bind-Value="selectedProductId"
                                       OnChanged="ApplyFilters"
                                       DisplayText="@(p => isAr ? p.NameAr : p.NameEn)"
                                       ItemValue="@(p => (Guid?)p.Id)"
                                       Label="@Localizer["Product"]"
                                       Placeholder="@Localizer["AllProducts"]"
                                       Compact="true" />
                </div>
                <div>
                    <SearchableDropdown TItem="CategoryDto"
                                       TValue="string"
                                       Items="filterCategories"
                                       @bind-Value="selectedCategoryId"
                                       OnChanged="ApplyFilters"
                                       DisplayText="c => isAr ? c.NameAr : c.NameEn"
                                       SearchText='c => $"{c.NameEn} {c.NameAr}"'
                                       ItemValue="c => c.Id.ToString()"
                                       Label='@Localizer["Category"]'
                                       Placeholder='@Localizer["AllCategories"]'
                                       Compact="true" />
                </div>
                <div>
                    <SearchableDropdown TItem="LookupDto"
                                       TValue="string"
                                       Items="unitTypes"
                                       @bind-Value="selectedUnitTypeId"
                                       OnChanged="ApplyFilters"
                                       DisplayText="u => isAr ? u.NameAr : u.NameEn"
                                       SearchText='u => $"{u.NameEn} {u.NameAr}"'
                                       ItemValue="u => u.Id.ToString()"
                                       Label='@Localizer["UnitType"]'
                                       Placeholder='@Localizer["AllUnitTypes"]'
                                       Compact="true" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                    <div class="relative">
                        <select @bind="selectedStatus" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                            <option value="">@Localizer["AllStatuses"]</option>
                            <option value="@((int)ItemStatus.Draft)">@Localizer["Draft"]</option>
                            <option value="@((int)ItemStatus.Active)">@Localizer["Active"]</option>
                            <option value="@((int)ItemStatus.Inactive)">@Localizer["Inactive"]</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
                <div>
                    <SearchableDropdown TItem="SupplierDto"
                                       TValue="string"
                                       Items="filterSuppliers"
                                       @bind-Value="selectedSupplierId"
                                       OnChanged="ApplyFilters"
                                       DisplayText="s => isAr ? s.NameAr : s.NameEn"
                                       SearchText='s => $"{s.NameEn} {s.NameAr}"'
                                       ItemValue="s => s.Id.ToString()"
                                       Label='@Localizer["Supplier"]'
                                       Placeholder='@Localizer["AllSuppliers"]'
                                       Compact="true" />
                </div>
            </div>
        </div>
    }
</div>

@if (isLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
        <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
        <span class="bf-text-danger">@errorMessage</span>
    </div>
}
else if (!DisplayList.Any())
{
    <div class="text-center py-12">
        <i class="bi bi-upc-scan text-6xl text-gray-300 mb-4"></i>
        <p class="text-gray-500 text-lg">@Localizer["NoUnitsFound"]</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["UnitOfMeasure"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["UnitType"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Product"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["BaseUnits"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["SellingPrice"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Cost"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                    <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var unit in DisplayList)
                {
                    <tr class="hover:bg-gray-50 transition-colors duration-150">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex items-center gap-3">
                                <div class="flex-shrink-0 h-10 w-10 bg-purple-100 rounded-lg flex items-center justify-center">
                                    <i class="bi bi-upc-scan text-purple-600"></i>
                                </div>
                                <div>
                                    <a href="@($"/admin/catalog/units/edit/{unit.Id}")" class="text-sm font-medium text-indigo-600 hover:text-indigo-800 hover:underline">@(isAr ? unit.UnitOfMeasureNameAr : unit.UnitOfMeasureNameEn)</a>
                                    @if (unitIdsNeedingAction.Contains(unit.Id))
                                    {
                                        <div class="mt-1">
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-amber-100 text-amber-800 border border-amber-200">
                                                <i class="bi bi-exclamation-circle-fill me-1"></i>@Localizer["NeedsAction"]
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex flex-wrap gap-1">
                                @foreach (var ut in unit.UnitTypes)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                        @(isAr ? ut.NameAr : ut.NameEn)
                                    </span>
                                }
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <a href="@($"/admin/products/edit/{unit.ProductId}")" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800 hover:underline">
                                @(isAr ? unit.ProductNameAr : unit.ProductNameEn)
                            </a>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@unit.Quantity</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            @if (unit.SellingPrice > 0)
                            {
                                <span class="font-medium text-gray-900">@unit.SellingPrice.ToString("N2")</span>
                            }
                            else
                            {
                                <span class="text-gray-400">-</span>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            @if (unit.UnitTypes.Any(ut => ut.Code == "UT_LOGISTICS"))
                            {
                                @if (unit.Cost > 0)
                                {
                                    <span class="font-medium text-gray-900">@unit.Cost.ToString("N2")</span>
                                }
                                else
                                {
                                    <span class="text-gray-400">-</span>
                                }
                            }
                            else
                            {
                                <span class="text-gray-400">-</span>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            @if (unit.Status == ItemStatus.Draft)
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                                    <i class="bi bi-hourglass-split me-1"></i> @Localizer["Draft"]
                                </span>
                            }
                            else if (unit.IsActive)
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-success-100 bf-text-success">
                                    <i class="bi bi-check-circle-fill me-1"></i> @Localizer["Active"]
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-danger-100 bf-text-danger">
                                    <i class="bi bi-x-circle-fill me-1"></i> @Localizer["Inactive"]
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                            @if (unit.Status == ItemStatus.Active)
                            {
                            <AuthorizeView Policy="Permission:units.price">
                                <Authorized>
                                    @if (unit.UnitTypes.Any(ut => ut.Code == "UT_SELLING"))
                                    {
                                        <button @onclick="() => OpenSellingDetailsModal(unit)" class="bf-text-success bf-hover-text-success-strong me-3" title="@Localizer["SetSellingDetails"]">
                                            <i class="bi bi-currency-dollar"></i>
                                        </button>
                                    }
                                </Authorized>
                                <NotAuthorized>
                                    @if (unit.UnitTypes.Any(ut => ut.Code == "UT_SELLING"))
                                    {
                                        <button disabled class="text-gray-300 me-3 cursor-not-allowed"><i class="bi bi-currency-dollar"></i></button>
                                    }
                                </NotAuthorized>
                            </AuthorizeView>
                            }
                            @if (unit.Status == ItemStatus.Active)
                            {
                            <AuthorizeView Policy="Permission:units.logistics">
                                <Authorized>
                                    @if (unit.UnitTypes.Any(ut => ut.Code == "UT_LOGISTICS"))
                                    {
                                        <button @onclick="() => OpenLogisticsDetailsModal(unit)" class="text-cyan-600 hover:text-cyan-800 me-3" title="@Localizer["SetLogisticsDetails"]">
                                            <i class="bi bi-truck"></i>
                                        </button>
                                    }
                                </Authorized>
                                <NotAuthorized>
                                    @if (unit.UnitTypes.Any(ut => ut.Code == "UT_LOGISTICS"))
                                    {
                                        <button disabled class="text-gray-300 me-3 cursor-not-allowed"><i class="bi bi-truck"></i></button>
                                    }
                                </NotAuthorized>
                            </AuthorizeView>
                            }
                            @if (unit.Status == ItemStatus.Active)
                            {
                            <AuthorizeView Policy="Permission:requests.write" Context="reqAuth">
                                <Authorized Context="reqAuth">
                                    @if (unit.UnitTypes.Any(ut => ut.Code == "UT_SELLING"))
                                    {
                                        <button @onclick="() => OpenChangePriceModal(unit)" class="text-amber-600 hover:text-amber-800 me-3" title="@Localizer["ChangePriceRequest"]">
                                            <i class="bi bi-tag"></i>
                                        </button>
                                    }
                                </Authorized>
                                <NotAuthorized>
                                    @if (unit.UnitTypes.Any(ut => ut.Code == "UT_SELLING"))
                                    {
                                        <button disabled class="text-gray-300 me-3 cursor-not-allowed"><i class="bi bi-tag"></i></button>
                                    }
                                </NotAuthorized>
                            </AuthorizeView>
                            }
                            @if (unit.Status == ItemStatus.Active)
                            {
                            <AuthorizeView Policy="Permission:requests.write" Context="logReqAuth">
                                <Authorized Context="logReqAuth">
                                    @if (unit.UnitTypes.Any(ut => ut.Code == "UT_LOGISTICS"))
                                    {
                                        <button @onclick="() => OpenLogisticsRequestModal(unit)" class="text-teal-600 hover:text-teal-800 me-3" title="@Localizer["SetLogisticsDetailsRequest"]">
                                            <i class="bi bi-box-seam"></i>
                                        </button>
                                    }
                                </Authorized>
                                <NotAuthorized>
                                    @if (unit.UnitTypes.Any(ut => ut.Code == "UT_LOGISTICS"))
                                    {
                                        <button disabled class="text-gray-300 me-3 cursor-not-allowed"><i class="bi bi-box-seam"></i></button>
                                    }
                                </NotAuthorized>
                            </AuthorizeView>
                            }
                            <AuthorizeView Policy="Permission:units.write">
                                <Authorized>
                                    @if (unit.Status != ItemStatus.Rejected)
                                    {
                                        <button @onclick="() => NavigateToEdit(unit.Id)" class="text-purple-600 hover:text-purple-900 me-3" title="@Localizer["Edit"]">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button disabled class="text-gray-400 me-3 cursor-not-allowed" title="@Localizer["Edit"]"><i class="bi bi-pencil-square"></i></button>
                                    }
                                </Authorized>
                                <NotAuthorized>
                                    <button disabled class="text-gray-400 me-3 cursor-not-allowed"><i class="bi bi-pencil-square"></i></button>
                                </NotAuthorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="Permission:units.delete">
                                <Authorized>
                                    <button @onclick="() => ConfirmDelete(unit.Id)" class="bf-text-danger bf-hover-text-danger-strong" title="@Localizer["Delete"]">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </Authorized>
                                <NotAuthorized>
                                    <button disabled class="text-gray-400 cursor-not-allowed"><i class="bi bi-trash"></i></button>
                                </NotAuthorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="@OnPageChanged" />
}

<!-- Delete Confirm -->
<ConfirmModal IsVisible="@showDeleteConfirm"
              Title="@Localizer["DeleteUnitTitle"]"
              Message="@Localizer["DeleteUnitConfirmation"]"
              OnConfirm="@DeleteUnit"
              OnCancel="@CancelDelete"
              IsDanger="true" />

<!-- Set Selling Details Modal -->
@if (showSellingModal)
{
    <div class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" @onclick="CloseSellingModal">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md" @onclick:stopPropagation>
            <div class="p-6 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
                    <i class="bi bi-currency-dollar bf-text-success"></i>
                    @Localizer["SetSellingDetails"]
                </h3>
            </div>
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["Product"]</label>
                    <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-gray-800 font-medium">
                        @(isAr ? sellingProductNameAr : sellingProductNameEn)
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["UnitOfMeasure"]</label>
                    <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-gray-600">
                        @(isAr ? sellingUomNameAr : sellingUomNameEn)
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["SellingPrice"] <span class="bf-text-danger-mark">*</span></label>
                    <input type="number" step="0.01" min="0" @bind="sellingNewPrice"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["SellingBarcode"]</label>
                    <input type="text" @bind="sellingBarcode"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500"
                           placeholder="@Localizer["EnterSellingBarcode"]" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["LowStockThreshold"]</label>
                    <input type="number" min="0" @bind="sellingLowStockThreshold"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500" />
                    <p class="text-xs text-gray-400 mt-1">@Localizer["LowStockThresholdHint"]</p>
                </div>
                @if (!string.IsNullOrEmpty(sellingError))
                {
                    <div class="p-3 bf-bg-danger-50 border bf-border-danger rounded-lg bf-text-danger text-sm">@sellingError</div>
                }
            </div>
            <div class="p-6 border-t border-gray-200 flex justify-end gap-3">
                <button @onclick="CloseSellingModal" class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors">@Localizer["Cancel"]</button>
                <button @onclick="SubmitSellingDetails" disabled="@sellingSubmitting"
                        class="px-4 py-2 bf-bg-success-600 bf-hover-bg-success-700 rounded-lg transition-colors disabled:opacity-50 inline-flex items-center gap-2">
                    @if (sellingSubmitting)
                    {
                        <Spinner Size="Spinner.SpinnerSize.Xs" Color="Spinner.SpinnerColor.White" />
                    }
                    <span>@Localizer["Save"]</span>
                </button>
            </div>
        </div>
    </div>
}

<!-- Set Logistics Details Modal -->
@if (showLogisticsModal)
{
    <div class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" @onclick="CloseLogisticsModal">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg" @onclick:stopPropagation>
            <div class="p-6 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
                    <i class="bi bi-truck text-cyan-600"></i>
                    @Localizer["SetLogisticsDetails"]
                </h3>
            </div>
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["Product"]</label>
                    <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-gray-800 font-medium">@(isAr ? logisticsProductNameAr : logisticsProductNameEn)</div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["UnitOfMeasure"]</label>
                    <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-gray-600">@(isAr ? logisticsUomNameAr : logisticsUomNameEn)</div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["CurrentCost"]</label>
                    <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-gray-600">@logisticsCurrentCost.ToString("N2") @Localizer["CurrencyUnit"]</div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["NewCost"] <span class="bf-text-danger-mark">*</span></label>
                    <input type="number" step="0.01" min="0" @bind="logisticsNewCost"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["LowStockThreshold"]</label>
                    <input type="number" min="0" @bind="logisticsLowStockThreshold"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500" />
                    <p class="text-xs text-gray-400 mt-1">@Localizer["LowStockThresholdHint"]</p>
                </div>
                <div>
                    <div class="flex justify-between items-center mb-2">
                        <label class="block text-sm font-medium text-gray-700">@Localizer["Suppliers"]</label>
                        <button @onclick="AddLogisticsSupplierRow" type="button" class="text-xs text-cyan-600 hover:text-cyan-800 font-medium">
                            <i class="bi bi-plus-circle me-1"></i>@Localizer["AddSupplier"]
                        </button>
                    </div>
                    @for (int i = 0; i < logisticsSuppliers.Count; i++)
                    {
                        var idx = i;
                        <div class="flex gap-2 mb-2">
                            <select @bind="logisticsSuppliers[idx].SupplierId" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-500 text-sm">
                                <option value="">@Localizer["SelectSupplier"]</option>
                                @foreach (var s in logisticsAvailableSuppliers)
                                {
                                    <option value="@s.Id">@(isAr ? s.NameAr : s.NameEn)</option>
                                }
                            </select>
                            <input type="text" @bind="logisticsSuppliers[idx].Barcode" placeholder="@Localizer["Barcode"]"
                                   class="flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-500 text-sm" />
                            <button @onclick="() => RemoveLogisticsSupplierRow(idx)" class="bf-icon-danger bf-hover-text-danger-strong px-2">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(logisticsError))
                {
                    <div class="p-3 bf-bg-danger-50 border bf-border-danger rounded-lg bf-text-danger text-sm">@logisticsError</div>
                }
            </div>
            <div class="p-6 border-t border-gray-200 flex justify-end gap-3">
