        (selectedProductId.HasValue ? 1 : 0) + (string.IsNullOrEmpty(selectedCategoryId) ? 0 : 1) +
        (string.IsNullOrEmpty(selectedSupplierId) ? 0 : 1);

    private List<UnitDto> DisplayList => units;

    // ── Delete ───────────────────────────────────────
    private bool showDeleteConfirm = false;
