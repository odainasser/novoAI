@page "/admin/catalog"
@page "/admin/catalog/{Tab}"
@page "/admin/categories"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.ProductsRead)]
@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using System.Globalization
@inject NavigationManager Navigation

<PageTitle>@Localizer["CatalogManagement"]</PageTitle>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6">
    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
            <i class="bi bi-grid-3x3-gap text-purple-600"></i>
            @Localizer["CatalogManagement"]
        </h1>
        <p class="text-gray-600 mt-2 text-sm sm:text-base">@Localizer["ManageCatalog"]</p>
    </div>

    <!-- Tabs -->
    <div class="mb-6">
        <nav class="tab-nav" aria-label="Tabs">
            <button @onclick='() => SetActiveTab("categories")'
                    class="tab-btn @GetTabClass("categories")">
                <i class="bi bi-tags"></i>
                @Localizer["Categories"]
            </button>
            <button @onclick='() => SetActiveTab("products")'
                    class="tab-btn @GetTabClass("products")">
                <i class="bi bi-box2"></i>
                @Localizer["Products"]
            </button>
        </nav>
    </div>

    <!-- Tab Content -->
    @if (activeTab == "products")
    {
        <CatalogProductsTab />
    }
    else if (activeTab == "categories")
    {
        <CatalogCategoriesTab />
    }

</div>

@code {
    [Parameter] public string? Tab { get; set; }

    private string activeTab = "categories";

    private string ResolveTab()
    {
        if (!string.IsNullOrEmpty(Tab))
            return Tab.ToLower() switch { "products" => "products", _ => "categories" };
        var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (uri.StartsWith("admin/categories", StringComparison.OrdinalIgnoreCase)) return "categories";
        return "categories";
    }

    protected override void OnInitialized()
    {
        activeTab = ResolveTab();
    }

    protected override void OnParametersSet()
    {
        activeTab = ResolveTab();
    }

    private async Task SetActiveTab(string tab)
    {
        activeTab = tab;
        Navigation.NavigateTo($"/admin/catalog/{tab}", replace: true);
        await Task.CompletedTask;
    }

    private string GetTabClass(string tab) =>
        activeTab == tab ? "tab-btn-active" : "";
}
