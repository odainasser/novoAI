@page "/admin/branches"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.BranchesRead)]
@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using Web.Components.Common
@using System.Globalization
@inject IBranchService BranchService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer

<PageTitle>@Localizer["BranchesManagement"]</PageTitle>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6">
            <!-- Header -->
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
                        <i class="bi bi-building text-purple-600"></i>
                        @Localizer["BranchesManagement"]
                    </h1>
                    <p class="text-gray-600 mt-2 text-sm sm:text-base">@Localizer["ManageBranches"]</p>
                </div>
                
                <AuthorizeView Policy="Permission:branches.write">
                    <Authorized>
                        <button @onclick="NavigateToCreate" class="btn-primary-action">
                            <i class="bi bi-plus-circle"></i>
                            <span>@Localizer["CreateBranch"]</span>
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>

            <!-- Filters -->
            <div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
                <div class="flex flex-wrap items-center gap-3 p-4">
                    <div class="flex-1 min-w-[200px]">
                        <SearchInput @bind-Value="searchTerm"
                                     OnSearch="HandleSearch"
                                     Placeholder="@Localizer["SearchBranches"]" />
                    </div>

                    <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                            class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")"> 
                        <i class="bi bi-funnel"></i>
                        <span>@Localizer["Filters"]</span>
                        @if (ActiveFilterCount > 0)
                        {
                            <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
                        }
                        <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
                    </button>

                    @if (HasActiveFilters())
                    {
                        <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                            <i class="bi bi-x-circle"></i>
                            <span>@Localizer["ResetFilters"]</span>
                        </button>
                    }
                </div>

                @if (showFiltersPanel)
                {
                    <div class="px-4 pb-4 pt-0 border-t border-gray-200">
                        <div class="grid grid-cols-1 sm:grid-cols-1 gap-3 pt-4">
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                                <div class="relative">
                                    <select @bind="selectedStatus" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                                        <option value="">@Localizer["AllStatuses"]</option>
                                        <option value="true">@Localizer["Active"]</option>
                                        <option value="false">@Localizer["Inactive"]</option>
                                    </select>
                                    <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

            </div>

            @if (isLoading)
            {
                <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
                    <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
                    <span class="bf-text-danger">@errorMessage</span>
                </div>
            }
            else if (branches == null || !branches.Any())
            {
                <div class="text-center py-12">
                    <i class="bi bi-building text-6xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500 text-lg">@Localizer["NoBranchesFound"]</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
                    @foreach (var branch in branches)
                    {
                        <div @key="branch.Id" class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-shadow duration-200 overflow-hidden">
                            <!-- Branch Image -->
                            <div class="h-40 bg-gray-100 flex items-center justify-center">
                                @if (!string.IsNullOrEmpty(branch.ImageUrl))
                                {
                                    <img src="@branch.ImageUrl" alt="@(isAr ? branch.NameAr : branch.NameEn)" class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <i class="bi bi-building text-4xl text-gray-300"></i>
                                }
                            </div>
                            
                            <!-- Branch Info -->
                            <div class="p-4">
                                <div class="flex justify-between items-start mb-2">
                                    <h3 class="text-lg font-semibold text-gray-900">
                                        @(isAr ? branch.NameAr : branch.NameEn)
                                    </h3>
                                    <span class="@(branch.IsActive ? "bf-bg-success-100 bf-text-success" : "bf-bg-danger-100 bf-text-danger") text-xs px-2 py-1 rounded-full">
                                        @(branch.IsActive ? Localizer["Active"] : Localizer["Inactive"])
                                    </span>
                                </div>
                                
                                @if (!string.IsNullOrEmpty(isAr ? branch.DescriptionAr : branch.DescriptionEn))
                                {
                                    <p class="text-gray-600 text-sm mb-3 line-clamp-2">
                                        @(isAr ? branch.DescriptionAr : branch.DescriptionEn)
                                    </p>
                                }
                                
                                <!-- Actions -->
                                <div class="flex justify-end gap-2 pt-3 border-t border-gray-100">
                                    <AuthorizeView Policy="Permission:branches.write">
                                        <Authorized>
                                            <button type="button" @onclick="@(() => NavigateToEdit(branch.Id))" @onclick:stopPropagation="true"
                                                    class="text-purple-600 hover:text-purple-900 me-3"
                                                    title="@Localizer["Edit"]">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                        </Authorized>
                                        <NotAuthorized>
                                            <button type="button" disabled class="text-gray-400 me-3 cursor-not-allowed" title="@Localizer["Edit"]">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                        </NotAuthorized>
                                    </AuthorizeView>
                                    <AuthorizeView Policy="Permission:branches.delete">
                                        <Authorized>
                                            <button type="button" @onclick="@(() => ConfirmDelete(branch.Id))" @onclick:stopPropagation="true"
                                                    class="p-2 bf-text-danger bf-hover-text-danger-strong bf-hover-bg-danger-50 rounded-lg transition-colors"
                                                    title="@Localizer["Delete"]">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </Authorized>
                                        <NotAuthorized>
                                            <button type="button" disabled class="p-2 text-gray-300 cursor-not-allowed" title="@Localizer["Delete"]">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </NotAuthorized>
                                    </AuthorizeView>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                
                <Pagination PageIndex="@pageIndex" 
                            TotalPages="@totalPages" 
                            TotalCount="@totalCount" 
                            PageSize="@pageSize" 
                            OnPageChanged="@OnPageChanged" />
            }
</div>

<ConfirmModal IsVisible="@showDeleteConfirm"
              Title="@Localizer["DeleteBranchTitle"]"
              Message="@Localizer["DeleteBranchConfirmation"]"
              OnConfirm="@DeleteBranch"
              OnCancel="@CancelDelete"
              IsDanger="true" />
@code {
    private List<BranchDto> branches = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private int pageIndex = 1;
    private int pageSize = 12;
    private int totalPages = 1;
    private int totalCount = 0;
    private string searchTerm = string.Empty;
    private string selectedStatus = string.Empty;
    private bool showFiltersPanel = false;

    private bool HasActiveFilters() => !string.IsNullOrEmpty(selectedStatus);
    private int ActiveFilterCount => string.IsNullOrEmpty(selectedStatus) ? 0 : 1;

    private bool showDeleteConfirm = false;
    private Guid branchToDelete = Guid.Empty;
    private bool isAr = false;

    protected override async Task OnInitializedAsync()
    {
        isAr = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        await LoadBranches();
    }

    private async Task LoadBranches()
    {
        isLoading = true;
        errorMessage = string.Empty;
            
        try
        {
            bool? isActive = string.IsNullOrEmpty(selectedStatus) ? null : bool.Parse(selectedStatus);
            
            var result = await BranchService.GetAllBranchesAsync(pageIndex, pageSize, searchTerm, isActive);
            
            branches = result.Items;
            totalPages = result.TotalPages;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            errorMessage = Localizer["FailedToLoadBranches"] + $": {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnPageChanged(int newPageIndex)
    {
        pageIndex = newPageIndex;
        await LoadBranches();
    }

    private async Task HandleSearch(string searchValue)
    {
        searchTerm = searchValue;
        pageIndex = 1;
        await LoadBranches();
    }

    private async Task ApplyFilters()
    {
        pageIndex = 1;
        await LoadBranches();
    }

    private async Task ResetFilters()
    {
        searchTerm = string.Empty;
        selectedStatus = string.Empty;
        pageIndex = 1;
        await LoadBranches();
    }

    private void NavigateToCreate()
    {
        Navigation.NavigateTo("/admin/branches/create");
    }

    private void NavigateToEdit(Guid branchId)
    {
        Navigation.NavigateTo($"/admin/branches/edit/{branchId}");
    }

    private void ConfirmDelete(Guid branchId)
    {
        branchToDelete = branchId;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        branchToDelete = Guid.Empty;
    }

    private async Task DeleteBranch()
    {
        try
        {
            await BranchService.DeleteBranchAsync(branchToDelete);
            showDeleteConfirm = false;
            branchToDelete = Guid.Empty;
            await LoadBranches();
        }
        catch (Exception ex)
        {
            errorMessage = Localizer["FailedToDeleteBranch"] + $": {ex.Message}";
            showDeleteConfirm = false;
            branchToDelete = Guid.Empty;
        }
    }

}
