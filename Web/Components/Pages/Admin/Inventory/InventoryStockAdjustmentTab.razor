@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using Web.Components.Common
@using System.Globalization
@using System.Text.Json
@using Web.Models.Requests
@inject IStockAdjustmentClientService StockAdjustmentService
@inject IInventoryHistoryClientService InventoryHistoryService
@inject IMediaService MediaService
@inject IWarehouseService WarehouseService
@inject IUnitService UnitService
@inject Web.Services.IRequestService RequestService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer

<div class="flex justify-end mb-4">
    <AuthorizeView Policy="Permission:inventory.write">
        <Authorized>
            <button @onclick="OpenCreateAdjustment" class="btn-primary-action">
                <i class="bi bi-plus-circle"></i>
                <span>@Localizer["CreateAdjustment"]</span>
            </button>
        </Authorized>
    </AuthorizeView>
</div>

<!-- Filters -->
<div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
    <div class="flex flex-wrap items-center gap-3 p-4">
        <div class="flex-1 min-w-[200px]">
            <SearchInput @bind-Value="searchTerm" OnSearch="HandleSearch" Placeholder="@Localizer["SearchAdjustments"]" />
        </div>

        <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")">
            <i class="bi bi-funnel"></i>
            <span>@Localizer["Filters"]</span>
            @if (ActiveFilterCount > 0)
            {
                <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
            }
            <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
        </button>

        @if (HasActiveFilters())
        {
            <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <i class="bi bi-x-circle"></i>
                <span>@Localizer["ResetFilters"]</span>
            </button>
        }
    </div>

    @if (showFiltersPanel)
    {
        <div class="px-4 pb-4 pt-0 border-t border-gray-200">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 pt-4">
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                    <div class="relative">
                        <select @bind="filterItemStatus" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                            <option value="">@Localizer["All"]</option>
                            <option value="active">@Localizer["Active"]</option>
                            <option value="draft">@Localizer["Draft"]</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Type"]</label>
                    <div class="relative">
                        <select @bind="filterType" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm" disabled="@(filterItemStatus == "draft")">
                            <option value="">@Localizer["AllTypes"]</option>
                            <option value="Damage">@Localizer["Damage"]</option>
                            <option value="Loss">@Localizer["Loss"]</option>
                            <option value="Theft">@Localizer["Theft"]</option>
                            <option value="Expiry">@Localizer["Expiry"]</option>
                            <option value="CorrectionAdd">@Localizer["CorrectionAdd"]</option>
                            <option value="CorrectionRemove">@Localizer["CorrectionRemove"]</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
                <div>
                    <SearchableDropdown TItem="WarehouseDto"
                                        TValue="string"
                                        Items="warehouses"
                                        @bind-Value="filterWarehouseId"
                                        OnChanged="ApplyFilters"
                                        DisplayText="w => isAr ? w.NameAr : w.NameEn"
                                        SearchText='w => $"{w.NameEn} {w.NameAr}"'
                                        ItemValue="w => w.Id.ToString()"
                                        Label='@Localizer["Warehouse"]'
                                        Placeholder='@Localizer["AllWarehouses"]'
                                        Disabled='@(filterItemStatus == "draft")'
                                        Compact="true" />
                </div>
            </div>
        </div>
    }
</div>

@if (isLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
        <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
        <span class="bf-text-danger">@errorMessage</span>
    </div>
}
else if (filterItemStatus == "draft" && !draftItems.Any())
{
    <div class="text-center py-12">
        <i class="bi bi-hourglass text-6xl text-gray-300 mb-4"></i>
        <p class="text-gray-500 text-lg">@Localizer["NoDraftsFound"]</p>
    </div>
}
else if (filterItemStatus == "draft")
{
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["AdjustmentNumber"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Warehouse"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Type"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["RequestedBy"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Date"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Items"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                    <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var draft in draftItems)
                {
                    var draftWarehouse = GetDraftWarehouse(draft.NewDataJson);
                    var draftAdjType = GetDraftAdjustmentType(draft.NewDataJson);
                    <tr class="hover:bg-gray-50 transition-colors duration-150">
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-500">—</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            @if (draftWarehouse != null)
                            {
                                <a href="@($"/admin/warehouses/edit/{draftWarehouse.Id}")" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800 hover:underline">@(isAr ? draftWarehouse.NameAr : draftWarehouse.NameEn)</a>
                            }
                            else { <span>—</span> }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@(string.IsNullOrEmpty(draftAdjType) ? "—" : Localizer[draftAdjType])</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <a href="@($"/admin/users/edit/{draft.RequestedById}")" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-bf-primary hover:underline">@draft.RequestedByName</a>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@draft.CreatedAt.ToLocal().ToString("dd/MM/yyyy")</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@GetDraftLineCount(draft.NewDataJson)</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <div class="flex flex-wrap items-center gap-1">
                                <span class="px-2 py-1 text-xs font-medium rounded-full bf-bg-warning-100 bf-text-warning">@Localizer["RequestStatusPending"]</span>
                                <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-semibold bf-bg-warning-100 bf-text-warning-strong border bf-border-warning">
                                    <i class="bi bi-exclamation-circle-fill me-1"></i>@Localizer["NeedsAction"]
                                </span>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                            <button @onclick="() => ViewDraftAdjustmentDetail(draft.Id)" title="@Localizer["View"]" class="text-indigo-600 hover:text-indigo-900 me-2">
                                <i class="bi bi-eye"></i>
                            </button>
                            <AuthorizeView Policy="Permission:inventory.delete">
                                <Authorized>
                                    <button @onclick="@(() => ConfirmDeleteItem(draft.Id))" title="@Localizer["Delete"]" class="bf-text-danger bf-hover-text-danger-strong">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="@OnPageChanged" />
}
else
{
    @if (!adjustmentList.Any() && !draftItems.Any())
    {
        <div class="text-center py-12">
            <i class="bi bi-sliders text-6xl text-gray-300 mb-4"></i>
            <p class="text-gray-500 text-lg">@Localizer["NoAdjustmentsFound"]</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["AdjustmentNumber"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Warehouse"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Type"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["RequestedBy"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Date"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                        <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @if (string.IsNullOrEmpty(filterItemStatus))
                    {
                        @foreach (var draft in draftItems)
                        {
                            var mixedDraftWarehouse = GetDraftWarehouse(draft.NewDataJson);
                            var mixedDraftAdjType = GetDraftAdjustmentType(draft.NewDataJson);
                            <tr class="hover:bg-amber-50 transition-colors duration-150">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-500">—</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    @if (mixedDraftWarehouse != null)
                                    {
                                        <a href="@($"/admin/warehouses/edit/{mixedDraftWarehouse.Id}")" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800 hover:underline">@(isAr ? mixedDraftWarehouse.NameAr : mixedDraftWarehouse.NameEn)</a>
                                    }
                                    else { <span>—</span> }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@(string.IsNullOrEmpty(mixedDraftAdjType) ? "—" : Localizer[mixedDraftAdjType])</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <a href="@($"/admin/users/edit/{draft.RequestedById}")" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-bf-primary hover:underline">@draft.RequestedByName</a>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@draft.CreatedAt.ToLocal().ToString("dd/MM/yyyy")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <div class="flex flex-wrap items-center gap-1">
                                        <span class="px-2 py-1 text-xs font-medium rounded-full bf-bg-warning-100 bf-text-warning">@Localizer["RequestStatusPending"]</span>
                                        <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-semibold bf-bg-warning-100 bf-text-warning-strong border bf-border-warning">
                                            <i class="bi bi-exclamation-circle-fill me-1"></i>@Localizer["NeedsAction"]
                                        </span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                                    <button @onclick="() => ViewDraftAdjustmentDetail(draft.Id)" title="@Localizer["View"]" class="text-indigo-600 hover:text-indigo-900 me-2">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <AuthorizeView Policy="Permission:inventory.delete">
                                        <Authorized>
                                            <button @onclick="@(() => ConfirmDeleteItem(draft.Id))" title="@Localizer["Delete"]" class="bf-text-danger bf-hover-text-danger-strong">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </Authorized>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    }
                    @foreach (var adj in adjustmentList)
                    {
                        <tr class="hover:bg-gray-50 transition-colors duration-150">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@adj.AdjustmentNumber</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <a href="@($"/admin/warehouses/edit/{adj.WarehouseId}")" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800 hover:underline">@(isAr ? adj.WarehouseNameAr : adj.WarehouseNameEn)</a>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@Localizer[adj.AdjustmentType]</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                @if (adj.RequestedById.HasValue)
                                {
                                    <a href="@($"/admin/users/edit/{adj.RequestedById}")" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-bf-primary hover:underline">@adj.RequestedByName</a>
                                }
                                else
                                {
                                    <span class="text-gray-500">—</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@(adj.RequestedDate?.ToLocal().ToString("dd/MM/yyyy") ?? adj.CreatedAt.ToLocal().ToString("dd/MM/yyyy"))</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <span class="px-2 py-1 text-xs font-medium rounded-full bf-bg-success-100 bf-text-success">@Localizer["Active"]</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                                <button @onclick="() => ViewAdjustmentDetail(adj.Id)" title="@Localizer["View"]" class="text-indigo-600 hover:text-indigo-900 me-2">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="@OnPageChanged" />
    }
}

<!-- Delete Confirm Modal -->
<ConfirmModal IsVisible="@showDeleteConfirm"
              Title="@Localizer["DeleteConfirmTitle"]"
              Message="@Localizer["DeleteConfirmMessage"]"
              OnConfirm="@HandleDelete"
              OnCancel="@(() => showDeleteConfirm = false)"
              IsDanger="true" />

<!-- Stock Adjustment Create Modal -->
@if (showAdjustmentModal)
{
    <div class="fixed inset-0 z-50 overflow-y-auto">
        <div class="flex items-center justify-center min-h-screen px-4">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" @onclick="CloseAdjustmentModal"></div>
            <div class="relative bg-white rounded-2xl shadow-xl max-w-4xl w-full max-h-[90vh] overflow-y-auto p-6 z-10">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold text-gray-900">@Localizer["CreateStockAdjustment"]</h3>
                    <button @onclick="CloseAdjustmentModal" class="text-gray-400 hover:text-gray-600">
                        <i class="bi bi-x-lg text-xl"></i>
                    </button>
                </div>

                <div class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["Warehouse"] *</label>
                            <select value="@adjustmentRequest.WarehouseId" @onchange="OnAdjustmentWarehouseChanged" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary focus:border-transparent">
                                <option value="@Guid.Empty">@Localizer["SelectWarehouse"]</option>
                                @foreach (var w in warehouses)
                                {
                                    <option value="@w.Id">@(isAr ? w.NameAr : w.NameEn)</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["AdjustmentType"] *</label>
                            <select @bind="adjustmentRequest.AdjustmentType" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary focus:border-transparent">
                                <option value="">@Localizer["SelectType"]</option>
                                <option value="Damage">@Localizer["Damage"]</option>
                                <option value="Loss">@Localizer["Loss"]</option>
                                <option value="Theft">@Localizer["Theft"]</option>
                                <option value="Expiry">@Localizer["Expiry"]</option>
                                <option value="CorrectionAdd">@Localizer["CorrectionAdd"]</option>
                                <option value="CorrectionRemove">@Localizer["CorrectionRemove"]</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["Explanation"]</label>
                        <textarea @bind="adjustmentRequest.Explanation" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary focus:border-transparent"></textarea>
                    </div>

                    <!-- Image Justification -->
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-2">@Localizer["JustificationImage"]</label>
                        <div class="flex items-start gap-4">
                            <div class="w-24 h-24 border-2 border-dashed border-gray-300 rounded-lg flex items-center justify-center bg-gray-50 overflow-hidden">
                                @if (!string.IsNullOrEmpty(adjustmentImageUrl))
                                {
                                    <img src="@adjustmentImageUrl" alt="Justification preview" class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <i class="bi bi-image text-3xl text-gray-300"></i>
                                }
                            </div>
                            <div class="flex flex-col gap-2">
                                <InputFile OnChange="OnAdjustmentImageSelected" accept="image/*" class="hidden" id="adjustmentImageInput" />
                                <label for="adjustmentImageInput" class="inline-flex items-center gap-2 px-3 py-1.5 bg-gray-100 text-gray-700 text-sm rounded-lg hover:bg-gray-200 transition-colors cursor-pointer">
                                    <i class="bi bi-upload"></i>
                                    <span>@(string.IsNullOrEmpty(adjustmentImageUrl) ? Localizer["UploadImage"] : Localizer["ChangeImage"])</span>
                                </label>
                                @if (!string.IsNullOrEmpty(adjustmentImageUrl))
                                {
                                    <button type="button" @onclick="RemoveAdjustmentImage" class="inline-flex items-center gap-2 px-3 py-1.5 text-xs bf-text-danger bf-hover-bg-danger-50 rounded-lg transition-colors">
                                        <i class="bi bi-trash"></i>
                                        <span>@Localizer["RemoveImage"]</span>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Adjustment Lines -->
                    <div class="border-t pt-4">
                        <div class="flex justify-between items-center mb-3">
                            <h4 class="text-lg font-semibold text-gray-800">@Localizer["Items"]</h4>
                            <button @onclick="AddAdjustmentLine"
                                    disabled="@(adjustmentRequest.WarehouseId == Guid.Empty || string.IsNullOrEmpty(adjustmentRequest.AdjustmentType))"
                                    class="inline-flex items-center gap-1 px-3 py-1.5 bf-bg-success-600 bf-hover-bg-success-700 rounded-lg text-sm disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                                <i class="bi bi-plus"></i> @Localizer["AddItem"]
                            </button>
                        </div>
                        @for (int i = 0; i < adjustmentRequest.Lines.Count; i++)
                        {
                            var idx = i;
                            <div class="grid grid-cols-12 gap-2 mb-2 items-end bg-gray-50 p-3 rounded-lg">
                                <div class="col-span-5">
                                    <label class="block text-xs text-gray-500">@Localizer["Unit"]</label>
                                    <SearchableDropdown TItem="Web.Models.Units.UnitDto" TValue="Guid"
                                                       Items="adjustmentUnits"
                                                       @bind-Value="adjustmentRequest.Lines[idx].UnitId"
                                                       DisplayText="@(u => (isAr ? u.ProductNameAr : u.ProductNameEn) + " - " + (isAr ? u.UnitOfMeasureNameAr : u.UnitOfMeasureNameEn) + " (" + u.Quantity + ")")"
                                                       ItemValue="@(u => u.Id)"
                                                       Placeholder="@Localizer["SelectUnit"]"
                                                       Compact="true"
                                                       Clearable="false" />
                                </div>
                                <div class="col-span-6">
                                    <label class="block text-xs text-gray-500">@Localizer["Quantity"]</label>
                                    <input type="number" @bind="adjustmentRequest.Lines[idx].AdjustmentQuantity" class="w-full border border-gray-300 rounded px-2 py-1.5 text-sm" />
                                </div>
                                <div class="col-span-1 flex items-end justify-end">
                                    <button @onclick="() => RemoveAdjustmentLine(idx)" class="bf-text-danger bf-hover-text-danger-strong p-1">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="mt-4 p-3 bf-bg-danger-50 border bf-border-danger rounded-lg bf-text-danger text-sm">
                        <i class="bi bi-exclamation-triangle me-1"></i> @modalError
                    </div>
                }

                <div class="flex justify-end gap-3 mt-6 pt-4 border-t">
                    <button @onclick="CloseAdjustmentModal" class="px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 transition-colors">
                        @Localizer["Cancel"]
                    </button>
                    <button @onclick="SaveAdjustment" disabled="@isSaving" class="px-4 py-2 bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-colors disabled:opacity-50 flex items-center justify-center gap-2">
                        @if (isSaving)
                        {
                            <Spinner Size="Spinner.SpinnerSize.Sm" />
                        }
                        <span>@Localizer["Save"]</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Detail View Modal -->
@if (showDetailModal)
{
    <div class="fixed inset-0 z-50 overflow-y-auto">
        <div class="flex items-center justify-center min-h-screen px-4">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" @onclick="() => showDetailModal = false"></div>
            <div class="relative bg-white rounded-2xl shadow-xl max-w-4xl w-full max-h-[90vh] overflow-y-auto p-6 z-10">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold text-gray-900">@detailModalTitle</h3>
                    <button @onclick="() => showDetailModal = false" class="text-gray-400 hover:text-gray-600">
                        <i class="bi bi-x-lg text-xl"></i>
                    </button>
                </div>
                @detailContent
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private string modalError = string.Empty;
    private bool isAr = false;
    private int pageIndex = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private int totalCount = 0;

    // Lookup Data
    private List<WarehouseDto> warehouses = new();
    private List<Web.Models.Units.UnitDto> units = new();

    // Filters
    private string searchTerm = string.Empty;
    private string filterStatus = string.Empty;
    private string filterWarehouseId = string.Empty;
    private string filterType = string.Empty;
    private bool showFiltersPanel = false;

    // View mode
    private string filterItemStatus = string.Empty;
    private List<RequestDto> draftItems = new();

    // Adjustment State
    private List<StockAdjustmentDto> adjustmentList = new();
    private bool showAdjustmentModal = false;
    private CreateStockAdjustmentRequest adjustmentRequest = new();
    private List<Web.Models.Units.UnitDto> adjustmentUnits = new();
    private IBrowserFile? adjustmentImageFile;
    private byte[]? adjustmentImageData;
    private string? adjustmentImageContentType;
    private string? adjustmentImageFileName;
    private string? adjustmentImageUrl;

    // Delete
    private bool showDeleteConfirm = false;
    private Guid itemToDelete = Guid.Empty;

    // Detail Modal
    private bool showDetailModal = false;
    private string detailModalTitle = string.Empty;
    private RenderFragment? detailContent;

    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);

        var uri = new Uri(Navigation.Uri);
        var queryParams = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        Guid? autoOpenId = null;
        if (queryParams.TryGetValue("id", out var idParam) && Guid.TryParse(idParam, out var parsedId))
            autoOpenId = parsedId;

        await LoadLookupData();
        await LoadData();

        if (autoOpenId.HasValue)
            await ViewAdjustmentDetail(autoOpenId.Value);
    }

    private async Task LoadLookupData()
    {
        try
        {
            warehouses = (await WarehouseService.GetActiveWarehousesAsync()).ToList();
            units = (await UnitService.GetAllAsync(1, 500, isActive: true)).Items;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load lookup data: {ex.Message}");
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            if (filterItemStatus == "draft")
            {
                var result = await RequestService.GetAllRequestsAsync(pageIndex, pageSize, searchTerm,
                    Web.Models.Enums.RequestType.AddStockAdjustment, Web.Models.Enums.RequestStatus.Pending);
                draftItems = result.Items;
                adjustmentList = new();
                totalPages = result.TotalPages;
                totalCount = result.TotalCount;
            }
            else
            {
                Guid? warehouseId = Guid.TryParse(filterWarehouseId, out var wId) ? wId : null;
                var adjResult = await StockAdjustmentService.GetAllAsync(pageIndex, pageSize, searchTerm,
                    string.IsNullOrEmpty(filterStatus) ? null : filterStatus,
                    string.IsNullOrEmpty(filterType) ? null : filterType, warehouseId, null, null);
                adjustmentList = adjResult.Items;
                totalPages = adjResult.TotalPages;
                totalCount = adjResult.TotalCount;

                if (string.IsNullOrEmpty(filterItemStatus))
                {
                    var draftResult = await RequestService.GetAllRequestsAsync(1, 100, null,
                        Web.Models.Enums.RequestType.AddStockAdjustment, Web.Models.Enums.RequestStatus.Pending);
                    draftItems = draftResult.Items;
                }
                else
                {
                    draftItems = new();
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static int GetDraftLineCount(string? json)
    {
        if (string.IsNullOrEmpty(json)) return 0;
        try
        {
            var el = JsonSerializer.Deserialize<JsonElement>(json);
            if (el.TryGetProperty("Lines", out var lines) && lines.ValueKind == JsonValueKind.Array)
                return lines.GetArrayLength();
        }
        catch { }
        return 0;
    }

    private WarehouseDto? GetDraftWarehouse(string? json)
    {
        if (string.IsNullOrEmpty(json)) return null;
        try
        {
            var el = JsonSerializer.Deserialize<JsonElement>(json);
            if (el.TryGetProperty("WarehouseId", out var prop) && Guid.TryParse(prop.GetString(), out var warehouseId))
                return warehouses.FirstOrDefault(w => w.Id == warehouseId);
        }
        catch { }
        return null;
    }

    private static string GetDraftAdjustmentType(string? json)
    {
        if (string.IsNullOrEmpty(json)) return string.Empty;
        try
        {
            var el = JsonSerializer.Deserialize<JsonElement>(json);
            if (el.TryGetProperty("AdjustmentType", out var prop) && prop.ValueKind == JsonValueKind.String)
                return prop.GetString() ?? string.Empty;
        }
        catch { }
        return string.Empty;
    }

    private async Task OnPageChanged(int newPage) { pageIndex = newPage; await LoadData(); }
    private async Task HandleSearch(string value) { searchTerm = value; pageIndex = 1; await LoadData(); }
    private async Task ApplyFilters() { pageIndex = 1; await LoadData(); }

    private async Task ResetFilters()
    {
        searchTerm = string.Empty;
        filterStatus = string.Empty;
        filterWarehouseId = string.Empty;
        filterType = string.Empty;
        filterItemStatus = string.Empty;
        showFiltersPanel = false;
        pageIndex = 1;
        await LoadData();
    }

    private bool HasActiveFilters() =>
        !string.IsNullOrEmpty(filterStatus) || !string.IsNullOrEmpty(filterWarehouseId) || !string.IsNullOrEmpty(filterType) || !string.IsNullOrEmpty(filterItemStatus);

    private int ActiveFilterCount
    {
        get
        {
            int count = 0;
            if (!string.IsNullOrEmpty(filterStatus)) count++;
            if (!string.IsNullOrEmpty(filterWarehouseId)) count++;
            if (!string.IsNullOrEmpty(filterType)) count++;
            if (!string.IsNullOrEmpty(filterItemStatus)) count++;
            return count;
        }
    }

    // Adjustment Actions
    private void OpenCreateAdjustment()
    {
        adjustmentRequest = new CreateStockAdjustmentRequest();
        adjustmentUnits = new();
        adjustmentImageFile = null;
        adjustmentImageData = null;
        adjustmentImageContentType = null;
        adjustmentImageFileName = null;
        adjustmentImageUrl = null;
        modalError = string.Empty;
        showAdjustmentModal = true;
    }

    private void CloseAdjustmentModal()
    {
        showAdjustmentModal = false;
        modalError = string.Empty;
        adjustmentImageFile = null;
        adjustmentImageData = null;
        adjustmentImageContentType = null;
        adjustmentImageFileName = null;
        adjustmentImageUrl = null;
    }

    private void AddAdjustmentLine() => adjustmentRequest.Lines.Add(new CreateStockAdjustmentLineRequest());
    private void RemoveAdjustmentLine(int idx) { if (adjustmentRequest.Lines.Count > 0) adjustmentRequest.Lines.RemoveAt(idx); }

    private async Task OnAdjustmentWarehouseChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        adjustmentRequest.WarehouseId = string.IsNullOrEmpty(val) ? Guid.Empty : Guid.Parse(val);
        adjustmentRequest.Lines.Clear();

        if (adjustmentRequest.WarehouseId != Guid.Empty)
        {
            try
            {
                var balances = await InventoryHistoryService.GetStockBalancesAsync(adjustmentRequest.WarehouseId);
                var unitIdsWithStock = balances
                    .Where(b => b.AvailableQuantity >= Math.Max(b.UnitBaseQuantity, 1))
                    .Select(b => b.UnitId)
                    .ToHashSet();
                adjustmentUnits = units.Where(u => unitIdsWithStock.Contains(u.Id)).ToList();
            }
            catch
            {
                adjustmentUnits = new();
            }
        }
        else
        {
            adjustmentUnits = new();
        }
    }

    private async Task OnAdjustmentImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        try
        {
            long maxFileSize = 5 * 1024 * 1024; // 5MB max

            using var memoryStream = new MemoryStream();
            await using var stream = file.OpenReadStream(maxFileSize);
            await stream.CopyToAsync(memoryStream);
            var buffer = memoryStream.ToArray();

            adjustmentImageData = buffer;
            adjustmentImageContentType = file.ContentType;
            adjustmentImageFileName = file.Name;
            adjustmentImageFile = file;

            var base64 = Convert.ToBase64String(buffer);
            adjustmentImageUrl = $"data:{file.ContentType};base64,{base64}";

            StateHasChanged();
        }
        catch (Exception ex)
        {
            modalError = $"Failed to process image: {ex.Message}";
        }
    }

    private void RemoveAdjustmentImage()
    {
        adjustmentImageFile = null;
        adjustmentImageData = null;
        adjustmentImageContentType = null;
        adjustmentImageFileName = null;
        adjustmentImageUrl = null;
    }

    private async Task SaveAdjustment()
    {
        isSaving = true;
        modalError = string.Empty;

        try
        {
            await RequestService.CreateAddStockAdjustmentRequestAsync(new Web.Models.Requests.CreateInventoryAdjustmentRequest { Data = adjustmentRequest });
            CloseAdjustmentModal();
            await LoadData();
        }
        catch (Web.Services.ServerValidationException ex)
        {
            modalError = string.Join(" ", ex.Errors.Values.SelectMany(v => v).Select(e => Localizer[e]));
        }
        catch (Exception ex) { modalError = ex.Message; }
        finally { isSaving = false; }
    }

    private async Task ViewAdjustmentDetail(Guid id)
    {
        var adj = await StockAdjustmentService.GetByIdAsync(id);
        if (adj == null) return;

        detailModalTitle = $"{Localizer["AdjustmentDetails"]} - {adj.AdjustmentNumber}";
        detailContent = __builder =>
        {
            <div class="space-y-4">
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                    <div><span class="text-xs text-gray-500 block">@Localizer["Warehouse"]</span><a href="@($"/admin/warehouses/edit/{adj.WarehouseId}")" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800 hover:underline">@(isAr ? adj.WarehouseNameAr : adj.WarehouseNameEn)</a></div>
                    <div><span class="text-xs text-gray-500 block">@Localizer["Type"]</span><span class="font-medium">@Localizer[adj.AdjustmentType]</span></div>
                    <div><span class="text-xs text-gray-500 block">@Localizer["RequestedBy"]</span>@if (adj.RequestedById.HasValue) { <a href="@($"/admin/users/edit/{adj.RequestedById}")" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-bf-primary hover:underline">@adj.RequestedByName</a> } else { <span class="font-medium">—</span> }</div>
                </div>
                @if (!string.IsNullOrEmpty(adj.Explanation))
                {
                    <div class="bg-gray-50 p-3 rounded-lg">
                        <span class="text-xs text-gray-500 block mb-1">@Localizer["Explanation"]</span>
                        <span>@adj.Explanation</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(adj.JustificationImageUrl))
                {
                    <div class="bg-gray-50 p-3 rounded-lg">
                        <span class="text-xs text-gray-500 block mb-2">@Localizer["JustificationImage"]</span>
                        <div class="border rounded-lg overflow-hidden bg-white flex items-center justify-center p-2" style="max-height: 400px; max-width: max-content;">
                            <img src="@adj.JustificationImageUrl" alt="Justification Image" class="max-h-full max-w-full object-contain" />
                        </div>
                    </div>
                }
                <div class="border-t pt-4">
                    <h4 class="font-semibold mb-3">@Localizer["Items"]</h4>
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["Unit"]</th>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["CurrentQty"]</th>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["AdjustmentQty"]</th>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["NewQty"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @foreach (var line in adj.Lines)
                            {
                                <tr>
                                    <td class="px-3 py-2">
                                        <a href="@($"/admin/catalog/units/edit/{line.UnitId}")" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800 hover:underline">@(isAr ? line.ProductNameAr : line.ProductNameEn)</a>
                                        <div class="text-xs text-gray-500 mt-1">@line.UnitBarcode</div>
                                    </td>
                                    <td class="px-3 py-2">
                                        @(line.CurrentQuantity / line.UnitBaseQuantity) @(isAr ? line.UnitOfMeasureNameAr : line.UnitOfMeasureNameEn)
                                        <span class="text-xs text-gray-500 block">(@line.CurrentQuantity @Localizer["BaseUnitItems"])</span>
                                    </td>
                                    @{
                                        var isRemovalType = adj.AdjustmentType is "Damage" or "Loss" or "Theft" or "Expiry" or "CorrectionRemove";
                                        var displaySign = isRemovalType ? "-" : "+";
                                        var signColor = isRemovalType ? "bf-text-danger" : "bf-text-success";
                                        var unitName = isAr ? line.UnitOfMeasureNameAr : line.UnitOfMeasureNameEn;
                                    }
                                    <td class="px-3 py-2 font-medium @signColor">
                                        @displaySign@line.AdjustmentQuantity @unitName
                                        <span class="text-xs text-gray-500 block">(@(line.AdjustmentQuantity * line.UnitBaseQuantity) @Localizer["BaseUnitItems"])</span>
                                    </td>
                                    <td class="px-3 py-2">
                                        @(line.NewQuantity / line.UnitBaseQuantity) @(isAr ? line.UnitOfMeasureNameAr : line.UnitOfMeasureNameEn)
                                        <span class="text-xs text-gray-500 block">(@line.NewQuantity @Localizer["BaseUnitItems"])</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        };
        showDetailModal = true;
    }

    // Delete
    private void ConfirmDeleteItem(Guid id)
    {
        itemToDelete = id;
        showDeleteConfirm = true;
    }

    private async Task HandleDelete()
    {
        showDeleteConfirm = false;
        try
        {
            await RequestService.DeleteRequestAsync(itemToDelete);
            await LoadData();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task ViewDraftAdjustmentDetail(Guid requestId)
    {
        var draft = await RequestService.GetRequestByIdAsync(requestId);
        if (draft == null || string.IsNullOrWhiteSpace(draft.NewDataJson))
            return;

        var data = JsonSerializer.Deserialize<CreateStockAdjustmentRequest>(draft.NewDataJson);
        if (data == null)
            return;

        detailModalTitle = $"{Localizer["AdjustmentDetails"]} - {Localizer["RequestStatusPending"]}";
        detailContent = __builder =>
        {
            <div class="space-y-4">
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                    <div><span class="text-xs text-gray-500 block">@Localizer["Type"]</span><span class="font-medium">@Localizer[data.AdjustmentType]</span></div>
                    <div><span class="text-xs text-gray-500 block">@Localizer["RequestedBy"]</span><a href="@($"/admin/users/edit/{draft.RequestedById}")" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-bf-primary hover:underline">@draft.RequestedByName</a></div>
                    <div><span class="text-xs text-gray-500 block">@Localizer["Status"]</span><span class="px-2 py-1 text-xs font-medium rounded-full bf-bg-warning-100 bf-text-warning">@Localizer["RequestStatusPending"]</span></div>
                </div>
                @if (!string.IsNullOrEmpty(data.Explanation))
                {
                    <div class="bg-gray-50 p-3 rounded-lg">
                        <span class="text-xs text-gray-500 block mb-1">@Localizer["Explanation"]</span>
                        <span>@data.Explanation</span>
                    </div>
                }
                <div class="border-t pt-4">
                    <h4 class="font-semibold mb-3">@Localizer["Items"]</h4>
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["Unit"]</th>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["Quantity"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @foreach (var line in data.Lines)
                            {
                                var unit = units.FirstOrDefault(u => u.Id == line.UnitId);
                                <tr>
                                    <td class="px-3 py-2">@(unit != null ? (isAr ? unit.ProductNameAr : unit.ProductNameEn) : "—")</td>
                                    <td class="px-3 py-2 font-medium">@line.AdjustmentQuantity</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        };
        showDetailModal = true;
    }
}
