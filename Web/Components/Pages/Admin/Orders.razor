@page "/admin/orders"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.OrdersRead)]
@using Microsoft.AspNetCore.Authorization
@using Web.Models.Enums
@using Web.Authorization
@using Web.Components.Common
@using Web.Models.Warehouses
@using System.Globalization
@inject IOrderService OrderService
@inject IWarehouseService WarehouseService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>@Localizer["OrdersManagement"]</PageTitle>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6">
            <!-- Header -->
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
                        <i class="bi bi-receipt text-purple-600"></i>
                        @Localizer["OrdersManagement"]
                    </h1>
                    <p class="text-gray-600 mt-2 text-sm sm:text-base">@Localizer["ManageOrders"]</p>
                </div>
            </div>


            <!-- Filters -->
            <div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
                <div class="flex flex-wrap items-center gap-3 p-4">
                    <div class="flex-1 min-w-[200px]">
                        <SearchInput @bind-Value="searchQuery"
                                     OnSearch="HandleSearch"
                                     Placeholder="@Localizer["SearchOrders"]" />
                    </div>

                    <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                            class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")"> 
                        <i class="bi bi-funnel"></i>
                        <span>@Localizer["Filters"]</span>
                        @if (ActiveFilterCount > 0)
                        {
                            <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
                        }
                        <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
                    </button>

                    @if (HasActiveFilters())
                    {
                        <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                            <i class="bi bi-x-circle"></i>
                            <span>@Localizer["ResetFilters"]</span>
                        </button>
                    }

                    <button @onclick="ExportToExcel"
                            disabled="@(isExporting || totalCount == 0)"
                            class="inline-flex items-center gap-2 py-2 px-4 bf-bg-success-600 bf-hover-bg-success-700 bf-border-success rounded-lg transition-colors text-sm font-medium disabled:opacity-50 disabled:cursor-not-allowed">
                        @if (isExporting)
                        {
                            <Spinner Size="Spinner.SpinnerSize.Xs" Color="Spinner.SpinnerColor.White" />
                            <span>@Localizer["Exporting"]</span>
                        }
                        else
                        {
                            <i class="bi bi-file-earmark-excel"></i>
                            <span>@Localizer["ExportToExcel"]</span>
                        }
                    </button>
                </div>

                @if (showFiltersPanel)
                {
                    <div class="px-4 pb-4 pt-0 border-t border-gray-200">
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 pt-4">
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Date"]</label>
                                <input type="date" @bind="selectedDate" @bind:after="ApplyFilters"
                                       class="w-full bg-white border border-gray-300 text-gray-700 py-2 px-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm" />
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                                <div class="relative">
                                    <select @bind="selectedStatusString" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                                        <option value="">@Localizer["AllStatuses"]</option>
                                        <option value="Completed">@Localizer["StatusCompleted"]</option>
                                        <option value="PartialRefunded">@Localizer["StatusPartialRefunded"]</option>
                                        <option value="Refunded">@Localizer["StatusRefunded"]</option>
                                    </select>
                                    <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                                </div>
                            </div>
                            <div>
                                <SearchableDropdown TItem="WarehouseDto"
                                                    TValue="string"
                                                    Items="availableStores"
                                                    @bind-Value="selectedStoreId"
                                                    OnChanged="ApplyFilters"
                                                    DisplayText='s => CultureInfo.CurrentUICulture.Name.StartsWith("ar") ? s.NameAr : s.NameEn'
                                                    SearchText='s => $"{s.NameEn} {s.NameAr}"'
                                                    ItemValue="s => s.Id.ToString()"
                                                    Label='@Localizer["Store"]'
                                                    Placeholder='@Localizer["AllStores"]'
                                                    Compact="true" />
                            </div>
                        </div>
                    </div>
                }

            </div>

            @if (isLoading)
            {
                <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
                    <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
                    <span class="bf-text-danger">@errorMessage</span>
                </div>
            }
            else if (orders == null || !orders.Any())
            {
                <div class="text-center py-12">
                    <i class="bi bi-receipt text-6xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500 text-lg">@Localizer["NoOrdersFound"]</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["OrderNumber"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["OrderDate"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["PaymentMethod"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Store"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Items"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Total"]</th>
                                <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var order in orders)
                            {
                                <tr class="hover:bg-gray-50 transition-colors duration-150">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            <div class="flex-shrink-0 h-10 w-10 bg-purple-100 rounded-lg flex items-center justify-center">
                                                <i class="bi bi-receipt text-purple-600"></i>
                                            </div>
                                            <div class="ms-4">
                                                <div class="text-sm font-medium text-gray-900 font-mono">
                                                    @order.OrderNumber
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                        @order.CreatedAt.ToLocal().ToString("g", cultureInfo)
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="px-2 py-1 text-xs font-medium rounded-full @GetPaymentMethodClass(order.PaymentMethod)">
                                            @GetPaymentMethodText(order.PaymentMethod)
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="px-2 py-1 text-xs font-medium rounded-full @GetStatusClass(order.Status)">
                                            @GetStatusText(order.Status)
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                        @if (order.WarehouseId.HasValue && !string.IsNullOrEmpty(order.WarehouseNameEn))
                                        {
                                            <a href="/admin/warehouses/edit/@order.WarehouseId" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800 hover:underline">@(isAr ? order.WarehouseNameAr : order.WarehouseNameEn)</a>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                        @order.ItemCount
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">
                                        @Localizer.GetLocalizedCurrency(order.Total)
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                                        <button @onclick="() => ViewOrder(order.Id)" 
                                                class="text-indigo-600 hover:text-indigo-900 me-3" 
                                                title="@Localizer["ViewOrder"]">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <Pagination PageIndex="@pageIndex" 
                            TotalPages="@totalPages" 
                            TotalCount="@totalCount" 
                            PageSize="@pageSize" 
                            OnPageChanged="@OnPageChanged" />
            }
</div>

            <!-- Order Details Modal -->
            <OrderDetailsModal IsVisible="@showOrderModal" Order="@selectedOrder" OnClose="CloseOrderModal" />

@code {
    private List<OrderDto> orders = new();
    private List<WarehouseDto> availableStores = new();

    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private bool isAr = false;
    private CultureInfo cultureInfo = new CultureInfo("en-AE");

    // Filters
    private string searchQuery = "";
    private OrderStatus? selectedStatus = null;
    private string selectedStatusString
    {
        get => selectedStatus?.ToString() ?? "";
        set => selectedStatus = string.IsNullOrEmpty(value) ? null : Enum.Parse<OrderStatus>(value);
    }
    private DateTime? selectedDate = null;
    private string selectedStoreId = string.Empty;
    private bool showFiltersPanel = false;

    private bool HasActiveFilters() => selectedStatus != null || selectedDate.HasValue || !string.IsNullOrEmpty(selectedStoreId);
    private int ActiveFilterCount => (selectedStatus != null ? 1 : 0) + (selectedDate.HasValue ? 1 : 0) + (string.IsNullOrEmpty(selectedStoreId) ? 0 : 1);
    // Pagination
    private int pageIndex = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private int totalCount = 0;

    // Modal
    private bool showOrderModal = false;
    private OrderDto? selectedOrder = null;

    // Export
    private bool isExporting = false;

    protected override async Task OnInitializedAsync()
    {
        var currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.ToLowerInvariant();
        isAr = currentCulture == "ar";
        cultureInfo = isAr ? new CultureInfo("ar-AE") : new CultureInfo("en-AE");

        // Subscribe to navigation events to reset filters
        Navigation.LocationChanged += OnLocationChanged;

        await LoadFilterData();
        await LoadOrders();
    }

    private async Task LoadFilterData()
    {
        try
        {
            var allWarehouses = await WarehouseService.GetActiveWarehousesAsync();
            availableStores = allWarehouses.Where(w => w.WarehouseTypeCode == "MS").ToList();
        }
        catch { }

    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // Reset filters when navigating to this page
        if (e.Location.Contains("/admin/orders", StringComparison.OrdinalIgnoreCase))
        {
            ResetFiltersValues();
            InvokeAsync(async () =>
            {
                await LoadOrders();
                StateHasChanged();
            });
        }
    }

    private void ResetFiltersValues()
    {
        searchQuery = "";
        selectedStatus = null;
        selectedDate = null;
        selectedStoreId = string.Empty;
        pageIndex = 1;
    }

    private async Task ResetFilters()
    {
        ResetFiltersValues();
        await LoadOrders();
    }

    private async Task HandleSearch(string searchValue)
    {
        searchQuery = searchValue;
        pageIndex = 1;
        await LoadOrders();
    }

    private async Task ApplyFilters()
    {
        pageIndex = 1;
        await LoadOrders();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private async Task LoadOrders()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            DateTime? fromDate = selectedDate;
            DateTime? toDate = selectedDate?.AddDays(1);
            Guid? warehouseId = string.IsNullOrEmpty(selectedStoreId) ? null : Guid.Parse(selectedStoreId);
            var result = await OrderService.GetAllOrdersAsync(
                pageIndex, 
                pageSize, 
                searchQuery, 
                selectedStatus, 
                null,
                null,
                fromDate,
                toDate,
                warehouseId,
                null);
            
            orders = result.Items;
            totalPages = result.TotalPages;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToLoadOrders"]}: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnPageChanged(int newPage)
    {
        pageIndex = newPage;
        await LoadOrders();
    }

    private async Task ViewOrder(Guid orderId)
    {
        try
        {
            selectedOrder = await OrderService.GetOrderByIdAsync(orderId);
            showOrderModal = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void CloseOrderModal()
    {
        showOrderModal = false;
        selectedOrder = null;
    }

    private string GetStatusClass(OrderStatus status) => status switch
    {
        OrderStatus.Completed => "bf-bg-success-100 bf-text-success",
        OrderStatus.Refunded => "bf-bg-danger-100 bf-text-danger",
        OrderStatus.PartialRefunded => "bf-bg-info-100 bf-text-info",
        _ => "bg-gray-100 text-gray-800"
    };

    private string GetPaymentMethodClass(PaymentMethod method) => method switch
    {
        PaymentMethod.Cash => "bf-bg-success-100 bf-text-success",
        PaymentMethod.Card => "bg-blue-100 text-blue-800",
        PaymentMethod.Mobile => "bg-purple-100 text-purple-800",
        PaymentMethod.Split => "bg-violet-100 text-violet-800",
        _ => "bg-gray-100 text-gray-800"
    };

    private string GetStatusText(OrderStatus status) => status switch
    {
        OrderStatus.Completed => Localizer["StatusCompleted"],
        OrderStatus.Refunded => Localizer["StatusRefunded"],
        OrderStatus.PartialRefunded => Localizer["StatusPartialRefunded"],
        _ => status.ToString()
    };

    private string GetPaymentMethodText(PaymentMethod method) => method switch
    {
        PaymentMethod.Cash => Localizer["PaymentCash"],
        PaymentMethod.Card => Localizer["PaymentCard"],
        PaymentMethod.Mobile => Localizer["PaymentMobile"],
        PaymentMethod.Split => Localizer["SplitPayment"],
        _ => method.ToString()
    };

    private async Task ExportToExcel()
    {
        if (isExporting) return;
        isExporting = true;
        try
        {
            DateTime? fromDate = selectedDate;
            DateTime? toDate = selectedDate?.AddDays(1);
            Guid? warehouseId = string.IsNullOrEmpty(selectedStoreId) ? null : Guid.Parse(selectedStoreId);

            var bytes = await OrderService.ExportOrdersToExcelAsync(
                searchQuery,
                selectedStatus,
                null,
                null,
                fromDate,
                toDate,
                warehouseId,
                null,
                isAr);

            var base64 = Convert.ToBase64String(bytes);
            var filename = $"orders-{DateTime.Now:yyyyMMdd-HHmm}.xlsx";
            await JSRuntime.InvokeAsync<bool>("App.downloadFile", filename,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", base64);
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["ExportFailed"]}: {ex.Message}";
        }
        finally
        {
            isExporting = false;
        }
    }
}
