@page "/admin/users"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.UsersRead)]
@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using Web.Components.Common
@using System.Globalization
@inject IUserManagementService UserService
@inject IRoleManagementService RoleService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer

<PageTitle>@Localizer["UsersManagement"]</PageTitle>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6">
            <!-- Header -->
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
                        <i class="bi bi-people text-purple-600"></i>
                        @Localizer["UsersManagement"]
                    </h1>
                    <p class="text-gray-600 mt-2 text-sm sm:text-base">@Localizer["ManageUserAccountsRolesPermissions"]</p>
                </div>
                
                <AuthorizeView Policy="Permission:users.write">
                    <Authorized>
                        <button @onclick="NavigateToCreate" 
                                class="btn-primary-action">
                            <i class="bi bi-plus-circle"></i>
                            <span>@Localizer["CreateUser"]</span>
                        </button>
                    </Authorized>
                    <NotAuthorized>
                        <button disabled 
                                class="inline-flex items-center gap-2 py-3 px-6 bg-gray-300 text-gray-500 rounded-lg cursor-not-allowed font-medium">
                            <i class="bi bi-plus-circle"></i>
                            <span>@Localizer["CreateUser"]</span>
                        </button>
                    </NotAuthorized>
                </AuthorizeView>
            </div>

            <!-- Filters -->
            <div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
                <div class="flex flex-wrap items-center gap-3 p-4">
                    <div class="flex-1 min-w-[200px]">
                        <SearchInput @bind-Value="searchTerm"
                                     OnSearch="HandleSearch"
                                     Placeholder="@Localizer["SearchUsers"]" />
                    </div>

                    <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                            class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")"> 
                        <i class="bi bi-funnel"></i>
                        <span>@Localizer["Filters"]</span>
                        @if (ActiveFilterCount > 0)
                        {
                            <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
                        }
                        <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
                    </button>

                    @if (HasActiveFilters())
                    {
                        <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                            <i class="bi bi-x-circle"></i>
                            <span>@Localizer["ResetFilters"]</span>
                        </button>
                    }
                </div>

                @if (showFiltersPanel)
                {
                    <div class="px-4 pb-4 pt-0 border-t border-gray-200">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-4">
                            <div>
                                <SearchableDropdown TItem="RoleResponse"
                                                    TValue="string"
                                                    Items="availableRoles"
                                                    @bind-Value="selectedRole"
                                                    OnChanged="ApplyFilters"
                                                    DisplayText='r => CultureInfo.CurrentUICulture.Name.StartsWith("ar") ? r.NameAr : r.NameEn'
                                                    SearchText='r => $"{r.NameEn} {r.NameAr}"'
                                                    ItemValue="r => r.NameEn"
                                                    Label='@Localizer["Role"]'
                                                    Placeholder='@Localizer["AllRoles"]'
                                                    Compact="true" />
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                                <div class="relative">
                                    <select @bind="selectedStatus" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                                        <option value="">@Localizer["AllStatuses"]</option>
                                        <option value="true">@Localizer["Active"]</option>
                                        <option value="false">@Localizer["Inactive"]</option>
                                    </select>
                                    <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

            </div>

            @if (isLoading)
            {
                <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
                    <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
                    <span class="bf-text-danger">@errorMessage</span>
                </div>
            }
            else if (users == null || !users.Any())
            {
                <div class="text-center py-12">
                    <i class="bi bi-inbox text-6xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500 text-lg">@Localizer["NoUsersFound"]</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["User"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Email"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Roles"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                                <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var user in users)
                            {
                                <tr class="hover:bg-gray-50 transition-colors duration-150">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            @if (!string.IsNullOrEmpty(user.AvatarUrl))
                                            {
                                                <img src="@user.AvatarUrl" alt="@user.FullName" class="flex-shrink-0 h-10 w-10 rounded-full object-cover border border-gray-200" />
                                            }
                                            else
                                            {
                                                <div class="flex-shrink-0 h-10 w-10 bg-purple-100 rounded-full flex items-center justify-center">
                                                    <i class="bi bi-person-fill text-purple-600"></i>
                                                </div>
                                            }
                                            <div class="ms-4">
                                                <div class="text-sm font-medium text-gray-900">
                                                    @user.FullName
                                                </div>
                                                @if (user.IsSystemUser)
                                                {
                                                    <div class="text-xs text-gray-500 mt-1 inline-flex items-center gap-2">
                                                        <i class="bi bi-lock-fill me-1"></i> @Localizer["SystemUser"]
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <a href="mailto:@user.Email" class="text-sm text-purple-600 hover:text-purple-800 hover:underline">@user.Email</a>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex flex-wrap gap-1">
                                            @foreach (var role in user.Roles ?? [])
                                            {
                                                <a class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 hover:underline"
                                                   href="@($"/admin/roles/edit/{role.Id}")">
                                                    @(CultureInfo.CurrentUICulture.Name.StartsWith("ar") ? role.NameAr : role.Name)
                                                </a>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        @if (user.IsActive)
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-success-100 bf-text-success">
                                                <i class="bi bi-check-circle-fill me-1"></i> @Localizer["Active"]
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-danger-100 bf-text-danger">
                                                <i class="bi bi-x-circle-fill me-1"></i> @Localizer["Inactive"]
                                            </span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                                        @* Show shifts link for users who are cashiers *@
                                        @if (user.Roles != null && user.Roles.Any(r => string.Equals(r.Name, "Cashier", StringComparison.OrdinalIgnoreCase) || string.Equals(r.NameEn, "Cashier", StringComparison.OrdinalIgnoreCase)))
                                        {
                                            <AuthorizeView Policy="Permission:shifts.read">
                                                <Authorized>
                                                    <button @onclick="() => OpenShiftsModal(user)" title="@Localizer["ViewShifts"]" class="text-amber-600 hover:text-amber-900 me-3">
                                                        <i class="bi bi-clock-history"></i>
                                                    </button>
                                                </Authorized>
                                                <NotAuthorized>
                                                    <button disabled class="text-gray-300 me-3 cursor-not-allowed" title="@Localizer["ViewShifts"]">
                                                        <i class="bi bi-clock-history"></i>
                                                    </button>
                                                </NotAuthorized>
                                            </AuthorizeView>
                                        }

                                        <AuthorizeView Policy="Permission:users.write">
                                            <Authorized>
                                                        @if (!user.IsSystemUser)
                                                        {
                                                            <button @onclick="() => NavigateToEdit(user.Id)" 
                                                                    class="text-purple-600 hover:text-purple-900 me-3" title="@Localizer["Edit"]">
                                                                <i class="bi bi-pencil-square"></i>
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <AuthorizeView Policy="Permission:users.read">
                                                                <Authorized Context="usersReadAuth">
                                                                    <button @onclick="() => NavigateToEdit(user.Id)"
                                                                            class="text-indigo-600 hover:text-indigo-900 me-3" title="@Localizer["ViewDetails"]">
                                                                        <i class="bi bi-eye"></i>
                                                                    </button>
                                                                </Authorized>
                                                                <NotAuthorized Context="usersReadAuthNot">
                                                                    <button disabled class="text-gray-400 me-3 cursor-not-allowed" title="@Localizer["ViewDetails"]">
                                                                        <i class="bi bi-eye"></i>
                                                                    </button>
                                                                </NotAuthorized>
                                                            </AuthorizeView>
                                                        }
                                            </Authorized>
                                            <NotAuthorized>
                                                @if (user.IsSystemUser)
                                                {
                                                    <AuthorizeView Policy="Permission:users.read">
                                                        <Authorized Context="usersReadAuth2">
                                                            <button @onclick="() => NavigateToEdit(user.Id)"
                                                                    class="text-indigo-600 hover:text-indigo-900 me-3" title="@Localizer["ViewDetails"]">
                                                                <i class="bi bi-eye"></i>
                                                            </button>
                                                        </Authorized>
                                                        <NotAuthorized Context="usersReadAuth2Not">
                                                            <button disabled class="text-gray-400 me-3 cursor-not-allowed" title="@Localizer["ViewDetails"]">
                                                                <i class="bi bi-eye"></i>
                                                            </button>
                                                        </NotAuthorized>
                                                    </AuthorizeView>
                                                }
                                                else {
                                                    <button disabled class="text-gray-400 me-3 cursor-not-allowed">
                                                        <i class="bi bi-pencil-square"></i>
                                                    </button>
                                                }
                                            </NotAuthorized>
                                        </AuthorizeView>
                                        <AuthorizeView Policy="Permission:users.delete">
                                            <Authorized>
                                                @if (!user.IsSystemUser)
                                                {
                                                    <button @onclick="() => ConfirmDelete(user.Id)" 
                                                            class="bf-text-danger bf-hover-text-danger-strong" title="@Localizer["Delete"]">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button disabled class="text-gray-400 cursor-not-allowed" title="@Localizer["SystemAdminModifyWarning"]">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                }
                                            </Authorized>
                                            <NotAuthorized>
                                                <button disabled class="text-gray-400 cursor-not-allowed">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </NotAuthorized>
                                        </AuthorizeView>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <Pagination PageIndex="@pageIndex" 
                                TotalPages="@totalPages" 
                                TotalCount="@totalCount" 
                                PageSize="@pageSize" 
                                OnPageChanged="@OnPageChanged" />
                </div>
            }
</div>

<ConfirmModal IsVisible="@showDeleteConfirm"
              Title="@Localizer["DeleteUserTitle"]"
              Message="@Localizer["DeleteUserConfirmation"]"
              OnConfirm="@DeleteUser"
              OnCancel="@CancelDelete"
              IsDanger="true" />

<CashierShiftsModal IsVisible="@showShiftsModal" CashierName="@shiftsModalCashierName" OnClose="CloseShiftsModal" />
@code {
private List<UserResponse> users = new();
private List<RoleResponse> availableRoles = new();
private bool isLoading = true;
private string errorMessage = string.Empty;
private bool showDeleteConfirm = false;
private Guid userToDelete;
    
// Filters
private string searchTerm = string.Empty;
private string selectedRole = string.Empty;
private string selectedStatus = string.Empty;
private bool showFiltersPanel = false;

private bool HasActiveFilters() => !string.IsNullOrEmpty(selectedRole) || !string.IsNullOrEmpty(selectedStatus);
private int ActiveFilterCount => (string.IsNullOrEmpty(selectedRole) ? 0 : 1) + (string.IsNullOrEmpty(selectedStatus) ? 0 : 1);
    
// Pagination
private int pageIndex = 1;
private int pageSize = 10;
private int totalPages = 1;
private int totalCount = 0;

protected override async Task OnInitializedAsync()
{
    await LoadRoles();
    await LoadUsers();
}

private async Task LoadRoles()
{
    try
    {
        // Fetch all roles for the filter dropdown
        // Using a large page size to get all roles
        var result = await RoleService.GetAllRolesAsync(1, 100);
        availableRoles = result.Items.ToList();
    }
    catch (Exception ex)
    {
        // Log error but don't stop user loading
        Console.WriteLine($"Failed to load roles: {ex.Message}");
    }
}

private async Task LoadUsers()
{
    isLoading = true;
    errorMessage = string.Empty;
        
    try
    {
        string? role = string.IsNullOrWhiteSpace(selectedRole) ? null : selectedRole;
        bool? isActive = string.IsNullOrEmpty(selectedStatus) ? null : bool.Parse(selectedStatus);
            
        var result = await UserService.GetAllUsersAsync(pageIndex, pageSize, role, searchTerm, isActive);
        users = result.Items;
        totalPages = result.TotalPages;
        totalCount = result.TotalCount;
    }
    catch (Exception ex)
    {
        errorMessage = Localizer["FailedToLoadUsers"] + $": {ex.Message}";
    }
    finally
    {
        isLoading = false;
    }
}
    
private async Task OnPageChanged(int newPageIndex)
{
    pageIndex = newPageIndex;
    await LoadUsers();
}

private async Task HandleSearch(string searchValue)
{
    searchTerm = searchValue;
    pageIndex = 1;
    await LoadUsers();
}

private async Task ApplyFilters()
{
    pageIndex = 1;
    await LoadUsers();
}

private async Task ResetFilters()
{
    searchTerm = string.Empty;
    selectedRole = string.Empty;
    selectedStatus = string.Empty;
    pageIndex = 1;
    await LoadUsers();
}

    private void NavigateToCreate()
    {
        Navigation.NavigateTo("/admin/users/create");
    }

    private void NavigateToEdit(Guid userId)
    {
        Navigation.NavigateTo($"/admin/users/edit/{userId}");
    }

    private void NavigateToShifts(UserResponse user)
    {
        // Navigate to admin shifts page with cashier filter in query string
        // We'll use `search` query param to pass the cashier name or id; shifts page expects `search` to filter
        var q = $"/admin/shifts?search={Uri.EscapeDataString(user.FullName)}";
        Navigation.NavigateTo(q);
    }

    // Modal for showing cashier shifts
    private bool showShiftsModal = false;
    private string? shiftsModalCashierName;

    private void OpenShiftsModal(UserResponse user)
    {
        shiftsModalCashierName = user.FullName;
        showShiftsModal = true;
    }

    private void CloseShiftsModal()
    {
        showShiftsModal = false;
        shiftsModalCashierName = null;
    }

    private void ConfirmDelete(Guid userId)
    {
        userToDelete = userId;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        userToDelete = Guid.Empty;
    }

    private async Task DeleteUser()
    {
        try
        {
            await UserService.DeleteUserAsync(userToDelete);
            showDeleteConfirm = false;
            await LoadUsers();
        }
        catch (Exception ex)
        {
            errorMessage = Localizer["FailedToDeleteUser"] + $": {ex.Message}";
            showDeleteConfirm = false;
        }
    }

}
