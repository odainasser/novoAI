@page "/admin/catalog/units/create"
@page "/admin/catalog/units/edit/{UnitId:guid}"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.UnitsWrite)]
@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using System.Globalization
@using System.Text.Json
@using Web.Components.Common
@using System.ComponentModel.DataAnnotations
@using Web.Models.Enums
@using Web.Models.Products
@using Web.Models.Lookups
@using Web.Models.Requests
@using Web.Services
@inject IUnitService UnitService
@inject IProductService ProductService
@inject ILookupService LookupService
@inject IRequestService RequestService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer

<PageTitle>@(IsEditMode ? Localizer["EditUnit"] : Localizer["CreateUnit"])</PageTitle>

@if (isLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else
{
    <EditForm Model="@model" OnValidSubmit="HandleValidSubmit" FormName="unitForm">
        <LocalizedDataAnnotationsValidator />
        <ServerValidator @ref="serverValidator" />

        <!-- Sticky top bar -->
        <div class="form-sticky-toolbar sticky top-0 z-30 -mx-4 sm:-mx-6 px-4 sm:px-6 py-3 mb-6">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <button type="button" @onclick="NavigateBack" class="p-2 -ml-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors">
                        <i class="bi bi-arrow-left text-lg"></i>
                    </button>
                    <h1 class="text-xl font-semibold text-gray-900">
                        @(IsEditMode ? Localizer["EditUnit"] : Localizer["CreateUnit"])
                    </h1>
                </div>
                <div class="flex items-center gap-2">
                    <button type="button" @onclick="NavigateBack" class="form-cancel-btn px-4 py-2 text-sm font-medium rounded-lg transition-colors">
                        @Localizer["Cancel"]
                    </button>
                    <button type="submit" disabled="@isSaving" class="px-4 py-2 text-sm font-medium bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-all disabled:opacity-50 inline-flex items-center gap-2">
                        @if (isSaving)
                        {
                            <Spinner Size="Spinner.SpinnerSize.Xs" Color="Spinner.SpinnerColor.White" />
                        }
                        <span>@(IsEditMode ? Localizer["Update"] : Localizer["Create"])</span>
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="mb-5 p-4 bg-red-50 border border-red-200 rounded-xl flex items-start gap-3">
                <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                <span class="text-red-800 text-sm">@errorMessage</span>
            </div>
        }

        <!-- Two-column Shopify-style layout -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

            <!-- Main column (2/3) -->
            <div class="lg:col-span-2 space-y-5">

                <!-- Card: Unit Details -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <div class="space-y-4">
                        <div>
                            <SearchableDropdown TItem="LookupDto" TValue="Guid"
                                               Items="unitsOfMeasure"
                                               @bind-Value="model.UnitOfMeasureId"
                                               DisplayText="@(u => isAr ? u.NameAr : u.NameEn)"
                                               ItemValue="@(u => u.Id)"
                                               Label="@Localizer["UnitOfMeasure"]"
                                               Placeholder="@Localizer["SelectUnitOfMeasure"]"
                                               Required="true"
                                               Clearable="false" />
                            <ValidationMessage For="@(() => model.UnitOfMeasureId)" class="text-red-600 text-xs mt-1" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                @Localizer["UnitType"] <span class="text-red-500">*</span>
                            </label>
                            <div class="flex flex-wrap gap-4 p-3 border border-gray-300 rounded-lg">
                                @foreach (var ut in unitTypes)
                                {
                                    var utId = ut.Id;
                                    <label class="flex items-center gap-2 cursor-pointer">
                                        <input type="checkbox"
                                               checked="@model.UnitTypeIds.Contains(utId)"
                                               @onchange="@(e => ToggleUnitType(utId, (bool)(e.Value ?? false)))"
                                               class="w-4 h-4 rounded border-gray-300 text-bf-primary focus:ring-bf-primary cursor-pointer" />
                                        <span class="text-sm text-gray-700">@(isAr ? ut.NameAr : ut.NameEn)</span>
                                    </label>
                                }
                            </div>
                            <ValidationMessage For="@(() => model.UnitTypeIds)" class="text-red-600 text-xs mt-1" />
                        </div>

                        <div>
                            <SearchableDropdown TItem="ProductDto" TValue="Guid"
                                               Items="products"
                                               @bind-Value="model.ProductId"
                                               DisplayText="@(p => isAr ? p.NameAr : p.NameEn)"
                                               ItemValue="@(p => p.Id)"
                                               Label="@Localizer["Product"]"
                                               Placeholder="@Localizer["SelectProduct"]"
                                               Required="true"
                                               Clearable="false" />
                            <ValidationMessage For="@(() => model.ProductId)" class="text-red-600 text-xs mt-1" />
                        </div>

                        <div class="max-w-xs">
                            <label for="quantity" class="block text-sm font-medium text-gray-700 mb-1.5">
                                @Localizer["BaseUnits"] <span class="text-red-500">*</span>
                            </label>
                            <InputNumber @bind-Value="model.Quantity"
                                         class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm"
                                         id="quantity"
                                         min="1" />
                            <ValidationMessage For="@(() => model.Quantity)" class="text-red-600 text-xs mt-1" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar (1/3) -->
            <div class="space-y-5">

                <!-- Card: Status -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <h2 class="text-sm font-semibold text-gray-900 mb-3">@Localizer["Status"]</h2>
                    <ToggleSwitch @bind-Value="model.IsActive" Label="@Localizer["Active"]" />
                    @if (IsEditMode)
                    {
                        <div class="mt-2">
                            @if (model.IsActive)
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                    <i class="bi bi-check-circle-fill me-1"></i> @Localizer["Active"]
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                    <i class="bi bi-x-circle-fill me-1"></i> @Localizer["Inactive"]
                                </span>
                            }
                        </div>
                        @if (unitNeedsAction)
                        {
                            <div class="mt-3">
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-800 border border-amber-200">
                                    <i class="bi bi-exclamation-circle-fill me-1"></i> @Localizer["NeedsAction"]
                                </span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter] public Guid? UnitId { get; set; }

    private bool IsEditMode => UnitId.HasValue;
    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private bool isAr = false;

    private ServerValidator? serverValidator;
    private UnitFormModel model = new();
    private List<ProductDto> products = new();
    private List<LookupDto> unitsOfMeasure = new();
    private List<LookupDto> unitTypes = new();
    private bool unitNeedsAction;

    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        await Task.WhenAll(LoadProducts(), LoadUnitsOfMeasure(), LoadUnitTypes());

        if (IsEditMode)
        {
            await LoadUnit();
        }
        else
        {
            isLoading = false;
        }
    }

    private async Task LoadProducts()
    {
        try
        {
            var result = await ProductService.GetAllProductsAsync(1, 1000, isActive: true);
            products = result.Items;
        }
        catch
        {
            products = new List<ProductDto>();
        }
    }

    private async Task LoadUnitsOfMeasure()
    {
        try
        {
            unitsOfMeasure = await LookupService.GetLookupsByParentAsync("UNIT_OF_MEASURE");
        }
        catch
        {
            unitsOfMeasure = new List<LookupDto>();
        }
    }

    private async Task LoadUnitTypes()
    {
        try
        {
            unitTypes = await LookupService.GetLookupsByParentAsync("UNIT_TYPE");
        }
        catch
        {
            unitTypes = new List<LookupDto>();
        }
    }

    private async Task LoadUnit()
    {
        try
        {
            var unit = await UnitService.GetByIdAsync(UnitId!.Value);
            if (unit == null || unit.Status == Web.Models.Enums.ItemStatus.Rejected)
            {
                Navigation.NavigateTo("/admin/catalog/units");
                return;
            }

            model.UnitOfMeasureId = unit.UnitOfMeasureId;
            model.UnitTypeIds = unit.UnitTypes.Select(ut => ut.Id).ToList();
            model.ProductId = unit.ProductId;
            model.Quantity = unit.Quantity;
            model.IsActive = unit.IsActive;
            model.Status = unit.Status;
            await LoadPendingRequestFlagAsync(unit.Id);
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToLoadUnit"]}: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleValidSubmit()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            var errors = new Dictionary<string, string[]>();

            if (model.UnitOfMeasureId == Guid.Empty)
                errors.Add(nameof(model.UnitOfMeasureId), new[] { "UnitOfMeasureRequired" });

            if (model.UnitTypeIds.Count == 0)
                errors.Add(nameof(model.UnitTypeIds), new[] { "UnitTypeRequired" });

            if (model.ProductId == Guid.Empty)
                errors.Add(nameof(model.ProductId), new[] { "ProductRequired" });

            if (errors.Any())
            {
                serverValidator?.DisplayErrors(errors);
                isSaving = false;
                return;
            }

            if (IsEditMode)
            {
                await UnitService.UpdateAsync(UnitId!.Value, new Web.Models.Units.UpdateUnitRequest
                {
                    UnitOfMeasureId = model.UnitOfMeasureId,
                    UnitTypeIds = model.UnitTypeIds,
                    ProductId = model.ProductId,
                    Quantity = model.Quantity,
                    Status = model.IsActive ? Web.Models.Enums.ItemStatus.Active : Web.Models.Enums.ItemStatus.Inactive
                });
            }
            else
            {
                await UnitService.CreateAsync(new Web.Models.Units.CreateUnitRequest
                {
                    UnitOfMeasureId = model.UnitOfMeasureId,
                    UnitTypeIds = model.UnitTypeIds,
                    ProductId = model.ProductId,
                    Quantity = model.Quantity,
                    Status = model.IsActive ? Web.Models.Enums.ItemStatus.Active : Web.Models.Enums.ItemStatus.Inactive
                });
            }

            Navigation.NavigateTo("/admin/catalog/units");
        }
        catch (ServerValidationException ex)
        {
            serverValidator?.DisplayErrors(ex.Errors);
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToSaveUnit"]}: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void NavigateBack() => Navigation.NavigateTo("/admin/catalog/units");

    private async Task LoadPendingRequestFlagAsync(Guid unitId)
    {
        unitNeedsAction = false;

        var pendingRequests = new List<RequestDto>();
        try
        {
            var pending = await RequestService.GetAllRequestsAsync(1, 1000, null, null, RequestStatus.Pending);
            pendingRequests = pending.Items;
        }
        catch
        {
            try
            {
                var pendingMine = await RequestService.GetMyRequestsAsync(1, 1000, null, null, RequestStatus.Pending);
                pendingRequests = pendingMine.Items;
            }
            catch
            {
                return;
            }
        }

        unitNeedsAction = pendingRequests.Any(req =>
            req.UnitId == unitId ||
            ExtractEntityIdFromRequest(req.NewDataJson, req.OldDataJson, "UnitId", "unitId", "Id", "id") == unitId);
    }

    private static Guid? ExtractEntityIdFromRequest(string? newDataJson, string? oldDataJson, params string[] keys)
    {
        return ExtractGuid(newDataJson, keys) ?? ExtractGuid(oldDataJson, keys);
    }

    private static Guid? ExtractGuid(string? json, params string[] keys)
    {
        if (string.IsNullOrWhiteSpace(json))
            return null;

        try
        {
            using var doc = JsonDocument.Parse(json);
            return ExtractGuidFromElement(doc.RootElement, keys);
        }
        catch
        {
            return null;
        }
    }

    private static Guid? ExtractGuidFromElement(JsonElement element, params string[] keys)
    {
        if (element.ValueKind == JsonValueKind.Object)
        {
            foreach (var prop in element.EnumerateObject())
            {
                if (keys.Contains(prop.Name, StringComparer.OrdinalIgnoreCase)
                    && prop.Value.ValueKind == JsonValueKind.String
                    && Guid.TryParse(prop.Value.GetString(), out var parsed))
                {
                    return parsed;
                }

                var nested = ExtractGuidFromElement(prop.Value, keys);
                if (nested.HasValue)
                    return nested;
            }
        }
        else if (element.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in element.EnumerateArray())
            {
                var nested = ExtractGuidFromElement(item, keys);
                if (nested.HasValue)
                    return nested;
            }
        }

        return null;
    }

    private void ToggleUnitType(Guid typeId, bool isChecked)
    {
        if (isChecked && !model.UnitTypeIds.Contains(typeId))
            model.UnitTypeIds.Add(typeId);
        else if (!isChecked)
            model.UnitTypeIds.Remove(typeId);
    }

    private class UnitFormModel
    {
        public Guid UnitOfMeasureId { get; set; } = Guid.Empty;

        public List<Guid> UnitTypeIds { get; set; } = new();

        public Guid ProductId { get; set; } = Guid.Empty;

        [Range(1, int.MaxValue, ErrorMessage = "BaseUnitsMustBePositive")]
        public int Quantity { get; set; } = 1;

        public bool IsActive { get; set; } = true;

        public Web.Models.Enums.ItemStatus Status { get; set; } = Web.Models.Enums.ItemStatus.Draft;
    }
}
