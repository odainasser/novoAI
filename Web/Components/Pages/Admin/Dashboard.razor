    private List<BarChart.BarChartItem> GetMovementBarChartItems()
    {
        var isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";

        var filtered = movementData
            .Where(w => !movementSelectedTypeId.HasValue || w.WarehouseTypeId == movementSelectedTypeId.Value);

        return filtered.Select(w =>
        {
            var isBranch = w.WarehouseTypeCode == "MW";
            var isCW = w.WarehouseTypeCode == "CW";
            string warehouseName = isAr && !string.IsNullOrEmpty(w.WarehouseNameAr) ? w.WarehouseNameAr : w.WarehouseName;
            string? branchName = isBranch
                ? (isAr && !string.IsNullOrEmpty(w.BranchNameAr) ? w.BranchNameAr : w.BranchNameEn)
                : null;
            var label = branchName != null ? $"{warehouseName} ({branchName})" : warehouseName;
            var typeName = isAr && !string.IsNullOrEmpty(w.WarehouseTypeNameAr) ? w.WarehouseTypeNameAr : w.WarehouseTypeName;

            int received, transferredIn, transferredOut;
            if (movementSelectedProductId.HasValue)
            {
                var p = w.Products.FirstOrDefault(p => p.ProductId == movementSelectedProductId.Value);
                received = isCW ? (p?.ReceivedQuantity ?? 0) : 0;
                transferredIn = p?.TransferredInQuantity ?? 0;
                transferredOut = p?.TransferredOutQuantity ?? 0;
            }
            else
            {
                received = isCW ? w.Products.Sum(p => p.ReceivedQuantity) : 0;
                transferredIn = w.Products.Sum(p => p.TransferredInQuantity);
                transferredOut = w.Products.Sum(p => p.TransferredOutQuantity);
            }

            return new { Label = label, TypeName = typeName, IsCW = isCW, Received = received, TransferredIn = transferredIn, TransferredOut = transferredOut };
        })
        .Where(v => v.Received > 0 || v.TransferredIn > 0 || v.TransferredOut > 0)
        .Select(v =>
        {
            var tooltip = $"<div class='chart-tooltip-row'><strong>{v.Label}</strong><br/>";
            if (v.IsCW)
                tooltip += $"<span class='chart-dot-light'>● </span>{Localizer["Received"]}: {v.Received}<br/>";
            tooltip += $"<span class='chart-dot-light'>● </span>{Localizer["TransferredIn"]}: {v.TransferredIn}<br/>"
                    + $"<span class='chart-dot-dark'>● </span>{Localizer["TransferredOut"]}: {v.TransferredOut}<br/>"
                    + $"<span class='chart-dot-muted'>● </span>{Localizer["WarehouseType"]}: {v.TypeName}</div>";

            var bars = new List<BarChart.BarChartBar>();
            if (v.Received > 0)
                bars.Add(new() { Value = v.Received, BgCssClass = "bf-bg-success-500", TextCssClass = "bf-text-success" });
            if (v.TransferredIn > 0)
                bars.Add(new() { Value = v.TransferredIn, BgCssClass = "bf-bg-info-600", TextCssClass = "bf-text-info" });
            if (v.TransferredOut > 0)
                bars.Add(new() { Value = v.TransferredOut, BgCssClass = "bf-bg-danger-500", TextCssClass = "bf-text-danger" });

            return new BarChart.BarChartItem
            {
                Label = v.Label,
                Tooltip = tooltip,
                Bars = bars
            };
        })
        .ToList();
    }

    private List<BarChart.BarChartLegend> GetMovementBarChartLegend()
    {
        return new List<BarChart.BarChartLegend>
        {
            new() { Label = Localizer["Received"], BgCssClass = "bf-bg-success-500" },
            new() { Label = Localizer["TransferredIn"], BgCssClass = "bf-bg-info-600" },
            new() { Label = Localizer["TransferredOut"], BgCssClass = "bf-bg-danger-500" }
        };
