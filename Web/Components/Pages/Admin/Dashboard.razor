    private async Task LoadMonthlyRevenueAsync()
    {
        try
        {
            monthlyRevenueData = await DashboardService.GetMonthlyRevenueAsync(12);

            revenueStoreList = monthlyRevenueData
                .SelectMany(m => m.Stores)
                .GroupBy(s => s.WarehouseId)
                .Select(g => g.First())
                .OrderBy(s => s.WarehouseName)
                .ToList();
        }
        catch
        {
            monthlyRevenueData = new();
            revenueStoreList = new();
        }
        finally
        {
            isLoadingMonthlyRevenue = false;
            StateHasChanged();
        }
    }

    private void OnRevenueStoreFilterChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        revenueSelectedStoreId = string.IsNullOrEmpty(val) ? null : Guid.Parse(val);
    }

    private void OnResetRevenueFilters()
    {
        revenueSelectedStoreId = null;
    }

    private List<LineChart.LineChartItem> GetRevenueLineChartItems()
    {
        var isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";

        return monthlyRevenueData.Select(m =>
        {
            var monthLabel = new DateTime(m.Year, m.Month, 1).ToString("MMM yyyy");
            decimal revenue;
            if (revenueSelectedStoreId.HasValue)
            {
                revenue = m.Stores
                    .Where(s => s.WarehouseId == revenueSelectedStoreId.Value)
                    .Sum(s => s.Revenue);
            }
            else
            {
                revenue = m.Stores.Sum(s => s.Revenue);
            }

            var storeBreakdown = string.Join("", m.Stores
                .Where(s => s.Revenue > 0)
                .Select(s =>
                {
                    var name = isAr && !string.IsNullOrEmpty(s.WarehouseNameAr) ? s.WarehouseNameAr : s.WarehouseName;
                    return $"<br/><span class='chart-dot-muted'>● </span>{name}: {s.Revenue.ToString("N0")}";
                }));

            var tooltip = $"<strong>{monthLabel}</strong><br/>"
                        + $"{Localizer["Revenue"]}: {revenue.ToString("N0")}"
                        + (revenueSelectedStoreId.HasValue ? "" : storeBreakdown);

            return new LineChart.LineChartItem
            {
                Label = monthLabel,
                Value = revenue,
                Tooltip = tooltip
            };
        }).ToList();
    }

    private List<LineChart.LineChartLegend> GetRevenueLineChartLegend()
    {
        return new List<LineChart.LineChartLegend>
        {
            new() { Label = Localizer["Revenue"], Color = "var(--bf-primary)" }
        };
    }

    // === Movement Chart Methods ===

    private async Task LoadMovementDataAsync()
    {
        try
        {
            movementData = await DashboardService.GetWarehouseCurrentStockAsync(movementFromDate, movementToDate);

            movementProductList = movementData
                .SelectMany(w => w.Products)
                .Where(p => p.ReceivedQuantity > 0 || p.TransferredInQuantity > 0 || p.TransferredOutQuantity > 0)
                .GroupBy(p => p.ProductId)
                .Select(g => g.First())
                .OrderBy(p => p.ProductName)
                .ToList();

            var allWarehouseTypes = await LookupService.GetLookupsByParentAsync("WAREHOUSE_TYPE");
            movementTypeList = allWarehouseTypes
                .Select(t => (TypeId: t.Id, TypeName: t.NameEn, TypeNameAr: t.NameAr))
                .OrderBy(t => t.TypeName)
                .ToList();
        }
        catch
        {
            movementData = new();
            movementProductList = new();
            movementTypeList = new();
        }
        finally
        {
            isLoadingMovement = false;
            StateHasChanged();
        }
    }

