    private List<BarChart.BarChartItem> GetStockBarChartItems()
    {
        var isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";

        var filtered = warehouseStockData
            .Where(w => !stockSelectedTypeId.HasValue || w.WarehouseTypeId == stockSelectedTypeId.Value);

        return filtered.Select(w =>
        {
            string warehouseName = isAr && !string.IsNullOrEmpty(w.WarehouseNameAr) ? w.WarehouseNameAr : w.WarehouseName;
            var isBranch = w.WarehouseTypeCode == "MW";
            string? branchName = isBranch
                ? (isAr && !string.IsNullOrEmpty(w.BranchNameAr) ? w.BranchNameAr : w.BranchNameEn)
                : null;
            var label = branchName != null ? $"{warehouseName} ({branchName})" : warehouseName;
            var typeName = isAr && !string.IsNullOrEmpty(w.WarehouseTypeNameAr) ? w.WarehouseTypeNameAr : w.WarehouseTypeName;

            // Apply stock status filter on products within this warehouse. Boundaries match
            // the dashboard summary tiles and the /admin/inventory/balances filter:
            //   - outofstock: AvailableQuantity <= 0
            //   - lowstock:   0 < AvailableQuantity <= LowStockThreshold
            //   - instock:    AvailableQuantity >  LowStockThreshold
            var products = w.Products.AsEnumerable();
            if (!string.IsNullOrEmpty(stockStockStatus))
            {
                products = stockStockStatus switch
                {
                    "outofstock" => products.Where(p => p.AvailableQuantity <= 0),
                    "lowstock" => products.Where(p => p.AvailableQuantity > 0 && p.AvailableQuantity <= p.LowStockThreshold),
                    "instock" => products.Where(p => p.AvailableQuantity > p.LowStockThreshold),
                    _ => products
                };
            }
            var filteredProducts = products.ToList();

            // For outofstock/lowstock show product count, otherwise show sum of available
            int chartValue;
            string valueLabel;
            bool isCountMode = stockStockStatus == "outofstock" || stockStockStatus == "lowstock";
            if (isCountMode)
            {
                if (stockSelectedProductId.HasValue)
                    chartValue = filteredProducts.Any(p => p.ProductId == stockSelectedProductId.Value) ? 1 : 0;
                else
                    chartValue = filteredProducts.Count;
                valueLabel = isCountMode ? Localizer["Products"] : Localizer["Available"];
            }
            else
            {
                if (stockSelectedProductId.HasValue)
                {
                    var p = filteredProducts.FirstOrDefault(p => p.ProductId == stockSelectedProductId.Value);
                    chartValue = p?.AvailableQuantity ?? 0;
                }
                else
                {
                    chartValue = filteredProducts.Sum(p => p.AvailableQuantity);
                }
                valueLabel = Localizer["Available"];
            }

            return new { Label = label, TypeName = typeName, ChartValue = chartValue, ValueLabel = valueLabel, IsCountMode = isCountMode };
        })
        .Where(v => v.ChartValue > 0)
        .Select(v =>
        {
            var tooltip = $"<div class='chart-tooltip-row'><strong>{v.Label}</strong><br/>"
                        + $"<span class='chart-dot-primary'>● </span>{v.ValueLabel}: {v.ChartValue}<br/>"
                        + $"<span class='chart-dot-muted'>● </span>{Localizer["WarehouseType"]}: {v.TypeName}</div>";

            var barColor = v.IsCountMode && stockStockStatus == "outofstock" ? "bf-bg-danger-500"
                         : v.IsCountMode && stockStockStatus == "lowstock"   ? "bf-bg-warning-500"
                         : "bf-bg-info-600";
            var textColor = v.IsCountMode && stockStockStatus == "outofstock" ? "bf-text-danger"
                          : v.IsCountMode && stockStockStatus == "lowstock"   ? "bf-text-warning"
                          : "bf-text-info";

            return new BarChart.BarChartItem
            {
                Label = v.Label,
                Tooltip = tooltip,
                Bars = new List<BarChart.BarChartBar>
                {
                    new() { Value = v.ChartValue, BgCssClass = barColor, TextCssClass = textColor }
                }
            };
        })
        .ToList();
    }

    private List<BarChart.BarChartLegend> GetStockBarChartLegend()
    {
        if (stockStockStatus == "outofstock")
            return new List<BarChart.BarChartLegend> { new() { Label = Localizer["OutOfStock"], BgCssClass = "bf-bg-danger-500" } };
        if (stockStockStatus == "lowstock")
            return new List<BarChart.BarChartLegend> { new() { Label = Localizer["LowStock"], BgCssClass = "bf-bg-warning-500" } };
        return new List<BarChart.BarChartLegend> { new() { Label = Localizer["Available"], BgCssClass = "bf-bg-info-600" } };
    }

