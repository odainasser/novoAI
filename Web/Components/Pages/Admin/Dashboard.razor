@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Web.Authorization
@using Web.Components.Common
@using Web.Models.Dashboard
@inject IDashboardClientService DashboardService
@attribute [Authorize]

<PageTitle>@Localizer["Dashboard"]</PageTitle>

<div>
    @if (isLoading)
    {
        <Spinner Size="Spinner.SpinnerSize.Xl" Centered="true" />
    }
    else
    {
        <!-- Hero Header -->
        <div class="relative overflow-hidden bg-gradient-to-br from-purple-600 to-purple-800 rounded-2xl shadow-lg mb-6">
            <div class="absolute inset-0 opacity-10 pointer-events-none">
                <i class="bi bi-cpu absolute -end-6 -bottom-8 text-[9rem] text-white"></i>
            </div>
            <div class="relative p-6 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
                <div class="min-w-0">
                    <div class="flex items-center gap-3">
                        <div class="h-11 w-11 bg-white/20 rounded-xl flex items-center justify-center backdrop-blur-sm shrink-0">
                            <i class="bi bi-columns-gap text-white text-xl"></i>
                        </div>
                        <div class="min-w-0">
                            <h1 class="text-2xl font-bold text-white truncate">@Localizer["Dashboard"]</h1>
                            <p class="text-sm text-white/70">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</p>
                        </div>
                    </div>
                    <div class="flex flex-wrap items-center gap-2 mt-4">
                        <AuthorizeView Policy="Permission:apps.read">
                            <Authorized>
                                <a href="/admin/apps" class="inline-flex items-center gap-2 px-3.5 py-2 rounded-lg bg-white/15 hover:bg-white/25 text-white text-sm font-medium backdrop-blur-sm transition-colors">
                                    <i class="bi bi-grid-3x3-gap"></i>
                                    @Localizer["Apps"]
                                </a>
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Policy="Permission:assistant.keywords.read">
                            <Authorized>
                                <a href="/admin/assistant/plans" class="inline-flex items-center gap-2 px-3.5 py-2 rounded-lg bg-white/15 hover:bg-white/25 text-white text-sm font-medium backdrop-blur-sm transition-colors">
                                    <i class="bi bi-cpu"></i>
                                    @Localizer["AIAssistant"]
                                </a>
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Policy="Permission:users.read">
                            <Authorized>
                                <a href="/admin/identity/users" class="inline-flex items-center gap-2 px-3.5 py-2 rounded-lg bg-white/15 hover:bg-white/25 text-white text-sm font-medium backdrop-blur-sm transition-colors">
                                    <i class="bi bi-people"></i>
                                    @Localizer["Users"]
                                </a>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                </div>
            </div>
        </div>

        <!-- AI Assistant Stat Cards -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
            <a href="/admin/apps" class="dash-card p-4 flex items-center gap-3 hover:shadow-md transition-shadow">
                <span class="dash-chip w-10 h-10 text-lg"><i class="bi bi-grid-3x3-gap"></i></span>
                <div class="min-w-0">
                    <p class="text-2xl font-bold text-gray-900 leading-none">@summary.ActiveApps<span class="text-sm font-medium text-gray-400">/@summary.TotalApps</span></p>
                    <p class="text-xs text-gray-500 mt-1 truncate">@Localizer["ActiveApps"]</p>
                </div>
            </a>
            <div class="dash-card p-4 flex items-center gap-3">
                <span class="dash-chip w-10 h-10 text-lg"><i class="bi bi-chat-square-text"></i></span>
                <div class="min-w-0">
                    <p class="text-2xl font-bold text-gray-900 leading-none">@summary.TotalQuestions</p>
                    <p class="text-xs text-gray-500 mt-1 truncate">@Localizer["TotalQuestions"]</p>
                </div>
            </div>
            <div class="dash-card p-4 flex items-center gap-3">
                <span class="dash-chip w-10 h-10 text-lg"><i class="bi bi-calendar-day"></i></span>
                <div class="min-w-0">
                    <p class="text-2xl font-bold text-gray-900 leading-none">@summary.QuestionsToday</p>
                    <p class="text-xs text-gray-500 mt-1 truncate">@Localizer["QuestionsToday"]</p>
                </div>
            </div>
            <div class="dash-card p-4 flex items-center gap-3">
                <span class="dash-chip w-10 h-10 text-lg"><i class="bi bi-graph-up-arrow"></i></span>
                <div class="min-w-0">
                    <p class="text-2xl font-bold text-gray-900 leading-none">@summary.AnsweredRatePercent%</p>
                    <p class="text-xs text-gray-500 mt-1 truncate">@Localizer["AnsweredRate"]</p>
                </div>
            </div>
            <a href="/admin/assistant/no-answers" class="dash-card p-4 flex items-center gap-3 hover:shadow-md transition-shadow">
                <span class="dash-chip w-10 h-10 text-lg"><i class="bi bi-slash-circle"></i></span>
                <div class="min-w-0">
                    <p class="text-2xl font-bold leading-none @(summary.OpenNoAnswers > 0 ? "bf-text-warning" : "text-gray-900")">@summary.OpenNoAnswers</p>
                    <p class="text-xs text-gray-500 mt-1 truncate">@Localizer["OpenNoAnswers"]</p>
                </div>
            </a>
            <a href="/admin/assistant/reported" class="dash-card p-4 flex items-center gap-3 hover:shadow-md transition-shadow">
                <span class="dash-chip w-10 h-10 text-lg"><i class="bi bi-flag"></i></span>
                <div class="min-w-0">
                    <p class="text-2xl font-bold leading-none @(summary.UnresolvedReports > 0 ? "bf-text-danger" : "text-gray-900")">@summary.UnresolvedReports</p>
                    <p class="text-xs text-gray-500 mt-1 truncate">@Localizer["UnresolvedReports"]</p>
                </div>
            </a>
        </div>

        <!-- Answer quality + governance -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
            <div class="dash-card p-4 sm:col-span-2">
                <div class="flex items-center justify-between mb-2">
                    <p class="text-sm font-semibold text-gray-900 flex items-center gap-2">
                        <i class="bi bi-stars text-purple-600"></i>
                        @Localizer["AnswerQuality"]
                    </p>
                    <p class="text-xl font-bold leading-none @QualityTextClass">@summary.QualityPercent%</p>
                </div>
                <div class="w-full h-3 bg-gray-100 rounded-full overflow-hidden" role="progressbar"
                     aria-valuenow="@summary.QualityPercent" aria-valuemin="0" aria-valuemax="100">
                    <div class="h-full rounded-full transition-all duration-700 @QualityBarClass"
                         style="width: @(summary.QualityPercent)%"></div>
                </div>
                <p class="text-[11px] text-gray-400 mt-2">
                    @summary.AnsweredQuestions @Localizer["QualityAnsweredLabel"] ·
                    @summary.FailedTurns @Localizer["QualityFailedLabel"] ·
                    @summary.ReportedTotal @Localizer["QualityReportedLabel"]
                </p>
            </div>

            <a href="/admin/assistant/plans" class="dash-card p-4 flex items-center gap-3 hover:shadow-md transition-shadow">
                <span class="dash-chip w-10 h-10 text-lg"><i class="bi bi-diagram-3"></i></span>
                <div class="min-w-0">
                    <p class="text-2xl font-bold text-gray-900 leading-none">@summary.ConfirmedPlans</p>
                    <p class="text-xs text-gray-500 mt-1 truncate">@Localizer["ConfirmedPlans"]</p>
                </div>
            </a>
        </div>

        <!-- Recent questions + activity feed -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <AuthorizeView Policy="Permission:assistant.keywords.read">
                <Authorized>
                    <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
                        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
                            <h2 class="text-sm font-semibold text-gray-900 flex items-center gap-2">
                                <i class="bi bi-chat-square-text text-purple-600"></i>
                                @Localizer["RecentQuestions"]
                            </h2>
                            <a href="/admin/assistant/plans" class="text-xs font-medium text-purple-600 hover:text-purple-800 hover:underline">@Localizer["ViewAll"]</a>
                        </div>
                        @if (summary.RecentQuestions.Count == 0)
                        {
                            <div class="px-5 py-8 text-center text-sm text-gray-400">@Localizer["NoQuestionsYet"]</div>
                        }
                        else
                        {
                            <ul class="divide-y divide-gray-100">
                                @foreach (var q in summary.RecentQuestions)
                                {
                                    <li class="px-5 py-3 flex items-start justify-between gap-3">
                                        <div class="min-w-0">
                                            <p class="text-sm text-gray-900 truncate" dir="auto" title="@q.Question">@q.Question</p>
                                            <div class="flex items-center gap-2 mt-1">
                                                @if (!string.IsNullOrEmpty(q.AppName))
                                                {
                                                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-indigo-100 text-indigo-700">@q.AppName</span>
                                                }
                                                <span class="text-[11px] text-gray-400">@q.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                            </div>
                                        </div>
                                        @if (q.Answered)
                                        {
                                            <span class="shrink-0 inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium bf-bg-success-100 bf-text-success">
                                                <i class="bi bi-check-circle"></i> @Localizer["Answered"]
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="shrink-0 inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium bg-gray-100 text-gray-500">
                                                <i class="bi bi-dash-circle"></i> @Localizer["Unanswered"]
                                            </span>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView Policy="Permission:system.audit">
                <Authorized>
                    <LogsFeed Inline="true" Count="8" Title="@Localizer["RecentActivity"]" ViewAllText="@Localizer["ViewAll"]" ViewAllUrl="/admin/logs" EmptyText="@Localizer["NoRecentActivity"]" />
                </Authorized>
            </AuthorizeView>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private DashboardSummaryDto summary = new();

    private string QualityBarClass => summary.QualityPercent switch
    {
        >= 80 => "bg-emerald-500",
        >= 50 => "bg-amber-500",
        _ => "bg-red-500"
    };

    private string QualityTextClass => summary.QualityPercent switch
    {
        >= 80 => "text-emerald-600",
        >= 50 => "text-amber-600",
        _ => "text-red-600"
    };

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        try
        {
            summary = await DashboardService.GetSummaryAsync();
        }
        catch
        {
            summary = new DashboardSummaryDto();
        }

        isLoading = false;
    }
}
