@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Web.Authorization
@using Web.Components.Common
@using Web.Models.Dashboard
@using Web.Models.Orders
@using Web.Models.Enums
@using System.Globalization
@inject IDashboardClientService DashboardService
@inject IOrderService OrderService
@inject ILookupService LookupService
@inject Web.Services.IRequestService RequestService
@inject NavigationManager Navigation
@using Web.Models.UserLogs
@using Web.Models.Lookups
@using Web.Models.Requests
@attribute [Authorize]

<PageTitle>@Localizer["Dashboard"]</PageTitle>

<div>
    @if (isLoading)
    {
        <Spinner Size="Spinner.SpinnerSize.Xl" Centered="true" />
    }
    else
    {
        <!-- Hero Header -->
        <div class="relative overflow-hidden bg-gradient-to-br from-purple-600 to-purple-800 rounded-2xl shadow-lg mb-6">
            <div class="absolute inset-0 opacity-10 pointer-events-none">
                <i class="bi bi-grid-1x2 absolute -end-6 -bottom-8 text-[9rem] text-white"></i>
            </div>
            <div class="relative p-6 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
                <div class="min-w-0">
                    <div class="flex items-center gap-3">
                        <div class="h-11 w-11 bg-white/20 rounded-xl flex items-center justify-center backdrop-blur-sm shrink-0">
                            <i class="bi bi-columns-gap text-white text-xl"></i>
                        </div>
                        <div class="min-w-0">
                            <h1 class="text-2xl font-bold text-white truncate">@Localizer["Dashboard"]</h1>
                            <p class="text-sm text-white/70">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</p>
                        </div>
                    </div>
                    <div class="flex flex-wrap items-center gap-2 mt-4">
                        <AuthorizeView Policy="Permission:orders.read">
                            <Authorized>
                                <a href="/admin/orders" class="inline-flex items-center gap-2 px-3.5 py-2 rounded-lg bg-white/15 hover:bg-white/25 text-white text-sm font-medium backdrop-blur-sm transition-colors">
                                    <i class="bi bi-bag-check"></i>
                                    @Localizer["Orders"]
                                </a>
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Policy="Permission:products.read">
                            <Authorized>
                                <a href="/admin/catalog/products" class="inline-flex items-center gap-2 px-3.5 py-2 rounded-lg bg-white/15 hover:bg-white/25 text-white text-sm font-medium backdrop-blur-sm transition-colors">
                                    <i class="bi bi-box2"></i>
                                    @Localizer["Products"]
                                </a>
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Policy="Permission:requests.read">
                            <Authorized>
                                <a href="/admin/requests" class="inline-flex items-center gap-2 px-3.5 py-2 rounded-lg bg-white/15 hover:bg-white/25 text-white text-sm font-medium backdrop-blur-sm transition-colors">
                                    <i class="bi bi-send"></i>
                                    @Localizer["Requests"]
                                </a>
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Policy="Permission:inventory.read">
                            <Authorized>
                                <a href="/admin/inventory" class="inline-flex items-center gap-2 px-3.5 py-2 rounded-lg bg-white/15 hover:bg-white/25 text-white text-sm font-medium backdrop-blur-sm transition-colors">
                                    <i class="bi bi-stack"></i>
                                    @Localizer["Inventory"]
                                </a>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                </div>
                <div class="shrink-0 bg-white/10 backdrop-blur-sm rounded-xl border border-white/15 p-4 lg:min-w-[340px]">
                    <p class="text-[11px] font-semibold uppercase tracking-wider text-white/60 mb-3 flex items-center gap-1.5">
                        <i class="bi bi-calendar2-check"></i>
                        @Localizer["TodaysPerformance"]
                    </p>
                    <div class="grid grid-cols-3 gap-2 text-center">
                        <div>
                            <p class="text-xl font-bold text-white">@summary.TodayItemsSold</p>
                            <p class="text-[11px] text-white/60 mt-0.5">@Localizer["ItemsSold"]</p>
                        </div>
                        <div class="border-x border-white/15">
                            <p class="text-xl font-bold text-white">@summary.TodayOrders</p>
                            <p class="text-[11px] text-white/60 mt-0.5">@Localizer["OrdersProcessed"]</p>
                        </div>
                        <div>
                            <p class="text-xl font-bold text-white">@summary.TodayRevenue.ToString("N0")</p>
                            <p class="text-[11px] text-white/60 mt-0.5">@Localizer["Revenue"]</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sales KPIs Row -->
        <AuthorizeView Policy="Permission:orders.read">
            <Authorized>
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                    <!-- Today's Revenue -->
                    <div class="dash-card p-5">
                        <div class="flex items-center justify-between mb-3">
                            <div class="h-10 w-10 dash-chip">
                                <i class="bi bi-cash-coin bf-text-success text-xl"></i>
                            </div>
                            <span class="text-xs font-medium px-2 py-1 rounded-full bf-bg-info-50 bf-text-info">@Localizer["Today"]</span>
                        </div>
                        <p class="text-2xl font-bold text-gray-900">@summary.TodayRevenue.ToString("N0")</p>
                        <p class="text-sm text-gray-500">@Localizer["TodayRevenue"]</p>
                    </div>

                    <!-- Today's Orders -->
                    <div class="dash-card p-5">
                        <div class="flex items-center justify-between mb-3">
                            <div class="h-10 w-10 dash-chip">
                                <i class="bi bi-bag-check bf-text-info text-xl"></i>
                            </div>
                            <span class="text-xs font-medium px-2 py-1 rounded-full bf-bg-info-50 bf-text-info">@Localizer["Today"]</span>
                        </div>
                        <p class="text-2xl font-bold text-gray-900">@summary.TodayOrders</p>
                        <p class="text-sm text-gray-500">@Localizer["TodayOrders"]</p>
                    </div>

                    <!-- Month Revenue -->
                    <div class="dash-card p-5">
                        <div class="flex items-center justify-between mb-3">
                            <div class="h-10 w-10 dash-chip">
                                <i class="bi bi-graph-up-arrow bf-text-success text-xl"></i>
                            </div>
                            <span class="text-xs font-medium px-2 py-1 rounded-full bf-bg-info-50 bf-text-info">@Localizer["ThisMonth"]</span>
                        </div>
                        <p class="text-2xl font-bold text-gray-900">@summary.MonthRevenue.ToString("N0")</p>
                        <p class="text-sm text-gray-500">@Localizer["MonthRevenue"]</p>
                    </div>

                    <!-- Month Orders -->
                    <div class="dash-card p-5">
                        <div class="flex items-center justify-between mb-3">
                            <div class="h-10 w-10 dash-chip">
                                <i class="bi bi-bag-check bf-text-info text-xl"></i>
                            </div>
                            <span class="text-xs font-medium px-2 py-1 rounded-full bf-bg-info-50 bf-text-info">@Localizer["ThisMonth"]</span>
                        </div>
                        <p class="text-2xl font-bold text-gray-900">@summary.MonthOrders</p>
                        <p class="text-sm text-gray-500">@Localizer["MonthOrders"]</p>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>

        <!-- Recent Orders (full width) -->
        <AuthorizeView Policy="Permission:orders.read">
            <Authorized>
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-6">
                    <div class="p-5 border-b border-gray-100 flex items-center justify-between">
                        <h3 class="font-semibold text-gray-900 flex items-center gap-2">
                            <span class="dash-chip w-7 h-7 text-sm"><i class="bi bi-stopwatch"></i></span>
                            @Localizer["RecentOrders"]
                        </h3>
                        <a href="/admin/orders" class="text-sm bf-text-info bf-hover-text-info-strong font-medium flex items-center gap-1">
                            @Localizer["ViewAllOrders"]
                            <i class="bi bi-arrow-right rtl:rotate-180"></i>
                        </a>
                    </div>
                    @if (recentOrders.Any())
                    {
                        <div class="overflow-x-auto">
                            <table class="w-full">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase">@Localizer["OrderNumber"]</th>
                                        <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase">@Localizer["Items"]</th>
                                        <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase">@Localizer["Total"]</th>
                                        <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase">@Localizer["Status"]</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    @foreach (var order in recentOrders)
                                    {
                                        <tr class="dash-row cursor-pointer" @onclick="() => ViewOrder(order.Id)">
                                            <td class="px-4 py-3 text-sm font-medium text-gray-900">@order.OrderNumber</td>
                                            <td class="px-4 py-3 text-sm text-gray-600">@order.ItemCount @Localizer["items"]</td>
                                            <td class="px-4 py-3 text-sm font-medium text-gray-900">@order.Total.ToString("N2")</td>
                                            <td class="px-4 py-3">
                                                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium @GetStatusClass(order.Status)">
                                                    @Localizer[order.Status.ToString()]
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-8 text-center">
                            <div class="h-12 w-12 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3">
                                <i class="bi bi-send text-gray-400 text-xl"></i>
                            </div>
                            <p class="text-gray-500 text-sm">@Localizer["NoRecentOrders"]</p>
                        </div>
                    }
                </div>
            </Authorized>
        </AuthorizeView>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Main Content Column -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Order Summary Cards -->
                <AuthorizeView Policy="Permission:orders.read">
                    <Authorized>
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                            <div class="p-5 border-b border-gray-100 flex items-center justify-between">
                                <h3 class="font-semibold text-gray-900 flex items-center gap-2">
                                    <span class="dash-chip w-7 h-7 text-sm"><i class="bi bi-bar-chart"></i></span>
                                    @Localizer["OrdersSummary"]
                                </h3>
                                <a href="/admin/orders" class="text-sm bf-text-info bf-hover-text-info-strong font-medium flex items-center gap-1">
                                    @Localizer["ViewAll"]
                                    <i class="bi bi-arrow-right rtl:rotate-180"></i>
                                </a>
                            </div>
                            <div class="p-5">
                                <div class="grid grid-cols-3 gap-4">
                                    <div class="text-center p-4 bf-bg-success-50 rounded-lg">
                                        <div class="h-12 w-12 bf-bg-success-100 rounded-full flex items-center justify-center mx-auto mb-2">
                                            <i class="bi bi-check-circle-fill bf-text-success text-xl"></i>
                                        </div>
                                        <p class="text-2xl font-bold bf-text-success">@summary.CompletedOrders</p>
                                        <p class="text-xs text-gray-600 mt-1">@Localizer["Completed"]</p>
                                    </div>
                                    <div class="text-center p-4 bf-bg-info-50 rounded-lg">
                                        <div class="h-12 w-12 bf-bg-info-100 rounded-full flex items-center justify-center mx-auto mb-2">
                                            <i class="bi bi-arrow-return-left bf-text-info text-xl"></i>
                                        </div>
                                        <p class="text-2xl font-bold bf-text-info">@summary.PartialRefundedOrders</p>
                                        <p class="text-xs text-gray-600 mt-1">@Localizer["PartialRefunded"]</p>
                                    </div>
                                    <div class="text-center p-4 bf-bg-danger-50 rounded-lg">
                                        <div class="h-12 w-12 bf-bg-danger-100 rounded-full flex items-center justify-center mx-auto mb-2">
                                            <i class="bi bi-x-circle-fill bf-text-danger text-xl"></i>
                                        </div>
                                        <p class="text-2xl font-bold bf-text-danger">@summary.RefundedOrders</p>
                                        <p class="text-xs text-gray-600 mt-1">@Localizer["Refunded"]</p>
                                    </div>
                                </div>

                                <!-- Progress bar -->
                                <div class="mt-5">
                                    <div class="flex items-center justify-between text-sm text-gray-600 mb-2">
                                        <span>@Localizer["CompletionRate"]</span>
                                        <span class="font-medium">@GetCompletionRate()%</span>
                                    </div>
                                    <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                                        <div class="h-full bf-bg-success-500 rounded-full transition-all duration-500 progress-bar-fill" style="--progress: @GetCompletionRate()%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <!-- Inventory Overview -->
                <AuthorizeView Policy="Permission:products.read">
                    <Authorized>
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                            <div class="p-5 border-b border-gray-100 flex items-center justify-between">
                                <h3 class="font-semibold text-gray-900 flex items-center gap-2">
                                    <span class="dash-chip w-7 h-7 text-sm"><i class="bi bi-stack"></i></span>
                                    @Localizer["InventoryOverview"]
                                </h3>
                                <a href="/admin/inventory/balances" class="text-sm bf-text-info bf-hover-text-info-strong font-medium flex items-center gap-1">
                                    @Localizer["ViewStock"]
                                    <i class="bi bi-arrow-right rtl:rotate-180"></i>
                                </a>
                            </div>
                            <div class="p-5">
                                <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-4 gap-4">
                                    <div class="text-center p-3 bf-bg-info-50 rounded-lg">
                                        <p class="text-xl font-bold bf-text-info">@summary.TotalProducts</p>
                                        <p class="text-xs text-gray-500 mt-1">@Localizer["TotalProducts"]</p>
                                    </div>
                                    <div class="text-center p-3 bf-bg-info-50 rounded-lg">
                                        <p class="text-xl font-bold bf-text-info">@summary.TotalCategories</p>
                                        <p class="text-xs text-gray-500 mt-1">@Localizer["Categories"]</p>
                                    </div>
                                    <div class="text-center p-3 bf-bg-info-50 rounded-lg">
                                        <p class="text-xl font-bold bf-text-info">@summary.TotalUnits</p>
                                        <p class="text-xs text-gray-500 mt-1">@Localizer["Units"]</p>
                                    </div>
                                    <div class="text-center p-3 bf-bg-info-50 rounded-lg">
                                        <p class="text-xl font-bold bf-text-info">@summary.TotalSuppliers</p>
                                        <p class="text-xs text-gray-500 mt-1">@Localizer["Suppliers"]</p>
                                    </div>
                                    <div class="text-center p-3 bf-bg-info-50 rounded-lg">
                                        <p class="text-xl font-bold bf-text-info">@summary.TotalWarehouses</p>
                                        <p class="text-xs text-gray-500 mt-1">@Localizer["Warehouses"]</p>
                                    </div>
                                    <a href="/admin/inventory/balances?filter=lowstock" class="text-center p-3 bf-bg-warning-50 border bf-border-warning rounded-lg bf-hover-bg-warning-100 transition-colors">
                                        <p class="text-xl font-bold bf-text-warning">@summary.LowStockProducts</p>
                                        <p class="text-xs bf-text-warning mt-1">@Localizer["LowStock"]</p>
                                    </a>
                                    <a href="/admin/inventory/balances?filter=outofstock" class="text-center p-3 bf-bg-danger-50 border bf-border-danger rounded-lg bf-hover-bg-danger-100 transition-colors">
                                        <p class="text-xl font-bold bf-text-danger">@summary.OutOfStockItems</p>
                                        <p class="text-xs bf-text-danger mt-1">@Localizer["OutOfStock"]</p>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <!-- Sales Analytics Tabbed Panel -->
                <AuthorizeView Policy="Permission:inventory.read">
                    <Authorized>
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden flex flex-col dashboard-panel">
                            <div class="px-5 pt-4 pb-0">
                                <div class="flex items-center justify-between mb-3">
                                    <h3 class="font-semibold text-gray-900 flex items-center gap-2">
                                        <span class="dash-chip w-7 h-7 text-sm"><i class="bi bi-coin"></i></span>
                                        @Localizer["SalesAnalytics"]
                                    </h3>
                                </div>
                                <div class="inline-flex p-1 bg-gray-100 rounded-lg gap-1">
                                    <button @onclick="SetSalesTabSales"
                                            class="@(salesTab == "sales" ? "bg-white bf-text-info shadow-sm" : "text-gray-500 hover:text-gray-700") px-4 py-2 text-xs font-medium rounded-md transition-all duration-200 flex items-center gap-1.5 cursor-pointer">
                                        <i class="bi bi-bar-chart-fill"></i>
                                        @Localizer["ProductSalesByStore"]
                                    </button>
                                    <button @onclick="SetSalesTabRevenue"
                                            class="@(salesTab == "revenue" ? "bg-white bf-text-info shadow-sm" : "text-gray-500 hover:text-gray-700") px-4 py-2 text-xs font-medium rounded-md transition-all duration-200 flex items-center gap-1.5 cursor-pointer">
                                        <i class="bi bi-graph-up"></i>
                                        @Localizer["MonthlyRevenue"]
                                    </button>
                                </div>
                            </div>
                            <div class="border-t border-gray-100 mt-3"></div>

                            <div class="p-5 flex-1 @(salesTab == "sales" ? "" : "hidden")">
                                    @if (!isLoadingWarehouseStats)
                                    {
                                        <div class="flex items-center gap-2 flex-wrap mb-4 dashboard-toolbar">
                                            <div class="flex items-center gap-1">
                                                <label class="text-xs text-gray-500">@Localizer["FromDate"]</label>
                                                <input type="date" value="@chartFromDate?.ToString("yyyy-MM-dd")"
                                                       max="@(chartToDate?.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd"))"
                                                       @onchange="OnFromDateChanged"
                                                       class="text-xs border border-gray-200 rounded-lg px-2 py-1.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-300 focus:border-purple-400 cursor-pointer" />
                                            </div>
                                            <div class="flex items-center gap-1">
                                                <label class="text-xs text-gray-500">@Localizer["ToDate"]</label>
                                                <input type="date" value="@chartToDate?.ToString("yyyy-MM-dd")"
                                                       min="@chartFromDate?.ToString("yyyy-MM-dd")"
                                                       max="@DateTime.Today.ToString("yyyy-MM-dd")"
                                                       @onchange="OnToDateChanged"
                                                       class="text-xs border border-gray-200 rounded-lg px-2 py-1.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-300 focus:border-purple-400 cursor-pointer" />
                                            </div>
                                            @if (chartProductList.Any())
                                            {
                                                <div class="relative">
                                                    <i class="bi bi-box2 absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                                    <select class="text-xs border border-gray-200 rounded-lg pl-7 pr-8 py-1.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-300 focus:border-purple-400 appearance-none cursor-pointer"
                                                            @onchange="OnProductFilterChanged">
                                                        <option value="">@Localizer["AllProducts"]</option>
                                                        @foreach (var p in chartProductList)
                                                        {
                                                            <option value="@p.ProductId" selected="@(chartSelectedProductId == p.ProductId)">@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar" && !string.IsNullOrEmpty(p.ProductNameAr) ? p.ProductNameAr : p.ProductName)</option>
                                                        }
                                                    </select>
                                                    <i class="bi bi-chevron-down absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                                </div>
                                            }
                                            @if (chartFromDate.HasValue || chartToDate.HasValue || chartSelectedProductId.HasValue)
                                            {
                                                <button @onclick="OnResetFilters"
                                                        class="text-xs border border-gray-200 rounded-lg px-2.5 py-1.5 bg-white bf-text-danger bf-hover-bg-danger-50 transition-colors cursor-pointer flex items-center gap-1"
                                                        title="@Localizer["ResetFilters"]">
                                                    <i class="bi bi-x-circle text-xs"></i>
                                                    @Localizer["ResetFilters"]
                                                </button>
                                            }
                                        </div>
                                    }
                                    @if (isLoadingWarehouseStats)
                                    {
                                        <div class="flex items-center justify-center dashboard-chart-area">
                                            <Spinner Size="Spinner.SpinnerSize.Md" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="dashboard-chart-frame">
                                            <BarChart Items="GetBarChartItems()"
                                                      LegendItems="GetBarChartLegend()"
                                                      Height="200"
                                                      EmptyText="@Localizer["NoSalesData"]" />
                                        </div>
                                    }
                            </div>
                            <div class="p-5 flex-1 @(salesTab == "revenue" ? "" : "hidden")">
                                    @if (!isLoadingMonthlyRevenue)
                                    {
                                        <div class="flex items-center gap-2 flex-wrap mb-4 dashboard-toolbar">
                                            @if (revenueStoreList.Any())
                                            {
                                                <div class="relative">
                                                    <i class="bi bi-bagabsolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                                    <select class="text-xs border border-gray-200 rounded-lg pl-7 pr-8 py-1.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-emerald-300 focus:border-emerald-400 appearance-none cursor-pointer"
                                                            @onchange="OnRevenueStoreFilterChanged">
                                                        <option value="">@Localizer["AllStores"]</option>
                                                        @foreach (var s in revenueStoreList)
                                                        {
                                                            <option value="@s.WarehouseId" selected="@(revenueSelectedStoreId == s.WarehouseId)">@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar" && !string.IsNullOrEmpty(s.WarehouseNameAr) ? s.WarehouseNameAr : s.WarehouseName)</option>
                                                        }
                                                    </select>
                                                    <i class="bi bi-chevron-down absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                                </div>
                                            }
                                            @if (revenueSelectedStoreId.HasValue)
                                            {
                                                <button @onclick="OnResetRevenueFilters"
                                                        class="text-xs border border-gray-200 rounded-lg px-2.5 py-1.5 bg-white bf-text-danger bf-hover-bg-danger-50 transition-colors cursor-pointer flex items-center gap-1"
                                                        title="@Localizer["ResetFilters"]">
                                                    <i class="bi bi-x-circle text-xs"></i>
                                                    @Localizer["ResetFilters"]
                                                </button>
                                            }
                                        </div>
                                    }
                                    @if (isLoadingMonthlyRevenue)
                                    {
                                        <div class="flex items-center justify-center dashboard-chart-area">
                                            <Spinner Size="Spinner.SpinnerSize.Md" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="dashboard-chart-frame">
                                            <LineChart Items="GetRevenueLineChartItems()"
                                                       LegendItems="GetRevenueLineChartLegend()"
                                                       Height="200"
                                                       EmptyText="@Localizer["NoRevenueData"]" />
                                        </div>
                                    }
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <!-- Inventory Analytics Tabbed Panel -->
                <AuthorizeView Policy="Permission:inventory.read">
                    <Authorized>
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden flex flex-col dashboard-panel">
                            <div class="px-5 pt-4 pb-0">
                                <div class="flex items-center justify-between mb-3">
                                    <h3 class="font-semibold text-gray-900 flex items-center gap-2">
                                        <span class="dash-chip w-7 h-7 text-sm"><i class="bi bi-stack"></i></span>
                                        @Localizer["InventoryAnalytics"]
                                    </h3>
                                </div>
                                <div class="inline-flex p-1 bg-gray-100 rounded-lg gap-1">
                                    <button @onclick="SetInventoryTabStock"
                                            class="@(inventoryTab == "stock" ? "bg-white bf-text-info shadow-sm" : "text-gray-500 hover:text-gray-700") px-4 py-2 text-xs font-medium rounded-md transition-all duration-200 flex items-center gap-1.5 cursor-pointer">
                                        <i class="bi bi-stack"></i>
                                        @Localizer["CurrentStockByWarehouse"]
                                    </button>
                                    <button @onclick="SetInventoryTabMovement"
                                            class="@(inventoryTab == "movement" ? "bg-white bf-text-info shadow-sm" : "text-gray-500 hover:text-gray-700") px-4 py-2 text-xs font-medium rounded-md transition-all duration-200 flex items-center gap-1.5 cursor-pointer">
                                        <i class="bi bi-arrow-down-up"></i>
                                        @Localizer["StockMovementByWarehouse"]
                                    </button>
                                </div>
                            </div>
                            <div class="border-t border-gray-100 mt-3"></div>

                            <div class="p-5 flex-1 @(inventoryTab == "stock" ? "" : "hidden")">
                                    @if (!isLoadingStock)
                                    {
                                        <div class="flex items-center gap-2 flex-wrap mb-4 dashboard-toolbar">
                                            @if (stockTypeList.Any())
                                            {
                                                <div class="relative">
                                                    <i class="bi bi-buildings absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                                    <select class="text-xs border border-gray-200 rounded-lg pl-7 pr-8 py-1.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-300 focus:border-blue-400 appearance-none cursor-pointer"
                                                            @onchange="OnStockTypeFilterChanged">
                                                        <option value="">@Localizer["AllWarehouseTypes"]</option>
                                                        @foreach (var t in stockTypeList)
                                                        {
                                                            <option value="@t.TypeId" selected="@(stockSelectedTypeId == t.TypeId)">@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar" && !string.IsNullOrEmpty(t.TypeNameAr) ? t.TypeNameAr : t.TypeName)</option>
                                                        }
                                                    </select>
                                                    <i class="bi bi-chevron-down absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                                </div>
                                            }
                                            @if (stockProductList.Any())
                                            {
                                                <div class="relative">
                                                    <i class="bi bi-box2 absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                                    <select class="text-xs border border-gray-200 rounded-lg pl-7 pr-8 py-1.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-300 focus:border-blue-400 appearance-none cursor-pointer"
                                                            @onchange="OnStockProductFilterChanged">
                                                        <option value="">@Localizer["AllProducts"]</option>
                                                        @foreach (var p in stockProductList)
                                                        {
                                                            <option value="@p.ProductId" selected="@(stockSelectedProductId == p.ProductId)">@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar" && !string.IsNullOrEmpty(p.ProductNameAr) ? p.ProductNameAr : p.ProductName)</option>
                                                        }
                                                    </select>
                                                    <i class="bi bi-chevron-down absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                                </div>
                                            }
                                            <div class="relative">
                                                <i class="bi bi-funnel absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                                <select class="text-xs border border-gray-200 rounded-lg pl-7 pr-8 py-1.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-300 focus:border-blue-400 appearance-none cursor-pointer"
                                                        @bind="stockStockStatus">
                                                    <option value="">@Localizer["AllStockStatus"]</option>
                                                    <option value="instock">@Localizer["InStock"]</option>
                                                    <option value="lowstock">@Localizer["LowStock"]</option>
                                                    <option value="outofstock">@Localizer["OutOfStock"]</option>
                                                </select>
                                                <i class="bi bi-chevron-down absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                            </div>
                                            @if (stockSelectedProductId.HasValue || stockSelectedTypeId.HasValue || !string.IsNullOrEmpty(stockStockStatus))
                                            {
                                                <button @onclick="OnResetStockFilters"
                                                        class="text-xs border border-gray-200 rounded-lg px-2.5 py-1.5 bg-white bf-text-danger bf-hover-bg-danger-50 transition-colors cursor-pointer flex items-center gap-1"
                                                        title="@Localizer["ResetFilters"]">
                                                    <i class="bi bi-x-circle text-xs"></i>
                                                    @Localizer["ResetFilters"]
                                                </button>
                                            }
                                        </div>
                                    }
                                    @if (isLoadingStock)
                                    {
                                        <div class="flex items-center justify-center dashboard-chart-area">
                                            <Spinner Size="Spinner.SpinnerSize.Md" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="dashboard-chart-frame">
                                            <BarChart Items="GetStockBarChartItems()"
                                                      LegendItems="GetStockBarChartLegend()"
                                                      Height="200"
                                                      EmptyText="@Localizer["NoStockData"]" />
                                        </div>
                                    }
                            </div>
                            <div class="p-5 flex-1 @(inventoryTab == "movement" ? "" : "hidden")">
                                    @if (!isLoadingMovement)
                                    {
                                        <div class="flex items-center gap-2 flex-wrap mb-4 dashboard-toolbar">
                                            <div class="flex items-center gap-1">
                                                <label class="text-xs text-gray-500">@Localizer["FromDate"]</label>
                                                <input type="date" value="@movementFromDate?.ToString("yyyy-MM-dd")"
                                                       max="@(movementToDate?.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd"))"
                                                       @onchange="OnMovementFromDateChanged"
                                                       class="text-xs border border-gray-200 rounded-lg px-2 py-1.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-300 focus:border-blue-400 cursor-pointer" />
                                            </div>
                                            <div class="flex items-center gap-1">
                                                <label class="text-xs text-gray-500">@Localizer["ToDate"]</label>
                                                <input type="date" value="@movementToDate?.ToString("yyyy-MM-dd")"
                                                       min="@movementFromDate?.ToString("yyyy-MM-dd")"
                                                       max="@DateTime.Today.ToString("yyyy-MM-dd")"
                                                       @onchange="OnMovementToDateChanged"
                                                       class="text-xs border border-gray-200 rounded-lg px-2 py-1.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-300 focus:border-blue-400 cursor-pointer" />
                                            </div>
                                            @if (movementTypeList.Any())
                                            {
                                                <div class="relative">
                                                    <i class="bi bi-buildings absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                                    <select class="text-xs border border-gray-200 rounded-lg pl-7 pr-8 py-1.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-300 focus:border-blue-400 appearance-none cursor-pointer"
                                                            @onchange="OnMovementTypeFilterChanged">
                                                        <option value="">@Localizer["AllWarehouseTypes"]</option>
                                                        @foreach (var t in movementTypeList)
                                                        {
                                                            <option value="@t.TypeId" selected="@(movementSelectedTypeId == t.TypeId)">@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar" && !string.IsNullOrEmpty(t.TypeNameAr) ? t.TypeNameAr : t.TypeName)</option>
                                                        }
                                                    </select>
                                                    <i class="bi bi-chevron-down absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                                </div>
                                            }
                                            @if (movementProductList.Any())
                                            {
                                                <div class="relative">
                                                    <i class="bi bi-box2 absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                                    <select class="text-xs border border-gray-200 rounded-lg pl-7 pr-8 py-1.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-300 focus:border-blue-400 appearance-none cursor-pointer"
                                                            @onchange="OnMovementProductFilterChanged">
                                                        <option value="">@Localizer["AllProducts"]</option>
                                                        @foreach (var p in movementProductList)
                                                        {
                                                            <option value="@p.ProductId" selected="@(movementSelectedProductId == p.ProductId)">@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar" && !string.IsNullOrEmpty(p.ProductNameAr) ? p.ProductNameAr : p.ProductName)</option>
                                                        }
                                                    </select>
                                                    <i class="bi bi-chevron-down absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                                                </div>
                                            }
                                            @if (movementSelectedProductId.HasValue || movementSelectedTypeId.HasValue || movementFromDate.HasValue || movementToDate.HasValue)
                                            {
                                                <button @onclick="OnResetMovementFilters"
                                                        class="text-xs border border-gray-200 rounded-lg px-2.5 py-1.5 bg-white bf-text-danger bf-hover-bg-danger-50 transition-colors cursor-pointer flex items-center gap-1"
                                                        title="@Localizer["ResetFilters"]">
                                                    <i class="bi bi-x-circle text-xs"></i>
                                                    @Localizer["ResetFilters"]
                                                </button>
                                            }
                                        </div>
                                    }
                                    @if (isLoadingMovement)
                                    {
                                        <div class="flex items-center justify-center dashboard-chart-area">
                                            <Spinner Size="Spinner.SpinnerSize.Md" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="dashboard-chart-frame">
                                            <BarChart Items="GetMovementBarChartItems()"
                                                      LegendItems="GetMovementBarChartLegend()"
                                                      Height="200"
                                                      EmptyText="@Localizer["NoStockData"]" />
                                        </div>
                                    }
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>

            <!-- Sidebar Column -->
            <div class="space-y-6">
                <!-- Pending Requests Widget -->
                <AuthorizeView Policy="Permission:requests.read">
                    <Authorized>
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
                            <div class="p-4 border-b border-gray-100 flex justify-between items-center">
                                <h3 class="font-semibold text-gray-900 flex items-center gap-2">
                                    <span class="dash-chip w-7 h-7 text-sm"><i class="bi bi-send-fill"></i></span>
                                    @Localizer["PendingRequests"]
                                </h3>
                                <a href="/admin/requests" class="text-sm bf-text-info bf-hover-text-info-strong font-medium flex items-center gap-1">
                                    @Localizer["ViewAll"]
                                    <i class="bi bi-arrow-right rtl:rotate-180"></i>
                                </a>
                            </div>
                            <div class="p-0">
                                @if (isLoadingRequests)
                                {
                                    <Spinner Size="Spinner.SpinnerSize.Md" Centered="true" />
                                }
                                else if (!pendingRequests.Any())
                                {
                                    <div class="p-8 text-center text-gray-400 text-sm">@Localizer["NoPendingRequests"]</div>
                                }
                                else
                                {
                                    <div class="relative">
                                        @{ var reqIndex = 0; }
                                        @foreach (var req in pendingRequests.Take(5))
                                        {
                                            var isFirstReq = reqIndex == 0;
                                            var isLastReq = reqIndex == Math.Min(pendingRequests.Count, 5) - 1;
                                            reqIndex++;
                                            <a href="/admin/requests" class="group dash-row flex gap-3 px-4 py-3 no-underline cursor-pointer relative">
                                                @* Timeline connector *@
                                                <div class="relative flex flex-col items-center">
                                                    @if (isFirstReq)
                                                    {
                                                        <span class="relative flex h-2.5 w-2.5 mt-1.5">
                                                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-bf-primary opacity-75"></span>
                                                            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-bf-primary"></span>
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="relative flex h-2.5 w-2.5 mt-1.5">
                                                            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-bf-primary"></span>
                                                        </span>
                                                    }
                                                    @if (!isLastReq)
                                                    {
                                                        <div class="w-px grow bg-gray-200 mt-1"></div>
                                                    }
                                                </div>
                                                @* Content *@
                                                <div class="grow min-w-0 pb-1">
                                                    <div class="flex items-baseline justify-between gap-2">
                                                        <p class="text-sm text-gray-700 truncate leading-snug">
                                                            <span class="font-semibold text-gray-900">@req.RequestedByName</span>
                                                            <span class="text-gray-500">@Localizer["Requested"].ToString().ToLower()</span>
                                                            <span class="font-medium text-gray-800">@Localizer[$"RequestType{req.Type}"]</span>
                                                        </p>
                                                        <span class="text-[11px] text-gray-400 whitespace-nowrap shrink-0">@FormatRelativeTime(req.CreatedAt)</span>
                                                    </div>
                                                    @if (!string.IsNullOrEmpty(req.ProductName))
                                                    {
                                                        <p class="text-xs text-gray-400 mt-0.5 truncate">@req.ProductName</p>
                                                    }
                                                </div>
                                            </a>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <!-- Activity Feed -->
                <AuthorizeView Policy="Permission:system.audit">
                    <Authorized>
                        <LogsFeed Inline="true" Count="5" Title="@Localizer["RecentActivity"]" ViewAllText="@Localizer["ViewAll"]" ViewAllUrl="/admin/logs" EmptyText="@Localizer["NoRecentActivity"]" />
                    </Authorized>
                </AuthorizeView>

            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool isLoadingWarehouseStats = true;
    private bool isLoadingStock = true;
    private string salesTab = "sales";
    private string inventoryTab = "stock";

    private void SetSalesTabSales() => salesTab = "sales";
    private void SetSalesTabRevenue() => salesTab = "revenue";
    private void SetInventoryTabStock() => inventoryTab = "stock";
    private void SetInventoryTabMovement() => inventoryTab = "movement";

    private DashboardSummaryDto summary = new();
    private List<OrderDto> recentOrders = new();
    private List<WarehouseProductStatsDto> warehouseStats = new();
    private List<ProductSalesStatsDto> chartProductList = new();
    private Guid? chartSelectedProductId = null;
    private DateTime? chartFromDate = null;
    private DateTime? chartToDate = null;

    // Stock chart state (Available only)
    private List<WarehouseStockDto> warehouseStockData = new();
    private List<ProductStockDto> stockProductList = new();
    private List<(Guid TypeId, string TypeName, string TypeNameAr)> stockTypeList = new();
    private Guid? stockSelectedProductId = null;
    private Guid? stockSelectedTypeId = null;
    private string stockStockStatus = string.Empty;

    // Pending requests widget state
    private bool isLoadingRequests = true;
    private List<RequestDto> pendingRequests = new();

    // Movement chart state (Received, Transferred In/Out)
    private bool isLoadingMovement = true;

    // Monthly revenue chart state
    private bool isLoadingMonthlyRevenue = true;
    private List<MonthlyRevenueDto> monthlyRevenueData = new();
    private List<StoreRevenueDto> revenueStoreList = new();
    private Guid? revenueSelectedStoreId = null;
    private List<WarehouseStockDto> movementData = new();
    private List<ProductStockDto> movementProductList = new();
    private List<(Guid TypeId, string TypeName, string TypeNameAr)> movementTypeList = new();
    private Guid? movementSelectedProductId = null;
    private Guid? movementSelectedTypeId = null;
    private DateTime? movementFromDate = null;
    private DateTime? movementToDate = null;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        try
        {
            summary = await DashboardService.GetSummaryAsync();
        }
        catch
        {
            summary = new DashboardSummaryDto();
        }

        try
        {
            var ordersResult = await OrderService.GetAllOrdersAsync(1, 5);
            recentOrders = ordersResult.Items.ToList();
        }
        catch
        {
            recentOrders = new();
        }

        isLoading = false;

        // Load warehouse stats after main dashboard to avoid blocking the page
        _ = LoadWarehouseStatsAsync();
        _ = LoadWarehouseStockAsync();
        _ = LoadMovementDataAsync();
        _ = LoadPendingRequestsAsync();
        _ = LoadMonthlyRevenueAsync();
    }

    private async Task LoadPendingRequestsAsync()
    {
        try
        {
            var result = await RequestService.GetAllRequestsAsync(1, 50, null, null, Web.Models.Enums.RequestStatus.Pending);
            pendingRequests = result.Items.ToList();
        }
        catch
        {
            pendingRequests = new();
        }
        finally
        {
            isLoadingRequests = false;
            StateHasChanged();
        }
    }

    private static string GetRequestTypeIcon(Web.Models.Enums.RequestType type) => type switch
    {
        Web.Models.Enums.RequestType.SetUnitPrice or Web.Models.Enums.RequestType.ChangePrice => "bi-tag",
        Web.Models.Enums.RequestType.ActivateProduct or Web.Models.Enums.RequestType.AddProduct or Web.Models.Enums.RequestType.UpdateProduct => "bi-box-seam",
        Web.Models.Enums.RequestType.ActivateUnit or Web.Models.Enums.RequestType.AddUnit or Web.Models.Enums.RequestType.UpdateUnit => "bi-upc-scan",
        Web.Models.Enums.RequestType.DeleteProduct or Web.Models.Enums.RequestType.DeleteUnit => "bi-trash",
        Web.Models.Enums.RequestType.SetLogisticsDetails => "bi-truck",
        Web.Models.Enums.RequestType.AddGRN => "bi-box-arrow-in-down",
        Web.Models.Enums.RequestType.AddStockAdjustment => "bi-sliders",
        Web.Models.Enums.RequestType.AddStockTransfer => "bi-arrow-left-right",
        _ => "bi-file-earmark-text"
    };

    private static string GetRequestTypeColorClass(Web.Models.Enums.RequestType type) => type switch
    {
        Web.Models.Enums.RequestType.ActivateProduct or Web.Models.Enums.RequestType.ActivateUnit => "bf-bg-success-100 bf-text-success",
        Web.Models.Enums.RequestType.DeleteProduct or Web.Models.Enums.RequestType.DeleteUnit => "bf-bg-danger-100 bf-text-danger",
        _ => "bf-bg-info-100 bf-text-info"
    };

    private async Task LoadWarehouseStatsAsync()
    {
        try
        {
            warehouseStats = await DashboardService.GetWarehouseProductStatsAsync(chartFromDate, chartToDate);

            // Build deduplicated product list from all warehouses (only products with any activity)
            chartProductList = warehouseStats
                .SelectMany(w => w.Products)
                .Where(p => p.QuantitySold > 0 || p.QuantityReturned > 0)
                .GroupBy(p => p.ProductId)
                .Select(g => g.First())
                .OrderBy(p => p.ProductName)
                .ToList();
        }
        catch
        {
            warehouseStats = new();
            chartProductList = new();
        }
        finally
        {
            isLoadingWarehouseStats = false;
            StateHasChanged();
        }
    }

    private void OnProductFilterChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        chartSelectedProductId = string.IsNullOrEmpty(val) ? null : Guid.Parse(val);
    }

    private async Task OnFromDateChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        chartFromDate = string.IsNullOrEmpty(val) ? null : DateTime.Parse(val);
        isLoadingWarehouseStats = true;
        StateHasChanged();
        await LoadWarehouseStatsAsync();
    }

    private async Task OnToDateChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        chartToDate = string.IsNullOrEmpty(val) ? null : DateTime.Parse(val);
        isLoadingWarehouseStats = true;
        StateHasChanged();
        await LoadWarehouseStatsAsync();
    }

    private async Task OnResetFilters()
    {
        chartFromDate = null;
        chartToDate = null;
        chartSelectedProductId = null;
        isLoadingWarehouseStats = true;
        StateHasChanged();
        await LoadWarehouseStatsAsync();
    }

    private List<BarChart.BarChartItem> GetBarChartItems()
    {
        var isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";

        return warehouseStats.Select(w =>
        {
            var name = isAr && !string.IsNullOrEmpty(w.WarehouseNameAr) ? w.WarehouseNameAr : w.WarehouseName;
            var sold = chartSelectedProductId.HasValue
                ? (w.Products.FirstOrDefault(p => p.ProductId == chartSelectedProductId.Value)?.QuantitySold ?? 0)
                : w.Products.Sum(p => p.QuantitySold);
            var returned = chartSelectedProductId.HasValue
                ? (w.Products.FirstOrDefault(p => p.ProductId == chartSelectedProductId.Value)?.QuantityReturned ?? 0)
                : w.Products.Sum(p => p.QuantityReturned);

            return new { Name = name, Sold = sold, Returned = returned, w.Revenue };
        })
        .Where(v => !chartSelectedProductId.HasValue || v.Sold > 0 || v.Returned > 0)
        .Select(v => new BarChart.BarChartItem
        {
            Label = v.Name,
            Tooltip = $"<div class='chart-tooltip-row'><strong>{v.Name}</strong><br/>"
                    + $"<span class='chart-dot-light'>● </span>{Localizer["Sold"]}: {v.Sold}<br/>"
                    + $"<span class='chart-dot-mid'>● </span>{Localizer["Returned"]}: {v.Returned}<br/>"
                    + $"<span class='chart-dot-primary'>● </span>{Localizer["Revenue"]}: {v.Revenue.ToString("N2")}</div>",
            Bars = new List<BarChart.BarChartBar>
            {
                new() { Value = v.Sold, BgCssClass = "bf-bg-success-500", TextCssClass = "bf-text-success" },
                new() { Value = v.Returned, BgCssClass = "bf-bg-danger-500", TextCssClass = "bf-text-danger" }
            }
        })
        .ToList();
    }

    private List<BarChart.BarChartLegend> GetBarChartLegend()
    {
        return new List<BarChart.BarChartLegend>
        {
            new() { Label = Localizer["Sold"], BgCssClass = "bf-bg-success-500" },
            new() { Label = Localizer["Returned"], BgCssClass = "bf-bg-danger-500" }
        };
    }

    private int GetCompletionRate()
    {
        if (summary.MonthOrders == 0) return 0;
        var revenueGenerating = summary.CompletedOrders + summary.PartialRefundedOrders;
        return (int)Math.Round((double)revenueGenerating / summary.MonthOrders * 100);
    }

    private string GetStatusClass(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.Completed => "bf-bg-success-100 bf-text-success",
            OrderStatus.Refunded => "bf-bg-danger-100 bf-text-danger",
            OrderStatus.PartialRefunded => "bf-bg-info-100 bf-text-info",
            _ => "bg-gray-100 text-gray-700"
        };
    }

    private void ViewOrder(Guid orderId)
    {
        Navigation.NavigateTo($"/admin/orders?view={orderId}");
    }

    private string FormatRelativeTime(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalMinutes < 1) return Localizer["JustNow"];
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}{Localizer["MinAgo"]}";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}{Localizer["HrAgo"]}";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}{Localizer["DayAgo"]}";
        return utcTime.ToLocal().ToString("MMM dd");
    }

    private async Task LoadWarehouseStockAsync()
    {
        try
        {
            warehouseStockData = await DashboardService.GetWarehouseCurrentStockAsync();

            stockProductList = warehouseStockData
                .SelectMany(w => w.Products)
                .GroupBy(p => p.ProductId)
                .Select(g => g.First())
                .OrderBy(p => p.ProductName)
                .ToList();

            var allWarehouseTypes = await LookupService.GetLookupsByParentAsync("WAREHOUSE_TYPE");
            stockTypeList = allWarehouseTypes
                .Select(t => (TypeId: t.Id, TypeName: t.NameEn, TypeNameAr: t.NameAr))
                .OrderBy(t => t.TypeName)
                .ToList();
        }
        catch
        {
            warehouseStockData = new();
            stockProductList = new();
            stockTypeList = new();
        }
        finally
        {
            isLoadingStock = false;
            StateHasChanged();
        }
    }

