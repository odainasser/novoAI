@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Web.Authorization
@using Web.Components.Common
@using Web.Models.Dashboard
@inject IDashboardClientService DashboardService
@attribute [Authorize]

<PageTitle>@Localizer["Dashboard"]</PageTitle>

<div>
    @if (isLoading)
    {
        <Spinner Size="Spinner.SpinnerSize.Xl" Centered="true" />
    }
    else
    {
        <!-- Hero Header -->
        <div class="relative overflow-hidden bg-gradient-to-br from-purple-600 to-purple-800 rounded-2xl shadow-lg mb-6">
            <div class="absolute inset-0 opacity-10 pointer-events-none">
                <i class="bi bi-grid-1x2 absolute -end-6 -bottom-8 text-[9rem] text-white"></i>
            </div>
            <div class="relative p-6 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
                <div class="min-w-0">
                    <div class="flex items-center gap-3">
                        <div class="h-11 w-11 bg-white/20 rounded-xl flex items-center justify-center backdrop-blur-sm shrink-0">
                            <i class="bi bi-columns-gap text-white text-xl"></i>
                        </div>
                        <div class="min-w-0">
                            <h1 class="text-2xl font-bold text-white truncate">@Localizer["Dashboard"]</h1>
                            <p class="text-sm text-white/70">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</p>
                        </div>
                    </div>
                    <div class="flex flex-wrap items-center gap-2 mt-4">
                        <AuthorizeView Policy="Permission:users.read">
                            <Authorized>
                                <a href="/admin/users" class="inline-flex items-center gap-2 px-3.5 py-2 rounded-lg bg-white/15 hover:bg-white/25 text-white text-sm font-medium backdrop-blur-sm transition-colors">
                                    <i class="bi bi-people"></i>
                                    @Localizer["Users"]
                                </a>
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Policy="Permission:roles.read">
                            <Authorized>
                                <a href="/admin/identity/roles" class="inline-flex items-center gap-2 px-3.5 py-2 rounded-lg bg-white/15 hover:bg-white/25 text-white text-sm font-medium backdrop-blur-sm transition-colors">
                                    <i class="bi bi-shield-lock"></i>
                                    @Localizer["Roles"]
                                </a>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                </div>
            </div>
        </div>

        <!-- Summary Stat Cards -->
        <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="dash-card p-4 flex items-center gap-3">
                <span class="dash-chip w-10 h-10 text-lg"><i class="bi bi-people"></i></span>
                <div class="min-w-0">
                    <p class="text-2xl font-bold text-gray-900 leading-none">@summary.TotalUsers</p>
                    <p class="text-xs text-gray-500 mt-1 truncate">@Localizer["TotalUsers"]</p>
                </div>
            </div>
            <div class="dash-card p-4 flex items-center gap-3">
                <span class="dash-chip w-10 h-10 text-lg"><i class="bi bi-person-check"></i></span>
                <div class="min-w-0">
                    <p class="text-2xl font-bold text-gray-900 leading-none">@summary.ActiveUsers</p>
                    <p class="text-xs text-gray-500 mt-1 truncate">@Localizer["ActiveUsers"]</p>
                </div>
            </div>
        </div>

        <!-- Activity Feed -->
        <AuthorizeView Policy="Permission:system.audit">
            <Authorized>
                <LogsFeed Inline="true" Count="5" Title="@Localizer["RecentActivity"]" ViewAllText="@Localizer["ViewAll"]" ViewAllUrl="/admin/logs" EmptyText="@Localizer["NoRecentActivity"]" />
            </Authorized>
        </AuthorizeView>
    }
</div>

@code {
    private bool isLoading = true;
    private DashboardSummaryDto summary = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        try
        {
            summary = await DashboardService.GetSummaryAsync();
        }
        catch
        {
            summary = new DashboardSummaryDto();
        }

        isLoading = false;
    }
}
