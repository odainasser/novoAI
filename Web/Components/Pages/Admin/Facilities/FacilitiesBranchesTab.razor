@using Web.Components.Common
@using Web.Models.Branches
@using System.Globalization
@inject IBranchService BranchService
@inject NavigationManager Navigation

<div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
    <div class="flex flex-wrap items-center gap-3 p-4">
        <div class="flex-1 min-w-[200px]">
            <SearchInput @bind-Value="branchesSearchTerm"
                         OnSearch="HandleBranchesSearch"
                         Placeholder="@Localizer["SearchBranches"]" />
        </div>

        <button @onclick="() => showBranchesFiltersPanel = !showBranchesFiltersPanel"
                class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showBranchesFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")"> 
            <i class="bi bi-funnel"></i>
            <span>@Localizer["Filters"]</span>
            @if (BranchesActiveFilterCount > 0)
            {
                <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@BranchesActiveFilterCount</span>
            }
            <i class="@($"bi bi-chevron-{(showBranchesFiltersPanel ? "up" : "down")} text-xs")"></i>
        </button>

        @if (HasBranchesActiveFilters())
        {
            <button @onclick="ResetBranchesFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <i class="bi bi-x-circle"></i>
                <span>@Localizer["ResetFilters"]</span>
            </button>
        }
    </div>

    @if (showBranchesFiltersPanel)
    {
        <div class="px-4 pb-4 pt-0 border-t border-gray-200">
            <div class="grid grid-cols-1 sm:grid-cols-1 gap-3 pt-4">
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                    <div class="relative">
                        <select @bind="branchesSelectedStatus" @bind:after="ApplyBranchesFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                            <option value="">@Localizer["AllStatuses"]</option>
                            <option value="true">@Localizer["Active"]</option>
                            <option value="false">@Localizer["Inactive"]</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (branchesIsLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else if (!string.IsNullOrEmpty(branchesError))
{
    <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
        <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
        <span class="bf-text-danger">@branchesError</span>
    </div>
}
else if (!branches.Any())
{
    <div class="text-center py-12">
        <i class="bi bi-building text-6xl text-gray-300 mb-4"></i>
        <p class="text-gray-500 text-lg">@Localizer["NoBranchesFound"]</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
        @foreach (var branch in branches)
        {
            <div @key="branch.Id" class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-shadow duration-200 overflow-hidden">
                <div class="h-40 bg-gray-100 flex items-center justify-center">
                    @if (!string.IsNullOrEmpty(branch.ImageUrl))
                    {
                        <img src="@branch.ImageUrl" alt="@(isAr ? branch.NameAr : branch.NameEn)" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <i class="bi bi-building text-4xl text-gray-300"></i>
                    }
                </div>
                <div class="p-4">
                    <div class="flex justify-between items-start mb-2">
                        <a href="@($"/admin/branches/edit/{branch.Id}")" class="text-lg font-semibold text-indigo-600 hover:text-indigo-800 hover:underline">@(isAr ? branch.NameAr : branch.NameEn)</a>
                        <span class="@(branch.IsActive ? "bf-bg-success-100 bf-text-success" : "bf-bg-danger-100 bf-text-danger") text-xs px-2 py-1 rounded-full">
                            @(branch.IsActive ? Localizer["Active"] : Localizer["Inactive"])
                        </span>
                    </div>
                    @if (!string.IsNullOrEmpty(isAr ? branch.DescriptionAr : branch.DescriptionEn))
                    {
                        <p class="text-gray-600 text-sm mb-3 line-clamp-2">@(isAr ? branch.DescriptionAr : branch.DescriptionEn)</p>
                    }
                    <div class="flex justify-end gap-2 pt-3 border-t border-gray-100">
                        <AuthorizeView Policy="Permission:branches.write">
                            <Authorized>
                                <button type="button" @onclick='@(() => Navigation.NavigateTo($"/admin/branches/edit/{branch.Id}"))' @onclick:stopPropagation="true"
                                        class="text-purple-600 hover:text-purple-900 me-3"
                                        title="@Localizer["Edit"]">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                            </Authorized>
                            <NotAuthorized>
                                <button type="button" disabled class="text-gray-400 me-3 cursor-not-allowed" title="@Localizer["Edit"]">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                            </NotAuthorized>
                        </AuthorizeView>
                        <AuthorizeView Policy="Permission:branches.delete">
                            <Authorized>
                                <button type="button" @onclick="@(() => ConfirmDeleteBranch(branch.Id))" @onclick:stopPropagation="true"
                                        class="p-2 bf-text-danger bf-hover-text-danger-strong bf-hover-bg-danger-50 rounded-lg transition-colors"
                                        title="@Localizer["Delete"]">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </Authorized>
                            <NotAuthorized>
                                <button type="button" disabled class="p-2 text-gray-300 cursor-not-allowed" title="@Localizer["Delete"]">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </NotAuthorized>
                        </AuthorizeView>
                    </div>
                </div>
            </div>
        }
    </div>
    <Pagination PageIndex="@branchesPage" TotalPages="@branchesTotalPages" TotalCount="@branchesTotalCount" PageSize="@branchesPageSize" OnPageChanged="@OnBranchesPageChanged" />
}

<!-- Modals -->
<ConfirmModal IsVisible="@showBranchDeleteConfirm"
              Title="@Localizer["DeleteBranchTitle"]"
              Message="@Localizer["DeleteBranchConfirmation"]"
              OnConfirm="@DeleteBranch"
              OnCancel="@(() => showBranchDeleteConfirm = false)"
              IsDanger="true" />

@code {
    private bool isAr;

    // ── Branches state ─────────────────────────────────────────
    private List<BranchDto> branches = new();
    private bool branchesIsLoading;
    private string branchesError = string.Empty;
    private string branchesSearchTerm = string.Empty;
    private string branchesSelectedStatus = string.Empty;
    private bool showBranchesFiltersPanel = false;
    private bool HasBranchesActiveFilters() => !string.IsNullOrEmpty(branchesSelectedStatus);
    private int BranchesActiveFilterCount => string.IsNullOrEmpty(branchesSelectedStatus) ? 0 : 1;
    private int branchesPage = 1;
    private int branchesPageSize = 12;
    private int branchesTotalPages = 1;
    private int branchesTotalCount;
    private bool showBranchDeleteConfirm;
    private Guid branchToDelete;

    // ── Lifecycle ─────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        await LoadBranches();
    }

    // ── Data loading ──────────────────────────────────────────
    private async Task LoadBranches()
    {
        branchesIsLoading = true;
        branchesError = string.Empty;
        try
        {
            bool? isActive = string.IsNullOrEmpty(branchesSelectedStatus) ? null : bool.Parse(branchesSelectedStatus);
            var result = await BranchService.GetAllBranchesAsync(branchesPage, branchesPageSize, branchesSearchTerm, isActive);
            branches = result.Items;
            branchesTotalPages = result.TotalPages;
            branchesTotalCount = result.TotalCount;
        }
        catch (Exception ex) { branchesError = Localizer["FailedToLoadBranches"] + $": {ex.Message}"; }
        finally { branchesIsLoading = false; }
    }

    // ── Filters & paging ──────────────────────────────────────
    private async Task OnBranchesPageChanged(int p) { branchesPage = p; await LoadBranches(); }
    private async Task HandleBranchesSearch(string v) { branchesSearchTerm = v; branchesPage = 1; await LoadBranches(); }
    private async Task ApplyBranchesFilters() { branchesPage = 1; await LoadBranches(); }
    private async Task ResetBranchesFilters() { branchesSearchTerm = string.Empty; branchesSelectedStatus = string.Empty; branchesPage = 1; await LoadBranches(); }

    // ── Delete ────────────────────────────────────────────────
    private void ConfirmDeleteBranch(Guid id) { branchToDelete = id; showBranchDeleteConfirm = true; }
    private async Task DeleteBranch()
    {
        try { await BranchService.DeleteBranchAsync(branchToDelete); showBranchDeleteConfirm = false; await LoadBranches(); }
        catch (Exception ex) { branchesError = Localizer["FailedToDeleteBranch"] + $": {ex.Message}"; showBranchDeleteConfirm = false; }
    }

}
