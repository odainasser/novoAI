@using Web.Components.Common
@using Web.Models.Branches
@using System.Globalization
@inject ITerminalService TerminalService
@inject IBranchService BranchService
@inject NavigationManager Navigation

<div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
    <div class="flex flex-wrap items-center gap-3 p-4">
        <div class="flex-1 min-w-[200px]">
            <SearchInput @bind-Value="terminalsSearchTerm"
                         OnSearch="HandleTerminalsSearch"
                         Placeholder="@Localizer["SearchTerminals"]" />
        </div>

        <button @onclick="() => showTerminalsFiltersPanel = !showTerminalsFiltersPanel"
                class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showTerminalsFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")"> 
            <i class="bi bi-funnel"></i>
            <span>@Localizer["Filters"]</span>
            @if (TerminalsActiveFilterCount > 0)
            {
                <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@TerminalsActiveFilterCount</span>
            }
            <i class="@($"bi bi-chevron-{(showTerminalsFiltersPanel ? "up" : "down")} text-xs")"></i>
        </button>

        @if (HasTerminalsActiveFilters())
        {
            <button @onclick="ResetTerminalsFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <i class="bi bi-x-circle"></i>
                <span>@Localizer["ResetFilters"]</span>
            </button>
        }
    </div>

    @if (showTerminalsFiltersPanel)
    {
        <div class="px-4 pb-4 pt-0 border-t border-gray-200">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-4">
                <div>
                    <SearchableDropdown TItem="BranchDto"
                                        TValue="string"
                                        Items="activeBranches"
                                        @bind-Value="terminalsSelectedBranchId"
                                        OnChanged="ApplyTerminalsFilters"
                                        DisplayText="m => isAr ? m.NameAr : m.NameEn"
                                        SearchText='m => $"{m.NameEn} {m.NameAr}"'
                                        ItemValue="m => m.Id.ToString()"
                                        Label="@Localizer["Branch"]"
                                        Placeholder="@Localizer["AllBranches"]"
                                        Compact="true" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                    <div class="relative">
                        <select @bind="terminalsSelectedStatus" @bind:after="ApplyTerminalsFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                            <option value="">@Localizer["AllStatuses"]</option>
                            <option value="true">@Localizer["Active"]</option>
                            <option value="false">@Localizer["Inactive"]</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (terminalsIsLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else if (!string.IsNullOrEmpty(terminalsError))
{
    <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
        <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
        <span class="bf-text-danger">@terminalsError</span>
    </div>
}
else if (!terminals.Any())
{
    <div class="text-center py-12">
        <i class="bi bi-display text-6xl text-gray-300 mb-4"></i>
        <p class="text-gray-500 text-lg">@Localizer["NoTerminalsFound"]</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Name"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Branch"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["ComputerIp"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["PrinterIp"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["PaymentMachineIp"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                    <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var terminal in terminals)
                {
                    <tr class="hover:bg-gray-50 transition-colors duration-150">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <a href="@($"/admin/terminals/edit/{terminal.Id}")" class="text-sm font-medium text-indigo-600 hover:text-indigo-800 hover:underline">@(isAr ? terminal.NameAr : terminal.NameEn)</a>
                            <div class="text-sm text-gray-500">@(isAr ? terminal.NameEn : terminal.NameAr)</div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <a href="/admin/branches/edit/@terminal.BranchId" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800 hover:underline">
                                @(isAr ? terminal.BranchNameAr : terminal.BranchNameEn)
                            </a>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-mono">@(terminal.ComputerIp ?? "—")</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-mono">@(terminal.PrinterIp ?? "—")</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-mono">@(terminal.PaymentMachineIp ?? "—")</td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            @if (terminal.IsActive)
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-success-100 bf-text-success">
                                    <i class="bi bi-check-circle-fill me-1"></i> @Localizer["Active"]
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-danger-100 bf-text-danger">
                                    <i class="bi bi-x-circle-fill me-1"></i> @Localizer["Inactive"]
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                            <AuthorizeView Policy="Permission:terminals.write">
                                <Authorized>
                                    <button @onclick='() => Navigation.NavigateTo($"/admin/terminals/edit/{terminal.Id}")' class="text-bf-primary hover:opacity-80 me-3">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                </Authorized>
                                <NotAuthorized>
                                    <button disabled class="text-gray-400 me-3 cursor-not-allowed">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                </NotAuthorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="Permission:terminals.delete">
                                <Authorized>
                                    <button @onclick="() => ConfirmDeleteTerminal(terminal.Id)" class="bf-text-danger bf-hover-text-danger-strong">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </Authorized>
                                <NotAuthorized>
                                    <button disabled class="text-gray-400 cursor-not-allowed">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </NotAuthorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <Pagination PageIndex="@terminalsPage" TotalPages="@terminalsTotalPages" TotalCount="@terminalsTotalCount" PageSize="@terminalsPageSize" OnPageChanged="@OnTerminalsPageChanged" />
}

<!-- Modals -->
<ConfirmModal IsVisible="@showTerminalDeleteConfirm"
              Title="@Localizer["DeleteTerminalTitle"]"
              Message="@Localizer["DeleteTerminalConfirmation"]"
              OnConfirm="@DeleteTerminal"
              OnCancel="@(() => showTerminalDeleteConfirm = false)"
              IsDanger="true" />

@code {
    private bool isAr;

    // ── Terminals state ───────────────────────────────────────
    private List<Web.Models.Terminals.TerminalDto> terminals = new();
    private List<BranchDto> activeBranches = new();
    private bool terminalsIsLoading;
    private string terminalsError = string.Empty;
    private string terminalsSearchTerm = string.Empty;
    private string terminalsSelectedStatus = string.Empty;
    private string terminalsSelectedBranchId = string.Empty;
    private bool showTerminalsFiltersPanel = false;
    private bool HasTerminalsActiveFilters() => !string.IsNullOrEmpty(terminalsSelectedStatus) || !string.IsNullOrEmpty(terminalsSelectedBranchId);
    private int TerminalsActiveFilterCount => new[] { terminalsSelectedStatus, terminalsSelectedBranchId }.Count(x => !string.IsNullOrEmpty(x));
    private int terminalsPage = 1;
    private int terminalsPageSize = 10;
    private int terminalsTotalPages = 1;
    private int terminalsTotalCount;
    private bool showTerminalDeleteConfirm;
    private Guid terminalToDelete;

    // ── Lifecycle ─────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        activeBranches = await BranchService.GetActiveBranchesAsync();
        await LoadTerminals();
    }

    // ── Data loading ──────────────────────────────────────────
    private async Task LoadTerminals()
    {
        terminalsIsLoading = true;
        terminalsError = string.Empty;
        try
        {
            bool? isActive = string.IsNullOrEmpty(terminalsSelectedStatus) ? null : bool.Parse(terminalsSelectedStatus);
            Guid? branchId = string.IsNullOrEmpty(terminalsSelectedBranchId) ? null : Guid.Parse(terminalsSelectedBranchId);
            var result = await TerminalService.GetAllTerminalsAsync(terminalsPage, terminalsPageSize, terminalsSearchTerm, isActive, branchId);
            terminals = result.Items;
            terminalsTotalPages = result.TotalPages;
            terminalsTotalCount = result.TotalCount;
        }
        catch (Exception ex) { terminalsError = Localizer["FailedToLoadTerminals"] + $": {ex.Message}"; }
        finally { terminalsIsLoading = false; }
    }

    // ── Filters & paging ──────────────────────────────────────
    private async Task OnTerminalsPageChanged(int p) { terminalsPage = p; await LoadTerminals(); }
    private async Task HandleTerminalsSearch(string v) { terminalsSearchTerm = v; terminalsPage = 1; await LoadTerminals(); }
    private async Task ApplyTerminalsFilters() { terminalsPage = 1; await LoadTerminals(); }
    private async Task ResetTerminalsFilters() { terminalsSearchTerm = string.Empty; terminalsSelectedStatus = string.Empty; terminalsSelectedBranchId = string.Empty; terminalsPage = 1; await LoadTerminals(); }

    // ── Delete ────────────────────────────────────────────────
    private void ConfirmDeleteTerminal(Guid id) { terminalToDelete = id; showTerminalDeleteConfirm = true; }
    private async Task DeleteTerminal()
    {
        try { await TerminalService.DeleteTerminalAsync(terminalToDelete); showTerminalDeleteConfirm = false; await LoadTerminals(); }
        catch (Exception ex) { terminalsError = Localizer["FailedToDeleteTerminal"] + $": {ex.Message}"; showTerminalDeleteConfirm = false; }
    }

}
