@using Web.Components.Common
@using Web.Models.Branches
@using System.Globalization
@inject IWarehouseService WarehouseService
@inject IBranchService BranchService
@inject ILookupService LookupService
@inject NavigationManager Navigation

<div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
    <div class="flex flex-wrap items-center gap-3 p-4">
        <div class="flex-1 min-w-[200px]">
            <SearchInput @bind-Value="warehousesSearchTerm"
                         OnSearch="HandleWarehousesSearch"
                         Placeholder="@Localizer["SearchWarehouses"]" />
        </div>

        <button @onclick="() => showWarehousesFiltersPanel = !showWarehousesFiltersPanel"
                class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showWarehousesFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")"> 
            <i class="bi bi-funnel"></i>
            <span>@Localizer["Filters"]</span>
            @if (WarehousesActiveFilterCount > 0)
            {
                <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@WarehousesActiveFilterCount</span>
            }
            <i class="@($"bi bi-chevron-{(showWarehousesFiltersPanel ? "up" : "down")} text-xs")"></i>
        </button>

        @if (HasWarehousesActiveFilters())
        {
            <button @onclick="ResetWarehousesFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <i class="bi bi-x-circle"></i>
                <span>@Localizer["ResetFilters"]</span>
            </button>
        }
    </div>

    @if (showWarehousesFiltersPanel)
    {
        <div class="px-4 pb-4 pt-0 border-t border-gray-200">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 pt-4">
                <div>
                    <SearchableDropdown TItem="LookupDto"
                                        TValue="string"
                                        Items="warehouseTypes"
                                        @bind-Value="warehousesSelectedTypeId"
                                        OnChanged="ApplyWarehousesFilters"
                                        DisplayText="w => isAr ? w.NameAr : w.NameEn"
                                        SearchText='w => $"{w.NameEn} {w.NameAr}"'
                                        ItemValue="w => w.Id.ToString()"
                                        Label='@Localizer["Type"]'
                                        Placeholder='@Localizer["AllTypes"]'
                                        Compact="true" />
                </div>
                <div>
                    <SearchableDropdown TItem="BranchDto"
                                        TValue="string"
                                        Items="activeBranches"
                                        @bind-Value="warehousesSelectedBranchId"
                                        OnChanged="ApplyWarehousesFilters"
                                        DisplayText="m => isAr ? m.NameAr : m.NameEn"
                                        SearchText='m => $"{m.NameEn} {m.NameAr}"'
                                        ItemValue="m => m.Id.ToString()"
                                        Label="@Localizer["Branch"]"
                                        Placeholder="@Localizer["AllBranches"]"
                                        Compact="true" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                    <div class="relative">
                        <select @bind="warehousesSelectedStatus" @bind:after="ApplyWarehousesFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                            <option value="">@Localizer["AllStatuses"]</option>
                            <option value="true">@Localizer["Active"]</option>
                            <option value="false">@Localizer["Inactive"]</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (warehousesIsLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else if (!string.IsNullOrEmpty(warehousesError))
{
    <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
        <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
        <span class="bf-text-danger">@warehousesError</span>
    </div>
}
else if (!warehouses.Any())
{
    <div class="text-center py-12">
        <i class="bi bi-house-gear text-6xl text-gray-300 mb-4"></i>
        <p class="text-gray-500 text-lg">@Localizer["NoWarehousesFound"]</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Name"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["WarehouseType"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Branch"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["ContactPerson"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                    <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var wh in warehouses)
                {
                    <tr class="hover:bg-gray-50 transition-colors duration-150">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <a href="@($"/admin/warehouses/edit/{wh.Id}")" class="text-sm font-medium text-indigo-600 hover:text-indigo-800 hover:underline">@(isAr ? wh.NameAr : wh.NameEn)</a>
                            <div class="text-sm text-gray-500">@(isAr ? wh.NameEn : wh.NameAr)</div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            @(isAr ? wh.WarehouseTypeNameAr : wh.WarehouseTypeNameEn)
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            @if (wh.BranchId.HasValue)
                            {
                                <a class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800 hover:underline"
                                   href="@($"/admin/branches/edit/{wh.BranchId}")">
                                    @(isAr ? wh.BranchNameAr : wh.BranchNameEn)
                                </a>
                            }
                            else
                            {
                                <span class="text-gray-400">—</span>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            @(wh.ContactPerson ?? "—")
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            @if (wh.IsActive)
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-success-100 bf-text-success">
                                    <i class="bi bi-check-circle-fill me-1"></i> @Localizer["Active"]
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-danger-100 bf-text-danger">
                                    <i class="bi bi-x-circle-fill me-1"></i> @Localizer["Inactive"]
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                            <AuthorizeView Policy="Permission:warehouses.write">
                                <Authorized>
                                    <button @onclick='() => Navigation.NavigateTo($"/admin/warehouses/edit/{wh.Id}")' class="text-bf-primary hover:opacity-80 me-3">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                </Authorized>
                                <NotAuthorized>
                                    <button disabled class="text-gray-400 me-3 cursor-not-allowed">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                </NotAuthorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="Permission:warehouses.delete">
                                <Authorized>
                                    <button @onclick="() => ConfirmDeleteWarehouse(wh.Id)" class="bf-text-danger bf-hover-text-danger-strong">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </Authorized>
                                <NotAuthorized>
                                    <button disabled class="text-gray-400 cursor-not-allowed">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </NotAuthorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <Pagination PageIndex="@warehousesPage" TotalPages="@warehousesTotalPages" TotalCount="@warehousesTotalCount" PageSize="@warehousesPageSize" OnPageChanged="@OnWarehousesPageChanged" />
}

<!-- Modals -->
<ConfirmModal IsVisible="@showWarehouseDeleteConfirm"
              Title="@Localizer["DeleteWarehouseTitle"]"
              Message="@Localizer["DeleteWarehouseConfirmation"]"
              OnConfirm="@DeleteWarehouse"
              OnCancel="@(() => showWarehouseDeleteConfirm = false)"
              IsDanger="true" />

@code {
    private bool isAr;

    // ── Warehouses state ──────────────────────────────────────
    private List<WarehouseDto> warehouses = new();
    private List<LookupDto> warehouseTypes = new();
    private List<BranchDto> activeBranches = new();
    private bool warehousesIsLoading;
    private string warehousesError = string.Empty;
    private string warehousesSearchTerm = string.Empty;
    private string warehousesSelectedStatus = string.Empty;
    private string warehousesSelectedTypeId = string.Empty;
    private string warehousesSelectedBranchId = string.Empty;
    private bool showWarehousesFiltersPanel = false;
    private bool HasWarehousesActiveFilters() => !string.IsNullOrEmpty(warehousesSelectedStatus) || !string.IsNullOrEmpty(warehousesSelectedTypeId) || !string.IsNullOrEmpty(warehousesSelectedBranchId);
    private int WarehousesActiveFilterCount => new[] { warehousesSelectedStatus, warehousesSelectedTypeId, warehousesSelectedBranchId }.Count(x => !string.IsNullOrEmpty(x));
    private int warehousesPage = 1;
    private int warehousesPageSize = 10;
    private int warehousesTotalPages = 1;
    private int warehousesTotalCount;
    private bool showWarehouseDeleteConfirm;
    private Guid warehouseToDelete;

    // ── Lifecycle ─────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        warehouseTypes = await LookupService.GetLookupsByParentAsync("WAREHOUSE_TYPE");
        activeBranches = await BranchService.GetActiveBranchesAsync();
        await LoadWarehouses();
    }

    // ── Data loading ──────────────────────────────────────────
    private async Task LoadWarehouses()
    {
        warehousesIsLoading = true;
        warehousesError = string.Empty;
        try
        {
            bool? isActive = string.IsNullOrEmpty(warehousesSelectedStatus) ? null : bool.Parse(warehousesSelectedStatus);
            Guid? typeId = string.IsNullOrEmpty(warehousesSelectedTypeId) ? null : Guid.Parse(warehousesSelectedTypeId);
            Guid? branchId = string.IsNullOrEmpty(warehousesSelectedBranchId) ? null : Guid.Parse(warehousesSelectedBranchId);
            var result = await WarehouseService.GetAllWarehousesAsync(warehousesPage, warehousesPageSize, warehousesSearchTerm, isActive, typeId, branchId);
            warehouses = result.Items;
            warehousesTotalPages = result.TotalPages;
            warehousesTotalCount = result.TotalCount;
        }
        catch (Exception ex) { warehousesError = Localizer["FailedToLoadWarehouses"] + $": {ex.Message}"; }
        finally { warehousesIsLoading = false; }
    }

    // ── Filters & paging ──────────────────────────────────────
    private async Task OnWarehousesPageChanged(int p) { warehousesPage = p; await LoadWarehouses(); }
    private async Task HandleWarehousesSearch(string v) { warehousesSearchTerm = v; warehousesPage = 1; await LoadWarehouses(); }
    private async Task ApplyWarehousesFilters() { warehousesPage = 1; await LoadWarehouses(); }
    private async Task ResetWarehousesFilters() { warehousesSearchTerm = string.Empty; warehousesSelectedStatus = string.Empty; warehousesSelectedTypeId = string.Empty; warehousesSelectedBranchId = string.Empty; warehousesPage = 1; await LoadWarehouses(); }

    // ── Delete ────────────────────────────────────────────────
    private void ConfirmDeleteWarehouse(Guid id) { warehouseToDelete = id; showWarehouseDeleteConfirm = true; }
    private async Task DeleteWarehouse()
    {
        try { await WarehouseService.DeleteWarehouseAsync(warehouseToDelete); showWarehouseDeleteConfirm = false; await LoadWarehouses(); }
        catch (Exception ex) { warehousesError = Localizer["FailedToDeleteWarehouse"] + $": {ex.Message}"; showWarehouseDeleteConfirm = false; }
    }

}
