@using Web.Authorization
@using Web.Components.Common
@using Web.Models.Assistant
@using Web.Models.Constants
@using Microsoft.AspNetCore.Authorization
@inject IAssistantAdminService AdminService
@inject IJsonStringLocalizer Localizer

<!-- Filters -->
<div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
    <div class="flex flex-wrap items-center gap-3 p-4">
        <div class="flex-1 min-w-[200px]">
            <SearchInput @bind-Value="naqSearch" OnSearch="HandleNaqSearch" Placeholder="@Localizer["SearchQuestions"]" />
        </div>

        <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")">
            <i class="bi bi-funnel"></i>
            <span>@Localizer["Filters"]</span>
            @if (HasActiveFilters())
            {
                <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
            }
            <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
        </button>

        @if (HasActiveFilters())
        {
            <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <i class="bi bi-x-circle"></i>
                <span>@Localizer["ResetFilters"]</span>
            </button>
        }
    </div>

    @if (showFiltersPanel)
    {
        <div class="px-4 pb-4 pt-0 border-t border-gray-200">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-4">
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["NoAnswerReason"]</label>
                    <SearchableDropdown TItem="string" TValue="string" Compact="true" Clearable="false"
                                        Items="NaqReasonFilters"
                                        DisplayText="@(r => string.IsNullOrEmpty(r) ? Localizer["AllReasons"] : ReasonLabel(r))"
                                        ItemValue="@(r => r)" @bind-Value="naqReasonFilter" OnChanged="ApplyFilters" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["App"]</label>
                    <div class="relative">
                        <select @bind="selectedAppId" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                            <option value="">@Localizer["AllApps"]</option>
                            @foreach (var a in appOptions)
                            {
                                <option value="@a.Id">@a.Name</option>
                            }
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (naqLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else if (naqItems.Count == 0)
{
    <div class="text-center py-12">
        <i class="bi bi-check2-circle text-6xl text-gray-300 mb-4"></i>
        <p class="text-gray-500 text-lg">@Localizer["NoNoAnswers"]</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Question"]</th>
                    <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["NoAnswerReason"]</th>
                    <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Frequency"]</th>
                    <th class="px-4 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var c in naqItems)
                {
                    <tr class="hover:bg-gray-50 align-top">
                        <td class="px-4 py-3 text-sm text-gray-900 max-w-md" dir="auto">
                            @c.SampleQuestion
                            @if (!string.IsNullOrEmpty(c.AppName))
                            {
                                <span class="ms-1 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-indigo-100 text-indigo-700">@c.AppName</span>
                            }
                        </td>
                        <td class="px-4 py-3 whitespace-nowrap">
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-medium @ReasonClass(c)">@ReasonLabel(c.EffectiveReason)</span>
                            @if (c.IsMisRefusal)
                            {
                                <span class="ms-1 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bf-bg-danger-100 bf-text-danger">@Localizer["MisRefusal"]</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-sm text-gray-600">@c.Frequency</td>
                        <td class="px-4 py-3 text-end whitespace-nowrap">
                            <button @onclick="() => OpenNaq(c)" class="text-purple-600 hover:text-purple-800" title="@Localizer["Review"]"><i class="bi bi-clipboard-check text-lg"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <Pagination PageIndex="@naqPage" TotalPages="@naqTotalPages" TotalCount="@naqTotalCount" PageSize="@naqPageSize" OnPageChanged="@OnNaqPageChanged" />
}

@* ── No-answer review modal (read-only) ────────────────────────── *@
@if (showNaqModal && naqEditing is not null)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center" @onclick="CloseNaq">
        <div class="bg-white rounded-xl shadow-lg w-full max-w-2xl mx-4 max-h-[90vh] flex flex-col overflow-hidden" @onclick:stopPropagation>
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
                    <i class="bi bi-clipboard-check text-purple-600"></i> @Localizer["ReviewNoAnswer"]
                    @if (!string.IsNullOrEmpty(naqEditing.AppName))
                    {
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-medium bg-indigo-100 text-indigo-700">@naqEditing.AppName</span>
                    }
                </h3>
                <button type="button" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors" @onclick="CloseNaq">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="px-5 py-4 space-y-4 overflow-y-auto">
                <div class="rounded-lg bg-gray-50 border border-gray-200 p-3">
                    <div class="text-xs font-medium text-gray-500 mb-1">@Localizer["Question"]</div>
                    <p class="text-sm text-gray-900" dir="auto">@naqEditing.SampleQuestion</p>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <div class="rounded-lg bg-gray-50 border border-gray-200 p-3">
                        <div class="text-xs font-medium text-gray-500 mb-1">@Localizer["CodeSetReason"]</div>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-medium @ReasonClass(naqEditing)">@ReasonLabel(naqEditing.EffectiveReason)</span>
                    </div>
                    <div class="rounded-lg bg-gray-50 border border-gray-200 p-3">
                        <div class="text-xs font-medium text-gray-500 mb-1">@Localizer["Frequency"]</div>
                        <p class="text-sm text-gray-900">@naqEditing.Frequency</p>
                    </div>
                </div>

                <div class="rounded-lg bg-gray-50 border border-gray-200 p-3">
                    <div class="text-xs font-medium text-gray-500 mb-1">@Localizer["Evidence"]</div>
                    <pre class="text-[11px] text-gray-700 whitespace-pre-wrap break-words" dir="ltr">@naqEditing.Evidence</pre>
                </div>

                <div class="rounded-lg bg-gray-50 border border-gray-200 p-3">
                    <div class="text-xs font-medium text-gray-500 mb-1">@Localizer["UserFacingMessage"]</div>
                    <p class="text-sm text-gray-600" dir="auto">@naqEditing.UserFacingMessage</p>
                </div>

                @if (!string.IsNullOrEmpty(naqError))
                {
                    <div class="p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700 flex items-center gap-2">
                        <i class="bi bi-exclamation-circle flex-shrink-0"></i> <span>@naqError</span>
                    </div>
                }
            </div>

            @* Read-only review: the reason is code-determined — nothing to act on here. *@
            <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-gray-200">
                <button type="button" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50" @onclick="CloseNaq">@Localizer["Close"]</button>
            </div>
        </div>
    </div>
}

@code {
    private List<NoAnswerClusterDto> naqItems = new();
    private bool naqLoading = true;
    private string naqSearch = string.Empty;
    private string naqReasonFilter = string.Empty;
    private bool showFiltersPanel = false;
    private int naqPage = 1, naqPageSize = 20, naqTotalPages = 1, naqTotalCount = 0;

    // Reason filter for browsing the queue (the reason itself is code-set, never edited here).
    private static readonly string[] NaqReasonFilters =
        { "", "NoCallingTool", "UnsupportedDomain", "UnsupportedEntity", "MissingParameter", "Error" };

    private string L(string key) => Localizer[key];
    private string ReasonLabel(string r) => string.IsNullOrEmpty(r) ? "—" : L($"Reason_{r}");

    private string ReasonClass(NoAnswerClusterDto c) =>
        c.IsMisRefusal ? "bg-red-50 text-red-700"
        : c.IsCoverageGap ? "bg-amber-50 text-amber-700"
        : "bg-gray-100 text-gray-600";

    private List<AppOptionDto> appOptions = new();
    private string selectedAppId = string.Empty;
    private Guid? SelectedAppGuid => Guid.TryParse(selectedAppId, out var g) ? g : null;

    protected override async Task OnInitializedAsync()
    {
        try { appOptions = await AdminService.GetAppOptionsAsync(); } catch { /* filter simply stays empty */ }
        await LoadNaq();
    }

    private async Task LoadNaq()
    {
        naqLoading = true;
        naqError = string.Empty;
        try
        {
            var result = await AdminService.GetNoAnswersAsync(naqPage, naqPageSize, naqReasonFilter, naqSearch, SelectedAppGuid);
            naqItems = result.Items;
            naqTotalPages = result.TotalPages;
            naqTotalCount = result.TotalCount;
        }
        catch (Exception ex) { naqError = ex.Message; }
        finally { naqLoading = false; }
    }

    private async Task HandleNaqSearch(string value) { naqSearch = value; naqPage = 1; await LoadNaq(); }
    private async Task ApplyFilters() { naqPage = 1; await LoadNaq(); }
    private async Task OnNaqPageChanged(int p) { naqPage = p; await LoadNaq(); }

    private bool HasActiveFilters() => !string.IsNullOrEmpty(naqReasonFilter) || !string.IsNullOrEmpty(selectedAppId);
    private int ActiveFilterCount => (string.IsNullOrEmpty(naqReasonFilter) ? 0 : 1) + (string.IsNullOrEmpty(selectedAppId) ? 0 : 1);
    private async Task ResetFilters() { naqReasonFilter = string.Empty; selectedAppId = string.Empty; naqPage = 1; await LoadNaq(); }

    // ── No-answer review modal (read-only) ────────────────────────────
    private bool showNaqModal = false;
    private string naqError = string.Empty;
    private NoAnswerClusterDto? naqEditing;

    private void OpenNaq(NoAnswerClusterDto c)
    {
        naqEditing = c;
        naqError = string.Empty;
        showNaqModal = true;
    }

    private void CloseNaq() { showNaqModal = false; naqEditing = null; }
}
