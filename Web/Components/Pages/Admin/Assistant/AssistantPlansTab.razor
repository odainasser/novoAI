@using Web.Authorization
@using Web.Components.Common
@using Web.Models.Assistant
@using Web.Models.Constants
@using Microsoft.AspNetCore.Authorization
@using System.Globalization
@inject IAssistantAdminService AdminService
@inject IJsonStringLocalizer Localizer

<!-- Filters -->
<div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
    <div class="flex flex-wrap items-center gap-3 p-4">
        <div class="flex-1 min-w-[200px]">
            <SearchInput @bind-Value="searchTerm"
                         OnSearch="HandleSearch"
                         Placeholder="@Localizer["SearchQuestions"]" />
        </div>

        <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")">
            <i class="bi bi-funnel"></i>
            <span>@Localizer["Filters"]</span>
            @if (HasActiveFilters())
            {
                <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
            }
            <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
        </button>

        @if (HasActiveFilters())
        {
            <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <i class="bi bi-x-circle"></i>
                <span>@Localizer["ResetFilters"]</span>
            </button>
        }
    </div>

    @if (showFiltersPanel)
    {
        <div class="px-4 pb-4 pt-0 border-t border-gray-200">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-4">
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                    <SearchableDropdown TItem="string" TValue="string" Compact="true" Clearable="false"
                                        Items="FilterStatuses"
                                        DisplayText="@(s => StatusLabel(s))" ItemValue="@(s => s)"
                                        @bind-Value="selectedStatus" OnChanged="ApplyFilters" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["App"]</label>
                    <div class="relative">
                        <select @bind="selectedAppId" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                            <option value="">@Localizer["AllApps"]</option>
                            @foreach (var a in appOptions)
                            {
                                <option value="@a.Id">@a.Name</option>
                            }
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (isLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
        <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
        <span class="bf-text-danger">@errorMessage</span>
    </div>
}
else if (items.Count == 0)
{
    <div class="text-center py-12">
        <i class="bi bi-chat-square-text text-6xl text-gray-300 mb-4"></i>
        <p class="text-gray-500 text-lg">@Localizer["NoInteractionsFound"]</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Question"]</th>
                    <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Answer"]</th>
                    <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["CallingTools"]</th>
                    <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Module"]</th>
                    <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Entities"]</th>
                    <th class="px-4 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Plan"]</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var i in items)
                {
                    var tools = i.PlanConfirmed && i.ConfirmedTools.Count > 0 ? i.ConfirmedTools : i.Tools;
                    var domains = i.PlanConfirmed && !string.IsNullOrEmpty(i.ConfirmedDomain) ? new List<string> { i.ConfirmedDomain! } : i.Domains;
                    var entities = i.PlanConfirmed && i.ConfirmedEntities.Count > 0 ? i.ConfirmedEntities : i.Entities;
                    <tr class="hover:bg-gray-50 align-top">
                        <td class="px-4 py-3 text-sm text-gray-900 max-w-xs" dir="auto">
                            @i.Question
                            @if (!string.IsNullOrEmpty(i.AppName))
                            {
                                <span class="ms-1 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-indigo-100 text-indigo-700">@i.AppName</span>
                            }
                            @if (i.IsMixing)
                            {
                                <span class="ms-1 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-purple-100 text-purple-700">@Localizer["Mixing"]</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-sm text-gray-500 max-w-xs truncate" dir="auto" title="@i.Answer">@i.Answer</td>
                        <td class="px-4 py-3">@Chips(tools, "bg-blue-50 text-blue-700", i.Answered ? null : Localizer["None"])</td>
                        <td class="px-4 py-3">@Chips(domains, "bg-emerald-50 text-emerald-700", "—")</td>
                        <td class="px-4 py-3">@Chips(entities, "bg-amber-50 text-amber-700", "—")</td>
                        <td class="px-4 py-3 text-end whitespace-nowrap">
                            @if (i.PlanConfirmed)
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bf-bg-success-100 bf-text-success me-2" title="@i.ReviewedBy">@Localizer["Confirmed"]</span>
                            }
                            <AuthorizeView Policy="Permission:assistant.keywords.approve">
                                <Authorized>
                                    <button @onclick="() => OpenPlan(i)" class="text-purple-600 hover:text-purple-800" title="@Localizer["CorrectPlan"]">
                                        <i class="bi bi-pencil-square text-lg"></i>
                                    </button>
                                </Authorized>
                                <NotAuthorized>
                                    <button @onclick="() => OpenPlan(i)" class="text-gray-400 hover:text-gray-600" title="@Localizer["ViewPlan"]">
                                        <i class="bi bi-eye text-lg"></i>
                                    </button>
                                </NotAuthorized>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="@OnPageChanged" />
}

@* ── Correct & confirm plan modal ──────────────────────────────── *@
@if (showModal && editing is not null)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center" @onclick="CloseModal">
        <div class="bg-white rounded-xl shadow-lg w-full max-w-2xl mx-4 max-h-[90vh] flex flex-col overflow-hidden" @onclick:stopPropagation>
            <!-- Header -->
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
                    <i class="bi bi-diagram-3 text-bf-primary"></i> @Localizer["CorrectAndConfirmPlan"]
                    @if (!string.IsNullOrEmpty(editing?.AppName))
                    {
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-medium bg-indigo-100 text-indigo-700">@editing!.AppName</span>
                    }
                </h3>
                <button type="button" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors" @onclick="CloseModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <!-- Body -->
            <div class="px-5 py-4 space-y-4 overflow-y-auto">
                <!-- Question -->
                <div class="rounded-lg bg-gray-50 border border-gray-200 p-3">
                    <div class="text-xs font-medium text-gray-500 mb-1">@Localizer["Question"]</div>
                    <p class="text-sm text-gray-900" dir="auto">@editing.Question</p>
                </div>

                <!-- Answer -->
                <div class="rounded-lg bg-gray-50 border border-gray-200 p-3">
                    <div class="text-xs font-medium text-gray-500 mb-1">@Localizer["Answer"]</div>
                    <p class="text-sm text-gray-700" dir="auto">@editing.Answer</p>
                </div>

                <!-- Plan -->
                <div class="rounded-lg bg-gray-50 border border-gray-200 p-3">
                    <div class="text-xs font-medium text-gray-500 mb-1">@Localizer["Plan"]</div>
                    @{ var planSteps = toolDrafts.Where(kv => kv.Value.Selected).ToList(); }
                    @if (planSteps.Count == 0)
                    {
                        <p class="text-sm text-gray-400">@(editing.Tools.Count == 0 ? Localizer["None"] : string.Join(", ", editing.Tools))</p>
                    }
                    else
                    {
                        <div class="space-y-2">
                            @foreach (var kv in planSteps)
                            {
                                <div class="text-sm">
                                    <span dir="ltr" class="font-medium text-gray-800">@kv.Key</span>
                                    <span class="text-xs text-gray-400">@DomainLabel(kv.Value.Domain)</span>
                                    @if (kv.Value.Params.Count > 0)
                                    {
                                        <div class="ms-4 mt-0.5 text-xs text-gray-600 space-y-0.5">
                                            @foreach (var p in kv.Value.Params)
                                            {
                                                <div><span dir="ltr">@p.Name</span> <span class="text-gray-400">→</span> @ParamSourceText(p)</div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                @if (planOptions is not null)
                {
                    <MultiSelectCheck TItem="AssistantToolInfoDto" TValue="string"
                                      Items="planOptions.Tools"
                                      DisplayText="@(t => $"{t.Name} — {DomainLabel(t.Domain)}")"
                                      ItemValue="@(t => t.Name)"
                                      SelectedValues="selectedToolNames"
                                      SelectedValuesChanged="OnToolsChanged"
                                      Searchable="true"
                                      ListClass="max-h-72"
                                      Label="@Localizer["CallingTools"]">
                        <ExpandedTemplate Context="tool">
                            @{ var d = toolDrafts[tool.Name]; }
                            @if (d.Params.Count > 0)
                            {
                                <div class="p-2.5 space-y-2">
                                    <p class="text-[11px] text-gray-500">@Localizer["ParamSourcesHint"]</p>
                                    @foreach (var p in d.Params)
                                    {
                                        <div class="space-y-1.5">
                                            <div class="text-xs text-gray-700" title="@p.Description">
                                                <span class="font-medium" dir="ltr">@p.Name</span>
                                                @if (p.Required) { <span class="text-red-500">*</span> }
                                            </div>
                                            <SearchableDropdown TItem="string" TValue="string" Compact="true" Clearable="false"
                                                                Items="ParamSources"
                                                                DisplayText="@(s => SourceLabel(s))"
                                                                ItemValue="@(s => s)"
                                                                Placeholder="@Localizer["ChooseSource"]"
                                                                Value="p.Source"
                                                                ValueChanged="@(v => OnParamSourceChanged(p, v))" />
                                            @if (p.Source == "static" && p.Enum.Count > 0)
                                            {
                                                <SearchableDropdown TItem="string" TValue="string" Compact="true"
                                                                    Items="p.Enum"
                                                                    DisplayText="@(s => s)" ItemValue="@(s => s)"
                                                                    Placeholder="—"
                                                                    @bind-Value="p.Value" />
                                            }
                                            else if (p.Source == "static")
                                            {
                                                <input @bind="p.Value" placeholder="@Localizer["Value"]" class="w-full px-2 py-1.5 border border-gray-300 rounded-lg text-sm" />
                                            }
                                            else if (p.Source == "extract")
                                            {
                                                <input @bind="p.Placeholder" placeholder="@($"{{{p.Name}}}")" dir="ltr" class="w-full px-2 py-1.5 border border-gray-300 rounded-lg text-sm" />
                                            }
                                            else if (p.Source == "context")
                                            {
                                                <SearchableDropdown TItem="string" TValue="string" Compact="true" Clearable="false"
                                                                    Items="ContextKeys"
                                                                    DisplayText="@(s => s)" ItemValue="@(s => s)"
                                                                    @bind-Value="p.ContextKey" />
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </ExpandedTemplate>
                    </MultiSelectCheck>

                    <SearchableDropdown TItem="string" TValue="string" Compact="true"
                                        Items="planOptions.Domains"
                                        DisplayText="@(d => DomainLabel(d))" ItemValue="@(d => d)"
                                        Label="@Localizer["Module"]"
                                        Placeholder="—"
                                        @bind-Value="selectedDomain" />

                    <SearchableDropdown TItem="string" TValue="string" Compact="true" Clearable="false"
                                        Items="PlanActions"
                                        DisplayText="@(a => ActionLabel(a))" ItemValue="@(a => a)"
                                        Label="@Localizer["Action"]"
                                        @bind-Value="selectedAction" />

                    <MultiSelectCheck TItem="string" TValue="string"
                                      Items="planOptions.Entities"
                                      DisplayText="@(e => EntityLabel(e))" ItemValue="@(e => e)"
                                      SelectedValues="selectedEntities"
                                      SelectedValuesChanged="@(v => { selectedEntities = v; })"
                                      Searchable="true"
                                      Label="@Localizer["Entities"]" />
                }

                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700 flex items-center gap-2">
                        <i class="bi bi-exclamation-circle flex-shrink-0"></i>
                        <span>@modalError</span>
                    </div>
                }
            </div>

            <!-- Footer -->
            <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-gray-200">
                <button type="button" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" @onclick="CloseModal">
                    @Localizer["Cancel"]
                </button>
                <AuthorizeView Policy="Permission:assistant.keywords.approve">
                    <Authorized>
                        <button type="button" @onclick="ConfirmPlan" disabled="@(saving || !CanConfirm())"
                                title="@(CanConfirm() ? null : Localizer["PlanIncompleteHint"])"
                                class="px-4 py-2 text-sm font-medium bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-all disabled:opacity-50 inline-flex items-center gap-2">
                            @if (saving)
                            {
                                <Spinner Size="Spinner.SpinnerSize.Xs" Color="Spinner.SpinnerColor.White" />
                            }
                            <i class="bi bi-check-circle"></i>
                            <span>@Localizer["ConfirmPlan"]</span>
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
}

@code {
    private List<AssistantInteractionDto> items = new();
    private AssistantPlanOptionsDto? planOptions;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string searchTerm = string.Empty;
    private bool showFiltersPanel = false;
    private string selectedStatus = string.Empty;   // "", "confirmed"

    private int pageIndex = 1;
    private int pageSize = 20;
    private int totalPages = 1;
    private int totalCount = 0;

    // Plan action vocabulary for the correction modal.
    private static readonly string[] PlanActions = { "list", "count", "sum", "compare", "top", "detail", "status" };

    // Interaction status filter options (unanswered turns live in the no-answer queue).
    private static readonly string[] FilterStatuses = { "", "confirmed" };
    private string StatusLabel(string s) => s switch
    {
        "confirmed" => L("Confirmed"),
        _ => L("AllStatuses")
    };

    // The option VALUES stay the code-owned English identifiers (plans match on them);
    // only the displayed labels are translated when the UI culture is Arabic. Tool
    // names always stay English — only their domain suffix is translated.
    private static bool IsArabic =>
        CultureInfo.CurrentUICulture.TwoLetterISOLanguageName
            .Equals("ar", StringComparison.OrdinalIgnoreCase);

    private static readonly Dictionary<string, string> ArDomains = new()
    {
        ["Sales"] = "المبيعات", ["Orders"] = "الطلبات", ["Products"] = "المنتجات",
        ["Inventory"] = "المخزون", ["Suppliers"] = "الموردون", ["Catalog"] = "الكتالوج",
        ["Promotions"] = "العروض", ["Shifts"] = "الورديات", ["Requests"] = "طلبات الموافقة",
        ["Purchasing"] = "المشتريات", ["Identity"] = "الهوية", ["Administration"] = "الإدارة",
        ["Warehouses"] = "المستودعات", ["Branches"] = "الفروع", ["Overview"] = "نظرة عامة"
    };

    private static readonly Dictionary<string, string> ArEntities = new()
    {
        ["Order"] = "طلب", ["Product"] = "منتج", ["StockBalance"] = "رصيد المخزون",
        ["Supplier"] = "مورّد", ["Category"] = "تصنيف", ["Unit"] = "وحدة",
        ["Promotion"] = "عرض", ["Shift"] = "وردية", ["Request"] = "طلب موافقة",
        ["PurchaseRequest"] = "طلب شراء", ["User"] = "مستخدم", ["Role"] = "دور",
        ["Branch"] = "فرع", ["Cashier"] = "كاشير", ["Warehouse"] = "مستودع",
        ["Dashboard"] = "لوحة المعلومات"
    };

    private static readonly Dictionary<string, string> ArActions = new()
    {
        ["list"] = "قائمة", ["count"] = "عدد", ["sum"] = "إجمالي", ["compare"] = "مقارنة",
        ["top"] = "الأعلى", ["detail"] = "تفاصيل", ["status"] = "الحالة"
    };

    private static string DomainLabel(string d) =>
        string.IsNullOrEmpty(d) ? "—" : (IsArabic && ArDomains.TryGetValue(d, out var v) ? v : d);
    private static string EntityLabel(string e) => IsArabic && ArEntities.TryGetValue(e, out var v) ? v : e;
    private static string ActionLabel(string a) => IsArabic && ArActions.TryGetValue(a, out var v) ? v : a;

    private string L(string key) => Localizer[key];

    // Code-owned option lists for the SearchableDropdowns in the param editor.
    private static readonly string[] ParamSources = { "omit", "static", "extract", "context" };
    private static readonly string[] ContextKeys = { "branchId", "userId" };
    private string SourceLabel(string s) => string.IsNullOrEmpty(s) ? "—" : L($"Source{char.ToUpperInvariant(s[0])}{s[1..]}");

    // A friendly "how this parameter is filled" label for the Plan box.
    private string ParamSourceText(ParamDraft p) => p.Source switch
    {
        "static" => string.IsNullOrWhiteSpace(p.Value) ? L("NoValue") : p.Value!,
        "extract" => L("FromQuestion"),
        "context" => p.ContextKey == "userId" ? L("CurrentUser") : L("CurrentBranch"),
        "omit" => L("DefaultValue"),
        _ => L("SetSource")
    };

    // Modal state
    private bool showModal = false;
    private bool saving = false;
    private string modalError = string.Empty;
    private AssistantInteractionDto? editing;
    private Dictionary<string, ToolDraft> toolDrafts = new();
    private List<string> selectedToolNames = new();
    private List<string> selectedEntities = new();
    private string selectedDomain = string.Empty;
    private string selectedAction = "list";

    // Keep the per-tool drafts' Selected flag in sync with the multi-select.
    private void OnToolsChanged(List<string> names)
    {
        selectedToolNames = names;
        foreach (var kv in toolDrafts) kv.Value.Selected = names.Contains(kv.Key);
    }

    private void OnParamSourceChanged(ParamDraft p, string? source)
    {
        p.Source = source ?? string.Empty;
        // Reset any value carried over from a different source.
        if (p.Source != "static") p.Value = null;
    }

    // Per-tool / per-param editing state for the correction modal.
    private sealed class ToolDraft
    {
        public bool Selected { get; set; }
        public string Domain { get; set; } = string.Empty;
        public List<ParamDraft> Params { get; } = new();
    }

    private sealed class ParamDraft
    {
        public string Name { get; set; } = string.Empty;
        public string Type { get; set; } = "string";
        public List<string> Enum { get; set; } = new();
        public string? Description { get; set; }
        public bool Required { get; set; }
        public string Source { get; set; } = string.Empty;   // "", omit, static, extract, context
        public string? Value { get; set; }
        public string? Placeholder { get; set; }
        public string ContextKey { get; set; } = "branchId";
    }

    // The completeness gate (mirrors the server): a tool selected, a domain + entity
    // for the match key, and EVERY parameter of every selected tool given a source.
    private bool CanConfirm()
    {
        if (string.IsNullOrEmpty(selectedDomain) || selectedEntities.Count == 0) return false;
        var anySelected = false;
        foreach (var d in toolDrafts.Values.Where(x => x.Selected))
        {
            anySelected = true;
            foreach (var p in d.Params)
            {
                if (string.IsNullOrEmpty(p.Source)) return false;
                if (p.Source == "static" && string.IsNullOrWhiteSpace(p.Value)) return false;
            }
        }
        return anySelected;
    }

    private List<AppOptionDto> appOptions = new();
    private string selectedAppId = string.Empty;
    private Guid? SelectedAppGuid => Guid.TryParse(selectedAppId, out var g) ? g : null;

    protected override async Task OnInitializedAsync()
    {
        try { planOptions = await AdminService.GetPlanOptionsAsync(); } catch { /* dropdowns simply stay empty */ }
        try { appOptions = await AdminService.GetAppOptionsAsync(); } catch { /* filter simply stays empty */ }
        await Load();
    }

    private async Task Load()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            var result = await AdminService.GetInteractionsAsync(
                pageIndex, pageSize, searchTerm,
                selectedStatus == "unanswered" ? true : null,
                selectedStatus == "confirmed" ? true : null,
                SelectedAppGuid);
            items = result.Items;
            totalPages = result.TotalPages;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            errorMessage = Localizer["FailedToLoadInteractions"] + $": {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSearch(string value) { searchTerm = value; pageIndex = 1; await Load(); }
    private async Task ApplyFilters() { pageIndex = 1; await Load(); }
    private async Task OnPageChanged(int p) { pageIndex = p; await Load(); }

    private bool HasActiveFilters() => !string.IsNullOrEmpty(selectedStatus) || !string.IsNullOrEmpty(selectedAppId);
    private int ActiveFilterCount => (string.IsNullOrEmpty(selectedStatus) ? 0 : 1) + (string.IsNullOrEmpty(selectedAppId) ? 0 : 1);

    private async Task ResetFilters() { selectedStatus = string.Empty; selectedAppId = string.Empty; pageIndex = 1; await Load(); }

    private void OpenPlan(AssistantInteractionDto i)
    {
        editing = i;
        modalError = string.Empty;

        // Prefill the chosen tools (confirmed plan if present, else the executed one);
        // every parameter starts UNDECIDED so the reviewer must consciously set a source.
        var chosen = new HashSet<string>(
            i.PlanConfirmed && i.ConfirmedTools.Count > 0 ? i.ConfirmedTools : i.Tools,
            StringComparer.OrdinalIgnoreCase);

        toolDrafts = new();
        foreach (var t in planOptions?.Tools ?? new())
        {
            var d = new ToolDraft { Selected = chosen.Contains(t.Name), Domain = t.Domain };
            foreach (var p in t.Parameters)
                d.Params.Add(new ParamDraft
                {
                    Name = p.Name,
                    Type = p.Type,
                    Enum = p.Enum,
                    Description = p.Description,
                    Required = p.Required,
                    Placeholder = $"{{{p.Name}}}"
                });
            toolDrafts[t.Name] = d;
        }
        selectedToolNames = toolDrafts.Where(kv => kv.Value.Selected).Select(kv => kv.Key).ToList();

        selectedEntities = (i.PlanConfirmed && i.ConfirmedEntities.Count > 0 ? i.ConfirmedEntities : i.Entities).ToList();
        selectedDomain = i.PlanConfirmed && !string.IsNullOrEmpty(i.ConfirmedDomain)
            ? i.ConfirmedDomain!
            : (i.Domains.FirstOrDefault() ?? string.Empty);
        selectedAction = "list";
        showModal = true;
    }

    private void CloseModal() { showModal = false; editing = null; }

    private async Task ConfirmPlan()
    {
        if (editing is null) return;
        saving = true;
        modalError = string.Empty;
        try
        {
            var entities = selectedEntities.ToList();
            var tools = toolDrafts
                .Where(kv => kv.Value.Selected)
                .Select(kv => new PlanToolInput
                {
                    Name = kv.Key,
                    Params = kv.Value.Params.Select(p => new PlanParamInput
                    {
                        Name = p.Name,
                        Source = p.Source,
                        Value = p.Source == "static" ? p.Value : null,
                        Placeholder = p.Source == "extract" ? (string.IsNullOrWhiteSpace(p.Placeholder) ? $"{{{p.Name}}}" : p.Placeholder) : null,
                        ContextKey = p.Source == "context" ? p.ContextKey : null
                    }).ToList()
                })
                .ToList();

            await AdminService.ConfirmPlanAsync(editing.Id, new ConfirmAssistantPlanRequest
            {
                Tools = tools,
                Domain = string.IsNullOrWhiteSpace(selectedDomain) ? null : selectedDomain,
                Entities = entities,
                Action = selectedAction,
                Entity = entities.FirstOrDefault(),
                SecondaryEntity = entities.Count > 1 ? entities[1] : null,
                SampleQuestion = editing.Question
            });
            showModal = false;
            editing = null;
            await Load();
        }
        catch (Exception ex)
        {
            modalError = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private RenderFragment Chips(List<string> values, string colorClasses, string? emptyText) => builder =>
    {
        if (values is null || values.Count == 0)
        {
            if (!string.IsNullOrEmpty(emptyText))
                builder.AddMarkupContent(0, $"<span class=\"text-xs text-gray-400\">{emptyText}</span>");
            return;
        }
        var seq = 1;
        foreach (var v in values)
        {
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", $"inline-block px-2 py-0.5 m-0.5 rounded text-[11px] font-medium {colorClasses}");
            builder.AddContent(seq++, v);
            builder.CloseElement();
        }
    };
}
