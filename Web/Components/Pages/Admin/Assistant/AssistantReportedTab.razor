@using Web.Authorization
@using Web.Components.Common
@using Web.Models.Assistant
@using Web.Models.Constants
@using Microsoft.AspNetCore.Authorization
@inject IAssistantAdminService AdminService
@inject IJsonStringLocalizer Localizer

<!-- Filters -->
<div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
    <div class="flex flex-wrap items-center gap-3 p-4">
        <div class="flex-1 min-w-[200px]">
            <SearchInput @bind-Value="search" OnSearch="HandleSearch" Placeholder="@Localizer["SearchQuestions"]" />
        </div>

        <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")">
            <i class="bi bi-funnel"></i>
            <span>@Localizer["Filters"]</span>
            @if (HasActiveFilters())
            {
                <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
            }
            <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
        </button>

        @if (HasActiveFilters())
        {
            <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <i class="bi bi-x-circle"></i>
                <span>@Localizer["ResetFilters"]</span>
            </button>
        }
    </div>

    @if (showFiltersPanel)
    {
        <div class="px-4 pb-4 pt-0 border-t border-gray-200">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-4">
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                    <SearchableDropdown TItem="string" TValue="string" Compact="true" Clearable="false"
                                        Items="StatusFilters"
                                        DisplayText="@(s => StatusLabel(s))"
                                        ItemValue="@(s => s)" @bind-Value="statusFilter" OnChanged="ApplyFilters" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["App"]</label>
                    <div class="relative">
                        <select @bind="selectedAppId" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                            <option value="">@Localizer["AllApps"]</option>
                            @foreach (var a in appOptions)
                            {
                                <option value="@a.Id">@a.Name</option>
                            }
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (loading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else if (items.Count == 0)
{
    <div class="text-center py-12">
        <i class="bi bi-flag text-6xl text-gray-300 mb-4"></i>
        <p class="text-gray-500 text-lg">@Localizer["NoReportedAnswers"]</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Question"]</th>
                    <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Feedback"]</th>
                    <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["ReportedAt"]</th>
                    <th class="px-4 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                    <th class="px-4 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var r in items)
                {
                    <tr class="hover:bg-gray-50 align-top">
                        <td class="px-4 py-3 text-sm text-gray-900 max-w-xs" dir="auto">
                            <span class="block truncate" title="@r.Question">@r.Question</span>
                            @if (!string.IsNullOrEmpty(r.AppName))
                            {
                                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-indigo-100 text-indigo-700">@r.AppName</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-sm text-gray-600 max-w-xs truncate" dir="auto" title="@r.Feedback">
                            @(string.IsNullOrWhiteSpace(r.Feedback) ? "-" : r.Feedback)
                        </td>
                        <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-600">@r.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="px-4 py-3 whitespace-nowrap">
                            @if (r.Resolved)
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[11px] font-medium bf-bg-success-100 bf-text-success">
                                    <i class="bi bi-check-circle"></i> @Localizer["Resolved"]
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[11px] font-medium bf-bg-warning-100 bf-text-warning">
                                    <i class="bi bi-flag"></i> @Localizer["Open"]
                                </span>
                            }
                        </td>
                        <td class="px-4 py-3 text-end whitespace-nowrap">
                            <div class="inline-flex items-center gap-2">
                                <button @onclick="() => Open(r)" class="text-purple-600 hover:text-purple-800" title="@Localizer["View"]">
                                    <i class="bi bi-eye text-lg"></i>
                                </button>
                                <AuthorizeView Policy="Permission:assistant.keywords.write" Context="wr">
                                    <Authorized Context="wr">
                                        <button @onclick="() => ToggleResolve(r)" class="@(r.Resolved ? "text-gray-500 hover:text-gray-700" : "bf-text-success")"
                                                title="@(r.Resolved ? Localizer["Reopen"] : Localizer["MarkResolved"])">
                                            <i class="bi @(r.Resolved ? "bi-arrow-counterclockwise" : "bi-check2-circle") text-lg"></i>
                                        </button>
                                    </Authorized>
                                </AuthorizeView>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="@OnPageChanged" />
}

@if (!string.IsNullOrEmpty(error))
{
    <div class="mt-4 p-3 bf-bg-danger-50 border bf-border-danger rounded-lg text-sm bf-text-danger flex items-center gap-2">
        <i class="bi bi-exclamation-circle flex-shrink-0"></i> <span>@error</span>
    </div>
}

@* Reported-answer detail modal *@
@if (showModal && editing is not null)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center" @onclick="Close">
        <div class="bg-white rounded-xl shadow-lg w-full max-w-2xl mx-4 max-h-[90vh] flex flex-col overflow-hidden" @onclick:stopPropagation>
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
                    <i class="bi bi-flag text-purple-600"></i> @Localizer["ReportedAnswer"]
                    @if (!string.IsNullOrEmpty(editing.AppName))
                    {
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-medium bg-indigo-100 text-indigo-700">@editing.AppName</span>
                    }
                </h3>
                <button type="button" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors" @onclick="Close">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="px-5 py-4 space-y-4 overflow-y-auto">
                <div class="rounded-lg bg-gray-50 border border-gray-200 p-3">
                    <div class="text-xs font-medium text-gray-500 mb-1">@Localizer["Question"]</div>
                    <p class="text-sm text-gray-900" dir="auto">@editing.Question</p>
                </div>

                <div class="rounded-lg bg-gray-50 border border-gray-200 p-3">
                    <div class="text-xs font-medium text-gray-500 mb-1">@Localizer["Answer"]</div>
                    <p class="text-sm text-gray-700 whitespace-pre-wrap" dir="auto">@editing.Answer</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(editing.Feedback))
                {
                    <div class="rounded-lg bf-bg-warning-50 border bf-border-warning p-3">
                        <div class="text-xs font-medium bf-text-warning mb-1">@Localizer["Feedback"]</div>
                        <p class="text-sm text-gray-800" dir="auto">@editing.Feedback</p>
                    </div>
                }

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <div class="rounded-lg bg-gray-50 border border-gray-200 p-3">
                        <div class="text-xs font-medium text-gray-500 mb-1">@Localizer["ReportedAt"]</div>
                        <p class="text-sm text-gray-900">@editing.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p>
                    </div>
                    <div class="rounded-lg bg-gray-50 border border-gray-200 p-3">
                        <div class="text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</div>
                        @if (editing.Resolved)
                        {
                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[11px] font-medium bf-bg-success-100 bf-text-success">
                                <i class="bi bi-check-circle"></i> @Localizer["Resolved"]
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[11px] font-medium bf-bg-warning-100 bf-text-warning">
                                <i class="bi bi-flag"></i> @Localizer["Open"]
                            </span>
                        }
                    </div>
                </div>
            </div>

            <AuthorizeView Policy="Permission:assistant.keywords.write" Context="wr2">
                <Authorized Context="wr2">
                    <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-gray-200">
                        <button type="button" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white btn-primary-action" @onclick="() => ToggleResolve(editing)">
                            <i class="bi @(editing.Resolved ? "bi-arrow-counterclockwise" : "bi-check2-circle")"></i>
                            @(editing.Resolved ? Localizer["Reopen"] : Localizer["MarkResolved"])
                        </button>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
}

@code {
    private List<ReportedAnswerDto> items = new();
    private bool loading = true;
    private string error = string.Empty;
    private string search = string.Empty;
    private string statusFilter = "open";
    private bool showFiltersPanel = false;
    private int pageIndex = 1, pageSize = 20, totalPages = 1, totalCount = 0;

    private static readonly string[] StatusFilters = { "open", "resolved", "all" };

    private bool showModal = false;
    private ReportedAnswerDto? editing;

    private string StatusLabel(string s) => s switch
    {
        "open" => Localizer["Open"],
        "resolved" => Localizer["Resolved"],
        _ => Localizer["All"]
    };

    private bool? ResolvedFilter() => statusFilter switch
    {
        "open" => false,
        "resolved" => true,
        _ => null
    };

    private List<AppOptionDto> appOptions = new();
    private string selectedAppId = string.Empty;
    private Guid? SelectedAppGuid => Guid.TryParse(selectedAppId, out var g) ? g : null;

    protected override async Task OnInitializedAsync()
    {
        try { appOptions = await AdminService.GetAppOptionsAsync(); } catch { /* filter simply stays empty */ }
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        error = string.Empty;
        try
        {
            var result = await AdminService.GetReportedAnswersAsync(pageIndex, pageSize, ResolvedFilter(), search, SelectedAppGuid);
            items = result.Items;
            totalPages = result.TotalPages;
            totalCount = result.TotalCount;
        }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    private async Task HandleSearch(string value) { search = value; pageIndex = 1; await Load(); }
    private async Task ApplyFilters() { pageIndex = 1; await Load(); }
    private async Task OnPageChanged(int p) { pageIndex = p; await Load(); }

    // "open" is the default view, so a non-default status counts as an active filter.
    private bool HasActiveFilters() => statusFilter != "open" || !string.IsNullOrEmpty(selectedAppId);
    private int ActiveFilterCount => (statusFilter == "open" ? 0 : 1) + (string.IsNullOrEmpty(selectedAppId) ? 0 : 1);
    private async Task ResetFilters() { statusFilter = "open"; selectedAppId = string.Empty; pageIndex = 1; await Load(); }

    private void Open(ReportedAnswerDto r) { editing = r; showModal = true; }
    private void Close() { showModal = false; editing = null; }

    private async Task ToggleResolve(ReportedAnswerDto r)
    {
        error = string.Empty;
        try
        {
            await AdminService.ResolveReportedAnswerAsync(r.Id, !r.Resolved);
            if (showModal) Close();
            await Load();
        }
        catch (Exception ex) { error = ex.Message; }
    }
}
