@page "/admin/lookups"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.LookupsRead)]
@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using Web.Components.Common
@using System.Globalization
@inject ILookupService LookupService
@inject NavigationManager Navigation

<PageTitle>@Localizer["LookupsManagement"]</PageTitle>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6">
            <!-- Header -->
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
                        <i class="bi bi-list-ul text-purple-600"></i>
                        @Localizer["LookupsManagement"]
                    </h1>
                    <p class="text-gray-600 mt-2 text-sm sm:text-base">@Localizer["ManageSystemLookups"]</p>
                </div>
                
                <AuthorizeView Policy="Permission:lookups.write">
                    <Authorized>
                        <button @onclick="NavigateToCreate" 
                                class="btn-primary-action">
                            <i class="bi bi-plus-circle"></i>
                            <span>@Localizer["CreateLookup"]</span>
                        </button>
                    </Authorized>
                    <NotAuthorized>
                        <button disabled 
                                class="inline-flex items-center gap-2 py-3 px-6 bg-gray-300 text-gray-500 rounded-lg cursor-not-allowed font-medium">
                            <i class="bi bi-plus-circle"></i>
                            <span>@Localizer["CreateLookup"]</span>
                        </button>
                    </NotAuthorized>
                </AuthorizeView>
            </div>

            <!-- Filters -->
            <div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
                <div class="flex flex-wrap items-center gap-3 p-4">
                    <div class="flex-1 min-w-[200px]">
                        <SearchInput @bind-Value="searchTerm"
                                     OnSearch="HandleSearch"
                                     Placeholder="@Localizer["SearchLookups"]" />
                    </div>

                    <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                            class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")"> 
                        <i class="bi bi-funnel"></i>
                        <span>@Localizer["Filters"]</span>
                        @if (ActiveFilterCount > 0)
                        {
                            <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
                        }
                        <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
                    </button>

                    @if (HasActiveFilters())
                    {
                        <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                            <i class="bi bi-x-circle"></i>
                            <span>@Localizer["ResetFilters"]</span>
                        </button>
                    }
                </div>

                @if (showFiltersPanel)
                {
                    <div class="px-4 pb-4 pt-0 border-t border-gray-200">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-4">
                            <div>
                                <SearchableDropdown TItem="LookupDto"
                                                    TValue="string"
                                                    Items="rootLookups"
                                                    @bind-Value="selectedType"
                                                    OnChanged="ApplyFilters"
                                                    DisplayText="l => isAr ? l.NameAr : l.NameEn"
                                                    SearchText='l => $"{l.NameEn} {l.NameAr} {l.Code}"'
                                                    ItemValue="l => l.Code"
                                                    Label='@Localizer["Parent"]'
                                                    Placeholder='@Localizer["AllParents"]'
                                                    Compact="true" />
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                                <div class="relative">
                                    <select @bind="selectedStatus" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                                        <option value="">@Localizer["AllStatuses"]</option>
                                        <option value="true">@Localizer["Active"]</option>
                                        <option value="false">@Localizer["Inactive"]</option>
                                    </select>
                                    <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

            </div>

            @if (isLoading)
            {
                <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
                    <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
                    <span class="bf-text-danger">@errorMessage</span>
                </div>
            }
            else if (lookups == null || !lookups.Any())
            {
                <div class="text-center py-12">
                    <i class="bi bi-inbox text-6xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500 text-lg">@Localizer["NoLookupsFound"]</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Code"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["NameEn"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["NameAr"]</th>
                                <!-- Type column removed -->
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Parent"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                                <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var lookup in lookups)
                            {
                                <tr class="hover:bg-gray-50 transition-colors duration-150">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                        <a href="@($"/admin/lookups/edit/{lookup.Id}")" class="text-sm font-medium text-indigo-600 hover:text-indigo-800 hover:underline">
                                            @lookup.Code
                                        </a>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                        @lookup.NameEn
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                        @lookup.NameAr
                                    </td>
                                    <!-- Type cell removed -->
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                        @if (lookup.ParentId.HasValue)
                                        {
                                            <a href="@($"/admin/lookups/edit/{lookup.ParentId}")" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-bf-primary hover:underline">
                                                @lookup.ParentName
                                            </a>
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        @if (lookup.IsActive)
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-success-100 bf-text-success">
                                                <i class="bi bi-check-circle-fill me-1"></i> @Localizer["Active"]
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-danger-100 bf-text-danger">
                                                <i class="bi bi-x-circle-fill me-1"></i> @Localizer["Inactive"]
                                            </span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                                        <AuthorizeView Policy="Permission:lookups.write">
                                            <Authorized>
                                                <button @onclick="() => NavigateToEdit(lookup.Id)" 
                                                        class="text-purple-600 hover:text-purple-900 me-3">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                            </Authorized>
                                            <NotAuthorized>
                                                <button disabled class="text-gray-400 me-3 cursor-not-allowed">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                            </NotAuthorized>
                                        </AuthorizeView>
                                        <AuthorizeView Policy="Permission:lookups.delete">
                                            <Authorized>
                                                <button @onclick="() => ConfirmDelete(lookup.Id)" 
                                                        class="bf-text-danger bf-hover-text-danger-strong">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </Authorized>
                                            <NotAuthorized>
                                                <button disabled class="text-gray-400 cursor-not-allowed">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </NotAuthorized>
                                        </AuthorizeView>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <Pagination PageIndex="@pageIndex" 
                                TotalPages="@totalPages" 
                                TotalCount="@totalCount" 
                                PageSize="@pageSize" 
                                OnPageChanged="@OnPageChanged" />
                </div>
            }
</div>

<AuthorizeView Policy="Permission:lookups.delete">
    <Authorized>
        @if (showDeleteConfirm)
        {
            <div class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50 flex items-center justify-center">
                <div class="bg-white rounded-xl shadow-2xl p-8 max-w-md w-full mx-4">
                    <h3 class="text-xl font-bold text-gray-900 mb-4">@Localizer["ConfirmDeleteTitle"]</h3>
                    <p class="text-gray-600 mb-6">@Localizer["ConfirmDeleteMessage"]</p>
                    <div class="flex gap-3">
                        <button @onclick="CancelDelete" 
                                class="flex-1 py-2 px-4 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors duration-200 font-medium">
                            @Localizer["Cancel"]
                        </button>
                        <button @onclick="DeleteLookup" 
                                class="flex-1 py-2 px-4 bf-bg-danger-600 bf-hover-bg-danger-700 rounded-lg transition-colors duration-200 font-medium">
                            @Localizer["Delete"]
                        </button>
                    </div>
                </div>
            </div>
        }
    </Authorized>
</AuthorizeView>

@code {
private List<LookupDto> lookups = new();
private List<LookupDto> rootLookups = new();
private bool isLoading = true;
private string errorMessage = string.Empty;
private bool showDeleteConfirm = false;
private Guid lookupToDelete;
private bool isAr = false;
    
// Filters
private string searchTerm = string.Empty;
private string selectedType = string.Empty;
private string selectedStatus = string.Empty;
private bool showFiltersPanel = false;

private bool HasActiveFilters() => !string.IsNullOrEmpty(selectedType) || !string.IsNullOrEmpty(selectedStatus);
private int ActiveFilterCount => (string.IsNullOrEmpty(selectedType) ? 0 : 1) + (string.IsNullOrEmpty(selectedStatus) ? 0 : 1);
    
// Pagination
private int pageIndex = 1;
private int pageSize = 10;
private int totalPages = 1;
private int totalCount = 0;

protected override async Task OnInitializedAsync()
{
    isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
    rootLookups = await LookupService.GetRootLookupsAsync();
    await LoadLookups();
}

private async Task LoadLookups()
{
    isLoading = true;
    errorMessage = string.Empty;
        
    try
    {
        string? parentCode = string.IsNullOrWhiteSpace(selectedType) ? null : selectedType;
        bool? isActive = string.IsNullOrEmpty(selectedStatus) ? null : bool.Parse(selectedStatus);
        var result = await LookupService.GetAllLookupsAsync(pageIndex, pageSize, parentCode, searchTerm, isActive);
        lookups = result.Items;
        totalPages = result.TotalPages;
        totalCount = result.TotalCount;
    }
    catch (Exception ex)
    {
        errorMessage = $"Failed to load lookups: {ex.Message}";
    }
    finally
    {
        isLoading = false;
    }
}
    
private async Task OnPageChanged(int newPageIndex)
{
    pageIndex = newPageIndex;
    await LoadLookups();
}

private async Task HandleSearch(string searchValue)
{
    searchTerm = searchValue;
    pageIndex = 1;
    await LoadLookups();
}

private async Task ApplyFilters()
{
    pageIndex = 1;
    await LoadLookups();
}

private async Task ResetFilters()
{
    searchTerm = string.Empty;
    selectedType = string.Empty;
    selectedStatus = string.Empty;
    pageIndex = 1;
    await LoadLookups();
}

    private void NavigateToCreate()
    {
        Navigation.NavigateTo("/admin/lookups/create");
    }

    private void NavigateToEdit(Guid id)
    {
        Navigation.NavigateTo($"/admin/lookups/edit/{id}");
    }

    private void ConfirmDelete(Guid id)
    {
        lookupToDelete = id;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        lookupToDelete = Guid.Empty;
    }

    private async Task DeleteLookup()
    {
        try
        {
            await LookupService.DeleteLookupAsync(lookupToDelete);
            showDeleteConfirm = false;
            await LoadLookups();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to delete lookup: {ex.Message}";
            showDeleteConfirm = false;
        }
    }
}
