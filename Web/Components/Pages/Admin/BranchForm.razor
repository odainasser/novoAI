@page "/admin/branches/create"
@page "/admin/branches/edit/{BranchId:guid}"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.BranchesWrite)]
@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using System.Globalization
@using Web.Components.Common
@using System.ComponentModel.DataAnnotations
@inject IBranchService BranchService
@inject IMediaService MediaService
@inject NavigationManager Navigation

<PageTitle>@(IsEditMode ? Localizer["EditBranch"] : Localizer["CreateBranch"])</PageTitle>

@if (isLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else
{
    <EditForm Model="@model" OnValidSubmit="@HandleSubmit" FormName="branchForm">
        <LocalizedDataAnnotationsValidator />
        <ServerValidator @ref="serverValidator" />

        <!-- Sticky top bar -->
        <div class="form-sticky-toolbar sticky top-0 z-30 -mx-4 sm:-mx-6 px-4 sm:px-6 py-3 mb-6">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <button type="button" @onclick="NavigateBack" class="p-2 -ml-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors">
                        <i class="bi bi-arrow-left text-lg"></i>
                    </button>
                    <h1 class="text-xl font-semibold text-gray-900">
                        @(IsEditMode ? Localizer["EditBranch"] : Localizer["CreateBranch"])
                    </h1>
                </div>
                <div class="flex items-center gap-2">
                    <button type="button" @onclick="NavigateBack" class="form-cancel-btn px-4 py-2 text-sm font-medium rounded-lg transition-colors">
                        @Localizer["Cancel"]
                    </button>
                    <button type="submit" disabled="@isSaving" class="px-4 py-2 text-sm font-medium bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-all disabled:opacity-50 inline-flex items-center gap-2">
                        @if (isSaving)
                        {
                            <Spinner Size="Spinner.SpinnerSize.Xs" Color="Spinner.SpinnerColor.White" />
                        }
                        <span>@(IsEditMode ? Localizer["Update"] : Localizer["Create"])</span>
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="mb-5 p-4 bg-red-50 border border-red-200 rounded-xl flex items-start gap-3">
                <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                <span class="text-red-800 text-sm">@errorMessage</span>
            </div>
        }

        <!-- Two-column Shopify-style layout -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

            <!-- Main column (2/3) -->
            <div class="lg:col-span-2 space-y-5">

                <!-- Card: Branch Details -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <div class="space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label for="nameEn" class="block text-sm font-medium text-gray-700 mb-1.5">
                                    @Localizer["BranchNameEn"] <span class="text-red-500">*</span>
                                </label>
                                <InputText @bind-Value="model.NameEn"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm"
                                    id="nameEn"
                                    placeholder="@Localizer["EnterBranchNameEn"]" />
                                <ValidationMessage For="@(() => model.NameEn)" class="text-red-600 text-xs mt-1" />
                            </div>
                            <div>
                                <label for="nameAr" class="block text-sm font-medium text-gray-700 mb-1.5">
                                    @Localizer["BranchNameAr"] <span class="text-red-500">*</span>
                                </label>
                                <InputText @bind-Value="model.NameAr"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm"
                                    id="nameAr"
                                    dir="rtl"
                                    placeholder="@Localizer["EnterBranchNameAr"]" />
                                <ValidationMessage For="@(() => model.NameAr)" class="text-red-600 text-xs mt-1" />
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label for="descriptionEn" class="block text-sm font-medium text-gray-700 mb-1.5">@Localizer["BranchDescriptionEn"]</label>
                                <InputTextArea @bind-Value="model.DescriptionEn"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm"
                                    id="descriptionEn"
                                    rows="3"
                                    placeholder="@Localizer["EnterDescriptionEn"]" />
                                <ValidationMessage For="@(() => model.DescriptionEn)" class="text-red-600 text-xs mt-1" />
                            </div>
                            <div>
                                <label for="descriptionAr" class="block text-sm font-medium text-gray-700 mb-1.5">@Localizer["BranchDescriptionAr"]</label>
                                <InputTextArea @bind-Value="model.DescriptionAr"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm"
                                    id="descriptionAr"
                                    rows="3"
                                    dir="rtl"
                                    placeholder="@Localizer["EnterDescriptionAr"]" />
                                <ValidationMessage For="@(() => model.DescriptionAr)" class="text-red-600 text-xs mt-1" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card: Media -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <h2 class="text-sm font-semibold text-gray-900 mb-3">@Localizer["BranchImage"]</h2>
                    <div class="flex items-start gap-4">
                        <div class="w-32 h-32 border-2 border-dashed border-gray-300 rounded-lg flex items-center justify-center bg-gray-50 overflow-hidden">
                            @if (!string.IsNullOrEmpty(imageUrl))
                            {
                                <img src="@imageUrl" alt="Branch image" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <i class="bi bi-building text-3xl text-gray-300"></i>
                            }
                        </div>
                        <div class="flex flex-col gap-2">
                            <InputFile OnChange="OnImageSelected" accept="image/*" class="hidden" id="branchImageInput" />
                            <label for="branchImageInput" class="inline-flex items-center gap-2 px-3 py-2 text-sm bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors cursor-pointer">
                                <i class="bi bi-upload"></i>
                                <span>@(string.IsNullOrEmpty(imageUrl) ? Localizer["UploadImage"] : Localizer["ChangeImage"])</span>
                            </label>
                            @if (!string.IsNullOrEmpty(imageUrl))
                            {
                                <button type="button" @onclick="RemoveImage" class="inline-flex items-center gap-2 px-3 py-2 text-sm text-red-600 hover:bg-red-50 rounded-lg transition-colors">
                                    <i class="bi bi-trash"></i>
                                    <span>@Localizer["RemoveImage"]</span>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar (1/3) -->
            <div class="space-y-5">

                <!-- Card: Status -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <h2 class="text-sm font-semibold text-gray-900 mb-3">@Localizer["Status"]</h2>
                    <ToggleSwitch @bind-Value="model.IsActive" Label="@Localizer["Active"]" />
                </div>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public Guid? BranchId { get; set; }

    private bool IsEditMode => BranchId.HasValue && BranchId.Value != Guid.Empty;
    
    private BranchFormModel model = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private bool isAr = false;
    private ServerValidator serverValidator = null!;
    private string? originalNameEn;
    private string? originalNameAr;
    private string? imageUrl;
    private IBrowserFile? selectedImageFile;
    private byte[]? selectedImageData;
    private string? selectedImageContentType;
    private string? selectedImageFileName;

    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        
        if (IsEditMode)
        {
            await LoadBranch();
        }
        
        isLoading = false;
    }

    private async Task LoadBranch()
    {
        try
        {
            var branch = await BranchService.GetBranchByIdAsync(BranchId!.Value);
            if (branch != null)
            {
                model = new BranchFormModel
                {
                    NameEn = branch.NameEn,
                    NameAr = branch.NameAr,
                    DescriptionEn = branch.DescriptionEn,
                    DescriptionAr = branch.DescriptionAr,
                    IsActive = branch.IsActive
                };
                
                originalNameEn = branch.NameEn;
                originalNameAr = branch.NameAr;
                imageUrl = branch.ImageUrl;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToLoadBranch"]}: {ex.Message}";
        }
    }

    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        try
        {
            long maxFileSize = 5 * 1024 * 1024; // 5MB max
            
            // Read file into memory and create preview
            using var memoryStream = new MemoryStream();
            await using var stream = file.OpenReadStream(maxFileSize);
            await stream.CopyToAsync(memoryStream);
            var buffer = memoryStream.ToArray();

            // Store file data for later upload
            selectedImageData = buffer;
            selectedImageContentType = file.ContentType;
            selectedImageFileName = file.Name;
            selectedImageFile = file; // Keep reference

            // Create preview
            var base64 = Convert.ToBase64String(buffer);
            imageUrl = $"data:{file.ContentType};base64,{base64}";

            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to process image: {ex.Message}";
        }
    }

    private async Task RemoveImage()
    {
        if (IsEditMode && BranchId.HasValue)
        {
            try
            {
                // Delete existing images from server
                var existingMedia = await MediaService.GetMediaForEntityAsync(BranchId.Value, "Branch", "image");
                foreach (var media in existingMedia)
                {
                    await MediaService.DeleteMediaAsync(media.Id);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Failed to delete image: {ex.Message}");
            }
        }
        
        selectedImageFile = null;
        selectedImageData = null;
        selectedImageContentType = null;
        selectedImageFileName = null;
        imageUrl = null;
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            // Check if branch name already exists
            bool nameEnChanged = !IsEditMode || !string.Equals(originalNameEn, model.NameEn, StringComparison.OrdinalIgnoreCase);
            bool nameArChanged = !IsEditMode || !string.Equals(originalNameAr, model.NameAr, StringComparison.OrdinalIgnoreCase);

            if (nameEnChanged || nameArChanged)
            {
                var exists = await BranchService.CheckBranchExistsAsync(model.NameEn, model.NameAr, IsEditMode ? BranchId : null);
                if (exists)
                {
                    serverValidator.DisplayErrors(new Dictionary<string, string[]>
                    {
                        { nameof(model.NameEn), new[] { Localizer["BranchAlreadyExists"] } }
                    });
                    isSaving = false;
                    return;
                }
            }

            BranchDto result;
            
            if (IsEditMode)
            {
                var updateRequest = new UpdateBranchRequest
                {
                    NameEn = model.NameEn,
                    NameAr = model.NameAr,
                    DescriptionEn = model.DescriptionEn,
                    DescriptionAr = model.DescriptionAr,
                    IsActive = model.IsActive
                };
                
                result = await BranchService.UpdateBranchAsync(BranchId!.Value, updateRequest);
            }
            else
            {
                var createRequest = new CreateBranchRequest
                {
                    NameEn = model.NameEn,
                    NameAr = model.NameAr,
                    DescriptionEn = model.DescriptionEn,
                    DescriptionAr = model.DescriptionAr,
                    IsActive = model.IsActive
                };
                
                result = await BranchService.CreateBranchAsync(createRequest);
            }

            // Upload image if selected
            if (selectedImageData != null && !string.IsNullOrEmpty(selectedImageFileName))
            {
                await UploadBranchImage(result.Id);
            }

            Navigation.NavigateTo("/admin/facilities/branches");
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToSaveBranch"]}: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task UploadBranchImage(Guid branchId)
    {
        if (selectedImageData == null || string.IsNullOrEmpty(selectedImageFileName)) return;

        try
        {
            // Use stored byte array to create a fresh stream for upload
            using var uploadStream = new MemoryStream(selectedImageData);

            // Delete existing image if any
            var existingMedia = await MediaService.GetMediaForEntityAsync(branchId, "Branch", "image");
            foreach (var media in existingMedia)
            {
                await MediaService.DeleteMediaAsync(media.Id);
            }

            await MediaService.UploadMediaAsync(branchId, "Branch", uploadStream, selectedImageFileName, selectedImageContentType ?? "image/png", "image");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to upload image: {ex.Message}");
            errorMessage = $"Failed to upload image: {ex.Message}";
        }
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/admin/facilities/branches");
    }

    public class BranchFormModel
    {
        [Required(ErrorMessage = "NameEnRequired")]
        [StringLength(256, ErrorMessage = "NameEnMaxLength")]
        public string NameEn { get; set; } = string.Empty;

        [Required(ErrorMessage = "NameArRequired")]
        [StringLength(256, ErrorMessage = "NameArMaxLength")]
        public string NameAr { get; set; } = string.Empty;

        [StringLength(2000, ErrorMessage = "DescriptionMaxLength")]
        public string? DescriptionEn { get; set; }

        [StringLength(2000, ErrorMessage = "DescriptionMaxLength")]
        public string? DescriptionAr { get; set; }

        public bool IsActive { get; set; } = true;
    }
}
