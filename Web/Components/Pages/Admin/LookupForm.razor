@page "/admin/lookups/create"
@page "/admin/lookups/edit/{LookupId:guid}"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.LookupsWrite)]
@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using System.Globalization
@using Web.Components.Common
@using System.ComponentModel.DataAnnotations
@inject ILookupService LookupService
@inject NavigationManager Navigation

<PageTitle>@(IsEditMode ? Localizer["EditLookup"] : Localizer["CreateLookup"])</PageTitle>

@if (isLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else
{
    <EditForm Model="@model" OnValidSubmit="@HandleSubmit" FormName="lookupForm">
        <LocalizedDataAnnotationsValidator />
        <ServerValidator @ref="serverValidator" />

        <!-- Sticky top bar -->
        <div class="form-sticky-toolbar sticky top-0 z-30 -mx-4 sm:-mx-6 px-4 sm:px-6 py-3 mb-6">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <button type="button" @onclick="Cancel" class="p-2 -ml-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors">
                        <i class="bi bi-arrow-left text-lg"></i>
                    </button>
                    <h1 class="text-xl font-semibold text-gray-900">
                        @(IsEditMode ? Localizer["EditLookup"] : Localizer["CreateLookup"])
                    </h1>
                </div>
                <div class="flex items-center gap-2">
                    <button type="button" @onclick="Cancel" class="form-cancel-btn px-4 py-2 text-sm font-medium rounded-lg transition-colors">
                        @Localizer["Cancel"]
                    </button>
                    <button type="submit" disabled="@isSaving" class="px-4 py-2 text-sm font-medium bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-all disabled:opacity-50 inline-flex items-center gap-2">
                        @if (isSaving)
                        {
                            <Spinner Size="Spinner.SpinnerSize.Xs" Color="Spinner.SpinnerColor.White" />
                        }
                        <span>@(IsEditMode ? Localizer["Update"] : Localizer["Create"])</span>
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="mb-5 p-4 bg-red-50 border border-red-200 rounded-xl flex items-start gap-3">
                <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                <span class="text-red-800 text-sm">@errorMessage</span>
            </div>
        }

        <!-- Two-column Shopify-style layout -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

            <!-- Main column (2/3) -->
            <div class="lg:col-span-2 space-y-5">

                <!-- Card: Lookup Details -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <div class="space-y-4">
                        <div>
                            <label for="code" class="block text-sm font-medium text-gray-700 mb-1.5">
                                @Localizer["Code"] <span class="text-red-500">*</span>
                            </label>
                            <InputText @bind-Value="model.Code"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm"
                                id="code"
                                placeholder="@Localizer["EnterLookupCode"]" />
                            <ValidationMessage For="@(() => model.Code)" class="text-red-600 text-xs mt-1" />
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label for="nameEn" class="block text-sm font-medium text-gray-700 mb-1.5">
                                    @Localizer["NameEn"] <span class="text-red-500">*</span>
                                </label>
                                <InputText @bind-Value="model.NameEn"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm"
                                    id="nameEn"
                                    placeholder="@Localizer["EnterLookupNameEn"]" />
                                <ValidationMessage For="@(() => model.NameEn)" class="text-red-600 text-xs mt-1" />
                            </div>
                            <div>
                                <label for="nameAr" class="block text-sm font-medium text-gray-700 mb-1.5">
                                    @Localizer["NameAr"] <span class="text-red-500">*</span>
                                </label>
                                <InputText @bind-Value="model.NameAr"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm"
                                    id="nameAr"
                                    placeholder="@Localizer["EnterLookupNameAr"]" />
                                <ValidationMessage For="@(() => model.NameAr)" class="text-red-600 text-xs mt-1" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar (1/3) -->
            <div class="space-y-5">

                <!-- Card: Organization -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <h2 class="text-sm font-semibold text-gray-900 mb-3">@Localizer["Parent"]</h2>
                    <InputSelect @bind-Value="model.ParentId"
                                 class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm"
                                 id="parentId">
                        <option value="">@Localizer["SelectParent"]</option>
                        @foreach (var root in rootLookups)
                        {
                            <option value="@root.Id">@(isAr ? root.NameAr : root.NameEn)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => model.ParentId)" class="text-red-600 text-xs mt-1" />
                </div>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public Guid? LookupId { get; set; }

    private bool IsEditMode => LookupId.HasValue && LookupId.Value != Guid.Empty;

    private LookupFormModel model = new();
    private List<LookupDto> rootLookups = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private ServerValidator serverValidator = null!;
    private string? originalCode;
    private string? originalNameEn;
    private string? originalNameAr;

    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        await LoadRootLookups();

        if (IsEditMode)
        {
            await LoadLookup();
        }

        isLoading = false;
    }

    private bool isAr = false;

    private async Task LoadRootLookups()
    {
        try
        {
            rootLookups = await LookupService.GetRootLookupsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load parents: {ex.Message}";
        }
    }

    private async Task LoadLookup()
    {
        try
        {
            var lookup = await LookupService.GetLookupByIdAsync(LookupId!.Value);
            if (lookup != null)
            {
                model = new LookupFormModel
                {
                    Code = lookup.Code,
                    NameEn = lookup.NameEn,
                    NameAr = lookup.NameAr,
                    ParentId = lookup.ParentId,
                    IsActive = lookup.IsActive
                };

                originalCode = lookup.Code;
                originalNameEn = lookup.NameEn;
                originalNameAr = lookup.NameAr;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load lookup: {ex.Message}";
        }
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            // Check if any values have changed that need uniqueness validation
            bool codeChanged = !IsEditMode || !string.Equals(originalCode, model.Code, StringComparison.OrdinalIgnoreCase);
            bool nameEnChanged = !IsEditMode || !string.Equals(originalNameEn, model.NameEn, StringComparison.OrdinalIgnoreCase);
            bool nameArChanged = !IsEditMode || !string.Equals(originalNameAr, model.NameAr, StringComparison.OrdinalIgnoreCase);

            if (codeChanged || nameEnChanged || nameArChanged)
            {
                var (codeExists, nameEnExists, nameArExists) = await LookupService.CheckLookupExistsAsync(
                    model.Code, model.NameEn, model.NameAr, IsEditMode ? LookupId : null);

                var errors = new Dictionary<string, string[]>();

                if (codeChanged && codeExists)
                {
                    errors[nameof(model.Code)] = new[] { Localizer["LookupCodeAlreadyExists"] };
                }
                if (nameEnChanged && nameEnExists)
                {
                    errors[nameof(model.NameEn)] = new[] { Localizer["LookupNameEnAlreadyExists"] };
                }
                if (nameArChanged && nameArExists)
                {
                    errors[nameof(model.NameAr)] = new[] { Localizer["LookupNameArAlreadyExists"] };
                }

                if (errors.Any())
                {
                    serverValidator.DisplayErrors(errors);
                    isSaving = false;
                    return;
                }
            }

            if (IsEditMode)
            {
                var updateRequest = new UpdateLookupRequest
                {
                    Code = model.Code,
                    NameEn = model.NameEn,
                    NameAr = model.NameAr,
                    ParentId = model.ParentId,
                    IsActive = model.IsActive
                };

                await LookupService.UpdateLookupAsync(LookupId!.Value, updateRequest);
            }
            else
            {
                var createRequest = new CreateLookupRequest
                {
                    Code = model.Code,
                    NameEn = model.NameEn,
                    NameAr = model.NameAr,
                    ParentId = model.ParentId,
                    IsActive = model.IsActive
                };

                await LookupService.CreateLookupAsync(createRequest);
            }

            Navigation.NavigateTo("/admin/lookups");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save lookup: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/admin/lookups");
    }

    private class LookupFormModel
    {
        [Required(ErrorMessage = "CodeRequired")]
        public string Code { get; set; } = string.Empty;

        [Required(ErrorMessage = "NameRequired")]
        public string NameEn { get; set; } = string.Empty;

        [Required(ErrorMessage = "NameRequired")]
        public string NameAr { get; set; } = string.Empty;

        public Guid? ParentId { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
