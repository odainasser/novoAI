@page "/admin/terminals/create"
@page "/admin/terminals/edit/{TerminalId:guid}"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.TerminalsWrite)]
@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using System.Globalization
@using Web.Components.Common
@using System.ComponentModel.DataAnnotations
@inject ITerminalService TerminalService
@inject IBranchService BranchService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer

<PageTitle>@(IsEditMode ? Localizer["EditTerminal"] : Localizer["CreateTerminal"])</PageTitle>

@if (isLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else
{
    <EditForm Model="@model" OnValidSubmit="@HandleSubmit" FormName="terminalForm">
        <LocalizedDataAnnotationsValidator />
        <ServerValidator @ref="serverValidator" />

        <!-- Sticky top bar -->
        <div class="form-sticky-toolbar sticky top-0 z-30 -mx-4 sm:-mx-6 px-4 sm:px-6 py-3 mb-6">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <button type="button" @onclick="NavigateBack" class="p-2 -ml-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors">
                        <i class="bi bi-arrow-left text-lg"></i>
                    </button>
                    <h1 class="text-xl font-semibold text-gray-900">
                        @(IsEditMode ? Localizer["EditTerminal"] : Localizer["CreateTerminal"])
                    </h1>
                    @if (IsEditMode)
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @(model.IsActive ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-600")">
                            @(model.IsActive ? Localizer["Active"] : Localizer["Inactive"])
                        </span>
                    }
                </div>
                <div class="flex items-center gap-2">
                    <button type="button" @onclick="NavigateBack" class="form-cancel-btn px-4 py-2 text-sm font-medium rounded-lg transition-colors">
                        @Localizer["Cancel"]
                    </button>
                    <button type="submit" disabled="@isSaving" class="px-4 py-2 text-sm font-medium bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-all disabled:opacity-50 inline-flex items-center gap-2">
                        @if (isSaving)
                        {
                            <Spinner Size="Spinner.SpinnerSize.Xs" Color="Spinner.SpinnerColor.White" />
                        }
                        <span>@(IsEditMode ? Localizer["Update"] : Localizer["Create"])</span>
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="mb-5 p-4 bg-red-50 border border-red-200 rounded-xl flex items-start gap-3">
                <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                <span class="text-red-800 text-sm">@errorMessage</span>
            </div>
        }

        <!-- Two-column Shopify-style layout -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

            <!-- Main column (2/3) -->
            <div class="lg:col-span-2 space-y-5">

                <!-- Card: Terminal Details -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <div class="space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label for="nameEn" class="block text-sm font-medium text-gray-700 mb-1.5">
                                    @Localizer["TerminalNameEn"] <span class="text-red-500">*</span>
                                </label>
                                <InputText @bind-Value="model.NameEn"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm"
                                    id="nameEn"
                                    placeholder="@Localizer["EnterTerminalNameEn"]" />
                                <ValidationMessage For="@(() => model.NameEn)" class="text-red-600 text-xs mt-1" />
                            </div>
                            <div>
                                <label for="nameAr" class="block text-sm font-medium text-gray-700 mb-1.5">
                                    @Localizer["TerminalNameAr"] <span class="text-red-500">*</span>
                                </label>
                                <InputText @bind-Value="model.NameAr"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm"
                                    id="nameAr" dir="rtl"
                                    placeholder="@Localizer["EnterTerminalNameAr"]" />
                                <ValidationMessage For="@(() => model.NameAr)" class="text-red-600 text-xs mt-1" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card: Network Configuration -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <h2 class="text-sm font-semibold text-gray-900 mb-3">@Localizer["NetworkConfiguration"]</h2>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label for="computerIp" class="block text-sm font-medium text-gray-700 mb-1.5">@Localizer["ComputerIp"]</label>
                            <InputText @bind-Value="model.ComputerIp"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm font-mono"
                                id="computerIp"
                                placeholder="@Localizer["EnterComputerIp"]" />
                            <ValidationMessage For="@(() => model.ComputerIp)" class="text-red-600 text-xs mt-1" />
                        </div>
                        <div>
                            <label for="printerIp" class="block text-sm font-medium text-gray-700 mb-1.5">@Localizer["PrinterIp"]</label>
                            <InputText @bind-Value="model.PrinterIp"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm font-mono"
                                id="printerIp"
                                placeholder="@Localizer["EnterPrinterIp"]" />
                            <ValidationMessage For="@(() => model.PrinterIp)" class="text-red-600 text-xs mt-1" />
                        </div>
                        <div>
                            <label for="paymentMachineIp" class="block text-sm font-medium text-gray-700 mb-1.5">@Localizer["PaymentMachineIp"]</label>
                            <InputText @bind-Value="model.PaymentMachineIp"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all text-sm font-mono"
                                id="paymentMachineIp"
                                placeholder="@Localizer["EnterPaymentMachineIp"]" />
                            <ValidationMessage For="@(() => model.PaymentMachineIp)" class="text-red-600 text-xs mt-1" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar (1/3) -->
            <div class="space-y-5">

                <!-- Card: Status -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <h2 class="text-sm font-semibold text-gray-900 mb-3">@Localizer["Status"]</h2>
                    <ToggleSwitch @bind-Value="model.IsActive" Label="@Localizer["Active"]" />
                </div>

                <!-- Card: Assignment -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <h2 class="text-sm font-semibold text-gray-900 mb-3">@Localizer["Branch"]</h2>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">
                            @Localizer["Branch"] <span class="text-red-500">*</span>
                        </label>
                        <SearchableDropdown TItem="Web.Models.Branches.BranchDto"
                                            TValue="string"
                                            Items="branches"
                                            @bind-Value="selectedBranchId"
                                            OnChanged="OnBranchChanged"
                                            DisplayText="m => isAr ? m.NameAr : m.NameEn"
                                            SearchText='m => $"{m.NameEn} {m.NameAr}"'
                                            ItemValue="m => m.Id.ToString()"
                                            Placeholder="@Localizer["SelectBranch"]"
                                            Clearable="true" />
                        <ValidationMessage For="@(() => model.BranchId)" class="text-red-600 text-xs mt-1" />
                    </div>
                </div>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public Guid? TerminalId { get; set; }

    private bool IsEditMode => TerminalId.HasValue && TerminalId.Value != Guid.Empty;

    private TerminalFormModel model = new();
    private List<Web.Models.Branches.BranchDto> branches = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private bool isAr = false;
    private ServerValidator serverValidator = null!;
    private string? originalNameEn;
    private string? originalNameAr;
    private string selectedBranchId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);

        branches = await BranchService.GetActiveBranchesAsync();

        if (IsEditMode)
        {
            await LoadTerminal();
        }

        isLoading = false;
    }

    private async Task LoadTerminal()
    {
        try
        {
            var terminal = await TerminalService.GetTerminalByIdAsync(TerminalId!.Value);
            if (terminal != null)
            {
                model = new TerminalFormModel
                {
                    NameEn = terminal.NameEn,
                    NameAr = terminal.NameAr,
                    ComputerIp = terminal.ComputerIp,
                    PrinterIp = terminal.PrinterIp,
                    PaymentMachineIp = terminal.PaymentMachineIp,
                    BranchId = terminal.BranchId,
                    IsActive = terminal.IsActive
                };
                selectedBranchId = terminal.BranchId.ToString();
                originalNameEn = terminal.NameEn;
                originalNameAr = terminal.NameAr;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToLoadTerminal"]}: {ex.Message}";
        }
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = string.Empty;
        model.BranchId = Guid.TryParse(selectedBranchId, out var parsedBranchId) ? parsedBranchId : Guid.Empty;

        try
        {
            var errors = new Dictionary<string, string[]>();

            // Branch required validation
            if (model.BranchId == Guid.Empty)
                errors.Add(nameof(model.BranchId), new[] { Localizer["BranchRequired"] });

            // Duplicate check
            bool nameEnChanged = !IsEditMode || !string.Equals(originalNameEn, model.NameEn, StringComparison.OrdinalIgnoreCase);
            bool nameArChanged = !IsEditMode || !string.Equals(originalNameAr, model.NameAr, StringComparison.OrdinalIgnoreCase);

            if (nameEnChanged || nameArChanged)
            {
                var exists = await TerminalService.CheckTerminalExistsAsync(model.NameEn, model.NameAr, IsEditMode ? TerminalId : null);
                if (exists)
                    errors.Add(nameof(model.NameEn), new[] { Localizer["TerminalAlreadyExists"] });
            }

            if (errors.Any())
            {
                serverValidator.DisplayErrors(errors);
                isSaving = false;
                return;
            }

            if (IsEditMode)
            {
                var req = new Web.Models.Terminals.UpdateTerminalRequest
                {
                    NameEn = model.NameEn,
                    NameAr = model.NameAr,
                    ComputerIp = model.ComputerIp,
                    PrinterIp = model.PrinterIp,
                    PaymentMachineIp = model.PaymentMachineIp,
                    BranchId = model.BranchId,
                    IsActive = model.IsActive
                };
                await TerminalService.UpdateTerminalAsync(TerminalId!.Value, req);
            }
            else
            {
                var req = new Web.Models.Terminals.CreateTerminalRequest
                {
                    NameEn = model.NameEn,
                    NameAr = model.NameAr,
                    ComputerIp = model.ComputerIp,
                    PrinterIp = model.PrinterIp,
                    PaymentMachineIp = model.PaymentMachineIp,
                    BranchId = model.BranchId,
                    IsActive = model.IsActive
                };
                await TerminalService.CreateTerminalAsync(req);
            }

            Navigation.NavigateTo("/admin/facilities/terminals");
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToSaveTerminal"]}: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private Task OnBranchChanged()
    {
        model.BranchId = Guid.TryParse(selectedBranchId, out var parsedBranchId) ? parsedBranchId : Guid.Empty;
        return Task.CompletedTask;
    }

    private void NavigateBack() => Navigation.NavigateTo("/admin/facilities/terminals");

    public class TerminalFormModel
    {
        [Required(ErrorMessage = "NameEnRequired")]
        [StringLength(256, ErrorMessage = "NameEnMaxLength")]
        public string NameEn { get; set; } = string.Empty;

        [Required(ErrorMessage = "NameArRequired")]
        [StringLength(256, ErrorMessage = "NameArMaxLength")]
        public string NameAr { get; set; } = string.Empty;

        [Required(ErrorMessage = "BranchRequired")]
        public Guid BranchId { get; set; }

        [StringLength(45, ErrorMessage = "MaxLengthError")]
        public string? ComputerIp { get; set; }

        [StringLength(45, ErrorMessage = "MaxLengthError")]
        public string? PrinterIp { get; set; }

        [StringLength(45, ErrorMessage = "MaxLengthError")]
        public string? PaymentMachineIp { get; set; }

        public bool IsActive { get; set; } = true;
    }
}
