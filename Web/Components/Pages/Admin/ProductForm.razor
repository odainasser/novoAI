@page "/admin/products/create"
@page "/admin/products/edit/{ProductId:guid}"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.ProductsWrite)]
@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using System.Globalization
@using System.Text.Json
@using Web.Components.Common
@using System.ComponentModel.DataAnnotations
@using Microsoft.JSInterop
@using Web.Services
@using Web.Services.Barcode
@using Web.Models.Units
@using Web.Models.Lookups
@using Web.Models.Enums
@using Web.Models.Requests
@using Web.Models.Suppliers
@inject IProductService ProductService
@inject ICategoryService CategoryService
@inject IMediaService MediaService
@inject IUnitService UnitService
@inject ILookupService LookupService
@inject IRequestService RequestService
@inject ISupplierService SupplierService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer
@inject IJSRuntime JSRuntime

<PageTitle>@(IsEditMode ? Localizer["EditProduct"] : Localizer["CreateProduct"])</PageTitle>

@if (isLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else
{
    <EditForm Model="@model" OnValidSubmit="@HandleSubmit" FormName="productForm">
        <LocalizedDataAnnotationsValidator />
        <ServerValidator @ref="serverValidator" />

        <!-- Shopify-style sticky top bar -->
        <div class="form-sticky-toolbar sticky top-0 z-30 -mx-4 sm:-mx-6 px-4 sm:px-6 py-3 mb-6">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <button type="button" @onclick="NavigateBack" class="p-2 -ml-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors">
                        <i class="bi bi-arrow-left text-lg"></i>
                    </button>
                    <h1 class="text-xl font-semibold text-gray-900">
                        @(IsEditMode ? Localizer["EditProduct"] : Localizer["CreateProduct"])
                    </h1>
                    @if (IsEditMode && model.Status != default)
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @(model.IsActive ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-600")">
                            @(model.IsActive ? Localizer["Active"] : Localizer["Inactive"])
                        </span>
                    }
                </div>
                <div class="flex items-center gap-2">
                    <button type="button" @onclick="NavigateBack" class="form-cancel-btn px-4 py-2 text-sm font-medium rounded-lg transition-colors">
                        @Localizer["Cancel"]
                    </button>
                    <button type="submit" disabled="@isSaving" class="px-4 py-2 text-sm font-medium bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-all disabled:opacity-50 inline-flex items-center gap-2">
                        @if (isSaving)
                        {
                            <Spinner Size="Spinner.SpinnerSize.Xs" Color="Spinner.SpinnerColor.White" />
                        }
                        <span>@(IsEditMode ? Localizer["Update"] : Localizer["Create"])</span>
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="mb-5 p-4 bg-red-50 border border-red-200 rounded-xl flex items-start gap-3">
                <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                <span class="text-red-800 text-sm">@errorMessage</span>
            </div>
        }

        <!-- Two-column Shopify-style layout -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

            <!-- ========== MAIN COLUMN (2/3) ========== -->
            <div class="lg:col-span-2 space-y-5">

                <!-- Card: Title & Description -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <div class="space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label for="nameEn" class="block text-sm font-medium text-gray-700 mb-1.5">
                                    @Localizer["ProductNameEn"] <span class="text-red-500">*</span>
                                </label>
                                <InputText @bind-Value="model.NameEn"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent text-sm transition-all"
                                    id="nameEn"
                                    placeholder="@Localizer["EnterProductNameEn"]" />
                                <ValidationMessage For="@(() => model.NameEn)" class="text-red-600 text-xs mt-1" />
                            </div>
                            <div>
                                <label for="nameAr" class="block text-sm font-medium text-gray-700 mb-1.5">
                                    @Localizer["ProductNameAr"] <span class="text-red-500">*</span>
                                </label>
                                <InputText @bind-Value="model.NameAr"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent text-sm transition-all"
                                    id="nameAr"
                                    dir="rtl"
                                    placeholder="@Localizer["EnterProductNameAr"]" />
                                <ValidationMessage For="@(() => model.NameAr)" class="text-red-600 text-xs mt-1" />
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label for="descriptionEn" class="block text-sm font-medium text-gray-700 mb-1.5">@Localizer["ProductDescriptionEn"]</label>
                                <InputTextArea @bind-Value="model.DescriptionEn"
                                    class="w-full min-h-[140px] px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent text-sm transition-all resize-y"
                                    id="descriptionEn"
                                    rows="6"
                                    placeholder="@Localizer["EnterDescriptionEn"]" />
                                <ValidationMessage For="@(() => model.DescriptionEn)" class="text-red-600 text-xs mt-1" />
                            </div>
                            <div>
                                <label for="descriptionAr" class="block text-sm font-medium text-gray-700 mb-1.5">@Localizer["ProductDescriptionAr"]</label>
                                <InputTextArea @bind-Value="model.DescriptionAr"
                                    class="w-full min-h-[140px] px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent text-sm transition-all resize-y"
                                    id="descriptionAr"
                                    rows="6"
                                    dir="rtl"
                                    placeholder="@Localizer["EnterDescriptionAr"]" />
                                <ValidationMessage For="@(() => model.DescriptionAr)" class="text-red-600 text-xs mt-1" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card: Media -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <h2 class="text-sm font-semibold text-gray-900 mb-3">@Localizer["ProductImages"]</h2>
                    @if (galleryImages.Any() || pendingImages.Any())
                    {
                        <div class="grid grid-cols-3 sm:grid-cols-4 gap-3 mb-4">
                            @foreach (var image in galleryImages)
                            {
                                <div class="relative group">
                                    <div class="w-full aspect-square border rounded-lg overflow-hidden bg-gray-50 @(image.IsMain ? "ring-2 ring-bf-primary" : "")">
                                        <img src="@MediaService.GetMediaUrl(image)" alt="@image.FileName" class="w-full h-full object-cover" />
                                    </div>
                                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-all rounded-lg flex items-center justify-center gap-1.5 opacity-0 group-hover:opacity-100">
                                        @if (!image.IsMain)
                                        {
                                            <button type="button" @onclick="() => SetMainImage(image.Id)" title="@Localizer["SetAsMain"]"
                                                    class="p-1.5 bg-white text-bf-primary rounded-full hover:opacity-80 transition-colors text-xs">
                                                <i class="bi bi-star"></i>
                                            </button>
                                        }
                                        <button type="button" @onclick="() => RemoveGalleryImage(image.Id)" title="@Localizer["Remove"]"
                                                class="p-1.5 bg-white text-red-600 rounded-full hover:bg-red-100 transition-colors text-xs">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                    @if (image.IsMain)
                                    {
                                        <div class="absolute top-1.5 left-1.5 bg-bf-primary text-bf-primary-contrast text-[10px] px-1.5 py-0.5 rounded-full flex items-center gap-0.5">
                                            <i class="bi bi-star-fill"></i>
                                            <span>@Localizer["Main"]</span>
                                        </div>
                                    }
                                </div>
                            }
                            @foreach (var pending in pendingImages)
                            {
                                <div class="relative group">
                                    <div class="w-full aspect-square border rounded-lg overflow-hidden bg-gray-50 @(pending.IsMain ? "ring-2 ring-bf-primary" : "")">
                                        <img src="@pending.PreviewUrl" alt="@pending.FileName" class="w-full h-full object-cover" />
                                    </div>
                                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-all rounded-lg flex items-center justify-center gap-1.5 opacity-0 group-hover:opacity-100">
                                        @if (!pending.IsMain)
                                        {
                                            <button type="button" @onclick="() => SetPendingMainImage(pending)" title="@Localizer["SetAsMain"]"
                                                    class="p-1.5 bg-white text-bf-primary rounded-full hover:opacity-80 transition-colors text-xs">
                                                <i class="bi bi-star"></i>
                                            </button>
                                        }
                                        <button type="button" @onclick="() => RemovePendingImage(pending)" title="@Localizer["Remove"]"
                                                class="p-1.5 bg-white text-red-600 rounded-full hover:bg-red-100 transition-colors text-xs">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                    @if (pending.IsMain)
                                    {
                                        <div class="absolute top-1.5 left-1.5 bg-bf-primary text-bf-primary-contrast text-[10px] px-1.5 py-0.5 rounded-full flex items-center gap-0.5">
                                            <i class="bi bi-star-fill"></i>
                                            <span>@Localizer["Main"]</span>
                                        </div>
                                    }
                                    <div class="absolute top-1.5 right-1.5 bg-yellow-500 text-white text-[10px] px-1.5 py-0.5 rounded-full">
                                        @Localizer["Pending"]
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="border-2 border-dashed border-gray-200 rounded-lg p-8 text-center text-gray-400 mb-3">
                            <i class="bi bi-images text-3xl mb-2 block"></i>
                            <p class="text-sm">@Localizer["NoImagesUploaded"]</p>
                        </div>
                    }
                    <div>
                        <InputFile OnChange="OnImagesSelected" accept="image/*" multiple class="hidden" id="productImagesInput" />
                        <label for="productImagesInput" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-bf-primary border border-bf-primary rounded-lg hover:bg-bf-primary hover:text-bf-primary-contrast transition-colors cursor-pointer">
                            <i class="bi bi-plus-lg"></i>
                            <span>@Localizer["AddImages"]</span>
                        </label>
                    </div>
                </div>

                <!-- Card: Units (Edit Mode Only) -->
                @if (IsEditMode)
                {
                    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-sm font-semibold text-gray-900 flex items-center gap-2">
                                <i class="bi bi-upc-scan text-purple-600"></i>
                                @Localizer["ProductUnits"]
                            </h2>
                            <button type="button" @onclick="ShowAddUnitForm"
                                    class="px-3 py-1.5 text-sm bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-colors font-medium inline-flex items-center gap-1.5">
                                <i class="bi bi-plus-lg text-xs"></i>
                                @Localizer["AddUnit"]
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(unitErrorMessage))
                        {
                            <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg flex items-start gap-2">
                                <i class="bi bi-exclamation-triangle-fill text-red-600 mt-0.5"></i>
                                <span class="text-red-800 text-sm">@unitErrorMessage</span>
                            </div>
                        }

                        <!-- Units Table -->
                        @if (isLoadingUnits)
                        {
                            <Spinner Size="Spinner.SpinnerSize.Md" Centered="true" />
                        }
                        else if (productUnits.Any())
                        {
                            <div class="overflow-x-auto -mx-5">
                                <table class="min-w-full divide-y divide-gray-200 text-sm">
                                    <thead class="bg-gray-50">
                                        <tr>
                                            <th class="px-4 py-2.5 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["UnitOfMeasure"]</th>
                                            <th class="px-4 py-2.5 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["UnitType"]</th>
                                            <th class="px-4 py-2.5 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["BaseUnits"]</th>
                                            <th class="px-4 py-2.5 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["SellingPrice"]</th>
                                            <th class="px-4 py-2.5 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Cost"]</th>
                                            <th class="px-4 py-2.5 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                                            <th class="px-4 py-2.5 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                                        </tr>
                                    </thead>
                                    <tbody class="bg-white divide-y divide-gray-100">
                                        @foreach (var unit in productUnits)
                                        {
                                            <tr class="hover:bg-gray-50/50 transition-colors">
                                                <td class="px-4 py-2.5 whitespace-nowrap">
                                                    <div class="flex items-center gap-2">
                                                        <div class="flex-shrink-0 h-7 w-7 bg-purple-100 rounded flex items-center justify-center">
                                                            <i class="bi bi-upc-scan text-purple-600 text-xs"></i>
                                                        </div>
                                                        <div>
                                                            <span class="font-medium text-gray-900 text-sm">@(isAr ? unit.UnitOfMeasureNameAr : unit.UnitOfMeasureNameEn)</span>
                                                            @if (unitIdsNeedingAction.Contains(unit.Id))
                                                            {
                                                                <div class="mt-1">
                                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-amber-100 text-amber-800 border border-amber-200">
                                                                        <i class="bi bi-exclamation-circle-fill me-1"></i>@Localizer["NeedsAction"]
                                                                    </span>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="px-4 py-2.5 whitespace-nowrap">
                                                    <div class="flex flex-wrap gap-1">
                                                        @foreach (var ut in unit.UnitTypes)
                                                        {
                                                            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-700">
                                                                @(isAr ? ut.NameAr : ut.NameEn)
                                                            </span>
                                                        }
                                                    </div>
                                                </td>
                                                <td class="px-4 py-2.5 whitespace-nowrap text-gray-600 text-sm">@unit.Quantity</td>
                                                <td class="px-4 py-2.5 whitespace-nowrap">
                                                    @if (unit.SellingPrice > 0)
                                                    {
                                                        <span class="font-medium text-gray-900 text-sm">@unit.SellingPrice.ToString("N2")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-gray-400">-</span>
                                                    }
                                                </td>
                                                <td class="px-4 py-2.5 whitespace-nowrap">
                                                    @if (unit.UnitTypes.Any(ut => ut.Code == "UT_LOGISTICS"))
                                                    {
                                                        @if (unit.Cost > 0)
                                                        {
                                                            <span class="font-medium text-gray-900 text-sm">@unit.Cost.ToString("N2")</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-gray-400">-</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="text-gray-400">-</span>
                                                    }
                                                </td>
                                                <td class="px-4 py-2.5 whitespace-nowrap">
                                                    @if (unit.IsActive)
                                                    {
                                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                            <i class="bi bi-check-circle-fill me-1"></i> @Localizer["Active"]
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                                            <i class="bi bi-x-circle-fill me-1"></i> @Localizer["Inactive"]
                                                        </span>
                                                    }
                                                </td>
                                                <td class="px-4 py-2.5 whitespace-nowrap text-end">
                                                    @if (unit.Status == ItemStatus.Active)
                                                    {
                                                        <AuthorizeView Policy="Permission:units.price">
                                                            <Authorized Context="priceAuth">
                                                                @if (unit.UnitTypes.Any(ut => ut.Code == "UT_SELLING"))
                                                                {
                                                                    <button type="button" @onclick="() => OpenSellingDetailsModal(unit)" class="text-green-600 hover:text-green-800 me-2" title="@Localizer["SetSellingDetails"]">
                                                                        <i class="bi bi-currency-dollar"></i>
                                                                    </button>
                                                                }
                                                            </Authorized>
                                                            <NotAuthorized Context="priceNoAuth">
                                                                @if (unit.UnitTypes.Any(ut => ut.Code == "UT_SELLING"))
                                                                {
                                                                    <button type="button" disabled class="text-gray-300 me-2 cursor-not-allowed"><i class="bi bi-currency-dollar"></i></button>
                                                                }
                                                            </NotAuthorized>
                                                        </AuthorizeView>
                                                        <AuthorizeView Policy="Permission:units.logistics">
                                                            <Authorized Context="logAuth">
                                                                @if (unit.UnitTypes.Any(ut => ut.Code == "UT_LOGISTICS"))
                                                                {
                                                                    <button type="button" @onclick="() => OpenLogisticsDetailsModal(unit)" class="text-cyan-600 hover:text-cyan-800 me-2" title="@Localizer["SetLogisticsDetails"]">
                                                                        <i class="bi bi-truck"></i>
                                                                    </button>
                                                                }
                                                            </Authorized>
                                                            <NotAuthorized Context="logNoAuth">
                                                                @if (unit.UnitTypes.Any(ut => ut.Code == "UT_LOGISTICS"))
                                                                {
                                                                    <button type="button" disabled class="text-gray-300 me-2 cursor-not-allowed"><i class="bi bi-truck"></i></button>
                                                                }
                                                            </NotAuthorized>
                                                        </AuthorizeView>
                                                        <AuthorizeView Policy="Permission:requests.write" Context="reqAuth">
                                                            <Authorized Context="reqAuth">
                                                                @if (unit.UnitTypes.Any(ut => ut.Code == "UT_SELLING"))
                                                                {
                                                                    <button type="button" @onclick="() => OpenChangePriceModal(unit)" class="text-amber-600 hover:text-amber-800 me-2" title="@Localizer["ChangePriceRequest"]">
                                                                        <i class="bi bi-tag"></i>
                                                                    </button>
                                                                }
                                                            </Authorized>
                                                            <NotAuthorized Context="reqNoAuth">
                                                                @if (unit.UnitTypes.Any(ut => ut.Code == "UT_SELLING"))
                                                                {
                                                                    <button type="button" disabled class="text-gray-300 me-2 cursor-not-allowed"><i class="bi bi-tag"></i></button>
                                                                }
                                                            </NotAuthorized>
                                                        </AuthorizeView>
                                                        <AuthorizeView Policy="Permission:requests.write" Context="logReqAuth">
                                                            <Authorized Context="logReqAuth">
                                                                @if (unit.UnitTypes.Any(ut => ut.Code == "UT_LOGISTICS"))
                                                                {
                                                                    <button type="button" @onclick="() => OpenLogisticsRequestModal(unit)" class="text-teal-600 hover:text-teal-800 me-2" title="@Localizer["SetLogisticsDetailsRequest"]">
                                                                        <i class="bi bi-box-seam"></i>
                                                                    </button>
                                                                }
                                                            </Authorized>
                                                            <NotAuthorized Context="logReqNoAuth">
                                                                @if (unit.UnitTypes.Any(ut => ut.Code == "UT_LOGISTICS"))
                                                                {
                                                                    <button type="button" disabled class="text-gray-300 me-2 cursor-not-allowed"><i class="bi bi-box-seam"></i></button>
                                                                }
                                                            </NotAuthorized>
                                                        </AuthorizeView>
                                                    }
                                                    <AuthorizeView Policy="Permission:units.write">
                                                        <Authorized Context="writeAuth">
                                                            @if (unit.Status != ItemStatus.Rejected)
                                                            {
                                                                <button type="button" @onclick="() => EditUnit(unit)" class="text-purple-600 hover:text-purple-900 me-2" title="@Localizer["Edit"]">
                                                                    <i class="bi bi-pencil-square"></i>
                                                                </button>
                                                            }
                                                            else
                                                            {
                                                                <button type="button" disabled class="text-gray-400 me-2 cursor-not-allowed"><i class="bi bi-pencil-square"></i></button>
                                                            }
                                                        </Authorized>
                                                        <NotAuthorized Context="writeNoAuth">
                                                            <button type="button" disabled class="text-gray-400 me-2 cursor-not-allowed"><i class="bi bi-pencil-square"></i></button>
                                                        </NotAuthorized>
                                                    </AuthorizeView>
                                                    <AuthorizeView Policy="Permission:units.delete">
                                                        <Authorized Context="deleteAuth">
                                                            <button type="button" @onclick="() => ConfirmDeleteUnit(unit.Id)" class="text-red-600 hover:text-red-900" title="@Localizer["Delete"]">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </Authorized>
                                                        <NotAuthorized Context="deleteNoAuth">
                                                            <button type="button" disabled class="text-gray-400 cursor-not-allowed"><i class="bi bi-trash"></i></button>
                                                        </NotAuthorized>
                                                    </AuthorizeView>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-8 text-gray-400">
                                <i class="bi bi-upc-scan text-3xl mb-2 block"></i>
                                <p class="text-sm">@Localizer["NoUnitsFound"]</p>
                            </div>
                        }
                    </div>
                }

            </div><!-- end main column -->

            <!-- ========== SIDEBAR (1/3) ========== -->
            <div class="space-y-5">

                <!-- Card: Status -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <h2 class="text-sm font-semibold text-gray-900 mb-3">@Localizer["Status"]</h2>
                    <ToggleSwitch @bind-Value="model.IsActive" Label="@Localizer["Active"]" />
                </div>

                <!-- Card: Product Organization -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <h2 class="text-sm font-semibold text-gray-900 mb-3">@Localizer["ProductOrganization"]</h2>
                    <div class="space-y-4">
                        <div>
                            <SearchableDropdown TItem="CategoryDto" TValue="Guid?"
                                               Items="categories"
                                               @bind-Value="model.CategoryId"
                                               DisplayText="@(c => isAr ? c.NameAr : c.NameEn)"
                                               ItemValue="@(c => (Guid?)c.Id)"
                                               Label="@Localizer["Category"]"
                                               Placeholder="@Localizer["SelectCategory"]"
                                               Required="true" />
                            <ValidationMessage For="@(() => model.CategoryId)" class="text-red-600 text-xs mt-1" />
                        </div>
                    </div>
                </div>

            </div><!-- end sidebar -->

        </div><!-- end two-column grid -->

        <!-- Modals (outside the grid) -->
        @if (IsEditMode)
        {
            <ConfirmModal IsVisible="@showDeleteUnitConfirm"
                          Title='@Localizer["DeleteUnit"]'
                          Message='@Localizer["ConfirmDeleteUnit"]'
                          ConfirmText='@Localizer["Delete"]'
                          CancelText='@Localizer["Cancel"]'
                          IsDanger="true"
                          OnConfirm="DeleteUnit"
                          OnCancel="@(() => showDeleteUnitConfirm = false)" />

            <ProductUnitModal IsVisible="@showUnitForm"
                              EditingUnit="@editingUnit"
                              ProductId="@ProductId!.Value"
                              UnitsOfMeasure="unitsOfMeasure"
                              UnitTypes="unitTypes"
                              OnCancel="CancelUnitForm"
                              OnSaved="OnUnitSaved" />

            <!-- Set Selling Details Modal -->
            @if (showSellingModal)
            {
                <div class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" @onclick="CloseSellingModal">
                    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md" @onclick:stopPropagation>
                        <div class="p-5 border-b border-gray-200">
                            <h3 class="text-base font-semibold text-gray-900 flex items-center gap-2">
