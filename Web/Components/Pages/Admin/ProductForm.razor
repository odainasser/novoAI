    private string logReqReason = string.Empty;
    private int logReqLowStockThreshold = 10;
    private class PendingImage
    {
        public Guid TempId { get; set; } = Guid.NewGuid();
        public string FileName { get; set; } = string.Empty;
        public string ContentType { get; set; } = string.Empty;
        public byte[] FileData { get; set; } = Array.Empty<byte>();
        public string PreviewUrl { get; set; } = string.Empty;
        public bool IsMain { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        
        if (IsEditMode)
        {
            // Phase 1: Load essential data to show the form quickly
            await Task.WhenAll(
                LoadCategories(),
                LoadProduct()
            );
            isLoading = false;

            // Phase 2: Load secondary data independently so slower calls do not block
            // gallery/units from appearing.
            StartBackgroundLoad(LoadGalleryImages);
            StartBackgroundLoad(LoadProductUnits);
            StartBackgroundLoad(LoadUnitsOfMeasure);
            StartBackgroundLoad(LoadUnitTypes);
        }
        else
        {
            await LoadCategories();
            isLoading = false;
        }
    }

    private void StartBackgroundLoad(Func<Task> loader)
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                await loader();
            }
            catch
            {
                // Loader methods already handle and report their own failures.
            }

            StateHasChanged();
        });
    }

