    // --- Logistics Details Request ---
    private async Task OpenLogisticsRequestModal(UnitDto unit)
    {
        logReqUnitId = unit.Id;
        logReqUomNameEn = unit.UnitOfMeasureNameEn ?? string.Empty;
        logReqUomNameAr = unit.UnitOfMeasureNameAr ?? string.Empty;
        logReqNewCost = unit.Cost;
        logReqSuppliers = unit.Suppliers.Select(s => new UnitSupplierItem { SupplierId = s.SupplierId, Barcode = s.Barcode }).ToList();
        logReqBarcodeReadOnlyRows = BuildReadOnlyBarcodeRows(logReqSuppliers);
        logReqSupplierBarcodesSaved = unit.Suppliers.Where(s => !string.IsNullOrWhiteSpace(s.Barcode)).ToDictionary(s => s.SupplierId, s => s.Barcode!);
        logReqLowStockThreshold = unit.LowStockThreshold;
        logReqReason = string.Empty;
        logReqError = string.Empty;
        logReqSubmitting = false;
        try { var r = await SupplierService.GetAllSuppliersAsync(1, 1000, isActive: true); logReqAvailableSuppliers = r.Items.ToList(); }
        catch { logReqAvailableSuppliers = new(); }

        try
        {
            var pending = await RequestService.GetPendingSetLogisticsDetailsRequestAsync(unit.Id);
            if (pending != null)
            {
                logReqReason = pending.Note ?? string.Empty;
            }
        }
        catch { /* no pending request */ }

        showLogisticsRequestModal = true;
    }
    private void CloseLogisticsRequestModal() => showLogisticsRequestModal = false;
    private void AddLogReqSupplierRow() => logReqSuppliers.Add(new UnitSupplierItem());
    private void RemoveLogReqSupplierRow(int index)
    {
        logReqSuppliers.RemoveAt(index);
        ReindexReadOnlyRows(logReqBarcodeReadOnlyRows, index);
    }
    private async Task SubmitLogisticsRequest()
    {
        logReqError = string.Empty;
        if (logReqNewCost < 0) { logReqError = Localizer["CostGreaterThanZero"]; return; }
        foreach (var item in logReqSuppliers)
        {
            if (item.SupplierId == Guid.Empty) { logReqError = Localizer["SelectSupplierForAllRows"]; return; }
            if (string.IsNullOrWhiteSpace(item.Barcode)) { logReqError = Localizer["EnterBarcodeForAllRows"]; return; }
        }
        if (logReqSuppliers.GroupBy(x => x.SupplierId).Any(g => g.Count() > 1)) { logReqError = Localizer["DuplicateSupplierNotAllowed"]; return; }
        logReqSubmitting = true;
        try
        {
            await RequestService.CreateSetLogisticsDetailsRequestAsync(new CreateSetLogisticsDetailsRequest
            {
                UnitId = logReqUnitId,
                NewCost = logReqNewCost,
                Suppliers = logReqSuppliers,
                LowStockThreshold = logReqLowStockThreshold,
                Note = string.IsNullOrWhiteSpace(logReqReason) ? null : logReqReason
            });
            showLogisticsRequestModal = false;
        }
        catch (Exception ex) { logReqError = ex.Message; }
        finally { logReqSubmitting = false; }
    }

    private static List<MediaDto> GetOldImagesFromRequest(RequestDto? req)
    {
        if (string.IsNullOrEmpty(req?.OldDataJson))
            return new List<MediaDto>();

        try
        {
            var data = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(req.OldDataJson);
            if (!data.TryGetProperty("Images", out var images) || images.ValueKind != System.Text.Json.JsonValueKind.Array)
                return new List<MediaDto>();

            var result = new List<MediaDto>();
            foreach (var item in images.EnumerateArray())
            {
                var media = new MediaDto
                {
                    Id = item.TryGetProperty("Id", out var idEl) && idEl.ValueKind != System.Text.Json.JsonValueKind.Null ? idEl.GetGuid() : Guid.Empty,
                    FileName = item.TryGetProperty("FileName", out var fileNameEl) ? fileNameEl.GetString() ?? string.Empty : string.Empty,
                    Url = item.TryGetProperty("Path", out var pathEl) ? pathEl.GetString() ?? string.Empty : string.Empty,
                    IsMain = item.TryGetProperty("IsMain", out var isMainEl) && isMainEl.ValueKind == System.Text.Json.JsonValueKind.True
                };
                result.Add(media);
            }

            return result;
        }
        catch
        {
            return new List<MediaDto>();
        }
    }

