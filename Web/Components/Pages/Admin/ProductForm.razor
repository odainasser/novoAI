    // Logistics Details Modal
    private bool showLogisticsModal = false;
    private bool logisticsSubmitting = false;
    private string logisticsError = string.Empty;
    private Guid logisticsUnitId;
    private string logisticsUomNameEn = string.Empty, logisticsUomNameAr = string.Empty;
    private decimal logisticsCurrentCost;
    private decimal logisticsNewCost;
    private List<UnitSupplierItem> logisticsSuppliers = new();
    private List<SupplierDto> logisticsAvailableSuppliers = new();
    private HashSet<int> logisticsBarcodeReadOnlyRows = new();
    private Dictionary<Guid, string> logisticsSupplierBarcodesSaved = new();
    private int logisticsLowStockThreshold = 10;

    // Change Price Request Modal
    private bool showChangePriceModal = false;
    private bool changePriceSubmitting = false;
