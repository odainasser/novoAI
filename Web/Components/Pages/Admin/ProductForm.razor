    private static HashSet<int> BuildReadOnlyBarcodeRows(List<UnitSupplierItem> suppliers)
    {
        var readOnlyRows = new HashSet<int>();
        for (var i = 0; i < suppliers.Count; i++)
        {
            if (!string.IsNullOrWhiteSpace(suppliers[i].Barcode))
                readOnlyRows.Add(i);
        }

        return readOnlyRows;
    }

    private static void ReindexReadOnlyRows(HashSet<int> readOnlyRows, int removedIndex)
    {
        if (readOnlyRows.Count == 0)
            return;

        var updated = readOnlyRows
            .Where(i => i != removedIndex)
            .Select(i => i > removedIndex ? i - 1 : i)
            .ToHashSet();

        readOnlyRows.Clear();
        foreach (var i in updated)
            readOnlyRows.Add(i);
    }

    private HashSet<string> GetExistingBarcodes()
    {
        var existing = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        foreach (var unit in productUnits)
        {
            if (!string.IsNullOrWhiteSpace(unit.SellingBarcode))
                existing.Add(unit.SellingBarcode.Trim());

            if (!string.IsNullOrWhiteSpace(unit.Barcode))
                existing.Add(unit.Barcode.Trim());
        }

        return existing;
    }

    private static string GenerateRandomBarcodeValue(HashSet<string> existing)
    {
        const string chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
        Span<char> buffer = stackalloc char[12];

        for (var attempt = 0; attempt < 25; attempt++)
        {
            for (var i = 0; i < buffer.Length; i++)
            {
                buffer[i] = chars[Random.Shared.Next(chars.Length)];
            }

            var candidate = new string(buffer);
            if (!existing.Contains(candidate))
                return candidate;
        }

        // Very unlikely fallback path
        return $"SB{DateTime.UtcNow:yyMMddHHmmss}";
    }

