    private async Task RemoveGalleryImage(Guid mediaId)
    {
        try
        {
            // All gallery images are now product images only (not pending request images)
            // Mark them for removal in the update request
            removedGalleryImageIds.Add(mediaId);
            if (selectedExistingMainImageId == mediaId)
                selectedExistingMainImageId = null;

            galleryImages.RemoveAll(m => m.Id == mediaId);

            if (!galleryImages.Any(image => image.IsMain))
            {
                var nextImage = galleryImages.FirstOrDefault();
                if (nextImage != null)
                {
                    selectedExistingMainImageId = nextImage.Id;
                    await InvokeAsync(StateHasChanged);
                }
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to delete image: {ex.Message}";
        }
    }

    private async Task SetMainImage(Guid mediaId)
    {
        if (!IsEditMode || !ProductId.HasValue) return;

        try
        {
            // All gallery images are product images, track main image selection
            selectedExistingMainImageId = mediaId;
            
            // Update local state - clear main from all gallery and pending images
            foreach (var image in galleryImages)
