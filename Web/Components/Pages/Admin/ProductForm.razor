    private async Task LoadUnitPendingRequestFlagsAsync()
    {
        unitIdsNeedingAction.Clear();
        if (!productUnits.Any()) return;

        var visibleUnitIds = productUnits.Select(unit => unit.Id).ToHashSet();
        var pendingRequests = new List<RequestDto>();

        try
        {
            var pending = await RequestService.GetAllRequestsAsync(1, 1000, null, null, RequestStatus.Pending);
            pendingRequests = pending.Items;
        }
        catch
        {
            try
            {
                var pendingMine = await RequestService.GetMyRequestsAsync(1, 1000, null, null, RequestStatus.Pending);
                pendingRequests = pendingMine.Items;
            }
            catch
            {
                return;
            }
        }

        foreach (var req in pendingRequests)
        {
            if (req.UnitId.HasValue && visibleUnitIds.Contains(req.UnitId.Value))
            {
                unitIdsNeedingAction.Add(req.UnitId.Value);
                continue;
            }

            var unitId = ExtractEntityIdFromRequest(req.NewDataJson, req.OldDataJson, "UnitId", "unitId", "Id", "id");
            if (unitId.HasValue && visibleUnitIds.Contains(unitId.Value))
                unitIdsNeedingAction.Add(unitId.Value);
        }
    }

    private static Guid? ExtractEntityIdFromRequest(string? newDataJson, string? oldDataJson, params string[] keys)
    {
        return ExtractGuid(newDataJson, keys) ?? ExtractGuid(oldDataJson, keys);
    }

    private static Guid? ExtractGuid(string? json, params string[] keys)
    {
        if (string.IsNullOrWhiteSpace(json))
            return null;

        try
        {
            using var doc = JsonDocument.Parse(json);
            return ExtractGuidFromElement(doc.RootElement, keys);
        }
        catch
        {
            return null;
        }
    }

    private static Guid? ExtractGuidFromElement(JsonElement element, params string[] keys)
    {
        if (element.ValueKind == JsonValueKind.Object)
        {
            foreach (var prop in element.EnumerateObject())
            {
                if (keys.Contains(prop.Name, StringComparer.OrdinalIgnoreCase)
                    && prop.Value.ValueKind == JsonValueKind.String
                    && Guid.TryParse(prop.Value.GetString(), out var parsed))
                {
                    return parsed;
                }

                var nested = ExtractGuidFromElement(prop.Value, keys);
                if (nested.HasValue)
                    return nested;
            }
        }
        else if (element.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in element.EnumerateArray())
            {
                var nested = ExtractGuidFromElement(item, keys);
                if (nested.HasValue)
                    return nested;
            }
        }

        return null;
    }

