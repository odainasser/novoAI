    private void ApplyPendingProductRequest(RequestDto pendingRequest)
    {
        // DO NOT apply pending changes to the form model
        // The form should always show the CURRENT product state
        // Pending changes are only visible in the request detail view (Requests tab)
        // This way, the user always sees what they're currently editing, not what's pending approval
    }

    private async Task LoadGalleryImages()
    {
        try
        {
            requestGalleryImageIds.Clear();

            // If there's a pending update request, show the OLD gallery (from snapshot in OldDataJson)
            // This shows what the images were BEFORE the pending changes
            if (pendingProductRequestId.HasValue && !string.IsNullOrEmpty(pendingProductRequestNameForTracking?.OldDataJson))
            {
                // Load old images from the pending request's OldDataJson snapshot
                galleryImages = GetOldImagesFromRequest(pendingProductRequestNameForTracking);
            }
            else
            {
                // No pending request: show current product media
                var productMedia = (await MediaService.GetMediaForEntityAsync(ProductId!.Value, "Product", "image"))
                    .Where(media => !removedGalleryImageIds.Contains(media.Id))
                    .ToList();

                galleryImages = productMedia;
            }

            // Normalize to a single main image in UI, even if source data has multiple mains.
            NormalizeSingleMain(galleryImages, selectedExistingMainImageId);
            selectedExistingMainImageId = galleryImages.FirstOrDefault(img => img.IsMain)?.Id;
        }
        catch
        {
            galleryImages = new List<MediaDto>();
        }
    }

    private async Task OnImagesSelected(InputFileChangeEventArgs e)
    {
        try
        {
            long maxFileSize = 10 * 1024 * 1024; // 10MB max per file
            var files = e.GetMultipleFiles(10).ToList(); // Max 10 files at once

            foreach (var file in files)
            {
                try
                {
                    // Read file data into memory (for both preview and upload)
                    using var memoryStream = new MemoryStream();
                    await using var stream = file.OpenReadStream(maxFileSize);
                    await stream.CopyToAsync(memoryStream);
                    var buffer = memoryStream.ToArray();
                    
                    var base64 = Convert.ToBase64String(buffer);
                    var previewUrl = $"data:{file.ContentType};base64,{base64}";

                    pendingImages.Add(new PendingImage
                    {
                        FileName = file.Name,
                        ContentType = file.ContentType,
                        FileData = buffer,
                        PreviewUrl = previewUrl
                    });
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Failed to process image {file.Name}: {ex.Message}");
                }
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to process images: {ex.Message}";
        }
    }

    private void RemovePendingImage(PendingImage pending)
