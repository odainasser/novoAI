    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            ProductDto result;
            
            if (IsEditMode)
            {
                var updateRequest = new UpdateProductRequest
                {
                    NameEn = model.NameEn,
                    NameAr = model.NameAr,
                    DescriptionEn = model.DescriptionEn,
                    DescriptionAr = model.DescriptionAr,
                    Code = model.Code,
                    CategoryId = model.CategoryId,
                    Status = model.IsActive ? Web.Models.Enums.ItemStatus.Active : Web.Models.Enums.ItemStatus.Inactive,
                    RemovedImageIds = removedGalleryImageIds.ToList(),
                    MainImageId = selectedExistingMainImageId
                };
                
                result = await ProductService.UpdateProductAsync(ProductId!.Value, updateRequest);

                // A pending request ID is required only when we have new images to upload
                // to the Request entity. If no request exists yet, create one on-demand.
                if (pendingImages.Any())
                {
                    await EnsurePendingProductRequestAsync(updateRequest);
                }
            }
            else
            {
                model.Code = await GenerateUniqueCodeAsync();

                var createRequest = new CreateProductRequest
                {
                    NameEn = model.NameEn,
                    NameAr = model.NameAr,
                    DescriptionEn = model.DescriptionEn,
                    DescriptionAr = model.DescriptionAr,
                    Code = model.Code,
                    CategoryId = model.CategoryId ?? Guid.Empty,
                    Status = model.IsActive ? Web.Models.Enums.ItemStatus.Active : Web.Models.Enums.ItemStatus.Inactive
                };
                
                result = await ProductService.CreateProductAsync(createRequest);
            }

            // Upload pending images
            if (pendingImages.Any())
            {
                var targetEntityId = result.Id;
                var targetEntityType = "Product";

                if (IsEditMode)
                {
                    if (!pendingProductRequestId.HasValue)
                        throw new InvalidOperationException("Pending product update request was not created.");

                    targetEntityId = pendingProductRequestId.Value;
                    targetEntityType = "Request";
                }

                await UploadPendingImages(targetEntityId, targetEntityType);
            }

            Navigation.NavigateTo("/admin/catalog/products");
        }
        catch (ServerValidationException ex)
        {
            serverValidator.DisplayErrors(ex.Errors);
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToSaveProduct"]}: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task<string> GenerateUniqueCodeAsync()
    {
        const int maxAttempts = 20;

        for (var i = 0; i < maxAttempts; i++)
        {
            var candidate = $"PRD-{DateTime.UtcNow:yyyyMMddHHmmss}-{Random.Shared.Next(100, 999)}";
            var exists = await ProductService.CheckCodeExistsAsync(candidate);
            if (!exists)
            {
                return candidate;
            }
        }

        throw new InvalidOperationException("Unable to generate a unique product code.");
    }

    private async Task UploadPendingImages(Guid entityId, string entityType)
    {
        if (!pendingImages.Any()) return;

        try
        {
            bool hasExistingMain = galleryImages.Any(g => g.IsMain);
            Guid? uploadedMainId = null;

            foreach (var pending in pendingImages.ToList())
            {
                using var uploadStream = new MemoryStream(pending.FileData);
                var uploaded = await MediaService.UploadMediaAsync(entityId, entityType, uploadStream, pending.FileName, pending.ContentType, "image");
                
                // Track the main image to set it after all uploads
                if (pending.IsMain)
                {
                    uploadedMainId = uploaded.Id;
                }
            }

            // Set main image: either user-selected pending main, or first image if no main exists
            if (uploadedMainId.HasValue)
            {
                await MediaService.SetMainMediaAsync(uploadedMainId.Value, entityId, entityType, "image");
            }
            else if (!hasExistingMain && !selectedExistingMainImageId.HasValue)
            {
                // If no main was selected and no existing main, set first uploaded as main
                var allMedia = await MediaService.GetMediaForEntityAsync(entityId, entityType, "image");
                var first = allMedia.FirstOrDefault();
                if (first != null && !allMedia.Any(m => m.IsMain))
                {
                    await MediaService.SetMainMediaAsync(first.Id, entityId, entityType, "image");
                }
            }

            pendingImages.Clear();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to upload images: {ex.Message}");
            errorMessage = $"Failed to upload images: {ex.Message}";
        }
    }

    private async Task EnsurePendingProductRequestAsync(UpdateProductRequest? seedRequest = null)
    {
        if (!ProductId.HasValue)
            return;

        var pendingRequest = await RequestService.GetPendingProductUpdateRequestAsync(ProductId.Value);

        if (pendingRequest == null && seedRequest != null)
        {
            // Force-create a pending update request for image uploads when the original update
            // call produced no request (e.g., image-only add with no field diffs).
            var fallbackRequest = new UpdateProductRequest
            {
                NameEn = seedRequest.NameEn,
                NameAr = seedRequest.NameAr,
                DescriptionEn = seedRequest.DescriptionEn,
                DescriptionAr = seedRequest.DescriptionAr,
                Code = seedRequest.Code,
                CategoryId = seedRequest.CategoryId,
                Status = seedRequest.Status,
                RemovedImageIds = seedRequest.RemovedImageIds?.ToList() ?? new List<Guid>(),
                MainImageId = seedRequest.MainImageId
                    ?? galleryImages.FirstOrDefault(g => g.IsMain)?.Id
                    ?? galleryImages.FirstOrDefault()?.Id
                    ?? Guid.Empty
            };

            await ProductService.UpdateProductAsync(ProductId.Value, fallbackRequest);
            pendingRequest = await RequestService.GetPendingProductUpdateRequestAsync(ProductId.Value);
        }

        if (pendingRequest == null)
            throw new InvalidOperationException("Pending product update request was not found.");

        pendingProductRequestId = pendingRequest.Id;
        pendingProductRequestNameForTracking = pendingRequest;
    }

    private static HashSet<Guid> ReadGuidSet(System.Text.Json.JsonElement data, string propertyName)
    {
        if (!data.TryGetProperty(propertyName, out var property) || property.ValueKind != System.Text.Json.JsonValueKind.Array)
            return new HashSet<Guid>();

        var values = new HashSet<Guid>();
        foreach (var item in property.EnumerateArray())
        {
            if (item.ValueKind == System.Text.Json.JsonValueKind.String && Guid.TryParse(item.GetString(), out var parsed))
                values.Add(parsed);
        }

        return values;
    }

    private static void NormalizeSingleMain(List<MediaDto> images, Guid? preferredMainId = null)
    {
        if (images.Count == 0)
            return;

        Guid mainId;
        if (preferredMainId.HasValue && images.Any(i => i.Id == preferredMainId.Value))
        {
            mainId = preferredMainId.Value;
        }
        else
        {
            mainId = images.FirstOrDefault(i => i.IsMain)?.Id ?? images[0].Id;
        }

        foreach (var image in images)
            image.IsMain = image.Id == mainId;
    }

