    private async Task SubmitLogisticsDetails()
    {
        logisticsError = string.Empty;
        if (logisticsNewCost < 0) { logisticsError = Localizer["CostGreaterThanZero"]; return; }
        foreach (var item in logisticsSuppliers)
        {
            if (item.SupplierId == Guid.Empty) { logisticsError = Localizer["SelectSupplierForAllRows"]; return; }
            if (string.IsNullOrWhiteSpace(item.Barcode)) { logisticsError = Localizer["EnterBarcodeForAllRows"]; return; }
        }
        if (logisticsSuppliers.GroupBy(x => x.SupplierId).Any(g => g.Count() > 1)) { logisticsError = Localizer["DuplicateSupplierNotAllowed"]; return; }
        logisticsSubmitting = true;
        try
        {
            await RequestService.CreateSetLogisticsDetailsRequestAsync(new CreateSetLogisticsDetailsRequest
            {
                UnitId = logisticsUnitId,
                NewCost = logisticsNewCost,
                Suppliers = logisticsSuppliers,
                LowStockThreshold = logisticsLowStockThreshold
            });
            showLogisticsModal = false;
            await LoadProductUnits();
        }
        catch (Exception ex) { logisticsError = ex.Message; }
        finally { logisticsSubmitting = false; }
    }

