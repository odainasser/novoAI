@page "/forgot-password"
@layout PublicLayout
@using Web.Components.Common
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer

<PageTitle>@Localizer["ForgotPasswordTitle"]</PageTitle>

<div class="relative min-h-screen bg-gray-50 flex items-center justify-center p-4 overflow-hidden">

    <div class="relative w-full max-w-5xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 bg-white rounded-2xl shadow-xl overflow-hidden min-h-[600px]">

            <!-- Left: Branding Panel -->
            <div class="hidden lg:flex flex-col items-center justify-center bg-gradient-to-br from-purple-700 via-purple-800 to-purple-900 text-white p-12 relative overflow-hidden">
                <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
                <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>

                <div class="relative z-10 text-center space-y-8">
                    <div class="inline-block p-5 rounded-2xl bg-white/10 backdrop-blur-sm">
                        <img src="/logo.png" alt="Logo" class="h-16 w-auto" />
                    </div>
                    <div>
                        <p class="text-purple-200 text-sm">Retail Management System</p>
                    </div>
                    <div class="space-y-3 text-left max-w-xs mx-auto">
                        <div class="flex items-center gap-3 bg-white/10 rounded-xl px-4 py-3 text-sm">
                            <i class="bi bi-shop text-lg text-purple-200"></i>
                            <span>Point of Sale</span>
                        </div>
                        <div class="flex items-center gap-3 bg-white/10 rounded-xl px-4 py-3 text-sm">
                            <i class="bi bi-box-seam text-lg text-purple-200"></i>
                            <span>Inventory Control</span>
                        </div>
                        <div class="flex items-center gap-3 bg-white/10 rounded-xl px-4 py-3 text-sm">
                            <i class="bi bi-graph-up-arrow text-lg text-purple-200"></i>
                            <span>Sales Analytics</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Forgot Password Form -->
            <div class="flex flex-col justify-center p-8 sm:p-12">
                <!-- Mobile Logo -->
                <div class="lg:hidden flex justify-center mb-8">
                    <div class="inline-block p-4 rounded-2xl bf-logo-badge">
                        <img src="/logo.png" alt="Logo" class="h-12 w-auto" />
                    </div>
                </div>

                <!-- Icon -->
                <div class="mb-6">
                    <div class="w-14 h-14 bg-purple-100 rounded-2xl flex items-center justify-center">
                        <i class="bi bi-key text-2xl text-purple-600"></i>
                    </div>
                </div>

                <!-- Header -->
                <div class="flex justify-between items-start mb-8">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-900 mb-1">@Localizer["ForgotPasswordTitle"]</h2>
                        <p class="text-gray-500 text-sm">@Localizer["EnterEmailResetLink"]</p>
                    </div>
                    <LanguageSelector />
                </div>

                @if (emailSent)
                {
                    <div class="p-5 bf-bg-success-50 border bf-border-success rounded-xl mb-6">
                        <div class="flex items-start gap-3">
                            <i class="bi bi-check-circle-fill bf-icon-success text-xl mt-0.5"></i>
                            <div>
                                <h5 class="font-semibold bf-text-success-strong mb-1 text-sm">@Localizer["CheckYourEmail"]</h5>
                                <p class="bf-text-success text-sm mb-1">@Localizer["IfAnAccountExistsResetLinkSent"]</p>
                                <p class="bf-text-success text-sm">@Localizer["PleaseCheckYourEmail"]</p>
                            </div>
                        </div>
                    </div>
                    <a href="/login"
                       class="w-full inline-flex items-center justify-center gap-2 py-3.5 bg-gradient-to-r from-purple-600 to-purple-800 text-white font-semibold rounded-xl hover:from-purple-700 hover:to-purple-900 transition-all duration-200 shadow-md hover:shadow-lg">
                        <i class="bi bi-arrow-left"></i>
                        <span>@Localizer["BackToLogin"]</span>
                    </a>
                }
                else
                {
                    @if (request != null)
                    {
                        <EditForm Model="@request" OnValidSubmit="@HandleSubmit">
                            <LocalizedDataAnnotationsValidator />

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="mb-5 p-3.5 bf-bg-danger-50 border bf-border-danger rounded-xl flex items-start gap-3">
                                    <i class="bi bi-exclamation-triangle-fill bf-icon-danger mt-0.5"></i>
                                    <span class="bf-text-danger text-sm">@errorMessage</span>
                                </div>
                            }

                            <div class="space-y-5">
                                <div>
                                    <label for="email" class="block text-sm font-semibold text-bf-primary mb-1.5">
                                        @Localizer["EmailAddress"] <span class="bf-text-danger-mark">*</span>
                                    </label>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                            <i class="bi bi-envelope text-gray-400"></i>
                                        </div>
                                        <InputText @bind-Value="request.Email"
                                                   class="w-full pl-10 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:bg-white transition-all duration-200 outline-none"
                                                   id="email"
                                                   placeholder="@Localizer["EmailAddress"]"
                                                   autocomplete="email" />
                                    </div>
                                    <ValidationMessage For="@(() => request.Email)" class="bf-text-danger-mark text-sm mt-1" />
                                </div>

                                <button type="submit"
                                        class="w-full py-3.5 bg-gradient-to-r from-purple-600 to-purple-800 text-white font-semibold rounded-xl hover:from-purple-700 hover:to-purple-900 focus:outline-none focus:ring-4 focus:ring-purple-300 transition-all duration-200 shadow-md hover:shadow-lg disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2.5"
                                        disabled="@isLoading">
                                    @if (isLoading)
                                    {
                                        <Spinner Size="Spinner.SpinnerSize.Sm" Color="Spinner.SpinnerColor.White" />
                                        <span>@Localizer["Sending"]</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-send"></i>
                                        <span>@Localizer["SendResetLink"]</span>
                                    }
                                </button>

                                <div class="text-center">
                                    <a href="/login" class="inline-flex items-center gap-2 text-sm font-medium text-purple-600 hover:text-purple-800 transition-colors duration-200">
                                        <i class="bi bi-arrow-left"></i>
                                        <span>@Localizer["BackToLogin"]</span>
                                    </a>
                                </div>
                            </div>
                        </EditForm>
                    }
                }

                <!-- Footer -->
                <div class="mt-8 pt-6 border-t border-gray-100 text-center">
                    <p class="text-xs text-gray-400">
                        © @DateTime.Now.Year @Localizer["AllRightsReserved"]
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>

@code {
    private ForgotPasswordRequest? request;
    private bool isLoading = false;
    private bool emailSent = false;
    private string errorMessage = string.Empty;

    protected override void OnInitialized()
    {
        request = new ForgotPasswordRequest();
    }

    private async Task HandleSubmit()
    {
        if (request == null) return;

        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var response = await AuthService.ForgotPasswordAsync(request);
            
            if (response.Success)
            {
                emailSent = true;
            }
            else
            {
                errorMessage = response.Message ?? Localizer["ErrorOccurred"];
            }
        }
        catch
        {
            errorMessage = Localizer["ErrorOccurred"];
        }
        finally
        {
            isLoading = false;
        }
    }
}
