@page "/logout"
@layout PublicLayout
@using Microsoft.AspNetCore.Components.Authorization
@using Web.Services
@using Web.Authentication
@using Blazored.LocalStorage
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject ILocalStorageService LocalStorage
@inject IJsonStringLocalizer Localizer

<div class="flex items-center justify-center min-h-screen bg-gray-50">
    <div class="text-center">
        <div class="mb-4 flex justify-center"><Spinner Size="Spinner.SpinnerSize.Xl" /></div>
        <h2 class="text-xl font-semibold text-gray-900">@Localizer["LoggingOut"]</h2>
        <p class="text-gray-500 mt-2">@Localizer["SigningOutMessage"]</p>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            await AuthService.LogoutAsync();

            try { await LocalStorage.ClearAsync(); } catch { }
        }
        catch
        {
        }

        Navigation.NavigateTo("/", forceLoad: true);
    }
}
