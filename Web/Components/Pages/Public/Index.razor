@page "/"
@page "/login"
@page "/admin/login"
@layout PublicLayout
@using Microsoft.AspNetCore.Components.Authorization
@using System.Globalization
@using Web.Components.Common
@using Web.Authentication
@using System.Text.RegularExpressions
@inject NavigationManager Navigation
@inject IAuthenticationService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJsonStringLocalizer Localizer

<PageTitle>@Localizer["SignIn"]</PageTitle>

<div class="relative min-h-screen bg-gray-50 flex items-center justify-center p-4 overflow-hidden">

    <!-- Main Container -->
    <div class="relative w-full max-w-5xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 bg-white rounded-2xl shadow-xl overflow-hidden min-h-[600px]">

            <!-- Left: Branding Panel -->
            <div class="hidden lg:flex flex-col items-center justify-center bg-gradient-to-br from-purple-700 via-purple-800 to-purple-900 text-white p-12 relative overflow-hidden">
                <!-- Decorative glow + AI motif -->
                <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
                <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
                <i class="bi bi-stars absolute top-10 left-10 text-white/10 text-5xl"></i>
                <i class="bi bi-cpu absolute bottom-12 right-10 text-white/10 text-6xl"></i>

                <div class="relative z-10 text-center space-y-8">
                    <div class="inline-block p-5 rounded-2xl bg-white/10 backdrop-blur-sm">
                        <img src="/logo.png" alt="Logo" class="h-16 w-auto" />
                    </div>
                    <div>
                        <p class="text-purple-200 text-sm">@Localizer["ByteAITagline"]</p>
                    </div>
                    <div class="space-y-3 text-start max-w-xs mx-auto">
                        <div class="flex items-center gap-3 bg-white/10 rounded-xl px-4 py-3 text-sm">
                            <i class="bi bi-cpu text-lg text-purple-200"></i>
                            <span>@Localizer["AIAssistant"]</span>
                        </div>
                        <div class="flex items-center gap-3 bg-white/10 rounded-xl px-4 py-3 text-sm">
                            <i class="bi bi-shield-check text-lg text-purple-200"></i>
                            <span>@Localizer["IdentityAndAccess"]</span>
                        </div>
                        <div class="flex items-center gap-3 bg-white/10 rounded-xl px-4 py-3 text-sm">
                            <i class="bi bi-clipboard-data text-lg text-purple-200"></i>
                            <span>@Localizer["AuditAndInsights"]</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Login Form -->
            <div class="flex flex-col justify-center p-8 sm:p-12">
                <!-- Mobile Logo -->
                <div class="lg:hidden flex flex-col items-center mb-8">
                    <div class="inline-block p-4 rounded-2xl bf-logo-badge">
                        <img src="/logo.png" alt="Logo" class="h-12 w-auto" />
                    </div>
                </div>

                <!-- Icon -->
                <div class="mb-6">
                    <div class="w-14 h-14 bg-purple-100 rounded-2xl flex items-center justify-center">
                        <i class="bi bi-stars text-2xl text-purple-600"></i>
                    </div>
                </div>

                <!-- Header -->
                <div class="flex justify-between items-start mb-8">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-900 mb-1">@Localizer["WelcomeBack"]</h2>
                        <p class="text-gray-500 text-sm">@Localizer["AccessYourAccount"]</p>
                    </div>
                    <LanguageSelector />
                </div>

                <!-- Form -->
                <EditForm Model="@loginRequest" OnValidSubmit="@HandleLogin" FormName="loginForm">
                    <LocalizedDataAnnotationsValidator />

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="mb-5 p-3.5 bf-bg-danger-50 border bf-border-danger rounded-xl flex items-start gap-3">
                            <i class="bi bi-exclamation-triangle-fill bf-icon-danger mt-0.5"></i>
                            <span class="bf-text-danger text-sm">@SanitizeError(errorMessage)</span>
                        </div>
                    }
                    else if (sessionExpiredNotice)
                    {
                        <div class="mb-5 p-3.5 bf-bg-warning-50 border bf-border-warning rounded-xl flex items-start gap-3">
                            <i class="bi bi-clock-history bf-icon-warning mt-0.5"></i>
                            <span class="bf-text-warning text-sm">@Localizer["SessionExpiredPleaseSignInAgain"]</span>
                        </div>
                    }

                    <div class="space-y-5">
                        <!-- Email -->
                        <div>
                            <label for="email" class="block text-sm font-semibold text-bf-primary mb-1.5">
                                @Localizer["EmailAddress"] <span class="bf-text-danger-mark">*</span>
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                    <i class="bi bi-envelope text-gray-400"></i>
                                </div>
                                <InputText @bind-Value="loginRequest.Email"
                                           type="email"
                                           class="w-full pl-10 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:bg-white transition-all duration-200 outline-none"
                                           id="email"
                                           placeholder="@Localizer["EmailAddress"]"
                                           disabled="@isLoading" />
                            </div>
                            <ValidationMessage For="@(() => loginRequest.Email)" class="bf-text-danger-mark text-sm mt-1" />
                        </div>

                        <!-- Password -->
                        <div>
                            <label for="password" class="block text-sm font-semibold text-bf-primary mb-1.5">
                                @Localizer["Password"] <span class="bf-text-danger-mark">*</span>
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                    <i class="bi bi-lock text-gray-400"></i>
                                </div>
                                <InputText @bind-Value="loginRequest.Password"
                                           type="@passwordInputType"
                                           class="w-full pl-10 pr-12 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:bg-white transition-all duration-200 outline-none"
                                           id="password"
                                           placeholder="@Localizer["EnterPassword"]"
                                           disabled="@isLoading" />
                                <button type="button"
                                        class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-gray-400 hover:text-gray-600 transition-colors"
                                        aria-label="Toggle password visibility"
                                        aria-pressed="@showPassword"
                                        @onclick="TogglePasswordVisibility">
                                    <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye") text-lg"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => loginRequest.Password)" class="bf-text-danger-mark text-sm mt-1" />
                        </div>

                        <!-- Forgot Password -->
                        <div class="flex justify-end">
                            <a href="/forgot-password" class="text-sm font-medium text-purple-600 hover:text-purple-800 transition-colors">
                                @Localizer["ForgotPassword"]
                            </a>
                        </div>

                        <!-- Submit -->
                        <button type="submit"
                                disabled="@isLoading"
                                class="w-full py-3.5 bg-gradient-to-r from-purple-600 to-purple-800 text-white font-semibold rounded-xl hover:from-purple-700 hover:to-purple-900 focus:outline-none focus:ring-4 focus:ring-purple-300 transition-all duration-200 shadow-md hover:shadow-lg disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2.5">
                            @if (isLoading)
                            {
                                <Spinner Size="Spinner.SpinnerSize.Sm" Color="Spinner.SpinnerColor.White" />
                                <span>@Localizer["Processing"]</span>
                            }
                            else
                            {
                                <i class="bi bi-box-arrow-in-right"></i>
                                <span>@Localizer["Login"]</span>
                            }
                        </button>
                    </div>
                </EditForm>

                <!-- Footer -->
                <div class="mt-8 pt-6 border-t border-gray-100 text-center space-y-1">
                    <p class="text-xs text-gray-500 font-medium">
                        © @DateTime.Now.Year @Localizer["AllRightsReserved"]
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>

@code {
    private LoginRequest loginRequest = new();
    private string errorMessage = string.Empty;
    private bool isLoading = false;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "sessionExpired")]
    private string? SessionExpired { get; set; }

    private bool sessionExpiredNotice = false;

    protected override async Task OnInitializedAsync()
    {
        sessionExpiredNotice = !string.IsNullOrEmpty(SessionExpired) && SessionExpired != "0";

        // Check if already logged in
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated == true)
        {
            RedirectUser(user);
        }
    }

    private void RedirectUser(System.Security.Claims.ClaimsPrincipal user)
    {
        if (!string.IsNullOrEmpty(ReturnUrl))
        {
            var target = ReturnUrl.StartsWith("/") ? ReturnUrl : "/" + ReturnUrl;
            Navigation.NavigateTo(target, forceLoad: true);
            return;
        }

        Navigation.NavigateTo("/admin", forceLoad: true);
    }

    private async Task HandleLogin()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            var response = await AuthService.LoginAsync(loginRequest);

            if (response.Success)
            {
                ((CustomAuthenticationStateProvider)AuthStateProvider).NotifyAuthenticationStateChanged();

                Navigation.NavigateTo("/admin", forceLoad: true);
            }
            else
            {
                // Try localizing the message key first; if unchanged, use the raw message
                var localized = Localizer[response.Message ?? "LoginFailed"];
                errorMessage = string.IsNullOrEmpty(localized) ? (response.Message ?? Localizer["LoginFailed"]) : localized;
            }
        }
        catch (HttpRequestException httpEx)
        {
            Console.WriteLine($"Login HTTP exception: {httpEx.Message}");
            Console.WriteLine($"Status Code: {httpEx.StatusCode}");

            if (httpEx.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                errorMessage = Localizer["InvalidEmailFormat"];
            }
            else
            {
                errorMessage = Localizer["LoginError"];
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Login exception: {ex.Message}");
            Console.WriteLine($"Exception type: {ex.GetType().Name}");
            errorMessage = Localizer["LoginError"];
        }
        finally
        {
            isLoading = false;
        }
    }

    private string SanitizeError(string msg)
    {
        if (string.IsNullOrEmpty(msg)) return string.Empty;
        // remove common UI tokens like 'Reload' and the close symbol '×'
        var sanitized = Regex.Replace(msg, "\\s*Reload\\s*×?", "", RegexOptions.IgnoreCase);
        // remove any stray '×' characters
        sanitized = sanitized.Replace("×","").Trim();
        return sanitized;
    }

    private string passwordInputType = "password";
    private bool showPassword = false;

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
        passwordInputType = showPassword ? "text" : "password";
    }
}
