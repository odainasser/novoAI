@page "/cashier/orders"
@layout CashierLayout
@attribute [Authorize(Roles = Roles.Cashier)]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Web.Components.Layout
@using Web.Components.Common
@using Web.Models.Enums
@using System.Globalization
@using System.Threading
@* Shift controls removed from this page; use Shifts page to start/end shifts *@
@using Web.Models.Shifts
@using Web.Models.Cashiers
@inject IShiftService ShiftService
@inject IOrderService OrderService
@inject ICashierManagementService CashierManagementService
@inject NavigationManager Navigation
@implements IDisposable

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }
}

<PageTitle>@Localizer["MyOrders"]</PageTitle>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6">
            <!-- Header -->
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-8">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
                        <i class="bi bi-receipt text-bf-primary"></i>
                        @Localizer["MyOrders"]
                    </h1>
                    <p class="text-gray-600 mt-2 text-sm sm:text-base">@Localizer["ManageOrders"]</p>
                </div>

@* Refund confirm modal *@
<ConfirmModal IsVisible="@showRefundConfirmModal"
              Title="@Localizer["Confirm"]"
              Message="@Localizer["ConfirmRefund"]"
              ConfirmText="@Localizer["Confirm"]"
              CancelText="@Localizer["Cancel"]"
              IsDanger="true"
              OnConfirm="OnConfirmRefund"
              OnCancel="OnCancelRefund" />

                
                <div class="flex flex-wrap items-center gap-3">
                    
                    <!-- Search -->
                    <div class="relative">
                        <input type="text" @bind="SearchQuery" @bind:event="oninput" @onkeyup="OnSearchKeyUp"
                               placeholder="@Localizer["Search"]..."
                               class="w-full sm:w-64 px-4 py-2 ps-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary focus:border-transparent" />
                        <i class="bi bi-search absolute start-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    </div>
                    
                    <!-- Status Filter -->
                    <div class="relative">
                    <select @bind="selectedStatus" @bind:after="LoadOrders"
                                class="appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-4 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary">
                        <option value="">@Localizer["AllStatuses"]</option>
                        <option value="@OrderStatus.Completed">@Localizer["StatusCompleted"]</option>
                        <option value="@OrderStatus.PartialRefunded">@Localizer["StatusPartialRefunded"]</option>
                        <option value="@OrderStatus.Refunded">@Localizer["StatusRefunded"]</option>
                    </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-700">
                            <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                        </div>
                    </div>

                    <!-- Date Filter -->
                    <div class="relative">
                        <input type="date" @bind="selectedDate" @bind:after="LoadOrders"
                               class="bg-white border border-gray-300 text-gray-700 py-2 px-4 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary" />
                    </div>

                    <!-- Store Filter -->
                    @if (assignedStores.Count > 1)
                    {
                        <div class="min-w-[220px]">
                            <SearchableDropdown TItem="AssignedWarehouseDto"
                                                TValue="string"
                                                Items="assignedStores"
                                                @bind-Value="selectedWarehouseId"
                                                OnChanged="OnStoreFilterChanged"
                                                DisplayText="s => isAr ? s.NameAr : s.NameEn"
                                                SearchText='s => $"{s.NameEn} {s.NameAr}"'
                                                ItemValue="s => s.Id.ToString()"
                                                Placeholder='@Localizer["AllStores"]' />
                        </div>
                    }

                    <!-- Reset Filters -->
    @if (!string.IsNullOrEmpty(searchQuery) || selectedStatus.HasValue || selectedDate.HasValue || !string.IsNullOrEmpty(selectedWarehouseId))
                    {
                        <button @onclick="ResetFiltersAndReload" 
                                class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors">
                            <i class="bi bi-x-circle"></i>
                            <span>@Localizer["ResetFilters"]</span>
                        </button>
                    }
                </div>
            </div>

            <!-- Statistics Cards -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
                <div class="bg-gray-50 rounded-lg p-3 border border-gray-200">
                    <p class="text-xs text-gray-500 uppercase font-medium tracking-wide">@Localizer["TodayOrders"]</p>
                    <p class="text-2xl font-bold text-gray-900 mt-1">@statistics.TodayOrders</p>
                </div>
                <div class="bg-gray-50 rounded-lg p-3 border border-gray-200">
                    <p class="text-xs text-gray-500 uppercase font-medium tracking-wide">@Localizer["TodayRevenue"]</p>
                    <p class="text-2xl font-bold text-gray-900 mt-1">@statistics.TodayRevenue.ToString("N2", cultureInfo) @Localizer["CurrencyUnit"]</p>
                </div>
                <div class="bg-gray-50 rounded-lg p-3 border border-gray-200">
                    <p class="text-xs text-gray-500 uppercase font-medium tracking-wide">@Localizer["TotalOrders"]</p>
                    <p class="text-2xl font-bold text-gray-900 mt-1">@statistics.TotalOrders</p>
                </div>
                <div class="bg-gray-50 rounded-lg p-3 border border-gray-200">
                    <p class="text-xs text-gray-500 uppercase font-medium tracking-wide">@Localizer["TotalRevenue"]</p>
                    <p class="text-2xl font-bold text-gray-900 mt-1">@statistics.TotalRevenue.ToString("N2", cultureInfo) @Localizer["CurrencyUnit"]</p>
                </div>
            </div>

            @if (isLoading)
            {
                <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="p-4 bg-red-50 border border-red-200 rounded-lg flex items-start gap-3">
                    <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                    <span class="text-red-800">@errorMessage</span>
                </div>
            }
            else if (orders == null || !orders.Any())
            {
                <div class="text-center py-12">
                    <i class="bi bi-receipt text-6xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500 text-lg">@Localizer["NoOrdersFound"]</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["OrderNumber"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["OrderDate"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["PaymentMethod"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Store"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Items"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Total"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Refunds"]</th>
                                <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var order in orders)
                            {
                                <tr class="hover:bg-gray-50 transition-colors duration-150">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            <div class="flex-shrink-0 h-10 w-10 bg-bf-primary/10 rounded-lg flex items-center justify-center">
                                                <i class="bi bi-receipt text-bf-primary"></i>
                                            </div>
                                            <div class="ms-4">
                                                <div class="text-sm font-medium text-gray-900 font-mono">
                                                    @order.OrderNumber
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                        @order.CreatedAt.ToLocal().ToString("g", cultureInfo)
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="px-2 py-1 text-xs font-medium rounded-full @GetPaymentMethodClass(order.PaymentMethod)">
                                            @GetPaymentMethodText(order.PaymentMethod)
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="px-2 py-1 text-xs font-medium rounded-full @GetStatusClass(order.Status)">
                                            @GetStatusText(order.Status)
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                        @if (order.WarehouseId.HasValue && !string.IsNullOrEmpty(isAr ? order.WarehouseNameAr : order.WarehouseNameEn))
                                        {
                                            <span>@(isAr ? order.WarehouseNameAr : order.WarehouseNameEn)</span>
                                        }
                                        else
                                        {
                                            <span class="text-gray-400">-</span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                        @order.ItemCount
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">
                                        @order.Total.ToString("N2", cultureInfo) @Localizer["CurrencyUnit"]
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                                        @if (order.Refunds != null && order.Refunds.Any())
                                        {
                                            <span class="px-2 py-1 text-xs font-medium rounded-full bg-red-100 text-red-800">
                                                @order.Refunds.Sum(r => r.Amount).ToString("N2", cultureInfo) @Localizer["CurrencyUnit"]
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-gray-400">-</span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                                        <button @onclick="() => ViewOrder(order.Id)"
                                                class="text-bf-primary hover:text-bf-primary-dark p-2 hover:bg-bf-primary/10 rounded-lg transition-colors me-1"
                                                title="@Localizer["ViewDetails"]">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        @if (canRefund && (order.Status == OrderStatus.Completed || order.Status == OrderStatus.PartialRefunded))
                                        {
                                            <button @onclick="() => ShowRefundConfirm(order.Id)"
                                                    class="ms-2 bf-text-danger bf-hover-bg-danger-50 p-2 rounded-lg transition-colors"
                                                    title="@Localizer["RefundOrder"]">
                                                <i class="bi bi-arrow-counterclockwise text-lg"></i>
                                            </button>
                                            <button @onclick="() => ShowPartialRefund(order.Id, order.Total)"
                                                    class="ms-2 bf-text-success bf-hover-bg-success-50 p-2 rounded-lg transition-colors"
                                                    title="@Localizer["PartialRefund"]">
                                                <i class="bi bi-cash-stack text-lg"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <Pagination PageIndex="@pageIndex" 
                            TotalPages="@totalPages" 
                            TotalCount="@totalCount" 
                            PageSize="@pageSize" 
                            OnPageChanged="@OnPageChanged" />
            }
</div>

<!-- Order Details Modal -->
<OrderDetailsModal IsVisible="@showOrderModal" Order="@selectedOrder" OnClose="CloseOrderModal" />
<PartialRefundModal IsVisible="@showPartialRefundModal"
                    Title="@Localizer["PartialRefund"]"
                    Message="@Localizer["PartialRefundMessage"]"
                    ConfirmText="@Localizer["Confirm"]"
                    CancelText="@Localizer["Cancel"]"
                    MaxAmount="@modalMaxAmount"
                    OrderItems="@selectedOrder?.Items"
                    OnConfirm="OnConfirmPartialRefund"
                    OnConfirmItems="OnConfirmPartialRefundItems"
                    OnCancel="OnCancelPartialRefund" />

@* Shift modals removed from orders page *@

@code {
    private List<OrderDto> orders = new();
    private OrderStatisticsDto statistics = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private bool isAr = false;
    private bool canRefund = true;
    private CultureInfo cultureInfo = new CultureInfo("en-AE");

    private CancellationTokenSource? searchCts;

    // Filters
    private string searchQuery = "";
    private string SearchQuery
    {
        get => searchQuery;
        set
        {
            if (searchQuery == value) return;
            searchQuery = value;
            _ = DebouncedSearchAsync();
        }
    }
    private OrderStatus? selectedStatus = null;
    private DateTime? selectedDate = null;
    private string selectedWarehouseId = "";
    private List<AssignedWarehouseDto> assignedStores = new();

    // Pagination
    private int pageIndex = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private int totalCount = 0;

    // Modal
    private bool showOrderModal = false;
    private OrderDto? selectedOrder = null;

    protected override async Task OnInitializedAsync()
    {
        var currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.ToLowerInvariant();
        isAr = currentCulture == "ar";
        cultureInfo = isAr ? new CultureInfo("ar-AE") : new CultureInfo("en-AE");

        // Check if current cashier can refund
        if (AuthState != null)
        {
            var authState = await AuthState;
            var canRefundClaim = authState.User.FindFirst("can_refund")?.Value;
            canRefund = string.Equals(canRefundClaim, "true", StringComparison.OrdinalIgnoreCase);
        }

        assignedStores = await CashierManagementService.GetMyAssignedStoresAsync();

        // Subscribe to navigation events to reset filters
        Navigation.LocationChanged += OnLocationChanged;

        await LoadStatistics();
        await LoadOrders();
        // Shift status handled on Shifts page; nothing to do here
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // Reset filters when navigating to this page
        if (e.Location.Contains("/cashier/orders", StringComparison.OrdinalIgnoreCase))
        {
            ResetFilters();
            InvokeAsync(async () =>
            {
                await LoadStatistics();
                await LoadOrders();
                    // Shift status handled on Shifts page
                StateHasChanged();
            });
        }
    }

    private void ResetFilters()
    {
        searchQuery = "";
        selectedStatus = null;
        selectedDate = null;
        selectedWarehouseId = "";
        pageIndex = 1;
    }

    private async Task OnStoreFilterChanged()
    {
        pageIndex = 1;
        await LoadOrders();
    }

    private async Task ResetFiltersAndReload()
    {
        ResetFilters();
        await LoadOrders();
    }

    private async Task LoadStatistics()
    {
        try
        {
            statistics = await OrderService.GetMyStatisticsAsync();
        }
        catch
        {
            statistics = new OrderStatisticsDto();
        }
    }

    private async Task LoadOrders()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            DateTime? fromDate = selectedDate;
            DateTime? toDate = selectedDate?.AddDays(1);

            var warehouseFilter = Guid.TryParse(selectedWarehouseId, out var wId) ? wId : (Guid?)null;
            var result = await OrderService.GetMyOrdersAsync(
                pageIndex,
                pageSize,
                searchQuery,
                selectedStatus,
                null,
                fromDate,
                toDate,
                warehouseFilter);
            
            orders = result.Items;
            totalPages = result.TotalPages;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToLoadOrders"]}: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            pageIndex = 1;
            await LoadOrders();
        }
    }

    private async Task DebouncedSearchAsync()
    {
        // Cancel previous pending search
        searchCts?.Cancel();
        searchCts?.Dispose();
        searchCts = new CancellationTokenSource();
        var token = searchCts.Token;

        try
        {
            await Task.Delay(300, token);
            pageIndex = 1;
            await LoadOrders();
        }
        catch (TaskCanceledException)
        {
            // ignore
        }
    }

    private async Task OnPageChanged(int newPage)
    {
        pageIndex = newPage;
        await LoadOrders();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        searchCts?.Cancel();
        searchCts?.Dispose();
    }

    private async Task ViewOrder(Guid orderId)
    {
        try
        {
            selectedOrder = await OrderService.GetOrderByIdAsync(orderId);
            showOrderModal = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task RefundOrder(Guid orderId)
    {
        try
        {
            var updated = await OrderService.CancelOrderAsync(orderId, "Refunded by cashier");
            if (updated != null)
            {
                // Update the order in the current list so UI reflects change immediately
                var idx = orders.FindIndex(o => o.Id == orderId);
                if (idx >= 0)
                {
                    orders[idx] = updated;
                }

                // Update selectedOrder if details modal is open
                if (selectedOrder != null && selectedOrder.Id == orderId)
                {
                    selectedOrder = updated;
                }

                await LoadStatistics();
            }
            else
            {
                errorMessage = Localizer["FailedToRefundOrder"] ?? "Failed to refund order";
            }
        }
        catch (Exception ex)
        {
            // Provide user-friendly message and log details if needed
            errorMessage = Localizer["FailedToRefundOrder"] ?? "Failed to refund order";
            Console.Error.WriteLine($"Refund error for order {orderId}: {ex}");
        }
    }

    private void CloseOrderModal()
    {
        showOrderModal = false;
        selectedOrder = null;
    }

    private string GetStatusClass(OrderStatus status) => status switch
    {
        OrderStatus.Completed => "bf-bg-success-100 bf-text-success",
        OrderStatus.Refunded => "bf-bg-danger-100 bf-text-danger",
        OrderStatus.PartialRefunded => "bf-bg-info-100 bf-text-info",
        _ => "bg-gray-100 text-gray-800"
    };

    private string GetPaymentMethodClass(PaymentMethod method) => method switch
    {
        PaymentMethod.Cash => "bg-green-100 text-green-800",
        PaymentMethod.Card => "bg-blue-100 text-blue-800",
        PaymentMethod.Mobile => "bg-purple-100 text-purple-800",
        PaymentMethod.Split => "bg-violet-100 text-violet-800",
        _ => "bg-gray-100 text-gray-800"
    };

// No-op to ensure code context for modal placement
    private string GetStatusText(OrderStatus status) => status switch
    {
        OrderStatus.Completed => Localizer["StatusCompleted"],
        OrderStatus.Refunded => Localizer["StatusRefunded"],
        OrderStatus.PartialRefunded => Localizer["StatusPartialRefunded"],
        _ => status.ToString()
    };

    private string GetPaymentMethodText(PaymentMethod method) => method switch
    {
        PaymentMethod.Cash => Localizer["PaymentCash"],
        PaymentMethod.Card => Localizer["PaymentCard"],
        PaymentMethod.Mobile => Localizer["PaymentMobile"],
        PaymentMethod.Split => Localizer["SplitPayment"],
        _ => method.ToString()
    };

    // (Dispose implemented above)

    // Render confirm modal component
    private bool showRefundConfirmModal = false;
    private Guid refundModalOrderId;
    private bool showPartialRefundModal = false;
    private Guid partialRefundOrderId;
    private decimal modalMaxAmount = 0;
    // Shift controls removed from this page

    private void ShowRefundConfirm(Guid orderId)
    {
        refundModalOrderId = orderId;
        showRefundConfirmModal = true;
    }

    private async Task OnConfirmRefund()
    {
        showRefundConfirmModal = false;
        await RefundOrder(refundModalOrderId);
    }

    private void OnCancelRefund()
    {
        showRefundConfirmModal = false;
    }

    private async Task OnConfirmPartialRefundItems(List<PartialRefundItemRequest> items)
    {
        showPartialRefundModal = false;
        try
        {
            var updated = await OrderService.PartialRefundAsync(partialRefundOrderId, items);
            if (updated != null)
            {
                var idx = orders.FindIndex(o => o.Id == partialRefundOrderId);
                if (idx >= 0) orders[idx] = updated;

                if (selectedOrder != null && selectedOrder.Id == partialRefundOrderId)
                    selectedOrder = updated;

                await LoadStatistics();
            }
            else
            {
                errorMessage = Localizer["FailedToPartialRefund"] ?? "Failed to partial refund";
            }
        }
        catch (Exception ex)
        {
            errorMessage = Localizer["FailedToPartialRefund"] ?? "Failed to partial refund";
            Console.Error.WriteLine($"Partial refund error for order {partialRefundOrderId}: {ex}");
        }
    }

    private void ShowPartialRefund(Guid orderId, decimal maxAmount)
    {
        partialRefundOrderId = orderId;
        // ensure selectedOrder matches this id so modal MaxAmount binding works
        if (selectedOrder == null || selectedOrder.Id != orderId)
        {
            // try to set selectedOrder from list to provide MaxAmount
            selectedOrder = orders.FirstOrDefault(o => o.Id == orderId);
        }

        modalMaxAmount = maxAmount;
        showPartialRefundModal = true;
    }

    // Shift handling removed from Orders page

    private async Task OnConfirmPartialRefund(decimal amount)
    {
        showPartialRefundModal = false;
        try
        {
            var updated = await OrderService.PartialRefundAsync(partialRefundOrderId, amount);
            if (updated != null)
            {
                var idx = orders.FindIndex(o => o.Id == partialRefundOrderId);
                if (idx >= 0) orders[idx] = updated;

                if (selectedOrder != null && selectedOrder.Id == partialRefundOrderId)
                    selectedOrder = updated;

                await LoadStatistics();
            }
            else
            {
                errorMessage = Localizer["FailedToPartialRefund"] ?? "Failed to partial refund";
            }
        }
        catch (Exception ex)
        {
            errorMessage = Localizer["FailedToPartialRefund"] ?? "Failed to partial refund";
            Console.Error.WriteLine($"Partial refund error for order {partialRefundOrderId}: {ex}");
        }
    }

    private void OnCancelPartialRefund()
    {
        showPartialRefundModal = false;
    }
}
