    private bool showStartShiftModal = false;

    private void StartShiftButton()
    {
        // Open the start-shift modal instead of starting directly
        showStartShiftModal = true;
    }

    private async Task SubmitStartShift(Web.Models.Shifts.StartShiftRequest req)
    {
        // Let exceptions bubble up so the StartShiftModal can display the error and remain open.
        var result = await ShiftService.StartShiftAsync(req);
        shiftMessage = Localizer["ShiftStarted"] ?? "Shift started";
        activeShift = result;
        showStartShiftModal = false;

        // Update warehouse from the new shift and reload products
        if (result.WarehouseId.HasValue)
            currentWarehouseId = result.WarehouseId;

        await LoadActiveProductsAsync();

        StateHasChanged();
    }

    private async Task LoadActiveProductsAsync()
    {
        const int pageSize = 500;
        var page = 1;
        var all = new List<ProductDto>();

        while (true)
        {
            var result = await ProductService.GetAllProductsAsync(
                page,
                pageSize,
                status: ItemStatus.Active,
                warehouseId: currentWarehouseId,
                onlyWithStock: false);

            all.AddRange(result.Items);

            if (page >= result.TotalPages || result.Items.Count == 0)
                break;

            page++;
        }

        products = all;
    }

    private void CancelStartShift()
    {
        showStartShiftModal = false;
    }

    private async Task EndShiftButton()
    {
        if (activeShift is null) return;
        try
        {
            var req = new Web.Models.Shifts.EndShiftRequest { CashOut = 0m, Comments = null };
            var result = await ShiftService.EndShiftAsync(activeShift.Id, req);
            shiftMessage = Localizer["ShiftEnded"];
            activeShift = null;
        }
        catch (Exception ex)
        {
            shiftMessage = ex.Message;
        }
    }

    // Unit selection modal
    private bool showUnitModal = false;
    private ProductDto? unitProduct = null;

    private (bool HasPromotion, decimal DiscountedPrice, DiscountType DiscountType, decimal DiscountValue, string PromotionName) GetBestPromotionForUnit(ProductDto product, ProductUnitDto unit)
    {
        if (!activePromotions.Any()) return (false, unit.SellingPrice, default, 0, string.Empty);

        var now = DateTime.UtcNow;

        var applicablePromotions = activePromotions.Where(p =>
            p.IsActive && p.StartDateTime <= now && p.EndDateTime >= now && (
                p.ApplyTo.HasFlag(PromotionApplyTo.AllSellingUnits) ||
                (p.ApplyTo.HasFlag(PromotionApplyTo.SpecificUnits) && p.UnitIds.Contains(unit.Id)) ||
                (p.ApplyTo.HasFlag(PromotionApplyTo.Categories) && product.CategoryId != null && p.CategoryIds.Contains(product.CategoryId.Value))
            )
        ).ToList();

        if (!applicablePromotions.Any()) return (false, unit.SellingPrice, default, 0, string.Empty);

        decimal bestPrice = unit.SellingPrice;
        PromotionDto? bestPromo = null;

        foreach (var promo in applicablePromotions)
        {
            decimal discounted = promo.DiscountType == DiscountType.Percentage
                ? unit.SellingPrice * (1 - promo.DiscountValue / 100m)
                : unit.SellingPrice - promo.DiscountValue;
            discounted = Math.Max(0, discounted);

            if (discounted < bestPrice)
            {
                bestPrice = discounted;
                bestPromo = promo;
            }
        }

        if (bestPromo == null) return (false, unit.SellingPrice, default, 0, string.Empty);
        return (true, bestPrice, bestPromo.DiscountType, bestPromo.DiscountValue, isAr ? bestPromo.NameAr : bestPromo.NameEn);
    }


