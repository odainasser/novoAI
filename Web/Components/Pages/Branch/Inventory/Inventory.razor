@page "/branch/inventory"
@page "/branch/inventory/{Tab?}"
@layout BranchLayout
@attribute [Authorize]
@attribute [RequirePermission(Permissions.InventoryRead)]
@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using System.Globalization
@inject ActiveBranchContext ActiveBranch
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>@Localizer["Inventory"]</PageTitle>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6">
    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
            <i class="bi bi-stack text-purple-600"></i>
            @Localizer["Inventory"]
        </h1>
        <p class="text-gray-600 mt-2 text-sm sm:text-base">@Localizer["ManageInventoryOperations"]</p>
    </div>

    @if (!ActiveBranch.IsSelected)
    {
        <Alert Type="Alert.AlertType.Warning"
               Message="@Localizer["NoBranchSelected"]"
               Dismissible="false" />
    }
    else
    {
        <!-- Tabs -->
        <div class="mb-6">
            <nav class="tab-nav" aria-label="Tabs">
                <AuthorizeView Policy="Permission:purchase-requests.read" Context="prTabAuth">
                    <Authorized Context="prTabAuth">
                        <button @onclick='() => SetActiveTab("purchase-requests")'
                                class="tab-btn @GetTabClass("purchase-requests")">
                            <i class="bi bi-bag-plus"></i>
                            @Localizer["PurchaseRequests"]
                        </button>
                    </Authorized>
                </AuthorizeView>
                <button @onclick='() => SetActiveTab("grn")'
                        class="tab-btn @GetTabClass("grn")">
                    <i class="bi bi-arrow-down-square"></i>
                    @Localizer["GoodsReceiving"]
                </button>
                <button @onclick='() => SetActiveTab("transfer")'
                        class="tab-btn @GetTabClass("transfer")">
                    <i class="bi bi-arrow-down-up"></i>
                    @Localizer["StockTransfers"]
                </button>
                <button @onclick='() => SetActiveTab("adjustment")'
                        class="tab-btn @GetTabClass("adjustment")">
                    <i class="bi bi-pencil-square"></i>
                    @Localizer["StockAdjustments"]
                </button>
                <button @onclick='() => SetActiveTab("stocktake")'
                        class="tab-btn @GetTabClass("stocktake")">
                    <i class="bi bi-clipboard-data"></i>
                    @Localizer["Stocktake"]
                </button>
                <button @onclick='() => SetActiveTab("balances")'
                        class="tab-btn @GetTabClass("balances")">
                    <i class="bi bi-archive"></i>
                    @Localizer["StockBalances"]
                </button>
                <button @onclick='() => SetActiveTab("history")'
                        class="tab-btn @GetTabClass("history")">
                    <i class="bi bi-activity"></i>
                    @Localizer["InventoryHistory"]
                </button>
            </nav>
        </div>

        <!-- Tab Content -->
        @if (activeTab == "purchase-requests")
        {
            <BranchInventoryPurchaseRequestsTab />
        }
        else if (activeTab == "grn")
        {
            <BranchInventoryGoodsReceivingTab />
        }
        else if (activeTab == "transfer")
        {
            <BranchInventoryStockTransferTab />
        }
        else if (activeTab == "adjustment")
        {
            <BranchInventoryStockAdjustmentTab />
        }
        else if (activeTab == "stocktake")
        {
            <BranchInventoryStocktakeTab />
        }
        else if (activeTab == "balances")
        {
            <BranchInventoryStockBalancesTab />
        }
        else if (activeTab == "history")
        {
            <BranchInventoryHistoryTab />
        }
    }
</div>

@code {
    [Parameter] public string? Tab { get; set; }

    private string activeTab = "grn";

    private string ResolveTab()
    {
        if (!string.IsNullOrEmpty(Tab))
            return Tab.ToLowerInvariant() switch
            {
                "goods-receiving" or "grn" => "grn",
                "stock-adjustments" or "adjustments" or "adjustment" => "adjustment",
                "stock-transfers" or "transfers" or "transfer" => "transfer",
                "purchase-requests" or "purchase-request" or "pr" => "purchase-requests",
                "stocktake" or "stocktakes" or "stock-take" or "stock-takes" => "stocktake",
                "balances" or "stock-balances" => "balances",
                "history" or "inventory-history" => "history",
                _ => "grn"
            };
        return "grn";
    }

    protected override void OnInitialized()
    {
        activeTab = ResolveTab();
        ActiveBranch.OnChanged += OnBranchChanged;

        if (!ActiveBranch.IsSelected)
        {
            Navigation.NavigateTo("/branch/select", replace: true);
        }
    }

    protected override void OnParametersSet()
    {
        activeTab = ResolveTab();
    }

    private async Task SetActiveTab(string tab)
    {
        activeTab = tab;
        var tabPath = tab switch
        {
            "grn" => "grn",
            "adjustment" => "adjustments",
            "transfer" => "transfers",
            "purchase-requests" => "purchase-requests",
            "stocktake" => "stocktake",
            "balances" => "balances",
            "history" => "history",
            _ => tab
        };
        Navigation.NavigateTo($"/branch/inventory/{tabPath}", replace: true);
        await Task.CompletedTask;
    }

    private string GetTabClass(string tab) =>
        activeTab == tab ? "tab-btn-active" : "";

    private void OnBranchChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ActiveBranch.OnChanged -= OnBranchChanged;
    }
}
