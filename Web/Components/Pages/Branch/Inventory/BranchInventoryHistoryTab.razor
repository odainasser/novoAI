@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using Web.Components.Common
@using Web.Models.Warehouses
@using System.Globalization
@inject IInventoryHistoryClientService InventoryHistoryService
@inject IWarehouseService WarehouseService
@inject ActiveBranchContext ActiveBranch
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer
@implements IDisposable

<!-- Filters -->
<div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
    <div class="flex flex-wrap items-center gap-3 p-4">
        <div class="flex-1 min-w-[200px]"></div>

        <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")">
            <i class="bi bi-funnel"></i>
            <span>@Localizer["Filters"]</span>
            @if (ActiveFilterCount > 0)
            {
                <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
            }
            <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
        </button>

        @if (HasActiveFilters())
        {
            <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <i class="bi bi-x-circle"></i>
                <span>@Localizer["ResetFilters"]</span>
            </button>
        }
    </div>

    @if (showFiltersPanel)
    {
        <div class="px-4 pb-4 pt-0 border-t border-gray-200">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 pt-4">
                <div>
                    <SearchableDropdown TItem="WarehouseDto"
                                        TValue="string"
                                        Items="branchWarehouses"
                                        @bind-Value="filterWarehouseId"
                                        OnChanged="ApplyFilters"
                                        DisplayText="w => isAr ? w.NameAr : w.NameEn"
                                        SearchText='w => $"{w.NameEn} {w.NameAr}"'
                                        ItemValue="w => w.Id.ToString()"
                                        Label='@Localizer["Warehouse"]'
                                        Placeholder='@Localizer["AllWarehouses"]'
                                        Compact="true" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["ActionType"]</label>
                    <div class="relative">
                        <select @bind="filterType" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                            <option value="">@Localizer["AllActionTypes"]</option>
                            <option value="GoodsReceiving">@Localizer["GoodsReceiving"]</option>
                            <option value="TransferOut">@Localizer["TransferOut"]</option>
                            <option value="TransferIn">@Localizer["TransferIn"]</option>
                            <option value="Sale">@Localizer["Sale"]</option>
                            <option value="Return">@Localizer["Return"]</option>
                            <option value="Adjustment">@Localizer["Adjustment"]</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["FromDate"]</label>
                    <input type="date" @bind="filterFromDate" @bind:after="ApplyFilters" class="w-full bg-white border border-gray-300 text-gray-700 py-2 px-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["ToDate"]</label>
                    <input type="date" @bind="filterToDate" @bind:after="ApplyFilters" class="w-full bg-white border border-gray-300 text-gray-700 py-2 px-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm" />
                </div>
            </div>
        </div>
    }
</div>

@if (isLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
        <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
        <span class="bf-text-danger">@errorMessage</span>
    </div>
}
else if (!historyList.Any())
{
    <div class="text-center py-12">
        <i class="bi bi-clock-history text-6xl text-gray-300 mb-4"></i>
        <p class="text-gray-500 text-lg">@Localizer["NoHistoryFound"]</p>
    </div>
}
else
{
    <div>
        <table class="w-full divide-y divide-gray-200 text-sm">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-3 py-2.5 text-start text-sm font-medium text-gray-600 uppercase tracking-wider">@Localizer["DateTime"]</th>
                    <th class="px-3 py-2.5 text-start text-sm font-medium text-gray-600 uppercase tracking-wider">@Localizer["Warehouse"]</th>
                    <th class="px-3 py-2.5 text-start text-sm font-medium text-gray-600 uppercase tracking-wider">@Localizer["Product"]</th>
                    <th class="px-3 py-2.5 text-start text-sm font-medium text-gray-600 uppercase tracking-wider">@Localizer["Action"]</th>
                    <th class="px-3 py-2.5 text-center text-sm font-medium text-gray-600 uppercase tracking-wider">@Localizer["Change"]</th>
                    <th class="px-3 py-2.5 text-center text-sm font-medium text-gray-600 uppercase tracking-wider">Before/After</th>
                    <th class="px-3 py-2.5 text-start text-sm font-medium text-gray-600 uppercase tracking-wider">@Localizer["Reference"]</th>
                    <th class="px-3 py-2.5 text-start text-sm font-medium text-gray-600 uppercase tracking-wider">@Localizer["PerformedBy"]</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var h in historyList)
                {
                    <tr class="hover:bg-gray-50 transition-colors duration-150">
                        <td class="px-3 py-2.5 whitespace-nowrap text-sm text-gray-600">@h.PerformedAt.ToLocal().ToString("dd/MM HH:mm")</td>
                        <td class="px-3 py-2.5 whitespace-nowrap text-sm">
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-sm font-medium bg-teal-100 text-teal-700">@(isAr ? h.WarehouseNameAr : h.WarehouseNameEn)</span>
                        </td>
                        <td class="px-3 py-2.5 text-sm">
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-sm font-medium bg-purple-100 text-purple-700">@(isAr ? h.ProductNameAr : h.ProductNameEn)</span>
                            <div class="text-xs text-gray-500 mt-0.5">(@(isAr ? h.UnitOfMeasureNameAr : h.UnitOfMeasureNameEn) - @h.UnitBaseQuantity @Localizer["BaseUnitItems"])</div>
                        </td>
                        <td class="px-3 py-2.5 whitespace-nowrap text-sm text-gray-600">@Localizer[h.ActionType]</td>
                        <td class="px-3 py-2.5 whitespace-nowrap text-sm font-medium text-center @(h.QuantityChange >= 0 ? "bf-text-success" : "bf-text-danger")">
                            @(h.QuantityChange >= 0 ? "+" : "")@h.QuantityChange
                        </td>
                        <td class="px-3 py-2.5 whitespace-nowrap text-sm text-center">
                            <span class="text-gray-500">@h.AvailableQuantityBefore</span>
                            <span class="text-gray-400 mx-1">→</span>
                            <span class="text-gray-500">@h.AvailableQuantityAfter</span>
                        </td>
                        <td class="px-3 py-2.5 text-sm text-gray-600">@(string.IsNullOrEmpty(h.ReferenceType) ? "—" : Localizer[h.ReferenceType])</td>
                        <td class="px-3 py-2.5 whitespace-nowrap text-sm text-gray-600">@(h.PerformedBy ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="@OnPageChanged" />
}

@code {
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private bool isAr = false;
    private int pageIndex = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private int totalCount = 0;

    // Lookup Data — branch warehouses only
    private List<WarehouseDto> branchWarehouses = new();

    // Filters
    private string filterWarehouseId = string.Empty;
    private string filterType = string.Empty;
    private DateTime? filterFromDate;
    private DateTime? filterToDate;
    private bool showFiltersPanel = false;

    // History State
    private List<InventoryHistoryDto> historyList = new();

    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        ActiveBranch.OnChanged += OnBranchChanged;
        await LoadLookupData();
        await LoadData();
    }

    private async Task LoadLookupData()
    {
        if (!ActiveBranch.BranchId.HasValue) return;
        try
        {
            var all = await WarehouseService.GetActiveWarehousesAsync();
            branchWarehouses = all.Where(w => w.BranchId == ActiveBranch.BranchId.Value).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load lookup data: {ex.Message}");
        }
    }

    private async Task LoadData()
    {
        if (!ActiveBranch.BranchId.HasValue) return;
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            Guid? warehouseId = Guid.TryParse(filterWarehouseId, out var wId) ? wId : null;
            var hResult = await InventoryHistoryService.GetAllAsync(
                pageIndex, pageSize, warehouseId, null,
                string.IsNullOrEmpty(filterType) ? null : filterType,
                filterFromDate, filterToDate,
                branchId: ActiveBranch.BranchId.Value);
            historyList = hResult.Items;
            totalPages = hResult.TotalPages;
            totalCount = hResult.TotalCount;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnPageChanged(int newPage) { pageIndex = newPage; await LoadData(); }
    private async Task ApplyFilters() { pageIndex = 1; await LoadData(); }

    private async Task ResetFilters()
    {
        filterWarehouseId = string.Empty;
        filterType = string.Empty;
        filterFromDate = null;
        filterToDate = null;
        showFiltersPanel = false;
        pageIndex = 1;
        await LoadData();
    }

    private bool HasActiveFilters() =>
        !string.IsNullOrEmpty(filterWarehouseId) || !string.IsNullOrEmpty(filterType) ||
        filterFromDate.HasValue || filterToDate.HasValue;

    private int ActiveFilterCount
    {
        get
        {
            int count = 0;
            if (!string.IsNullOrEmpty(filterWarehouseId)) count++;
            if (!string.IsNullOrEmpty(filterType)) count++;
            if (filterFromDate.HasValue) count++;
            if (filterToDate.HasValue) count++;
            return count;
        }
    }

    private void OnBranchChanged()
    {
        pageIndex = 1;
        filterWarehouseId = string.Empty;
        _ = InvokeAsync(async () =>
        {
            await LoadLookupData();
            await LoadData();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ActiveBranch.OnChanged -= OnBranchChanged;
    }
}
