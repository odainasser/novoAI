@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using Web.Components.Common
@using Web.Models.Warehouses
@using System.Globalization
@using System.Text.Json
@using Web.Models.Requests
@inject IGoodsReceivingClientService GoodsReceivingService
@inject IWarehouseService WarehouseService
@inject IUnitService UnitService
@inject Web.Services.IRequestService RequestService
@inject ActiveBranchContext ActiveBranch
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer
@implements IDisposable

<div class="flex justify-end mb-4">
    <AuthorizeView Policy="Permission:requests.write">
        <Authorized>
            <button @onclick="OpenCreateGrn" disabled="@(!IsCentralWarehouseActive)" class="btn-primary-action" title="@(!IsCentralWarehouseActive ? Localizer["CentralWarehouseDeactivated"] : "")">
                <i class="bi bi-plus-circle"></i>
                <span>@Localizer["CreateGRN"]</span>
            </button>
        </Authorized>
    </AuthorizeView>
</div>

@if (!IsCentralWarehouseActive)
{
    <div class="mb-4 p-4 bf-bg-warning-50 border bf-border-warning rounded-lg flex items-center gap-3">
        <i class="bi bi-exclamation-triangle-fill bf-icon-warning text-lg"></i>
        <span class="text-sm bf-text-warning">@Localizer["CentralWarehouseDeactivatedMessage"]</span>
    </div>
}

<!-- Filters -->
<div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
    <div class="flex flex-wrap items-center gap-3 p-4">
        <div class="flex-1 min-w-[200px]">
            <SearchInput @bind-Value="searchTerm" OnSearch="HandleSearch" Placeholder="@Localizer["SearchGRN"]" />
        </div>

        <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")">
            <i class="bi bi-funnel"></i>
            <span>@Localizer["Filters"]</span>
            @if (ActiveFilterCount > 0)
            {
                <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
            }
            <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
        </button>

        @if (HasActiveFilters())
        {
            <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <i class="bi bi-x-circle"></i>
                <span>@Localizer["ResetFilters"]</span>
            </button>
        }
    </div>

    @if (showFiltersPanel)
    {
        <div class="px-4 pb-4 pt-0 border-t border-gray-200">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-4">
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                    <div class="relative">
                        <select @bind="filterItemStatus" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                            <option value="">@Localizer["All"]</option>
                            <option value="active">@Localizer["Active"]</option>
                            <option value="draft">@Localizer["Draft"]</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
                <div>
                    <SearchableDropdown TItem="WarehouseDto"
                                        TValue="string"
                                        Items="branchWarehouses"
                                        @bind-Value="filterWarehouseId"
                                        OnChanged="ApplyFilters"
                                        DisplayText="w => isAr ? w.NameAr : w.NameEn"
                                        SearchText='w => $"{w.NameEn} {w.NameAr}"'
                                        ItemValue="w => w.Id.ToString()"
                                        Label='@Localizer["Warehouse"]'
                                        Placeholder='@Localizer["AllWarehouses"]'
                                        Disabled='@(filterItemStatus == "draft")'
                                        Compact="true" />
                </div>
            </div>
        </div>
    }
</div>

@if (isLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
        <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
        <span class="bf-text-danger">@errorMessage</span>
    </div>
}
else if (filterItemStatus == "draft" && !draftItems.Any())
{
    <div class="text-center py-12">
        <i class="bi bi-hourglass text-6xl text-gray-300 mb-4"></i>
        <p class="text-gray-500 text-lg">@Localizer["NoDraftsFound"]</p>
    </div>
}
else if (filterItemStatus == "draft")
{
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Label"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["RequestedBy"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Date"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Items"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                    <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var draft in draftItems)
                {
                    <tr class="hover:bg-gray-50 transition-colors duration-150">
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-500">—</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-bf-primary">@draft.RequestedByName</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@draft.CreatedAt.ToLocal().ToString("dd/MM/yyyy")</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@GetDraftProductCount(draft.NewDataJson)</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <span class="px-2 py-1 text-xs font-medium rounded-full bf-bg-warning-100 bf-text-warning">@Localizer["RequestStatusPending"]</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                            <button @onclick="() => ViewDraftGrnDetail(draft.Id)" title="@Localizer["View"]" class="text-indigo-600 hover:text-indigo-900">
                                <i class="bi bi-eye"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="@OnPageChanged" />
}
else
{
    @if (!grnList.Any() && !draftItems.Any())
    {
        <div class="text-center py-12">
            <i class="bi bi-box-arrow-in-down text-6xl text-gray-300 mb-4"></i>
            <p class="text-gray-500 text-lg">@Localizer["NoGRNFound"]</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["GRNNumber"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["RequestedBy"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Date"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Items"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                        <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @if (string.IsNullOrEmpty(filterItemStatus))
                    {
                        @foreach (var draft in draftItems)
                        {
                            <tr class="hover:bg-amber-50 transition-colors duration-150">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-500">—</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-bf-primary">@draft.RequestedByName</span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@draft.CreatedAt.ToLocal().ToString("dd/MM/yyyy")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@GetDraftProductCount(draft.NewDataJson)</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <span class="px-2 py-1 text-xs font-medium rounded-full bf-bg-warning-100 bf-text-warning">@Localizer["RequestStatusPending"]</span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                                    <button @onclick="() => ViewDraftGrnDetail(draft.Id)" title="@Localizer["View"]" class="text-indigo-600 hover:text-indigo-900">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    @foreach (var grn in grnList)
                    {
                        <tr class="hover:bg-gray-50 transition-colors duration-150">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@grn.GRNNumber</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-bf-primary">@(grn.RequestedBy ?? "—")</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@(grn.ReceivedDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@GetGrnProductCount(grn)</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <span class="px-2 py-1 text-xs font-medium rounded-full bf-bg-success-100 bf-text-success">@Localizer["RequestStatusApproved"]</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                                <button @onclick="() => ViewGrnDetail(grn.Id)" title="@Localizer["View"]" class="text-indigo-600 hover:text-indigo-900">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="@OnPageChanged" />
    }
}

<!-- GRN Create Modal -->
@if (showGrnModal)
{
    <div class="fixed inset-0 z-50 overflow-y-auto">
        <div class="flex items-center justify-center min-h-screen px-4">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" @onclick="CloseGrnModal"></div>
            <div class="relative bg-white rounded-2xl shadow-xl max-w-5xl w-full max-h-[90vh] overflow-y-auto p-6 z-10">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold text-gray-900">@Localizer["CreateGRN"]</h3>
                    <button @onclick="CloseGrnModal" class="text-gray-400 hover:text-gray-600">
                        <i class="bi bi-x-lg text-xl"></i>
                    </button>
                </div>

                <div class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["PurchaseOrderReference"]</label>
                            <input type="text" @bind="grnRequest.PurchaseOrderReference" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary focus:border-transparent" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["ReceivedDate"]</label>
                            <input type="date" @bind="grnRequest.ReceivedDate" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary focus:border-transparent" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["Notes"]</label>
                        <textarea @bind="grnRequest.Notes" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary focus:border-transparent"></textarea>
                    </div>

                    <!-- GRN Lines -->
                    <div class="border-t pt-4">
                        <div class="flex justify-between items-center mb-3">
                            <h4 class="text-lg font-semibold text-gray-800">@Localizer["Items"]</h4>
                            <button @onclick="AddGrnLine" class="inline-flex items-center gap-1 px-3 py-1.5 bf-bg-success-600 bf-hover-bg-success-700 rounded-lg text-sm">
                                <i class="bi bi-plus"></i> @Localizer["AddItem"]
                            </button>
                        </div>
                        @for (int i = 0; i < grnRequest.Lines.Count; i++)
                        {
                            var idx = i;
                            var selectedUnit = logisticsUnits.FirstOrDefault(u => u.Id == grnRequest.Lines[idx].UnitId);
                            var lineSuppliers = selectedUnit?.Suppliers ?? new List<Web.Models.Units.UnitSupplierDto>();
                            <div class="mb-3 bg-gray-50 p-3 rounded-lg">
                                <div class="grid grid-cols-12 gap-2 items-end">
                                    <div class="col-span-4">
                                        <label class="block text-xs text-gray-500">@Localizer["Product"] *</label>
                                        <SearchableDropdown TItem="Web.Models.Units.UnitDto" TValue="Guid"
                                                           Items="logisticsUnits"
                                                           Value="grnRequest.Lines[idx].UnitId"
                                                           ValueChanged="(v) => OnGrnLineUnitSelected(idx, v)"
                                                           DisplayText="@(u => (isAr ? u.ProductNameAr : u.ProductNameEn) + " - " + (isAr ? u.UnitOfMeasureNameAr : u.UnitOfMeasureNameEn) + " (" + u.Quantity + ")")"
                                                           ItemValue="@(u => u.Id)"
                                                           Placeholder="@Localizer["SelectProduct"]"
                                                           Compact="true"
                                                           Clearable="false" />
                                    </div>
                                    <div class="col-span-3">
                                        <label class="block text-xs text-gray-500">@Localizer["Supplier"] *</label>
                                        <select @bind="grnRequest.Lines[idx].SupplierId" class="w-full border border-gray-300 rounded px-2 py-1.5 text-sm" disabled="@(lineSuppliers.Count == 0)">
                                            <option value="@Guid.Empty">@Localizer["SelectSupplier"]</option>
                                            @foreach (var s in lineSuppliers)
                                            {
                                                <option value="@s.SupplierId">@(isAr ? s.SupplierNameAr : s.SupplierNameEn)</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-span-2">
                                        <label class="block text-xs text-gray-500">@Localizer["Cost"]</label>
                                        <input type="number" min="0" step="0.01" @bind="grnRequest.Lines[idx].Cost" class="w-full border border-gray-300 rounded px-2 py-1.5 text-sm" />
                                    </div>
                                    <div class="col-span-2">
                                        <label class="block text-xs text-gray-500">@Localizer["Received"] *</label>
                                        <input type="number" min="1" value="@grnRequest.Lines[idx].ReceivedQuantity" @onchange="(e) => OnGrnLineReceivedChanged(idx, e)" class="w-full border border-gray-300 rounded px-2 py-1.5 text-sm" />
                                    </div>
                                    <div class="col-span-1 flex items-end justify-end">
                                        <button @onclick="() => RemoveGrnLine(idx)" class="bf-text-danger bf-hover-text-danger-strong p-1">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="mt-4 p-3 bf-bg-danger-50 border bf-border-danger rounded-lg bf-text-danger text-sm">
                        <i class="bi bi-exclamation-triangle me-1"></i> @modalError
                    </div>
                }

                <div class="flex justify-end gap-3 mt-6 pt-4 border-t">
                    <button @onclick="CloseGrnModal" class="px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 transition-colors">
                        @Localizer["Cancel"]
                    </button>
                    <button @onclick="SaveGrn" disabled="@isSaving" class="px-4 py-2 bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-colors disabled:opacity-50 flex items-center justify-center gap-2">
                        @if (isSaving)
                        {
                            <Spinner Size="Spinner.SpinnerSize.Sm" />
                        }
                        <span>@Localizer["Save"]</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Detail View Modal -->
@if (showDetailModal)
{
    <div class="fixed inset-0 z-50 overflow-y-auto">
        <div class="flex items-center justify-center min-h-screen px-4">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" @onclick="() => showDetailModal = false"></div>
            <div class="relative bg-white rounded-2xl shadow-xl max-w-4xl w-full max-h-[90vh] overflow-y-auto p-6 z-10">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold text-gray-900">@detailModalTitle</h3>
                    <button @onclick="() => showDetailModal = false" class="text-gray-400 hover:text-gray-600">
                        <i class="bi bi-x-lg text-xl"></i>
                    </button>
                </div>
                @detailContent
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private bool isAr = false;
    private int pageIndex = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private int totalCount = 0;

    // Lookup Data — branch warehouses only
    private List<WarehouseDto> branchWarehouses = new();
    private List<WarehouseDto> centralWarehouses = new();
    private List<Web.Models.Units.UnitDto> logisticsUnits = new();

    // Filters
    private string searchTerm = string.Empty;
    private string filterWarehouseId = string.Empty;
    private bool showFiltersPanel = false;
    private string filterItemStatus = string.Empty;

    private List<RequestDto> draftItems = new();
    private List<GoodsReceivingNoteDto> grnList = new();

    // GRN Create Modal
    private bool showGrnModal = false;
    private bool isSaving = false;
    private string modalError = string.Empty;
    private CreateGoodsReceivingNoteRequest grnRequest = new();
    private Guid? editingDraftRequestId = null;

    // Detail Modal
    private bool showDetailModal = false;
    private string detailModalTitle = string.Empty;
    private RenderFragment? detailContent;

    private bool IsCentralWarehouseActive => centralWarehouses.Any();

    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        ActiveBranch.OnChanged += OnBranchChanged;
        await LoadLookupData();
        await LoadData();
    }

    private async Task LoadLookupData()
    {
        if (!ActiveBranch.BranchId.HasValue) return;
        try
        {
            var all = await WarehouseService.GetActiveWarehousesAsync();
            branchWarehouses = all.Where(w => w.BranchId == ActiveBranch.BranchId.Value).ToList();
            // Central warehouses are organisation-wide; needed so we can enforce the
            // same "CW must be active" check the admin GRN modal uses.
            centralWarehouses = all.Where(w => w.WarehouseTypeCode == "CW").ToList();
            var units = (await UnitService.GetAllAsync(1, 500, isActive: true)).Items;
            logisticsUnits = units.Where(u => u.UnitTypes.Any(ut => ut.Code == "UT_LOGISTICS")).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load lookup data: {ex.Message}");
        }
    }

    // GRN Modal Actions
    private void OpenCreateGrn()
    {
        editingDraftRequestId = null;
        grnRequest = new CreateGoodsReceivingNoteRequest { ReceivedDate = DateTime.Today };
        modalError = string.Empty;
        showGrnModal = true;
    }

    private void CloseGrnModal()
    {
        editingDraftRequestId = null;
        showGrnModal = false;
        modalError = string.Empty;
    }

    private void AddGrnLine() => grnRequest.Lines.Add(new CreateGoodsReceivingNoteLineRequest());
    private void RemoveGrnLine(int idx) { if (grnRequest.Lines.Count > 0) grnRequest.Lines.RemoveAt(idx); }

    private void OnGrnLineUnitSelected(int idx, Guid unitId)
    {
        grnRequest.Lines[idx].UnitId = unitId;
        grnRequest.Lines[idx].SupplierId = Guid.Empty;
        var unit = logisticsUnits.FirstOrDefault(u => u.Id == unitId);
        grnRequest.Lines[idx].Cost = unit?.Cost ?? 0;
        grnRequest.Lines[idx].ReceivedQuantity = unitId == Guid.Empty ? 0 : 1;
        if (unit?.Suppliers.Count == 1)
            grnRequest.Lines[idx].SupplierId = unit.Suppliers[0].SupplierId;
    }

    private void OnGrnLineReceivedChanged(int idx, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var qty) && qty > 0)
        {
            grnRequest.Lines[idx].ReceivedQuantity = qty;
            var unit = logisticsUnits.FirstOrDefault(u => u.Id == grnRequest.Lines[idx].UnitId);
            if (unit != null)
                grnRequest.Lines[idx].Cost = unit.Cost * qty;
        }
    }

    private async Task SaveGrn()
    {
        if (!ActiveBranch.BranchId.HasValue) return;
        isSaving = true;
        modalError = string.Empty;

        if (!IsCentralWarehouseActive)
        {
            modalError = Localizer["CentralWarehouseDeactivatedMessage"];
            isSaving = false;
            return;
        }

        try
        {
            if (editingDraftRequestId.HasValue)
            {
                var updated = await RequestService.UpdateAddGRNRequestAsync(editingDraftRequestId.Value,
                    new Web.Models.Requests.CreateInventoryGRNRequest { Data = grnRequest });
                if (updated == null) throw new InvalidOperationException(Localizer["NotFound"]);
            }
            else
            {
                await RequestService.CreateAddGRNRequestAsync(
                    new Web.Models.Requests.CreateInventoryGRNRequest { Data = grnRequest },
                    branchId: ActiveBranch.BranchId.Value);
            }

            CloseGrnModal();
            await LoadData();
        }
        catch (Web.Services.ServerValidationException ex)
        {
            modalError = string.Join(" ", ex.Errors.Values.SelectMany(v => v).Select(e => Localizer[e]));
        }
        catch (Exception ex) { modalError = ex.Message; }
        finally { isSaving = false; }
    }

    private async Task LoadData()
    {
        if (!ActiveBranch.BranchId.HasValue) return;
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            if (filterItemStatus == "draft")
            {
                // Branch drafts: GRN requests submitted by users of this branch
                var result = await RequestService.GetAllRequestsAsync(pageIndex, pageSize, searchTerm,
                    Web.Models.Enums.RequestType.AddGRN, Web.Models.Enums.RequestStatus.Pending,
                    branchId: ActiveBranch.BranchId.Value);
                draftItems = result.Items;
                grnList = new();
                totalPages = result.TotalPages;
                totalCount = result.TotalCount;
            }
            else
            {
                Guid? warehouseId = Guid.TryParse(filterWarehouseId, out var wId) ? wId : null;
                var grnResult = await GoodsReceivingService.GetAllAsync(pageIndex, pageSize, searchTerm,
                    null, warehouseId, null, null, branchId: ActiveBranch.BranchId.Value);
                grnList = grnResult.Items;
                totalPages = grnResult.TotalPages;
                totalCount = grnResult.TotalCount;

                if (string.IsNullOrEmpty(filterItemStatus))
                {
                    var draftResult = await RequestService.GetAllRequestsAsync(1, 100, null,
                        Web.Models.Enums.RequestType.AddGRN, Web.Models.Enums.RequestStatus.Pending,
                        branchId: ActiveBranch.BranchId.Value);
                    draftItems = draftResult.Items;
                }
                else
                {
                    draftItems = new();
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private int GetDraftProductCount(string? json)
    {
        if (string.IsNullOrEmpty(json)) return 0;
        try
        {
            var el = JsonSerializer.Deserialize<JsonElement>(json);
            if (el.TryGetProperty("Lines", out var lines) && lines.ValueKind == JsonValueKind.Array)
            {
                var productIds = new HashSet<Guid>();
                var unknownUnitsCount = 0;
                foreach (var line in lines.EnumerateArray())
                {
                    if (!line.TryGetProperty("UnitId", out var unitIdProp) || unitIdProp.ValueKind != JsonValueKind.String) continue;
                    if (!Guid.TryParse(unitIdProp.GetString(), out var unitId)) continue;
                    var unit = logisticsUnits.FirstOrDefault(u => u.Id == unitId);
                    if (unit != null) productIds.Add(unit.ProductId);
                    else unknownUnitsCount++;
                }
                return productIds.Count + unknownUnitsCount;
            }
        }
        catch { }
        return 0;
    }

    private int GetGrnProductCount(GoodsReceivingNoteDto grn)
    {
        if (grn?.Lines == null || grn.Lines.Count == 0) return 0;
        var productIds = new HashSet<Guid>();
        var fallbackProductNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var line in grn.Lines)
        {
            var unit = logisticsUnits.FirstOrDefault(u => u.Id == line.UnitId);
            if (unit != null) { productIds.Add(unit.ProductId); continue; }
            var productName = isAr ? line.ProductNameAr : line.ProductNameEn;
            if (!string.IsNullOrWhiteSpace(productName)) fallbackProductNames.Add(productName.Trim());
        }
        return productIds.Count + fallbackProductNames.Count;
    }

    private async Task OnPageChanged(int newPage) { pageIndex = newPage; await LoadData(); }
    private async Task HandleSearch(string value) { searchTerm = value; pageIndex = 1; await LoadData(); }
    private async Task ApplyFilters() { pageIndex = 1; await LoadData(); }

    private async Task ResetFilters()
    {
        searchTerm = string.Empty;
        filterWarehouseId = string.Empty;
        filterItemStatus = string.Empty;
        showFiltersPanel = false;
        pageIndex = 1;
        await LoadData();
    }

    private bool HasActiveFilters() => !string.IsNullOrEmpty(filterWarehouseId) || !string.IsNullOrEmpty(filterItemStatus);

    private int ActiveFilterCount
    {
        get
        {
            int count = 0;
            if (!string.IsNullOrEmpty(filterWarehouseId)) count++;
            if (!string.IsNullOrEmpty(filterItemStatus)) count++;
            return count;
        }
    }

    private void OnBranchChanged()
    {
        pageIndex = 1;
        filterWarehouseId = string.Empty;
        _ = InvokeAsync(async () =>
        {
            await LoadLookupData();
            await LoadData();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ActiveBranch.OnChanged -= OnBranchChanged;
    }

    private async Task ViewGrnDetail(Guid id)
    {
