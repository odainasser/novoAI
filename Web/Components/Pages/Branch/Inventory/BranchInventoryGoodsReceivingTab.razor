        var grn = await GoodsReceivingService.GetByIdAsync(id, branchId: ActiveBranch.BranchId.Value);
        if (grn == null) return;

        detailModalTitle = $"{Localizer["GRNDetails"]} - {grn.GRNNumber}";
        detailContent = __builder =>
        {
            <div class="space-y-4">
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                    <div><span class="text-xs text-gray-500 block">@Localizer["Warehouse"]</span><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800">@(isAr ? grn.WarehouseNameAr : grn.WarehouseNameEn)</span></div>
                    <div><span class="text-xs text-gray-500 block">@Localizer["ReceivedDate"]</span><span class="font-medium">@(grn.ReceivedDate?.ToString("dd/MM/yyyy") ?? "—")</span></div>
                    <div><span class="text-xs text-gray-500 block">@Localizer["RequestedBy"]</span><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-bf-primary">@(grn.RequestedBy ?? "—")</span></div>
                    <div><span class="text-xs text-gray-500 block">@Localizer["TotalItems"]</span><span class="font-medium">@GetGrnProductCount(grn)</span></div>
                    <div><span class="text-xs text-gray-500 block">@Localizer["POReference"]</span><span class="font-medium">@(grn.PurchaseOrderReference ?? "—")</span></div>
                    <div><span class="text-xs text-gray-500 block">@Localizer["TotalCost"]</span><span class="font-medium">@grn.Lines.Sum(l => l.Cost).ToString("N2")</span></div>
                </div>
                @if (!string.IsNullOrEmpty(grn.Notes))
                {
                    <div class="bg-gray-50 p-3 rounded-lg">
                        <span class="text-xs text-gray-500 block mb-1">@Localizer["Notes"]</span>
                        <span>@grn.Notes</span>
                    </div>
                }
                <div class="border-t pt-4">
                    <h4 class="font-semibold mb-3">@Localizer["Items"]</h4>
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["Unit"]</th>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["Supplier"]</th>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["Cost"]</th>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["Received"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @foreach (var line in grn.Lines)
                            {
                                var unitName = isAr ? line.UnitOfMeasureNameAr : line.UnitOfMeasureNameEn;
                                var receivedBaseQty = line.ReceivedQuantity * line.UnitBaseQuantity;
                                <tr>
                                    <td class="px-3 py-2">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">@(isAr ? line.ProductNameAr : line.ProductNameEn)</span>
                                        <div class="text-xs text-gray-500 mt-1">@line.UnitBarcode</div>
                                    </td>
                                    <td class="px-3 py-2">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">@(isAr ? line.SupplierNameAr : line.SupplierNameEn)</span>
                                    </td>
                                    <td class="px-3 py-2">@line.Cost.ToString("N2")</td>
                                    <td class="px-3 py-2">
                                        @line.ReceivedQuantity @unitName
                                        <span class="text-xs text-gray-500">(@receivedBaseQty @Localizer["Items"])</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        };
        showDetailModal = true;
    }

