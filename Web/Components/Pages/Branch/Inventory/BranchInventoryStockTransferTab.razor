@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using Web.Components.Common
@using Web.Models.Warehouses
@using System.Globalization
@using System.Text.Json
@using Web.Models.Requests
@inject IStockTransferClientService StockTransferService
@inject IInventoryHistoryClientService InventoryHistoryService
@inject IWarehouseService WarehouseService
@inject IUnitService UnitService
@inject Web.Services.IRequestService RequestService
@inject ActiveBranchContext ActiveBranch
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer
@implements IDisposable

<div class="flex justify-end mb-4">
    <AuthorizeView Policy="Permission:requests.write">
        <Authorized>
            <button @onclick="OpenCreateTransfer" disabled="@(!IsCentralWarehouseActive)" class="btn-primary-action" title="@(!IsCentralWarehouseActive ? Localizer["CentralWarehouseDeactivated"] : "")">
                <i class="bi bi-plus-circle"></i>
                <span>@Localizer["CreateTransfer"]</span>
            </button>
        </Authorized>
    </AuthorizeView>
</div>

@if (!IsCentralWarehouseActive)
{
    <div class="mb-4 p-4 bf-bg-warning-50 border bf-border-warning rounded-lg flex items-center gap-3">
        <i class="bi bi-exclamation-triangle-fill bf-icon-warning text-lg"></i>
        <span class="text-sm bf-text-warning">@Localizer["CentralWarehouseDeactivatedMessage"]</span>
    </div>
}

<!-- Filters -->
<div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
    <div class="flex flex-wrap items-center gap-3 p-4">
        <div class="flex-1 min-w-[200px]">
            <SearchInput @bind-Value="searchTerm" OnSearch="HandleSearch" Placeholder="@Localizer["SearchTransfers"]" />
        </div>

        <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")">
            <i class="bi bi-funnel"></i>
            <span>@Localizer["Filters"]</span>
            @if (ActiveFilterCount > 0)
            {
                <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
            }
            <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
        </button>

        @if (HasActiveFilters())
        {
            <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <i class="bi bi-x-circle"></i>
                <span>@Localizer["ResetFilters"]</span>
            </button>
        }
    </div>

    @if (showFiltersPanel)
    {
        <div class="px-4 pb-4 pt-0 border-t border-gray-200">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 pt-4">
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                    <div class="relative">
                        <select @bind="filterItemStatus" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                            <option value="">@Localizer["All"]</option>
                            <option value="active">@Localizer["Active"]</option>
                            <option value="draft">@Localizer["Draft"]</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["TransferType"]</label>
                    <div class="relative">
                        <select @bind="filterTransferType" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm" disabled="@(filterItemStatus == "draft")">
                            <option value="">@Localizer["AllTypes"]</option>
                            <option value="ToCentral">@Localizer["ToCentral"]</option>
                            <option value="FromCentral">@Localizer["FromCentral"]</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
                <div>
                    <SearchableDropdown TItem="WarehouseDto"
                                        TValue="string"
                                        Items="branchWarehouses"
                                        @bind-Value="filterWarehouseId"
                                        OnChanged="ApplyFilters"
                                        DisplayText="w => isAr ? w.NameAr : w.NameEn"
                                        SearchText='w => $"{w.NameEn} {w.NameAr}"'
                                        ItemValue="w => w.Id.ToString()"
                                        Label='@Localizer["Warehouse"]'
                                        Placeholder='@Localizer["AllWarehouses"]'
                                        Disabled='@(filterItemStatus == "draft")'
                                        Compact="true" />
                </div>
            </div>
        </div>
    }
</div>

@if (isLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
        <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
        <span class="bf-text-danger">@errorMessage</span>
    </div>
}
else if (filterItemStatus == "draft" && !draftItems.Any())
{
    <div class="text-center py-12">
        <i class="bi bi-hourglass text-6xl text-gray-300 mb-4"></i>
        <p class="text-gray-500 text-lg">@Localizer["NoDraftsFound"]</p>
    </div>
}
else if (filterItemStatus == "draft")
{
    <div class="overflow-hidden">
        <table class="w-full table-fixed divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["TransferNumber"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["TransferType"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Warehouse"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Date"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Items"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                    <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var draft in draftItems)
                {
                    var draftType = GetDraftTransferType(draft.NewDataJson);
                    var draftWarehouse = GetDraftWarehouse(draft.NewDataJson);
                    <tr class="hover:bg-gray-50 transition-colors duration-150">
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-500">—</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            @if (!string.IsNullOrEmpty(draftType))
                            {
                                <span class="@(draftType == "ToCentral" ? "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800" : "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800")">@Localizer[draftType]</span>
                            }
                            else { <span>—</span> }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            @if (draftWarehouse != null)
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800">@(isAr ? draftWarehouse.NameAr : draftWarehouse.NameEn)</span>
                            }
                            else { <span>—</span> }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@draft.CreatedAt.ToLocal().ToString("dd/MM/yyyy")</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@GetDraftLineCount(draft.NewDataJson)</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <span class="px-2 py-1 text-xs font-medium rounded-full bf-bg-warning-100 bf-text-warning">@Localizer["RequestStatusPending"]</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                            <button @onclick="() => ViewDraftTransferDetail(draft.Id)" title="@Localizer["View"]" class="text-indigo-600 hover:text-indigo-900">
                                <i class="bi bi-eye"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="@OnPageChanged" />
}
else
{
    @if (!transferList.Any() && !draftItems.Any())
    {
        <div class="text-center py-12">
            <i class="bi bi-arrow-left-right text-6xl text-gray-300 mb-4"></i>
            <p class="text-gray-500 text-lg">@Localizer["NoTransfersFound"]</p>
        </div>
    }
    else
    {
        <div class="overflow-hidden">
            <table class="w-full table-fixed divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["TransferNumber"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["TransferType"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Warehouse"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Date"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Items"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                        <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @if (string.IsNullOrEmpty(filterItemStatus))
                    {
                        @foreach (var draft in draftItems)
                        {
                            var mixedDraftType = GetDraftTransferType(draft.NewDataJson);
                            var mixedDraftWarehouse = GetDraftWarehouse(draft.NewDataJson);
                            <tr class="hover:bg-amber-50 transition-colors duration-150">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-500">—</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    @if (!string.IsNullOrEmpty(mixedDraftType))
                                    {
                                        <span class="@(mixedDraftType == "ToCentral" ? "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800" : "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800")">@Localizer[mixedDraftType]</span>
                                    }
                                    else { <span>—</span> }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    @if (mixedDraftWarehouse != null)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800">@(isAr ? mixedDraftWarehouse.NameAr : mixedDraftWarehouse.NameEn)</span>
                                    }
                                    else { <span>—</span> }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@draft.CreatedAt.ToLocal().ToString("dd/MM/yyyy")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@GetDraftLineCount(draft.NewDataJson)</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <span class="px-2 py-1 text-xs font-medium rounded-full bf-bg-warning-100 bf-text-warning">@Localizer["RequestStatusPending"]</span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                                    <button @onclick="() => ViewDraftTransferDetail(draft.Id)" title="@Localizer["View"]" class="text-indigo-600 hover:text-indigo-900">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    @foreach (var trf in transferList)
                    {
                        <tr class="hover:bg-gray-50 transition-colors duration-150">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@trf.TransferNumber</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                <span class="@(trf.TransferType == "ToCentral" ? "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800" : "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800")">
                                    @Localizer[trf.TransferType]
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800">@(isAr ? trf.WarehouseNameAr : trf.WarehouseNameEn)</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@(trf.RequestedDate?.ToLocal().ToString("dd/MM/yyyy") ?? trf.CreatedAt.ToLocal().ToString("dd/MM/yyyy"))</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@trf.Lines.Count</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <span class="px-2 py-1 text-xs font-medium rounded-full bf-bg-success-100 bf-text-success">@Localizer["Active"]</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                                <button @onclick="() => ViewTransferDetail(trf.Id)" title="@Localizer["View"]" class="text-indigo-600 hover:text-indigo-900">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="@OnPageChanged" />
    }
}

<!-- Stock Transfer Create Modal -->
@if (showTransferModal)
{
    <div class="fixed inset-0 z-50 overflow-y-auto">
        <div class="flex items-center justify-center min-h-screen px-4">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" @onclick="CloseTransferModal"></div>
            <div class="relative bg-white rounded-2xl shadow-xl max-w-4xl w-full max-h-[90vh] overflow-y-auto p-6 z-10">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold text-gray-900">@Localizer["CreateTransfer"]</h3>
                    <button @onclick="CloseTransferModal" class="text-gray-400 hover:text-gray-600">
                        <i class="bi bi-x-lg text-xl"></i>
                    </button>
                </div>

                <div class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["TransferType"] *</label>
                            <select value="@transferRequest.TransferType" @onchange="OnTransferTypeChanged" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary focus:border-transparent">
                                <option value="">@Localizer["SelectTransferType"]</option>
                                <option value="ToCentral">@Localizer["ToCentral"]</option>
                                <option value="FromCentral">@Localizer["FromCentral"]</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["Warehouse"] *</label>
                            <select value="@transferRequest.WarehouseId" @onchange="OnTransferWarehouseChanged" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary focus:border-transparent">
                                <option value="@Guid.Empty">@Localizer["SelectWarehouse"]</option>
                                @foreach (var w in branchWarehouses.Where(w => w.WarehouseTypeCode != "CW"))
                                {
                                    <option value="@w.Id">@(isAr ? w.NameAr : w.NameEn)</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["Notes"]</label>
                        <textarea @bind="transferRequest.Notes" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary focus:border-transparent"></textarea>
                    </div>

                    <!-- Transfer Lines -->
                    <div class="border-t pt-4">
                        <div class="flex justify-between items-center mb-3">
                            <h4 class="text-lg font-semibold text-gray-800">@Localizer["Items"]</h4>
                            <button @onclick="AddTransferLine" class="inline-flex items-center gap-1 px-3 py-1.5 bf-bg-success-600 bf-hover-bg-success-700 rounded-lg text-sm">
                                <i class="bi bi-plus"></i> @Localizer["AddItem"]
                            </button>
                        </div>
                        @for (int i = 0; i < transferRequest.Lines.Count; i++)
                        {
                            var idx = i;
                            <div class="grid grid-cols-12 gap-2 mb-2 items-end bg-gray-50 p-3 rounded-lg">
                                <div class="col-span-5">
                                    <label class="block text-xs text-gray-500">@Localizer["Unit"]</label>
                                    <SearchableDropdown TItem="Web.Models.Units.UnitDto" TValue="Guid"
                                                       Items="transferUnits"
                                                       @bind-Value="transferRequest.Lines[idx].UnitId"
                                                       DisplayText="@(u => (isAr ? u.ProductNameAr : u.ProductNameEn) + " - " + (isAr ? u.UnitOfMeasureNameAr : u.UnitOfMeasureNameEn) + " (" + u.Quantity + ")")"
                                                       ItemValue="@(u => u.Id)"
                                                       Placeholder="@Localizer["SelectUnit"]"
                                                       Compact="true"
                                                       Clearable="false" />
                                </div>
                                <div class="col-span-6">
                                    <label class="block text-xs text-gray-500">@Localizer["Quantity"]</label>
                                    <input type="number" min="1" @bind="transferRequest.Lines[idx].Quantity" class="w-full border border-gray-300 rounded px-2 py-1.5 text-sm" />
                                </div>
                                <div class="col-span-1 flex items-end justify-end">
                                    <button @onclick="() => RemoveTransferLine(idx)" class="bf-text-danger bf-hover-text-danger-strong p-1">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="mt-4 p-3 bf-bg-danger-50 border bf-border-danger rounded-lg bf-text-danger text-sm">
                        <i class="bi bi-exclamation-triangle me-1"></i> @modalError
                    </div>
                }

                <div class="flex justify-end gap-3 mt-6 pt-4 border-t">
                    <button @onclick="CloseTransferModal" class="px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 transition-colors">
                        @Localizer["Cancel"]
                    </button>
                    <button @onclick="SaveTransfer" disabled="@isSaving" class="px-4 py-2 bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-colors disabled:opacity-50 flex items-center justify-center gap-2">
                        @if (isSaving)
                        {
                            <Spinner Size="Spinner.SpinnerSize.Sm" />
                        }
                        <span>@Localizer["Save"]</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Detail View Modal -->
@if (showDetailModal)
{
    <div class="fixed inset-0 z-50 overflow-y-auto">
        <div class="flex items-center justify-center min-h-screen px-4">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" @onclick="() => showDetailModal = false"></div>
            <div class="relative bg-white rounded-2xl shadow-xl max-w-4xl w-full max-h-[90vh] overflow-y-auto p-6 z-10">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold text-gray-900">@detailModalTitle</h3>
                    <button @onclick="() => showDetailModal = false" class="text-gray-400 hover:text-gray-600">
                        <i class="bi bi-x-lg text-xl"></i>
                    </button>
                </div>
                @detailContent
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private bool isAr = false;
    private int pageIndex = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private int totalCount = 0;

    private List<WarehouseDto> branchWarehouses = new();
    private List<WarehouseDto> centralWarehouses = new();
    private List<Web.Models.Units.UnitDto> units = new();

    private string searchTerm = string.Empty;
    private string filterWarehouseId = string.Empty;
    private string filterTransferType = string.Empty;
    private bool showFiltersPanel = false;
    private string filterItemStatus = string.Empty;

    private List<RequestDto> draftItems = new();
    private List<StockTransferDto> transferList = new();

    // Create Modal
    private bool showTransferModal = false;
    private bool isSaving = false;
    private string modalError = string.Empty;
    private CreateStockTransferRequest transferRequest = new();
    private List<Web.Models.Units.UnitDto> transferUnits = new();

    private bool showDetailModal = false;
    private string detailModalTitle = string.Empty;
    private RenderFragment? detailContent;

    private bool IsCentralWarehouseActive => centralWarehouses.Any();

    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        ActiveBranch.OnChanged += OnBranchChanged;
        await LoadLookupData();
        await LoadData();
    }

    private async Task LoadLookupData()
    {
        if (!ActiveBranch.BranchId.HasValue) return;
        try
        {
            var all = await WarehouseService.GetActiveWarehousesAsync();
            branchWarehouses = all.Where(w => w.BranchId == ActiveBranch.BranchId.Value).ToList();
            // Central warehouses are needed both as a source for FromCentral transfers and
            // to enforce the "CW must be active" check the admin modal uses.
            centralWarehouses = all.Where(w => w.WarehouseTypeCode == "CW").ToList();
            units = (await UnitService.GetAllAsync(1, 500, isActive: true)).Items;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load lookup data: {ex.Message}");
        }
    }

    private async Task LoadData()
    {
        if (!ActiveBranch.BranchId.HasValue) return;
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            if (filterItemStatus == "draft")
            {
                var result = await RequestService.GetAllRequestsAsync(pageIndex, pageSize, searchTerm,
                    Web.Models.Enums.RequestType.AddStockTransfer, Web.Models.Enums.RequestStatus.Pending,
                    branchId: ActiveBranch.BranchId.Value);
                draftItems = result.Items;
                transferList = new();
                totalPages = result.TotalPages;
                totalCount = result.TotalCount;
            }
            else
            {
                Guid? warehouseId = Guid.TryParse(filterWarehouseId, out var wId) ? wId : null;
                var trfResult = await StockTransferService.GetAllAsync(pageIndex, pageSize, searchTerm,
                    warehouseId,
                    string.IsNullOrEmpty(filterTransferType) ? null : filterTransferType, null, null,
                    branchId: ActiveBranch.BranchId.Value);
                transferList = trfResult.Items;
                totalPages = trfResult.TotalPages;
                totalCount = trfResult.TotalCount;

                if (string.IsNullOrEmpty(filterItemStatus))
                {
                    var draftResult = await RequestService.GetAllRequestsAsync(1, 100, null,
                        Web.Models.Enums.RequestType.AddStockTransfer, Web.Models.Enums.RequestStatus.Pending,
                        branchId: ActiveBranch.BranchId.Value);
                    draftItems = draftResult.Items;
                }
                else
                {
                    draftItems = new();
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static int GetDraftLineCount(string? json)
    {
        if (string.IsNullOrEmpty(json)) return 0;
        try
        {
            var el = JsonSerializer.Deserialize<JsonElement>(json);
            if (el.TryGetProperty("Lines", out var lines) && lines.ValueKind == JsonValueKind.Array)
                return lines.GetArrayLength();
        }
        catch { }
        return 0;
    }

    private WarehouseDto? GetDraftWarehouse(string? json)
    {
        if (string.IsNullOrEmpty(json)) return null;
        try
        {
            var el = JsonSerializer.Deserialize<JsonElement>(json);
            if (el.TryGetProperty("WarehouseId", out var prop) && Guid.TryParse(prop.GetString(), out var warehouseId))
                return branchWarehouses.FirstOrDefault(w => w.Id == warehouseId);
        }
        catch { }
        return null;
    }

    private static string GetDraftTransferType(string? json)
    {
        if (string.IsNullOrEmpty(json)) return string.Empty;
        try
        {
            var el = JsonSerializer.Deserialize<JsonElement>(json);
            if (el.TryGetProperty("TransferType", out var prop) && prop.ValueKind == JsonValueKind.String)
                return prop.GetString() ?? string.Empty;
        }
        catch { }
        return string.Empty;
    }

    private async Task OnPageChanged(int newPage) { pageIndex = newPage; await LoadData(); }
    private async Task HandleSearch(string value) { searchTerm = value; pageIndex = 1; await LoadData(); }
    private async Task ApplyFilters() { pageIndex = 1; await LoadData(); }

    private async Task ResetFilters()
    {
        searchTerm = string.Empty;
        filterWarehouseId = string.Empty;
        filterTransferType = string.Empty;
        filterItemStatus = string.Empty;
        showFiltersPanel = false;
        pageIndex = 1;
        await LoadData();
    }

    private bool HasActiveFilters() =>
        !string.IsNullOrEmpty(filterWarehouseId) || !string.IsNullOrEmpty(filterTransferType) ||
        !string.IsNullOrEmpty(filterItemStatus);

    private int ActiveFilterCount
    {
        get
        {
            int count = 0;
            if (!string.IsNullOrEmpty(filterWarehouseId)) count++;
            if (!string.IsNullOrEmpty(filterTransferType)) count++;
            if (!string.IsNullOrEmpty(filterItemStatus)) count++;
            return count;
        }
    }

    private void OnBranchChanged()
    {
        pageIndex = 1;
        filterWarehouseId = string.Empty;
        _ = InvokeAsync(async () =>
        {
            await LoadLookupData();
            await LoadData();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ActiveBranch.OnChanged -= OnBranchChanged;
    }

    // Transfer Modal Actions
    private void OpenCreateTransfer()
    {
        transferRequest = new CreateStockTransferRequest();
        transferUnits = new();
        modalError = string.Empty;
        showTransferModal = true;
    }

    private void CloseTransferModal() { showTransferModal = false; modalError = string.Empty; }
    private void AddTransferLine() => transferRequest.Lines.Add(new CreateStockTransferLineRequest());
    private void RemoveTransferLine(int idx) { if (transferRequest.Lines.Count > 0) transferRequest.Lines.RemoveAt(idx); }

    private async Task OnTransferTypeChanged(ChangeEventArgs e)
    {
        transferRequest.TransferType = e.Value?.ToString() ?? string.Empty;
        transferRequest.Lines.Clear();
        await LoadTransferUnits();
    }

    private async Task OnTransferWarehouseChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        transferRequest.WarehouseId = string.IsNullOrEmpty(val) ? Guid.Empty : Guid.Parse(val);
        transferRequest.Lines.Clear();
        await LoadTransferUnits();
    }

    private async Task LoadTransferUnits()
    {
        Guid sourceWarehouseId;
        if (transferRequest.TransferType == "ToCentral")
        {
            sourceWarehouseId = transferRequest.WarehouseId;
        }
        else if (transferRequest.TransferType == "FromCentral")
        {
            var cw = centralWarehouses.FirstOrDefault();
            sourceWarehouseId = cw?.Id ?? Guid.Empty;
        }
        else
        {
            transferUnits = new();
            return;
        }

        if (sourceWarehouseId != Guid.Empty)
        {
            try
            {
                var balances = await InventoryHistoryService.GetStockBalancesAsync(sourceWarehouseId);
                var unitIdsWithStock = balances
                    .Where(b => b.AvailableQuantity >= Math.Max(b.UnitBaseQuantity, 1))
                    .Select(b => b.UnitId)
                    .ToHashSet();
                transferUnits = units.Where(u => unitIdsWithStock.Contains(u.Id)).ToList();
            }
            catch
            {
                transferUnits = new();
            }
        }
        else
        {
            transferUnits = new();
        }
    }

    private async Task SaveTransfer()
    {
        if (!ActiveBranch.BranchId.HasValue) return;
        isSaving = true;
        modalError = string.Empty;

        if (string.IsNullOrEmpty(transferRequest.TransferType))
        {
            modalError = Localizer["TransferTypeRequired"];
            isSaving = false;
            return;
        }

        if (transferRequest.WarehouseId == Guid.Empty)
        {
            modalError = Localizer["WarehouseRequired"];
            isSaving = false;
            return;
        }

        if (!IsCentralWarehouseActive)
        {
            modalError = Localizer["CentralWarehouseDeactivatedMessage"];
            isSaving = false;
            return;
        }

        try
        {
            await RequestService.CreateAddStockTransferRequestAsync(
                new Web.Models.Requests.CreateInventoryTransferRequest { Data = transferRequest },
                branchId: ActiveBranch.BranchId.Value);
            CloseTransferModal();
            await LoadData();
        }
        catch (Web.Services.ServerValidationException ex)
        {
            modalError = string.Join(" ", ex.Errors.Values.SelectMany(v => v).Select(e => Localizer[e]));
        }
        catch (Exception ex) { modalError = ex.Message; }
        finally { isSaving = false; }
    }

