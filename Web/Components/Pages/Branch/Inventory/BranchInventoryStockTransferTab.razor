        var data = JsonSerializer.Deserialize<CreateStockTransferRequest>(draft.NewDataJson);
        if (data == null) return;

        detailModalTitle = $"{Localizer["TransferDetails"]} - {Localizer["RequestStatusPending"]}";
        detailContent = __builder =>
        {
            <div class="space-y-4">
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                    <div><span class="text-xs text-gray-500 block">@Localizer["TransferType"]</span><span class="font-medium">@(string.IsNullOrEmpty(data.TransferType) ? "—" : Localizer[data.TransferType])</span></div>
                    <div><span class="text-xs text-gray-500 block">@Localizer["RequestedBy"]</span><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-bf-primary">@draft.RequestedByName</span></div>
                    <div><span class="text-xs text-gray-500 block">@Localizer["Status"]</span><span class="px-2 py-1 text-xs font-medium rounded-full bf-bg-warning-100 bf-text-warning">@Localizer["RequestStatusPending"]</span></div>
                </div>
                @if (!string.IsNullOrEmpty(data.Notes))
                {
                    <div class="bg-gray-50 p-3 rounded-lg">
                        <span class="text-xs text-gray-500 block mb-1">@Localizer["Notes"]</span>
                        <span>@data.Notes</span>
                    </div>
                }
                <div class="border-t pt-4">
                    <h4 class="font-semibold mb-3">@Localizer["Items"]</h4>
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["Unit"]</th>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["Quantity"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @foreach (var line in data.Lines)
                            {
                                var unit = units.FirstOrDefault(u => u.Id == line.UnitId);
                                <tr>
                                    <td class="px-3 py-2">@(unit != null ? (isAr ? unit.ProductNameAr : unit.ProductNameEn) : "—")</td>
