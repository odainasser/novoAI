        if (trf == null) return;

        detailModalTitle = $"{Localizer["TransferDetails"]} - {trf.TransferNumber}";
        detailContent = __builder =>
        {
            <div class="space-y-4">
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                    <div><span class="text-xs text-gray-500 block">@Localizer["TransferType"]</span><span class="@(trf.TransferType == "ToCentral" ? "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800" : "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800")">@Localizer[trf.TransferType]</span></div>
                    <div><span class="text-xs text-gray-500 block">@Localizer["Warehouse"]</span><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800">@(isAr ? trf.WarehouseNameAr : trf.WarehouseNameEn)</span></div>
