@page "/branch/cashiers"
@layout BranchLayout
@attribute [Authorize]
@attribute [RequirePermission(Permissions.CashiersRead)]
@using Microsoft.AspNetCore.Authorization
@using System.Globalization
@using Web.Authorization
@using Web.Components.Common
@using Web.Models.Cashiers
@using Web.Models.Warehouses
@inject ICashierManagementService CashierService
@inject IWarehouseService WarehouseService
@inject ActiveBranchContext ActiveBranch
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>@Localizer["Cashiers"]</PageTitle>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6">
            <!-- Header -->
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
                        <i class="bi bi-people text-purple-600"></i>
                        @Localizer["Cashiers"]
                    </h1>
                    <p class="text-gray-600 mt-2 text-sm sm:text-base">@Localizer["BranchCashiersDescription"]</p>
                </div>
            </div>

            <!-- Filters -->
            <div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
                <div class="flex flex-wrap items-center gap-3 p-4">
                    <div class="flex-1 min-w-[200px]">
                        <SearchInput @bind-Value="searchTerm"
                                     OnSearch="HandleSearch"
                                     Placeholder="@Localizer["SearchCashiers"]" />
                    </div>

                    <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                            class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")">
                        <i class="bi bi-funnel"></i>
                        <span>@Localizer["Filters"]</span>
                        @if (ActiveFilterCount > 0)
                        {
                            <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
                        }
                        <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
                    </button>

                    @if (HasActiveFilters())
                    {
                        <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                            <i class="bi bi-x-circle"></i>
                            <span>@Localizer["ResetFilters"]</span>
                        </button>
                    }
                </div>

                @if (showFiltersPanel)
                {
                    <div class="px-4 pb-4 pt-0 border-t border-gray-200">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-4">
                            <div>
                                <SearchableDropdown TItem="WarehouseDto"
                                                    TValue="string"
                                                    Items="branchStores"
                                                    @bind-Value="selectedStoreId"
                                                    OnChanged="ApplyFilters"
                                                    DisplayText='w => isAr ? w.NameAr : w.NameEn'
                                                    SearchText='w => $"{w.NameEn} {w.NameAr}"'
                                                    ItemValue="w => w.Id.ToString()"
                                                    Label='@Localizer["Store"]'
                                                    Placeholder='@Localizer["AllStores"]'
                                                    Compact="true" />
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                                <div class="relative">
                                    <select @bind="selectedStatus" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                                        <option value="">@Localizer["AllStatuses"]</option>
                                        <option value="true">@Localizer["Active"]</option>
                                        <option value="false">@Localizer["Inactive"]</option>
                                    </select>
                                    <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

            </div>

            @if (!ActiveBranch.IsSelected)
            {
                <Alert Type="Alert.AlertType.Warning"
                       Message="@Localizer["NoBranchSelected"]"
                       Dismissible="false" />
            }
            else if (isLoading)
            {
                <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
                    <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
                    <span class="bf-text-danger">@errorMessage</span>
                </div>
            }
            else if (pagedCashiers == null || !pagedCashiers.Any())
            {
                <div class="text-center py-12">
                    <i class="bi bi-inbox text-6xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500 text-lg">@Localizer["NoCashiersFound"]</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Cashier"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Email"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Stores"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                                <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var c in pagedCashiers)
                            {
                                <tr class="hover:bg-gray-50 transition-colors duration-150">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            @if (!string.IsNullOrEmpty(c.AvatarUrl))
                                            {
                                                <img src="@c.AvatarUrl" alt="@c.FullName" class="flex-shrink-0 h-10 w-10 rounded-full object-cover border border-gray-200" />
                                            }
                                            else
                                            {
                                                <div class="flex-shrink-0 h-10 w-10 bg-purple-100 rounded-full flex items-center justify-center">
                                                    <i class="bi bi-person-fill text-purple-600"></i>
                                                </div>
                                            }
                                            <div class="ms-4">
                                                <div class="text-sm font-medium text-gray-900">@c.FullName</div>
                                                @if (!string.IsNullOrEmpty(c.PhoneNumber))
                                                {
                                                    <div class="text-xs text-gray-500 mt-0.5">@c.PhoneNumber</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <a href="mailto:@c.Email" class="text-sm text-purple-600 hover:text-purple-800 hover:underline">@c.Email</a>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex flex-wrap gap-1">
                                            @{
                                                // Show only the cashier's stores that belong to this branch.
                                                var branchStoreIds = branchStores.Select(s => s.Id).ToHashSet();
                                                var visibleStores = c.AssignedWarehouses
                                                    .Where(w => branchStoreIds.Contains(w.Id))
                                                    .ToList();
                                            }
                                            @if (visibleStores.Any())
                                            {
                                                @foreach (var w in visibleStores)
                                                {
                                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800">
                                                        @(isAr ? w.NameAr : w.NameEn)
                                                    </span>
                                                }
                                            }
                                            else if (c.WarehouseId.HasValue && branchStoreIds.Contains(c.WarehouseId.Value))
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800">
                                                    @(isAr ? c.WarehouseNameAr : c.WarehouseNameEn)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-gray-400 text-sm">-</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        @if (c.IsActive)
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-success-100 bf-text-success">
                                                <i class="bi bi-check-circle-fill me-1"></i> @Localizer["Active"]
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-danger-100 bf-text-danger">
                                                <i class="bi bi-x-circle-fill me-1"></i> @Localizer["Inactive"]
                                            </span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                                        <AuthorizeView Policy="Permission:shifts.read">
                                            <Authorized>
                                                <button @onclick="() => OpenShiftsModal(c)" title="@Localizer["ViewShifts"]" class="text-amber-600 hover:text-amber-900">
                                                    <i class="bi bi-clock-history"></i>
                                                </button>
                                            </Authorized>
                                            <NotAuthorized>
                                                <button disabled class="text-gray-300 cursor-not-allowed" title="@Localizer["ViewShifts"]">
                                                    <i class="bi bi-clock-history"></i>
                                                </button>
                                            </NotAuthorized>
                                        </AuthorizeView>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <Pagination PageIndex="@pageIndex"
                                TotalPages="@totalPages"
                                TotalCount="@totalCount"
                                PageSize="@pageSize"
                                OnPageChanged="@OnPageChanged" />
                </div>
            }
</div>

<CashierShiftsModal IsVisible="@showShiftsModal" CashierName="@shiftsModalCashierName" OnClose="CloseShiftsModal" />

@code {
    private List<CashierResponse> branchCashiers = new();
    private List<CashierResponse> pagedCashiers = new();
    private List<WarehouseDto> branchStores = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private bool isAr = false;

    // Filters
    private string searchTerm = string.Empty;
    private string selectedStoreId = string.Empty;
    private string selectedStatus = string.Empty;
    private bool showFiltersPanel = false;

    private bool HasActiveFilters() => !string.IsNullOrEmpty(selectedStoreId) || !string.IsNullOrEmpty(selectedStatus);
    private int ActiveFilterCount => (string.IsNullOrEmpty(selectedStoreId) ? 0 : 1) + (string.IsNullOrEmpty(selectedStatus) ? 0 : 1);

    // Pagination (client-side — list is small per branch and the cashier API doesn't accept branchId)
    private int pageIndex = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private int totalCount = 0;

    // Shifts modal
    private bool showShiftsModal = false;
    private string? shiftsModalCashierName;

    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);

        ActiveBranch.OnChanged += OnBranchChanged;

        if (!ActiveBranch.IsSelected)
        {
            Navigation.NavigateTo("/branch/select", replace: true);
            return;
        }

        await LoadAll();
    }

    private async Task LoadAll()
    {
        await LoadBranchStores();
        await LoadCashiers();
    }

    private async Task LoadBranchStores()
    {
        if (!ActiveBranch.BranchId.HasValue) return;
        var branchId = ActiveBranch.BranchId.Value;
        try
        {
            var allWarehouses = await WarehouseService.GetActiveWarehousesAsync();
            branchStores = allWarehouses
                .Where(w => w.WarehouseTypeCode == "MS" && w.BranchId == branchId)
                .ToList();
        }
        catch
        {
            branchStores = new List<WarehouseDto>();
        }
    }

    private async Task LoadCashiers()
    {
        if (!ActiveBranch.BranchId.HasValue) return;
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            // Cashier API has no branchId filter, so we fetch a large page and filter
            // client-side to cashiers assigned to any of this branch's MS warehouses.
            bool? isActive = string.IsNullOrEmpty(selectedStatus) ? null : bool.Parse(selectedStatus);
            var result = await CashierService.GetAllCashiersAsync(1, 500, searchTerm, isActive);

            var branchStoreIds = branchStores.Select(s => s.Id).ToHashSet();

            branchCashiers = result.Items
                .Where(c => (c.WarehouseId.HasValue && branchStoreIds.Contains(c.WarehouseId.Value))
                            || c.AssignedWarehouses.Any(a => branchStoreIds.Contains(a.Id)))
                .ToList();

            // Optional store filter narrows further to a specific branch store
            if (!string.IsNullOrEmpty(selectedStoreId) && Guid.TryParse(selectedStoreId, out var storeFilterId))
            {
                branchCashiers = branchCashiers
                    .Where(c => c.WarehouseId == storeFilterId
                                || c.AssignedWarehouses.Any(a => a.Id == storeFilterId))
                    .ToList();
            }

            ApplyPaging();
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToLoadCashiers"]}: {ex.Message}";
            branchCashiers = new List<CashierResponse>();
            pagedCashiers = new List<CashierResponse>();
            totalCount = 0;
            totalPages = 1;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyPaging()
    {
        totalCount = branchCashiers.Count;
        totalPages = Math.Max(1, (int)Math.Ceiling((double)totalCount / pageSize));
        if (pageIndex > totalPages) pageIndex = totalPages;
        pagedCashiers = branchCashiers
            .Skip((pageIndex - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private async Task HandleSearch(string searchValue)
    {
        searchTerm = searchValue;
        pageIndex = 1;
        await LoadCashiers();
    }

    private async Task ApplyFilters()
    {
        pageIndex = 1;
        await LoadCashiers();
    }

    private async Task ResetFilters()
    {
        searchTerm = string.Empty;
        selectedStoreId = string.Empty;
        selectedStatus = string.Empty;
        pageIndex = 1;
        await LoadCashiers();
    }

    private void OnPageChanged(int newPageIndex)
    {
        pageIndex = newPageIndex;
        ApplyPaging();
        StateHasChanged();
    }

    private void OnBranchChanged()
    {
        pageIndex = 1;
        searchTerm = string.Empty;
        selectedStoreId = string.Empty;
        selectedStatus = string.Empty;
        _ = InvokeAsync(LoadAll);
    }

    public void Dispose()
    {
        ActiveBranch.OnChanged -= OnBranchChanged;
    }

    private void OpenShiftsModal(CashierResponse c)
    {
        shiftsModalCashierName = c.FullName;
        showShiftsModal = true;
    }

    private void CloseShiftsModal()
    {
        showShiftsModal = false;
        shiftsModalCashierName = null;
    }
}
