    private async Task ToggleDetail(Guid requestId)
    {
        if (expandedRequestId == requestId)
        {
            expandedRequestId = null;
            return;
        }

        expandedRequestId = requestId;

        var req = requests.FirstOrDefault(r => r.Id == requestId);

        // Resolve unit names for inventory requests
        if (req != null && !requestUnitNamesMap.ContainsKey(requestId) &&
            (req.Type == RequestType.AddGRN || req.Type == RequestType.AddStockAdjustment || req.Type == RequestType.AddStockTransfer) &&
            !string.IsNullOrEmpty(req.NewDataJson))
        {
            try
            {
                var data = JsonSerializer.Deserialize<JsonElement>(req.NewDataJson);
                var unitIds = new HashSet<Guid>();

                if (data.TryGetProperty("Lines", out var lines) && lines.ValueKind == JsonValueKind.Array)
                {
                    foreach (var line in lines.EnumerateArray())
                    {
                        if (line.TryGetProperty("UnitId", out var uid) && Guid.TryParse(uid.GetString(), out var unitId))
                            unitIds.Add(unitId);
                    }
                }

                var unitNames = new Dictionary<Guid, string>();
                foreach (var unitId in unitIds)
                {
                    var unit = await UnitService.GetByIdAsync(unitId);
                    if (unit != null)
                    {
                        var productName = isAr ? unit.ProductNameAr : unit.ProductNameEn;
                        var uomName = isAr ? unit.UnitOfMeasureNameAr : unit.UnitOfMeasureNameEn;
                        unitNames[unitId] = $"{productName} ({uomName}, {Localizer["BaseUnits"]}: {unit.Quantity})";
                    }
                }

                requestUnitNamesMap[requestId] = unitNames;
            }
            catch
            {
                requestUnitNamesMap[requestId] = new Dictionary<Guid, string>();
            }
        }

        if (!requestMediaMap.ContainsKey(requestId)
            && req?.Type != RequestType.DeleteProduct && req?.Type != RequestType.DeleteUnit)
        {
            try
            {
                var oldImages = GetOldImagesFromRequest(req);
                var newImages = new List<MediaDto>();
                var removedImageIds = new HashSet<Guid>();
                Guid? selectedMainImageId = null;

                if (!string.IsNullOrEmpty(req?.NewDataJson))
                {
                    try
                    {
                        var data = JsonSerializer.Deserialize<JsonElement>(req.NewDataJson);
                        if (data.TryGetProperty("RemovedImageIds", out var removedIds) && removedIds.ValueKind == JsonValueKind.Array)
                        {
                            foreach (var item in removedIds.EnumerateArray())
                            {
                                if (Guid.TryParse(item.GetString(), out var removedId))
                                    removedImageIds.Add(removedId);
                            }
                        }

                        if (data.TryGetProperty("MainImageId", out var mainImageId) && mainImageId.ValueKind != JsonValueKind.Null)
                            selectedMainImageId = mainImageId.GetGuid();
                    }
                    catch
                    {
                        removedImageIds.Clear();
                        selectedMainImageId = null;
                    }
                }

                var requestMedia = (await MediaService.GetMediaForEntityAsync(requestId, "Request", "image")).ToList();

                if (!oldImages.Any() && req?.ProductId.HasValue == true)
                {
                    oldImages = (await MediaService.GetMediaForEntityAsync(req.ProductId.Value, "Product", "image"))
                        .Select(CloneMedia)
                        .ToList();
                }

                if (req?.Status == RequestStatus.Pending)
                {
                    newImages.AddRange(requestMedia.Select(CloneMedia));
                    var existingIds = newImages.Select(m => m.Id).ToHashSet();
                    newImages.AddRange(oldImages
                        .Where(m => !removedImageIds.Contains(m.Id) && !existingIds.Contains(m.Id))
                        .Select(CloneMedia));
                }
                else if (req?.ProductId.HasValue == true)
                {
                    newImages = (await MediaService.GetMediaForEntityAsync(req.ProductId.Value, "Product", "image"))
                        .Select(CloneMedia)
                        .ToList();
                }
                else
                {
                    newImages.AddRange(requestMedia.Select(CloneMedia));
                }

                var requestMain = requestMedia.FirstOrDefault(media => media.IsMain);
                if (requestMain != null)
                {
                    foreach (var media in newImages)
                        media.IsMain = media.Id == requestMain.Id;
                }
                else if (selectedMainImageId.HasValue)
                {
                    foreach (var media in newImages)
                        media.IsMain = media.Id == selectedMainImageId.Value;
                }

                requestMediaMap[requestId] = new RequestImageDiff
                {
                    OldImages = oldImages,
                    NewImages = newImages
                };
            }
            catch
            {
                requestMediaMap[requestId] = new RequestImageDiff();
            }
        }
    }

    private RenderFragment RenderInventoryRequestData(RequestDto req, Dictionary<Guid, string> unitNames) => builder =>
    {
        if (string.IsNullOrEmpty(req.NewDataJson)) return;

        JsonElement data;
        try { data = JsonSerializer.Deserialize<JsonElement>(req.NewDataJson); }
        catch { return; }

        int seq = 0;

        var fields = new List<(string Label, string Value)>();
        if (req.Type == RequestType.AddGRN)
        {
            if (data.TryGetProperty("ReceivedDate", out var rd) && rd.ValueKind != JsonValueKind.Null
                && DateTime.TryParse(rd.GetString(), out var dt))
                fields.Add((Localizer["ReceivedDate"], dt.ToString("dd/MM/yyyy")));
            if (data.TryGetProperty("PurchaseOrderReference", out var por) && por.ValueKind != JsonValueKind.Null
                && !string.IsNullOrEmpty(por.GetString()))
                fields.Add((Localizer["POReference"], por.GetString()!));
            if (data.TryGetProperty("Notes", out var grnNotes) && grnNotes.ValueKind != JsonValueKind.Null
                && !string.IsNullOrEmpty(grnNotes.GetString()))
                fields.Add((Localizer["Notes"], grnNotes.GetString()!));
        }
        else if (req.Type == RequestType.AddStockAdjustment)
        {
            if (data.TryGetProperty("AdjustmentType", out var adjType) && adjType.ValueKind != JsonValueKind.Null)
                fields.Add((Localizer["AdjustmentType"], Localizer[adjType.GetString() ?? ""]));
            if (data.TryGetProperty("Explanation", out var exp) && exp.ValueKind != JsonValueKind.Null
                && !string.IsNullOrEmpty(exp.GetString()))
                fields.Add((Localizer["Explanation"], exp.GetString()!));
        }
        else if (req.Type == RequestType.AddStockTransfer)
        {
            if (data.TryGetProperty("TransferType", out var trfType) && trfType.ValueKind != JsonValueKind.Null)
                fields.Add((Localizer["TransferType"], Localizer[trfType.GetString() ?? ""]));
            if (data.TryGetProperty("Notes", out var trfNotes) && trfNotes.ValueKind != JsonValueKind.Null
                && !string.IsNullOrEmpty(trfNotes.GetString()))
                fields.Add((Localizer["Notes"], trfNotes.GetString()!));
