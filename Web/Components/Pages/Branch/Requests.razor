        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "mb-4");

        builder.OpenElement(seq++, "h4");
        builder.AddAttribute(seq++, "class", "text-sm font-semibold text-gray-700 mb-2 flex items-center gap-1");
        builder.OpenElement(seq++, "i");
        builder.AddAttribute(seq++, "class", "bi bi-file-earmark-plus bf-icon-success");
        builder.CloseElement();
        builder.AddContent(seq++, " " + Localizer["NewData"]);
        builder.CloseElement();

        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "bf-bg-success-50 border bf-border-success rounded-lg p-3 text-sm");

        if (fields.Any())
        {
            builder.OpenElement(seq++, "dl");
            builder.AddAttribute(seq++, "class", "space-y-1");
            foreach (var (label, value) in fields)
            {
                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "flex items-start gap-2");
                builder.OpenElement(seq++, "dt");
                builder.AddAttribute(seq++, "class", "font-medium text-gray-600 min-w-[120px]");
                builder.AddContent(seq++, label);
                builder.CloseElement();
                builder.OpenElement(seq++, "dd");
                builder.AddAttribute(seq++, "class", "text-gray-700");
                builder.AddContent(seq++, value);
                builder.CloseElement();
                builder.CloseElement();
            }
            builder.CloseElement();
        }

        if (data.TryGetProperty("Lines", out var lines) && lines.ValueKind == JsonValueKind.Array && lines.GetArrayLength() > 0)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "mt-3 pt-3 border-t bf-border-success");

            builder.OpenElement(seq++, "p");
            builder.AddAttribute(seq++, "class", "font-medium text-gray-600 mb-2");
            builder.AddContent(seq++, $"{Localizer["Items"]} ({lines.GetArrayLength()})");
            builder.CloseElement();

            builder.OpenElement(seq++, "table");
            builder.AddAttribute(seq++, "class", "min-w-full text-xs divide-y divide-green-100");

            builder.OpenElement(seq++, "thead");
            builder.OpenElement(seq++, "tr");

            void Th(string text)
            {
                builder.OpenElement(seq++, "th");
                builder.AddAttribute(seq++, "class", "px-2 py-1.5 text-start font-medium text-gray-500");
                builder.AddContent(seq++, text);
