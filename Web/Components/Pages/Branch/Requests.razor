                    builder.AddContent(seq++, aQty.GetInt32().ToString());
                else if (req.Type == RequestType.AddStockTransfer && line.TryGetProperty("Quantity", out var tQty))
                    builder.AddContent(seq++, tQty.GetInt32().ToString());
