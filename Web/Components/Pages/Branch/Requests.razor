@page "/branch/requests"
@layout BranchLayout
@attribute [Authorize]
@attribute [RequirePermission(Permissions.RequestsRead)]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Globalization
@using System.Text.Json
@using Web.Authorization
@using Web.Components.Common
@using Web.Models.Enums
@using Web.Models.Requests
@using Web.Services
@inject IRequestService RequestService
@inject IMediaService MediaService
@inject IUnitService UnitService
@inject ICurrentUserService CurrentUserService
@inject ActiveBranchContext ActiveBranch
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>@Localizer["Requests"]</PageTitle>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
                <i class="bi bi-clipboard2-pulse text-purple-600"></i>
                @Localizer["Requests"]
            </h1>
            <p class="text-gray-600 mt-2 text-sm sm:text-base">@Localizer["BranchRequestsDescription"]</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
        <div class="flex flex-wrap items-center gap-3 p-4">
            <div class="flex-1 min-w-[200px]">
                <SearchInput @bind-Value="searchQuery"
                             OnSearch="HandleSearch"
                             Placeholder="@Localizer["SearchRequests"]" />
            </div>

            <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                    class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")">
                <i class="bi bi-funnel"></i>
                <span>@Localizer["Filters"]</span>
                @if (ActiveFilterCount > 0)
                {
                    <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
                }
                <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
            </button>

            @if (HasActiveFilters())
            {
                <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                    <i class="bi bi-x-circle"></i>
                    <span>@Localizer["ResetFilters"]</span>
                </button>
            }
        </div>

        @if (showFiltersPanel)
        {
            <div class="px-4 pb-4 pt-0 border-t border-gray-200">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-4">
                    <div>
                        <SearchableDropdown TItem="RequestType"
                                            TValue="string"
                                            Items="RequestTypeOptions"
                                            @bind-Value="SelectedTypeValue"
                                            OnChanged="LoadRequests"
                                            DisplayText="t => GetTypeText(t)"
                                            SearchText="t => GetTypeText(t)"
                                            ItemValue="t => t.ToString()"
                                            Label='@Localizer["Type"]'
                                            Placeholder='@Localizer["AllTypes"]'
                                            Compact="true" />
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                        <div class="relative">
                            <select @bind="selectedStatus" @bind:after="LoadRequests" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                                <option value="">@Localizer["AllStatuses"]</option>
                                <option value="@RequestStatus.Pending">@Localizer["RequestStatusPending"]</option>
                                <option value="@RequestStatus.Approved">@Localizer["RequestStatusApproved"]</option>
                                <option value="@RequestStatus.Rejected">@Localizer["RequestStatusRejected"]</option>
                            </select>
                            <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                        </div>
                    </div>
                </div>
            </div>
        }

    </div>

    @if (!ActiveBranch.IsSelected)
    {
        <Alert Type="Alert.AlertType.Warning"
               Message="@Localizer["NoBranchSelected"]"
               Dismissible="false" />
    }
    else if (isLoading)
    {
        <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
            <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
            <span class="bf-text-danger">@errorMessage</span>
        </div>
    }
    else if (requests == null || !requests.Any())
    {
        <div class="text-center py-12">
            <i class="bi bi-inbox text-6xl text-gray-300 mb-4"></i>
            <p class="text-gray-500 text-lg">@Localizer["NoRequestsFound"]</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Type"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["RequestedBy"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Details"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Date"]</th>
                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                        <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var req in requests)
                    {
                        <tr class="hover:bg-gray-50 transition-colors duration-150">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 py-1 text-xs font-medium rounded-full @GetTypeBadgeClass(req.Type)">
                                    @GetTypeText(req.Type)
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-cyan-100 text-cyan-800">
                                    @req.RequestedByName
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                @if (req.Type == RequestType.ChangePrice || req.Type == RequestType.SetUnitPrice || req.Type == RequestType.SetLogisticsDetails)
                                {
                                    <div class="text-sm">
                                        <div class="font-medium text-gray-900">@req.ProductName</div>
                                        @if (IsUnitRelatedRequest(req.Type) || req.UnitId.HasValue)
                                        {
                                            <div class="mt-1 flex flex-wrap gap-1">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-sky-100 text-sky-800 border border-sky-200">@Localizer["Unit"]</span>
                                            </div>
                                        }
                                        <div class="text-gray-500">
                                            @if (req.CurrentPrice.HasValue)
                                            {
                                                <span>@req.CurrentPrice.Value.ToString("N2", cultureInfo) @Localizer["CurrencyUnit"]</span>
                                                <i class="bi bi-arrow-right mx-1 rtl:rotate-180"></i>
                                            }
                                            <span class="font-semibold @(req.Type == RequestType.ChangePrice ? "text-purple-600" : req.Type == RequestType.SetLogisticsDetails ? "text-teal-600" : "bf-text-success")">@req.NewPrice?.ToString("N2", cultureInfo) @Localizer["CurrencyUnit"]</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(req.Note))
                                        {
                                            <div class="text-xs text-gray-400 mt-1">@req.Note</div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="text-sm">
                                        <div class="font-medium text-gray-900">@req.ProductName</div>
                                        @if (IsUnitRelatedRequest(req.Type) || req.UnitId.HasValue)
                                        {
                                            <div class="mt-1 flex flex-wrap gap-1">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-sky-100 text-sky-800 border border-sky-200">@Localizer["Unit"]</span>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(req.Note))
                                        {
                                            <div class="text-xs text-gray-400 mt-1">@req.Note</div>
                                        }
                                    </div>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                @req.CreatedAt.ToLocal().ToString("g", cultureInfo)
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 py-1 text-xs font-medium rounded-full @GetStatusClass(req.Status)">
                                    @GetStatusText(req.Status)
                                </span>
                                @if (req.Status == RequestStatus.Approved && req.ApprovedByName != null)
                                {
                                    <div class="mt-1"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-success-100 bf-text-success">@req.ApprovedByName</span></div>
                                }
                                else if (req.Status == RequestStatus.Rejected && req.RejectedByName != null)
                                {
                                    <div class="mt-1"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bf-bg-danger-100 bf-text-danger">@req.RejectedByName</span></div>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                                @if (HasExpandableContent(req))
                                {
                                <button @onclick="() => ToggleDetail(req.Id)"
                                        class="text-blue-600 hover:text-blue-800 p-2 hover:bg-blue-50 rounded-lg transition-colors"
                                        title="@Localizer["ViewDetails"]">
                                    <i class="bi @(expandedRequestId == req.Id ? "bi-chevron-up" : "bi-chevron-down") text-lg"></i>
                                </button>
                                }
                                @if (req.Status == RequestStatus.Pending && req.RequestedById == currentUserId)
                                {
                                    <button @onclick="() => ConfirmDelete(req.Id)"
                                            class="ms-1 bf-text-danger bf-hover-text-danger-strong p-2 bf-hover-bg-danger-50 rounded-lg transition-colors"
                                            title="@Localizer["Delete"]">
                                        <i class="bi bi-trash text-lg"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                        @if (expandedRequestId == req.Id)
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-4 bg-gray-50">
                                    @if (req.Type == RequestType.AddGRN || req.Type == RequestType.AddStockAdjustment || req.Type == RequestType.AddStockTransfer)
                                    {
                                        @RenderInventoryRequestData(req, requestUnitNamesMap.GetValueOrDefault(req.Id) ?? new())
                                    }
                                    else if (req.Type == RequestType.DeleteProduct || req.Type == RequestType.DeleteUnit)
                                    {
                                        <div class="flex flex-col gap-2 mb-4">
                                            <div class="flex items-start gap-2 @(req.Status == RequestStatus.Rejected ? "bf-bg-danger-50 border bf-border-danger" : "bf-bg-success-50 border bf-border-success") rounded-lg px-3 py-2 text-sm">
                                                <i class="bi bi-person-check @(req.Status == RequestStatus.Rejected ? "bf-icon-danger" : "bf-icon-success") mt-0.5"></i>
                                                <div>
                                                    <span class="font-medium @(req.Status == RequestStatus.Rejected ? "bf-text-danger" : "bf-text-success")">@Localizer["ReviewNote"]:</span>
                                                    <span class="@(req.Status == RequestStatus.Rejected ? "bf-text-danger" : "bf-text-success") ms-1">@(string.IsNullOrEmpty(req.ReviewNote) ? "—" : req.ReviewNote)</span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                    else if (!string.IsNullOrEmpty(req.NewDataJson))
                                    {
                                        <div class="grid grid-cols-1 @(string.IsNullOrEmpty(req.OldDataJson) ? "" : "md:grid-cols-2") gap-4 mb-4">
                                            @if (!string.IsNullOrEmpty(req.OldDataJson))
                                            {
                                                <div>
                                                    <h4 class="text-sm font-semibold text-gray-700 mb-2 flex items-center gap-1">
                                                        <i class="bi bi-file-earmark-minus bf-icon-danger"></i> @Localizer["OldData"]
                                                    </h4>
                                                    <div class="bf-bg-danger-50 border bf-border-danger rounded-lg p-3 text-sm">
                                                        @RenderJsonProperties(req.OldDataJson, req.NewDataJson, req.Type)
                                                    </div>
                                                </div>
                                            }
                                            <div>
                                                <h4 class="text-sm font-semibold text-gray-700 mb-2 flex items-center gap-1">
                                                    <i class="bi bi-file-earmark-plus bf-icon-success"></i> @Localizer["NewData"]
                                                </h4>
                                                <div class="bf-bg-success-50 border bf-border-success rounded-lg p-3 text-sm">
                                                    @RenderJsonProperties(req.NewDataJson, req.OldDataJson, req.Type)
                                                </div>
                                            </div>
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(req.Note) || !string.IsNullOrEmpty(req.ReviewNote))
                                    {
                                        <div class="flex flex-col gap-2 mb-4">
                                            @if (!string.IsNullOrEmpty(req.Note))
                                            {
                                                <div class="flex items-start gap-2 bg-blue-50 border border-blue-200 rounded-lg px-3 py-2 text-sm">
                                                    <i class="bi bi-chat-left-text text-blue-500 mt-0.5"></i>
                                                    <div>
                                                        <span class="font-medium text-blue-700">@Localizer["RequesterNote"]:</span>
                                                        <span class="text-blue-800 ms-1">@req.Note</span>
                                                    </div>
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(req.ReviewNote))
                                            {
                                                <div class="flex items-start gap-2 @(req.Status == RequestStatus.Rejected ? "bf-bg-danger-50 border bf-border-danger" : "bf-bg-success-50 border bf-border-success") rounded-lg px-3 py-2 text-sm">
                                                    <i class="bi bi-person-check @(req.Status == RequestStatus.Rejected ? "bf-icon-danger" : "bf-icon-success") mt-0.5"></i>
                                                    <div>
                                                        <span class="font-medium @(req.Status == RequestStatus.Rejected ? "bf-text-danger" : "bf-text-success")">@Localizer["ReviewNote"]:</span>
                                                        <span class="@(req.Status == RequestStatus.Rejected ? "bf-text-danger" : "bf-text-success") ms-1">@req.ReviewNote</span>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }

                                    @if (requestMediaMap.TryGetValue(req.Id, out var imageDiff)
                                        && (imageDiff.OldImages.Any() || imageDiff.NewImages.Any())
                                        && req.Type != RequestType.DeleteProduct && req.Type != RequestType.DeleteUnit)
                                    {
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                            <div>
                                                <h4 class="text-sm font-semibold text-gray-700 mb-2 flex items-center gap-1">
                                                    <i class="bi bi-images bf-icon-danger"></i> @Localizer["OldData"]
                                                    <span class="text-xs font-normal text-gray-400 ms-1">(@imageDiff.OldImages.Count)</span>
                                                </h4>
                                                @if (imageDiff.OldImages.Any())
                                                {
                                                    <div class="flex flex-wrap gap-3">
                                                        @foreach (var media in imageDiff.OldImages)
                                                        {
                                                            <div class="relative group">
                                                                <a href="@MediaService.GetMediaUrl(media)" target="_blank" rel="noopener">
                                                                    <img src="@MediaService.GetMediaUrl(media)"
                                                                         alt="@media.FileName"
                                                                         class="w-24 h-24 object-cover rounded-lg border border-gray-200 shadow-sm group-hover:opacity-90 transition-opacity" />
                                                                </a>
                                                                @if (media.IsMain)
                                                                {
                                                                    <span class="absolute top-1 start-1 bg-blue-600 text-white text-xs px-1 rounded">
                                                                        <i class="bi bi-star-fill"></i>
                                                                    </span>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="text-sm text-gray-400">@Localizer["NoImagesUploaded"]</div>
                                                }
                                            </div>

                                            <div>
                                                <h4 class="text-sm font-semibold text-gray-700 mb-2 flex items-center gap-1">
                                                    <i class="bi bi-images bf-icon-success"></i> @Localizer["NewData"]
                                                    <span class="text-xs font-normal text-gray-400 ms-1">(@imageDiff.NewImages.Count)</span>
                                                </h4>
                                                @if (imageDiff.NewImages.Any())
                                                {
                                                    <div class="flex flex-wrap gap-3">
                                                        @foreach (var media in imageDiff.NewImages)
                                                        {
                                                            <div class="relative group">
                                                                <a href="@MediaService.GetMediaUrl(media)" target="_blank" rel="noopener">
                                                                    <img src="@MediaService.GetMediaUrl(media)"
                                                                         alt="@media.FileName"
                                                                         class="w-24 h-24 object-cover rounded-lg border border-gray-200 shadow-sm group-hover:opacity-90 transition-opacity" />
                                                                </a>
                                                                @if (media.IsMain)
                                                                {
                                                                    <span class="absolute top-1 start-1 bg-blue-600 text-white text-xs px-1 rounded">
                                                                        <i class="bi bi-star-fill"></i>
                                                                    </span>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="text-sm text-gray-400">@Localizer["NoImagesUploaded"]</div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <Pagination PageIndex="@pageIndex"
                    TotalPages="@totalPages"
                    TotalCount="@totalCount"
                    PageSize="@pageSize"
                    OnPageChanged="@OnPageChanged" />
    }
</div>

@if (showConfirmModal)
{
    <div class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50 flex items-center justify-center">
        <div class="bg-white rounded-xl shadow-2xl p-8 max-w-md w-full mx-4">
            <h3 class="text-xl font-bold text-gray-900 mb-2">@Localizer["DeleteRequest"]</h3>
            <p class="text-gray-600 mb-4">@Localizer["ConfirmDeleteRequest"]</p>
            <div class="flex gap-3">
                <button type="button" @onclick="OnCancelAction"
                        class="flex-1 py-2 px-4 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors duration-200 font-medium">
                    @Localizer["Cancel"]
                </button>
                <button type="button" @onclick="OnConfirmDelete"
                        class="flex-1 py-2 px-4 bf-bg-danger-600 bf-hover-bg-danger-700 rounded-lg transition-colors duration-200 font-medium">
                    @Localizer["Delete"]
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<RequestDto> requests = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private bool isAr = false;
    private CultureInfo cultureInfo = new CultureInfo("en-AE");
    private Guid currentUserId = Guid.Empty;

    // Expanded detail row
    private Guid? expandedRequestId = null;
    private Dictionary<Guid, RequestImageDiff> requestMediaMap = new();
    private Dictionary<Guid, Dictionary<Guid, string>> requestUnitNamesMap = new();

    // Filters
    private string searchQuery = "";
    private RequestType? selectedType = null;
    private RequestStatus? selectedStatus = null;
    private bool showFiltersPanel = false;

    private static readonly List<RequestType> RequestTypeOptions =
    [
        RequestType.ChangePrice,
        RequestType.SetUnitPrice,
        RequestType.ActivateProduct,
        RequestType.ActivateUnit,
        RequestType.AddProduct,
        RequestType.UpdateProduct,
        RequestType.AddUnit,
        RequestType.UpdateUnit,
        RequestType.AddGRN,
        RequestType.AddStockAdjustment,
        RequestType.AddStockTransfer,
        RequestType.DeleteProduct,
        RequestType.DeleteUnit,
        RequestType.SetLogisticsDetails
    ];

    private string SelectedTypeValue
    {
        get => selectedType?.ToString() ?? string.Empty;
        set
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                selectedType = null;
                return;
            }

            selectedType = Enum.TryParse<RequestType>(value, out var parsed) ? parsed : null;
        }
    }

    private bool HasActiveFilters() => selectedType.HasValue || selectedStatus.HasValue;
    private int ActiveFilterCount => (selectedType.HasValue ? 1 : 0) + (selectedStatus.HasValue ? 1 : 0);

    // Pagination
    private int pageIndex = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private int totalCount = 0;

    // Confirm modal
    private bool showConfirmModal = false;
    private Guid pendingDeleteId;

    protected override async Task OnInitializedAsync()
    {
        var currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.ToLowerInvariant();
        isAr = currentCulture == "ar";
        cultureInfo = isAr ? new CultureInfo("ar-AE") : new CultureInfo("en-AE");

        ActiveBranch.OnChanged += OnBranchChanged;

        if (!ActiveBranch.IsSelected)
        {
            Navigation.NavigateTo("/branch/select", replace: true);
            return;
        }

        var user = await CurrentUserService.GetCurrentUserAsync();
        currentUserId = user.UserId;

        await LoadRequests();
    }

    private async Task LoadRequests()
    {
        if (!ActiveBranch.BranchId.HasValue) return;
        isLoading = true;
        errorMessage = string.Empty;
        expandedRequestId = null;
        requestMediaMap.Clear();
        requestUnitNamesMap.Clear();

        try
        {
            var result = await RequestService.GetAllRequestsAsync(
                pageIndex, pageSize, searchQuery, selectedType, selectedStatus,
                branchId: ActiveBranch.BranchId.Value);
            requests = result.Items;
            totalPages = result.TotalPages;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToLoadRequests"]}: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSearch(string searchValue)
    {
        searchQuery = searchValue;
        pageIndex = 1;
        await LoadRequests();
    }

    private async Task ResetFilters()
    {
        searchQuery = "";
        selectedType = null;
        selectedStatus = null;
        pageIndex = 1;
        await LoadRequests();
    }

    private async Task OnPageChanged(int newPage)
    {
        pageIndex = newPage;
        await LoadRequests();
    }

    private void OnBranchChanged()
    {
        pageIndex = 1;
        _ = InvokeAsync(async () =>
        {
            await LoadRequests();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ActiveBranch.OnChanged -= OnBranchChanged;
    }

    private void ConfirmDelete(Guid id)
    {
        pendingDeleteId = id;
        showConfirmModal = true;
    }

    private async Task OnConfirmDelete()
    {
        showConfirmModal = false;
        try
        {
            // DeleteMyRequestAsync enforces ownership server-side; the UI also hides the
            // button for non-owners so this should always succeed when reached.
            await RequestService.DeleteMyRequestAsync(pendingDeleteId);
            await LoadRequests();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void OnCancelAction()
    {
        showConfirmModal = false;
    }

    private string GetStatusClass(RequestStatus status) => status switch
    {
        RequestStatus.Pending => "bf-bg-warning-100 bf-text-warning",
        RequestStatus.Approved => "bf-bg-success-100 bf-text-success",
        RequestStatus.Rejected => "bf-bg-danger-100 bf-text-danger",
        _ => "bg-gray-100 text-gray-800"
    };

