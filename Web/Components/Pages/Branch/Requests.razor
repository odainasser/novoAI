            builder.CloseElement();
            builder.CloseElement();
            builder.CloseElement();
        }

        builder.CloseElement();
        builder.CloseElement();
    };

    private RenderFragment RenderJsonProperties(string json, string? compareJson, RequestType? type = null) => builder =>
    {
        try
        {
            var props = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(json);
            Dictionary<string, JsonElement>? compareProps = null;
            if (!string.IsNullOrEmpty(compareJson))
                compareProps = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(compareJson);

            if (props == null) return;

            int seq = 0;
            builder.OpenElement(seq++, "dl");
            builder.AddAttribute(seq++, "class", "space-y-1");

            foreach (var kvp in props)
            {
                if (kvp.Key == "RemovedImageIds" || kvp.Key == "MainImageId" || kvp.Key == "Images")
                    continue;

                if (kvp.Key.EndsWith("Id") || kvp.Key.EndsWith("Ids") || kvp.Key == "IsActive")
                    continue;
                if (type == RequestType.AddUnit && (kvp.Key == "SellingPrice" || kvp.Key == "Cost" || kvp.Key == "Barcode"))
                    continue;
                if (isAr && kvp.Key.EndsWith("En"))
                    continue;
                if (!isAr && kvp.Key.EndsWith("Ar"))
                    continue;

                var label = kvp.Key;
                if (label.EndsWith("En") || label.EndsWith("Ar"))
                    label = label[..^2];

                if (kvp.Value.ValueKind == JsonValueKind.Array)
                {
                    builder.OpenElement(seq++, "div");
                    builder.AddAttribute(seq++, "class", "mt-1");

                    builder.OpenElement(seq++, "dt");
                    builder.AddAttribute(seq++, "class", "font-medium text-gray-600 mb-1");
                    builder.AddContent(seq++, Localizer[label]);
                    builder.CloseElement();

                    var items = kvp.Value.EnumerateArray().ToList();
                    if (items.Count == 0)
                    {
                        builder.OpenElement(seq++, "dd");
                        builder.AddAttribute(seq++, "class", "text-gray-500 text-xs italic");
                        builder.AddContent(seq++, "—");
                        builder.CloseElement();
                    }
                    else
                    {
                        foreach (var item in items)
                        {
                            if (item.ValueKind == JsonValueKind.Object)
                            {
                                builder.OpenElement(seq++, "dd");
                                builder.AddAttribute(seq++, "class", "ms-2 mb-1 px-2 py-1 bg-white/60 border border-gray-200 rounded text-xs");

                                var parts = new List<string>();
                                foreach (var p in item.EnumerateObject())
                                {
                                    if (p.Name.EndsWith("Id") || p.Name.EndsWith("Ids")) continue;
                                    if (isAr && p.Name.EndsWith("En")) continue;
                                    if (!isAr && p.Name.EndsWith("Ar")) continue;

                                    var pLabel = p.Name;
                                    if (pLabel.EndsWith("En") || pLabel.EndsWith("Ar"))
                                        pLabel = pLabel[..^2];

                                    var pVal = p.Value.ToString();
                                    if (!string.IsNullOrEmpty(pVal))
                                        parts.Add($"{Localizer[pLabel]}: {pVal}");
                                }
                                builder.AddContent(seq++, string.Join(" · ", parts));
                                builder.CloseElement();
                            }
                            else
                            {
                                builder.OpenElement(seq++, "dd");
                                builder.AddAttribute(seq++, "class", "ms-2 text-gray-700 text-xs");
                                builder.AddContent(seq++, item.ToString());
                                builder.CloseElement();
                            }
                        }
                    }

                    builder.CloseElement();
                    continue;
                }

                var val = kvp.Value.ToString();

                var compareKey = isAr ? (label + "Ar") : (label + "En");
                if (compareProps != null && !compareProps.ContainsKey(compareKey))
                    compareKey = kvp.Key;

                var isDiff = false;
                if (compareProps != null && compareProps.TryGetValue(compareKey, out var compareVal))
                {
                    isDiff = val != compareVal.ToString();
                }

                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "flex items-start gap-2");

                builder.OpenElement(seq++, "dt");
                builder.AddAttribute(seq++, "class", "font-medium text-gray-600 min-w-[120px]");
                builder.AddContent(seq++, label);
                builder.CloseElement();

                builder.OpenElement(seq++, "dd");
                builder.AddAttribute(seq++, "class", isDiff ? "font-semibold text-gray-900" : "text-gray-700");
                builder.AddContent(seq++, string.IsNullOrEmpty(val) ? "-" : val);
                if (isDiff)
                {
                    builder.AddContent(seq++, " ");
                    builder.OpenElement(seq++, "i");
                    builder.AddAttribute(seq++, "class", "bi bi-dot text-orange-500");
                    builder.CloseElement();
                }
                builder.CloseElement();

                builder.CloseElement();
            }

            builder.CloseElement();
        }
        catch
        {
            builder.OpenElement(0, "pre");
            builder.AddAttribute(1, "class", "text-xs text-gray-600 whitespace-pre-wrap");
            builder.AddContent(2, json);
            builder.CloseElement();
        }
    };

    private bool HasExpandableContent(RequestDto req)
    {
        if ((req.Type == RequestType.DeleteProduct || req.Type == RequestType.DeleteUnit)
            && req.Status == RequestStatus.Pending)
            return false;

        if (!string.IsNullOrEmpty(req.Note) || !string.IsNullOrEmpty(req.ReviewNote))
            return true;

        if (requestMediaMap.TryGetValue(req.Id, out var mediaDiff)
            && (mediaDiff.OldImages.Any() || mediaDiff.NewImages.Any()))
            return true;

        if (req.Type == RequestType.UpdateProduct
            && !string.IsNullOrEmpty(req.NewDataJson)
            && HasImageChanges(req.NewDataJson))
            return true;

        if ((req.Type == RequestType.AddGRN || req.Type == RequestType.AddStockAdjustment || req.Type == RequestType.AddStockTransfer)
            && !string.IsNullOrEmpty(req.NewDataJson))
            return true;

        if (!string.IsNullOrEmpty(req.NewDataJson) && HasVisibleJsonProperties(req.NewDataJson))
            return true;

        if ((req.Type == RequestType.DeleteProduct || req.Type == RequestType.DeleteUnit)
            && req.Status != RequestStatus.Pending)
            return true;

        return false;
    }

    private bool HasVisibleJsonProperties(string json)
    {
        try
        {
            using var doc = JsonDocument.Parse(json);
            foreach (var prop in doc.RootElement.EnumerateObject())
            {
                if (prop.Name == "RemovedImageIds")
                    continue;
                if (prop.Name == "MainImageId")
                    continue;
                if (prop.Name == "Images")
                    continue;
                if (prop.Name.EndsWith("Id") || prop.Name.EndsWith("Ids") || prop.Name == "IsActive")
                    continue;
                if (isAr && prop.Name.EndsWith("En")) continue;
                if (!isAr && prop.Name.EndsWith("Ar")) continue;
                return true;
            }
            return false;
        }
        catch { return false; }
    }

    private static bool HasImageChanges(string json)
    {
        try
        {
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;
            if (root.TryGetProperty("RemovedImageIds", out var removed)
                && removed.ValueKind == JsonValueKind.Array
                && removed.GetArrayLength() > 0)
                return true;

            if (root.TryGetProperty("MainImageId", out var mainImageId)
                && mainImageId.ValueKind != JsonValueKind.Null)
                return true;

            return false;
        }
        catch
        {
            return false;
        }
    }

    private static List<MediaDto> GetOldImagesFromRequest(RequestDto? req)
    {
        if (string.IsNullOrEmpty(req?.OldDataJson))
            return new List<MediaDto>();

        try
        {
            var data = JsonSerializer.Deserialize<JsonElement>(req.OldDataJson);
            if (!data.TryGetProperty("Images", out var images) || images.ValueKind != JsonValueKind.Array)
                return new List<MediaDto>();

            var result = new List<MediaDto>();
            foreach (var item in images.EnumerateArray())
            {
                var media = new MediaDto
                {
                    Id = item.TryGetProperty("Id", out var idEl) && idEl.ValueKind != JsonValueKind.Null ? idEl.GetGuid() : Guid.Empty,
                    FileName = item.TryGetProperty("FileName", out var fileNameEl) ? fileNameEl.GetString() ?? string.Empty : string.Empty,
                    Url = item.TryGetProperty("Path", out var pathEl) ? pathEl.GetString() ?? string.Empty : string.Empty,
                    IsMain = item.TryGetProperty("IsMain", out var isMainEl) && isMainEl.ValueKind == JsonValueKind.True
                };
                result.Add(media);
            }

            return result;
        }
        catch
        {
            return new List<MediaDto>();
        }
    }

    private static MediaDto CloneMedia(MediaDto media) => new()
    {
        Id = media.Id,
        FileName = media.FileName,
        ContentType = media.ContentType,
        Size = media.Size,
        Url = media.Url,
        CollectionName = media.CollectionName,
        IsMain = media.IsMain,
        CreatedAt = media.CreatedAt
    };

    private sealed class RequestImageDiff
    {
        public List<MediaDto> OldImages { get; set; } = new();
        public List<MediaDto> NewImages { get; set; } = new();
    }
