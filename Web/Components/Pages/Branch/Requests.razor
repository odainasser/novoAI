            Th("#");
            Th(Localizer["Unit"]);
            Th(req.Type == RequestType.AddGRN ? Localizer["Received"] : Localizer["Quantity"]);
            if (req.Type == RequestType.AddGRN) Th(Localizer["Cost"]);

            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(seq++, "tbody");
            builder.AddAttribute(seq++, "class", "divide-y divide-green-100");

            int lineIdx = 1;
            foreach (var line in lines.EnumerateArray())
