@page "/branch/notifications"
@layout BranchLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using System.Globalization
@using Web.Components.Common
@using Web.Models.Notifications
@inject INotificationClientService NotificationService
@inject ActiveBranchContext ActiveBranch
@inject NavigationManager Navigation

<PageTitle>@Localizer["Notifications"]</PageTitle>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6">
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
                <i class="bi bi-bell text-purple-600"></i>
                @Localizer["Notifications"]
            </h1>
            <p class="text-gray-600 mt-2 text-sm sm:text-base">@Localizer["BranchNotificationsDescription"]</p>
        </div>
        @if (items.Any(n => !n.IsRead))
        {
            <button @onclick="MarkAllRead"
                    class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium">
                <i class="bi bi-check2-all"></i>
                <span>@Localizer["MarkAllAsRead"]</span>
            </button>
        }
    </div>

    <div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 p-4 flex flex-wrap items-end gap-3">
        <label class="inline-flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" @bind="unreadOnly" @bind:after="ApplyFilters" class="h-4 w-4 rounded border-gray-300 text-bf-primary focus:ring-bf-primary" />
            <span>@Localizer["ShowUnreadOnly"]</span>
        </label>
    </div>

    <ListContent IsLoading="isLoading"
                 ErrorMessage="@errorMessage"
                 IsEmpty="!items.Any()"
                 EmptyIcon="bell"
                 EmptyMessage="@Localizer["NoNotifications"]">
        <ChildContent>
        <ul class="divide-y divide-gray-200">
            @foreach (var n in items)
            {
                <li class="@(n.IsRead ? "" : "bg-purple-50/30") p-4 hover:bg-gray-50 cursor-pointer transition-colors duration-150"
                    @onclick="() => Open(n)">
                    <div class="flex items-start gap-3">
                        @if (!n.IsRead)
                        {
                            <span class="mt-1.5 inline-block w-2 h-2 rounded-full bg-bf-primary flex-shrink-0"></span>
                        }
                        else
                        {
                            <span class="mt-1.5 inline-block w-2 h-2 flex-shrink-0"></span>
                        }
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center justify-between gap-3">
                                <p class="text-sm font-semibold text-gray-900 truncate">@(isAr ? n.TitleAr : n.TitleEn)</p>
                                <span class="text-xs text-gray-500 flex-shrink-0">@n.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                            </div>
                            <p class="text-sm text-gray-600 mt-1">@(isAr ? n.BodyAr : n.BodyEn)</p>
                        </div>
                    </div>
                </li>
            }
        </ul>
        <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="OnPageChanged" />
        </ChildContent>
    </ListContent>
</div>

@code {
    private List<NotificationDto> items = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private bool unreadOnly = false;
    private bool isAr => CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);

    private int pageIndex = 1;
    private int pageSize = 20;
    private int totalPages = 1;
    private int totalCount = 0;

    protected override async Task OnInitializedAsync()
    {
        if (!ActiveBranch.IsSelected) { Navigation.NavigateTo("/branch/select", replace: true); return; }
        await Load();
    }

    private async Task Load()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            var result = await NotificationService.GetAsync(pageIndex, pageSize, unreadOnly);
            items = result.Items;
            totalPages = result.TotalPages;
            totalCount = result.TotalCount;
        }
        catch (Exception ex) { errorMessage = Localizer["FailedToLoad"] + $": {ex.Message}"; }
        finally { isLoading = false; }
    }

    private async Task ApplyFilters() { pageIndex = 1; await Load(); }
    private async Task OnPageChanged(int p) { pageIndex = p; await Load(); }

    private async Task Open(NotificationDto n)
    {
        if (!n.IsRead)
        {
            try { await NotificationService.MarkReadAsync(n.Id); n.IsRead = true; }
            catch { }
        }
        if (!string.IsNullOrEmpty(n.Link))
        {
            Navigation.NavigateTo(n.Link);
        }
    }

    private async Task MarkAllRead()
    {
        try
        {
            await NotificationService.MarkAllReadAsync();
            foreach (var n in items) n.IsRead = true;
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }
}
