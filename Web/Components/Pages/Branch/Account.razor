@page "/branch/account"
@page "/branch/account/{Tab}"
@layout BranchLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Web.Components.Common

<PageTitle>@Localizer["Account"]</PageTitle>

<AccountProfile ActiveTab="@activeTab" OnTabChanged="SetActiveTab" BasePath="/branch/account" />

@code {
    [Parameter] public string? Tab { get; set; }

    private string activeTab = "profile";

    protected override void OnInitialized()
    {
        activeTab = ResolveTab();
    }

    protected override void OnParametersSet()
    {
        activeTab = ResolveTab();
    }

    private string ResolveTab() =>
        Tab?.ToLower() switch
        {
            "change-password" or "password" => "password",
            _ => "profile"
        };

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
    }
}
