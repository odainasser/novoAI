@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

@code {
    protected override async Task OnInitializedAsync()
    {
        // Preserve the full relative path including query string and prefix with a leading slash
        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri) ?? string.Empty;
        if (!returnUrl.StartsWith('/'))
            returnUrl = "/" + returnUrl;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user?.Identity?.IsAuthenticated == true)
        {
            // Authenticated but not authorized -> send to the dashboard
            Navigation.NavigateTo("/admin", forceLoad: true);
        }
        else
        {
            // Not authenticated -> redirect to login and preserve returnUrl (URL-encode)
            var encoded = Uri.EscapeDataString(returnUrl);
            Navigation.NavigateTo($"/login?returnUrl={encoded}", forceLoad: true);
        }
    }
}
