@inherits LayoutComponentBase
@attribute [Authorize]
@implements IDisposable
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using Web.Components.Common
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IMediaService MediaService
@inject IJSRuntime JS

<div class="min-h-screen bg-gray-50" data-theme="@(isDarkMode ? "dark" : "light")">
    <!-- Top Navigation Bar -->
    <nav class="portal-header fixed top-0 left-0 right-0 z-50 h-16 border-b border-white/10 bg-[var(--bf-header-bg)]">
        <div class="px-4 lg:px-6 h-full">
            <div class="flex justify-between items-center h-full">
                <!-- Left: Menu toggle + Logo -->
                <div class="flex items-center gap-2">
                    <button @onclick="ToggleSidebarMobile"
                            class="lg:hidden header-icon-btn">
                        <i class="bi @(isSidebarOpen ? "bi-x-lg" : "bi-list") text-xl"></i>
                    </button>
                    <button @onclick="ToggleMinimized"
                            class="hidden lg:flex header-icon-btn"
                            title="@(isSidebarMinimized ? Localizer["ExpandSidebar"] : Localizer["CollapseSidebar"])">
                        <i class="bi bi-list text-xl"></i>
                    </button>
                    <div class="header-separator hidden lg:block"></div>
                    <a href="/admin" class="flex items-center gap-2.5">
                        <img src="/logo.png" alt="Logo" class="h-9 w-auto" />
                    </a>
                </div>

                <!-- Right: Actions + User Menu -->
                <div class="flex items-center gap-1 sm:gap-1.5">
                    <!-- Notifications Bell -->
                    <NotificationBell />

                    <!-- Dark Mode Toggle -->
                    <button @onclick="ToggleDarkMode"
                            class="header-icon-btn"
                            title="@(isDarkMode ? Localizer["LightMode"] : Localizer["DarkMode"])">
                        <i class="bi @(isDarkMode ? "bi-sun-fill" : "bi-moon-stars-fill") text-xl"></i>
                    </button>

                    <div class="header-separator hidden sm:block"></div>

                    <LanguageSelector Dark="false" />

                    <div class="header-separator"></div>

                    <AuthorizeView Context="auth">
                        <Authorized>
                            @if (auth.User.Identity?.IsAuthenticated == true)
                            {
                                <Dropdown Alignment="right" ToggleCss="bf-dropdown-toggle bf-dropdown-compact !text-white !border-0 !px-2 !py-1.5 !rounded-xl" ToggleStyle="">
                                    <ToggleContent>
                                        <div class="flex items-center gap-2.5 group cursor-pointer">
                                            @if (!string.IsNullOrEmpty(avatarUrl))
                                            {
                                                <img src="@avatarUrl" alt="User avatar" class="h-9 w-9 rounded-full object-cover ring-2 ring-white/50 transition-all duration-200 group-hover:ring-white/80 group-hover:scale-105" />
                                            }
                                            else
                                            {
                                                <div class="h-9 w-9 rounded-full flex items-center justify-center text-white text-sm font-bold bg-white/20 ring-2 ring-white/30 transition-all duration-200 group-hover:bg-white/30 group-hover:ring-white/50 group-hover:scale-105">
                                                    @(displayName.Length > 0 ? displayName[0].ToString().ToUpper() : "A")
                                                </div>
                                            }
                                            <div class="hidden sm:block text-left">
                                                <p class="text-sm font-semibold text-white leading-tight tracking-tight">@displayName</p>
                                                <p class="text-[11px] text-white/60 font-medium">@Localizer["Administrator"]</p>
                                            </div>
                                            <i class="bi bi-chevron-down text-[10px] text-white/50 transition-transform duration-200"></i>
                                        </div>
                                    </ToggleContent>
                                    <ChildContent>
                                        <div class="px-4 py-3 bg-gradient-to-br from-gray-50 to-white border-b border-gray-100">
                                            <div class="flex items-center gap-3">
                                                @if (!string.IsNullOrEmpty(avatarUrl))
                                                {
                                                    <img src="@avatarUrl" alt="" class="h-10 w-10 rounded-full object-cover ring-1 ring-gray-200" />
                                                }
                                                else
                                                {
                                                    <div class="h-10 w-10 rounded-full flex items-center justify-center text-white text-sm font-bold bg-[var(--bf-primary)]">
                                                        @(displayName.Length > 0 ? displayName[0].ToString().ToUpper() : "A")
                                                    </div>
                                                }
                                                <div class="min-w-0">
                                                    <p class="text-sm font-semibold text-gray-900 truncate">@displayName</p>
                                                    <p class="text-xs text-gray-500 truncate">@currentUser?.Email</p>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="py-1">
                                            <a href="/admin/account" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors duration-150">
                                                <i class="bi bi-person-circle text-gray-400"></i>
                                                <span>@Localizer["MyProfile"]</span>
                                            </a>
                                        </div>
                                        <div class="border-t border-gray-100"></div>
                                        <div class="py-1">
                                            <button @onclick='() => Navigation.NavigateTo("/logout", true)' 
                                                    class="w-full flex items-center gap-3 px-4 py-2.5 text-sm !text-red-600 hover:!bg-red-50 transition-colors duration-150">
                                                <i class="bi bi-box-arrow-right rtl:rotate-180 text-red-400"></i>
                                                <span>@Localizer["SignOut"]</span>
                                            </button>
                                        </div>
                                    </ChildContent>
                                </Dropdown>
                            }
                        </Authorized>
                        <NotAuthorized>
                            <a href="/login" class="px-4 py-2 text-sm text-bf-primary hover:text-green-700 font-medium">
                                @Localizer["SignIn"]
                            </a>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>
    </nav>

    <!-- Mobile Sidebar Overlay -->
    @if (isSidebarOpen)
    {
        <div @onclick="CloseSidebar" class="fixed inset-0 bg-black bg-opacity-50 z-40 lg:hidden"></div>
    }

    <!-- Left Sidebar - Fixed on desktop -->
    <aside class="@GetSidebarClasses()">
        <nav class="px-3 py-5 space-y-1">
            <!-- Dashboard -->
            <NavLink href="/admin"
                     @onclick="CloseSidebar"
                     class="sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 text-sm font-medium relative overflow-hidden"
                     ActiveClass="sidebar-link-active"
                     Match="NavLinkMatch.All">
                <span class="sidebar-link-indicator"></span>
                <span class="sidebar-link-icon"><i class="bi bi-columns-gap"></i></span>
                <span class="sidebar-text">@Localizer["Dashboard"]</span>
                <span class="sidebar-tooltip">@Localizer["Dashboard"]</span>
            </NavLink>

            <AuthorizeView Context="outerAuth">
                <Authorized Context="outerAuth">
                    <AuthorizeView Context="auth">
                        <Authorized Context="auth">
                            @{
                                var permissions = auth.User.FindAll("permission");
                                var hasInventoryPermissions = permissions.Any(p =>
                                    p.Value == "suppliers.read" || p.Value == "products.read" ||
                                    p.Value == "inventory.read" || p.Value == "requests.read");
                                var hasIdentityPermissions = permissions.Any(p =>
                                    p.Value == "users.read" || p.Value == "roles.read");
                                var hasFacilitiesPermissions = permissions.Any(p =>
                                    p.Value == "branches.read" || p.Value == "warehouses.read" || p.Value == "terminals.read");
                                var hasLookupsPermission = permissions.Any(p =>
                                    p.Value == "lookups.read");
                                var hasAuditPermission = permissions.Any(p =>
                                    p.Value == "system.audit");
                                var hasAssistantPermission = permissions.Any(p =>
                                    p.Value == "assistant.keywords.read");
                                var hasSettingsPermissions = hasFacilitiesPermissions || hasLookupsPermission;
                            }

                            @* === MERCHANDISE === *@
                            @if (hasInventoryPermissions)
                            {
                                <div class="sidebar-section-header mt-5 mb-1.5">
                                    <div class="mx-3 mb-2 border-t border-gray-100"></div>
                                    <p class="px-3 text-[0.65rem] font-bold text-gray-400 uppercase tracking-widest flex items-center gap-2">
                                        <i class="bi bi-bag text-[0.6rem]"></i>
                                        @Localizer["Merchandise"]
                                    </p>
                                </div>

                                <AuthorizeView Policy="Permission:products.read" Context="productsAuth">
                                    <Authorized Context="productsAuth">
                                        <div class="@GroupCss("catalog", "admin/catalog")">
                                            <button type="button" @onclick='() => ToggleGroup("catalog", "admin/catalog")'
                                                    class="sidebar-link sidebar-group-toggle group flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 text-sm font-medium relative overflow-hidden">
                                                <span class="sidebar-link-indicator"></span>
                                                <span class="sidebar-link-icon"><i class="bi bi-grid-3x3-gap"></i></span>
                                                <span class="sidebar-text">@Localizer["Catalog"]</span>
                                                <i class="bi bi-chevron-down sidebar-chevron"></i>
                                                <span class="sidebar-tooltip">@Localizer["Catalog"]</span>
                                            </button>
                                            <div class="sidebar-children">
                                                <NavLink href="/admin/catalog/categories"
                                                         @onclick="CloseSidebar"
                                                         class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                         ActiveClass="sidebar-link-active">
                                                    <span class="sidebar-link-indicator"></span>
                                                    <span class="sidebar-link-icon"><i class="bi bi-tags"></i></span>
                                                    <span class="sidebar-text">@Localizer["Categories"]</span>
                                                </NavLink>
                                                <NavLink href="/admin/catalog/products"
                                                         @onclick="CloseSidebar"
                                                         class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                         ActiveClass="sidebar-link-active">
                                                    <span class="sidebar-link-indicator"></span>
                                                    <span class="sidebar-link-icon"><i class="bi bi-box2"></i></span>
                                                    <span class="sidebar-text">@Localizer["Products"]</span>
                                                </NavLink>
                                            </div>
                                        </div>
                                    </Authorized>
                                </AuthorizeView>

                                <AuthorizeView Policy="Permission:inventory.read" Context="inventoryAuth">
                                    <Authorized Context="inventoryAuth">
                                        <div class="@GroupCss("inventory", "admin/inventory")">
                                            <button type="button" @onclick='() => ToggleGroup("inventory", "admin/inventory")'
                                                    class="sidebar-link sidebar-group-toggle group flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 text-sm font-medium relative overflow-hidden">
                                                <span class="sidebar-link-indicator"></span>
                                                <span class="sidebar-link-icon"><i class="bi bi-stack"></i></span>
                                                <span class="sidebar-text">@Localizer["Inventory"]</span>
                                                <i class="bi bi-chevron-down sidebar-chevron"></i>
                                                <span class="sidebar-tooltip">@Localizer["Inventory"]</span>
                                            </button>
                                            <div class="sidebar-children">
                                                <AuthorizeView Policy="Permission:purchase-requests.read" Context="prNav">
                                                    <Authorized Context="prNav">
                                                        <NavLink href="/admin/inventory/purchase-requests"
                                                                 @onclick="CloseSidebar"
                                                                 class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                                 ActiveClass="sidebar-link-active">
                                                            <span class="sidebar-link-indicator"></span>
                                                            <span class="sidebar-link-icon"><i class="bi bi-bag-plus"></i></span>
                                                            <span class="sidebar-text">@Localizer["PurchaseRequests"]</span>
                                                        </NavLink>
                                                    </Authorized>
                                                </AuthorizeView>
                                                <NavLink href="/admin/inventory/grn"
                                                         @onclick="CloseSidebar"
                                                         class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                         ActiveClass="sidebar-link-active">
                                                    <span class="sidebar-link-indicator"></span>
                                                    <span class="sidebar-link-icon"><i class="bi bi-arrow-down-square"></i></span>
                                                    <span class="sidebar-text">@Localizer["GoodsReceiving"]</span>
                                                </NavLink>
                                                <NavLink href="/admin/inventory/transfers"
                                                         @onclick="CloseSidebar"
                                                         class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                         ActiveClass="sidebar-link-active">
                                                    <span class="sidebar-link-indicator"></span>
                                                    <span class="sidebar-link-icon"><i class="bi bi-arrow-down-up"></i></span>
                                                    <span class="sidebar-text">@Localizer["StockTransfers"]</span>
                                                </NavLink>
                                                <NavLink href="/admin/inventory/adjustments"
                                                         @onclick="CloseSidebar"
                                                         class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                         ActiveClass="sidebar-link-active">
                                                    <span class="sidebar-link-indicator"></span>
                                                    <span class="sidebar-link-icon"><i class="bi bi-pencil-square"></i></span>
                                                    <span class="sidebar-text">@Localizer["StockAdjustments"]</span>
                                                </NavLink>
                                                <NavLink href="/admin/inventory/stocktake"
                                                         @onclick="CloseSidebar"
                                                         class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                         ActiveClass="sidebar-link-active">
                                                    <span class="sidebar-link-indicator"></span>
                                                    <span class="sidebar-link-icon"><i class="bi bi-clipboard-data"></i></span>
                                                    <span class="sidebar-text">@Localizer["Stocktake"]</span>
                                                </NavLink>
                                                <NavLink href="/admin/inventory/balances"
                                                         @onclick="CloseSidebar"
                                                         class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                         ActiveClass="sidebar-link-active">
                                                    <span class="sidebar-link-indicator"></span>
                                                    <span class="sidebar-link-icon"><i class="bi bi-archive"></i></span>
                                                    <span class="sidebar-text">@Localizer["StockBalances"]</span>
                                                </NavLink>
                                                <NavLink href="/admin/inventory/history"
                                                         @onclick="CloseSidebar"
                                                         class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                         ActiveClass="sidebar-link-active">
                                                    <span class="sidebar-link-indicator"></span>
                                                    <span class="sidebar-link-icon"><i class="bi bi-activity"></i></span>
                                                    <span class="sidebar-text">@Localizer["InventoryHistory"]</span>
                                                </NavLink>
                                            </div>
                                        </div>
                                    </Authorized>
                                </AuthorizeView>

                                <AuthorizeView Policy="Permission:suppliers.read" Context="suppliersAuth">
                                    <Authorized Context="suppliersAuth">
                                        <NavLink href="/admin/suppliers"
                                                 @onclick="CloseSidebar"
                                                 class="sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 text-sm font-medium relative overflow-hidden"
                                                 ActiveClass="sidebar-link-active">
                                            <span class="sidebar-link-indicator"></span>
                                            <span class="sidebar-link-icon"><i class="bi bi-truck-front"></i></span>
                                            <span class="sidebar-text">@Localizer["Suppliers"]</span>
                                            <span class="sidebar-tooltip">@Localizer["Suppliers"]</span>
                                        </NavLink>
                                    </Authorized>
                                </AuthorizeView>

                                <AuthorizeView Policy="Permission:requests.read" Context="requestsAuth">
                                    <Authorized Context="requestsAuth">
                                        <div class="@GroupCss("requests", "admin/requests")">
                                            <button type="button" @onclick='() => ToggleGroup("requests", "admin/requests")'
                                                    class="sidebar-link sidebar-group-toggle group flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 text-sm font-medium relative overflow-hidden">
                                                <span class="sidebar-link-indicator"></span>
                                                <span class="sidebar-link-icon"><i class="bi bi-send"></i></span>
                                                <span class="sidebar-text">@Localizer["Requests"]</span>
                                                <i class="bi bi-chevron-down sidebar-chevron"></i>
                                                <span class="sidebar-tooltip">@Localizer["Requests"]</span>
                                            </button>
                                            <div class="sidebar-children">
                                                <NavLink href="/admin/requests/all"
                                                         @onclick="CloseSidebar"
                                                         class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                         ActiveClass="sidebar-link-active">
                                                    <span class="sidebar-link-indicator"></span>
                                                    <span class="sidebar-link-icon"><i class="bi bi-envelope-paper"></i></span>
                                                    <span class="sidebar-text">@Localizer["Requests"]</span>
                                                </NavLink>
                                                <NavLink href="/admin/requests/my"
                                                         @onclick="CloseSidebar"
                                                         class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                         ActiveClass="sidebar-link-active">
                                                    <span class="sidebar-link-indicator"></span>
                                                    <span class="sidebar-link-icon"><i class="bi bi-file-person"></i></span>
                                                    <span class="sidebar-text">@Localizer["MyRequests"]</span>
                                                </NavLink>
                                            </div>
                                        </div>
                                    </Authorized>
                                </AuthorizeView>


                            }

                            @* === ADMINISTRATION === *@
                            @if (hasSettingsPermissions || hasIdentityPermissions || hasAuditPermission || hasAssistantPermission)
                            {
                                <div class="sidebar-section-header mt-5 mb-1.5">
                                    <div class="mx-3 mb-2 border-t border-gray-100"></div>
                                    <p class="px-3 text-[0.65rem] font-bold text-gray-400 uppercase tracking-widest flex items-center gap-2">
                                        <i class="bi bi-gear text-[0.6rem]"></i>
                                        @Localizer["Administration"]
                                    </p>
                                </div>

                                @if (hasIdentityPermissions)
                                {
                                    <div class="@GroupCss("identity", "admin/identity")">
                                        <button type="button" @onclick='() => ToggleGroup("identity", "admin/identity")'
                                                class="sidebar-link sidebar-group-toggle group flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 text-sm font-medium relative overflow-hidden">
                                            <span class="sidebar-link-indicator"></span>
                                            <span class="sidebar-link-icon"><i class="bi bi-shield-check"></i></span>
                                            <span class="sidebar-text">@Localizer["Identity"]</span>
                                            <i class="bi bi-chevron-down sidebar-chevron"></i>
                                            <span class="sidebar-tooltip">@Localizer["Identity"]</span>
                                        </button>
                                        <div class="sidebar-children">
                                            <AuthorizeView Policy="Permission:roles.read" Context="rolesAuth">
                                                <Authorized Context="rolesAuth">
                                                    <NavLink href="/admin/identity/roles"
                                                             @onclick="CloseSidebar"
                                                             class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                             ActiveClass="sidebar-link-active">
                                                        <span class="sidebar-link-indicator"></span>
                                                        <span class="sidebar-link-icon"><i class="bi bi-person-gear"></i></span>
                                                        <span class="sidebar-text">@Localizer["Roles"]</span>
                                                    </NavLink>
                                                </Authorized>
                                            </AuthorizeView>
                                            <AuthorizeView Policy="Permission:users.read" Context="usersAuth">
                                                <Authorized Context="usersAuth">
                                                    <NavLink href="/admin/identity/users"
                                                             @onclick="CloseSidebar"
                                                             class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                             ActiveClass="sidebar-link-active">
                                                        <span class="sidebar-link-indicator"></span>
                                                        <span class="sidebar-link-icon"><i class="bi bi-person-vcard"></i></span>
                                                        <span class="sidebar-text">@Localizer["Users"]</span>
                                                    </NavLink>
                                                </Authorized>
                                            </AuthorizeView>
                                        </div>
                                    </div>
                                }

                                @if (hasAssistantPermission)
                                {
                                    <div class="@GroupCss("assistant", "admin/assistant")">
                                        <button type="button" @onclick='() => ToggleGroup("assistant", "admin/assistant")'
                                                class="sidebar-link sidebar-group-toggle group flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 text-sm font-medium relative overflow-hidden">
                                            <span class="sidebar-link-indicator"></span>
                                            <span class="sidebar-link-icon"><i class="bi bi-cpu"></i></span>
                                            <span class="sidebar-text">@Localizer["AIAssistant"]</span>
                                            <i class="bi bi-chevron-down sidebar-chevron"></i>
                                            <span class="sidebar-tooltip">@Localizer["AIAssistant"]</span>
                                        </button>
                                        <div class="sidebar-children">
                                            <NavLink href="/admin/assistant/plans"
                                                     @onclick="CloseSidebar"
                                                     class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                     ActiveClass="sidebar-link-active">
                                                <span class="sidebar-link-indicator"></span>
                                                <span class="sidebar-link-icon"><i class="bi bi-chat-square-text"></i></span>
                                                <span class="sidebar-text">@Localizer["PlansReview"]</span>
                                            </NavLink>
                                            <NavLink href="/admin/assistant/no-answers"
                                                     @onclick="CloseSidebar"
                                                     class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                     ActiveClass="sidebar-link-active">
                                                <span class="sidebar-link-indicator"></span>
                                                <span class="sidebar-link-icon"><i class="bi bi-slash-circle"></i></span>
                                                <span class="sidebar-text">@Localizer["NoAnswersQueue"]</span>
                                            </NavLink>
                                            <NavLink href="/admin/assistant/reported"
                                                     @onclick="CloseSidebar"
                                                     class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                     ActiveClass="sidebar-link-active">
                                                <span class="sidebar-link-indicator"></span>
                                                <span class="sidebar-link-icon"><i class="bi bi-flag"></i></span>
                                                <span class="sidebar-text">@Localizer["ReportedAnswers"]</span>
                                            </NavLink>
                                        </div>
                                    </div>
                                }

                                @if (hasFacilitiesPermissions)
                                {
                                    <div class="@GroupCss("facilities", "admin/facilities")">
                                        <button type="button" @onclick='() => ToggleGroup("facilities", "admin/facilities")'
                                                class="sidebar-link sidebar-group-toggle group flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 text-sm font-medium relative overflow-hidden">
                                            <span class="sidebar-link-indicator"></span>
                                            <span class="sidebar-link-icon"><i class="bi bi-buildings"></i></span>
                                            <span class="sidebar-text">@Localizer["Facilities"]</span>
                                            <i class="bi bi-chevron-down sidebar-chevron"></i>
                                            <span class="sidebar-tooltip">@Localizer["Facilities"]</span>
                                        </button>
                                        <div class="sidebar-children">
                                            <AuthorizeView Policy="Permission:branches.read" Context="branchesAuth">
                                                <Authorized Context="branchesAuth">
                                                    <NavLink href="/admin/facilities/branches"
                                                             @onclick="CloseSidebar"
                                                             class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                             ActiveClass="sidebar-link-active">
                                                        <span class="sidebar-link-indicator"></span>
                                                        <span class="sidebar-link-icon"><i class="bi bi-shop-window"></i></span>
                                                        <span class="sidebar-text">@Localizer["Branches"]</span>
                                                    </NavLink>
                                                </Authorized>
                                            </AuthorizeView>
                                            <AuthorizeView Policy="Permission:warehouses.read" Context="warehousesAuth">
                                                <Authorized Context="warehousesAuth">
                                                    <NavLink href="/admin/facilities/warehouses"
                                                             @onclick="CloseSidebar"
                                                             class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                             ActiveClass="sidebar-link-active">
                                                        <span class="sidebar-link-indicator"></span>
                                                        <span class="sidebar-link-icon"><i class="bi bi-houses"></i></span>
                                                        <span class="sidebar-text">@Localizer["Warehouses"]</span>
                                                    </NavLink>
                                                </Authorized>
                                            </AuthorizeView>
                                            <AuthorizeView Policy="Permission:terminals.read" Context="terminalsAuth">
                                                <Authorized Context="terminalsAuth">
                                                    <NavLink href="/admin/facilities/terminals"
                                                             @onclick="CloseSidebar"
                                                             class="sidebar-link sidebar-link-sub group flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200 relative overflow-hidden"
                                                             ActiveClass="sidebar-link-active">
                                                        <span class="sidebar-link-indicator"></span>
                                                        <span class="sidebar-link-icon"><i class="bi bi-pc-display"></i></span>
                                                        <span class="sidebar-text">@Localizer["Terminals"]</span>
                                                    </NavLink>
                                                </Authorized>
                                            </AuthorizeView>
                                        </div>
                                    </div>
                                }

                                @if (hasLookupsPermission)
                                {
                                    <NavLink href="/admin/lookups"
                                             @onclick="CloseSidebar"
                                             class="sidebar-link sidebar-link-danger group flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 text-sm font-medium relative overflow-hidden"
                                             ActiveClass="sidebar-link-active sidebar-link-active-danger">
                                        <span class="sidebar-link-indicator"></span>
                                        <span class="sidebar-link-icon"><i class="bi bi-card-list"></i></span>
                                        <span class="sidebar-text">@Localizer["Lookups"]</span>
                                        <span class="sidebar-tooltip">@Localizer["Lookups"]</span>
                                    </NavLink>
                                }

                                @if (hasAuditPermission)
                                {
                                    <NavLink href="/admin/logs"
                                             @onclick="CloseSidebar"
                                             class="sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 text-sm font-medium relative overflow-hidden"
                                             ActiveClass="sidebar-link-active">
                                        <span class="sidebar-link-indicator"></span>
                                        <span class="sidebar-link-icon"><i class="bi bi-file-earmark-text"></i></span>
                                        <span class="sidebar-text">@Localizer["AuditLogs"]</span>
                                        <span class="sidebar-tooltip">@Localizer["AuditLogs"]</span>
                                    </NavLink>
                                }
                            }
                        </Authorized>
                    </AuthorizeView>
                </Authorized>
            </AuthorizeView>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="pt-16 @(isSidebarMinimized ? "lg:ms-16" : "lg:ms-60") min-h-screen flex flex-col transition-all duration-300">
        <div class="p-4 lg:p-6 flex-1 bg-gray-50">
            @Body
        </div>

        <!-- Admin Footer -->
        <footer class="portal-footer border-t border-gray-200 bg-white px-4 lg:px-6 py-3">
            <div class="flex items-center justify-end text-xs text-gray-500">
                <span><span class="text-[var(--bf-primary)]">&copy;</span> @DateTime.Now.Year @Localizer["SystemName"]</span>
            </div>
        </footer>
    </main>

    <AiAssistantWidget />
</div>

<div id="blazor-error-ui" class="fixed bottom-0 left-0 right-0 bg-red-600 text-white p-4 shadow-lg hidden" data-nosnippet>
    <div class="flex items-center justify-between max-w-7xl mx-auto">
        <div class="flex items-center gap-3">
            <i class="bi bi-exclamation-triangle-fill text-xl"></i>
            <span>@Localizer["ErrorOccurred"]</span>
            <a href="." class="underline hover:no-underline">@Localizer["Reload"]</a>
        </div>
        <button class="text-white hover:text-gray-200 text-2xl" onclick="document.getElementById('blazor-error-ui').style.display='none'">&times;</button>
    </div>
</div>

@code {
    private UserDto currentUser = new();
    private string? avatarUrl;
    private string displayName = string.Empty;
    private bool triedLoadAvatar = false;
    private bool isSidebarOpen = false;
    private bool isSidebarMinimized = false;
    private bool isDarkMode = false;

    // Multi-level nav: track per-group manual override of expansion.
    // Default behavior: a group is open iff the current route is inside its prefix.
    // Manual toggles persist until the next navigation, then reset.
    private readonly HashSet<string> manuallyExpanded = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> manuallyCollapsed = new(StringComparer.OrdinalIgnoreCase);

    private string CurrentRelative =>
        Navigation.ToBaseRelativePath(Navigation.Uri).TrimEnd('/').ToLowerInvariant();

    private bool IsActiveGroup(string prefix)
    {
        var rel = CurrentRelative;
        prefix = prefix.Trim('/').ToLowerInvariant();
        return rel == prefix || rel.StartsWith(prefix + "/", StringComparison.Ordinal);
    }

    private bool IsGroupOpen(string key, string prefix)
    {
        if (manuallyCollapsed.Contains(key)) return false;
        if (manuallyExpanded.Contains(key)) return true;
        return IsActiveGroup(prefix);
    }

    private void ToggleGroup(string key, string prefix)
    {
        var open = IsGroupOpen(key, prefix);
        manuallyExpanded.Remove(key);
        manuallyCollapsed.Remove(key);
        if (open) manuallyCollapsed.Add(key);
        else manuallyExpanded.Add(key);
    }

    private string GroupCss(string key, string prefix)
    {
        var open = IsGroupOpen(key, prefix);
        var current = IsActiveGroup(prefix);
        return $"sidebar-group{(open ? " is-open" : "")}{(current ? " is-current" : "")}";
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        manuallyExpanded.Clear();
        manuallyCollapsed.Clear();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private async Task ToggleDarkMode()
    {
        isDarkMode = !isDarkMode;
        await JS.InvokeVoidAsync("AdminDarkMode.set", isDarkMode);
    }

    private void ToggleSidebarMobile()
    {
        isSidebarOpen = !isSidebarOpen;
    }

    private void ToggleMinimized()
    {
        isSidebarMinimized = !isSidebarMinimized;
    }

    private void CloseSidebar()
    {
        isSidebarOpen = false;
    }

    private string GetSidebarClasses()
    {
        var width = isSidebarMinimized ? "w-16 sidebar-mini" : "w-60";
        var baseClasses = $"fixed top-16 {width} h-[calc(100vh-4rem)] bg-white shadow-sm border-e border-gray-200 overflow-y-auto transition-all duration-300 ease-in-out z-40";
        
        if (isSidebarOpen)
        {
            return $"{baseClasses} left-0 rtl:left-auto rtl:right-0 translate-x-0";
        }
        else
        {
            return $"{baseClasses} left-0 rtl:left-auto rtl:right-0 -translate-x-full rtl:translate-x-full lg:translate-x-0 lg:rtl:translate-x-0";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;

        try
        {
            await LoadUserInfoAsync();

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var relative = Navigation.ToBaseRelativePath(Navigation.Uri);

            if (user.Identity?.IsAuthenticated == true && 
                (user.IsInRole(Roles.Administrator) || 
                 user.IsInRole(Roles.Manager) || 
                 user.IsInRole(Roles.Support) ||
                 user.IsInRole(Roles.User)))
            {
                if (!string.IsNullOrEmpty(relative) && 
                     relative.StartsWith("cashier", StringComparison.OrdinalIgnoreCase))
                {
                    Navigation.NavigateTo("/admin", forceLoad: true);
                    return;
                }
            }

            // BranchManager landing on /admin (e.g. via stale tab, bookmark, or
            // notification deep-link) gets bounced to /branch. Administrators
            // with the BranchManager role bypass this because the earlier block
            // returns before we reach here when they're an Administrator.
            if (user.Identity?.IsAuthenticated == true
                && user.IsInRole(Roles.BranchManager)
                && !user.IsInRole(Roles.Administrator))
            {
                if (!string.IsNullOrEmpty(relative) &&
                    relative.StartsWith("admin", StringComparison.OrdinalIgnoreCase))
                {
                    Navigation.NavigateTo("/branch", forceLoad: true);
                    return;
                }
            }
        }
        catch
        {
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                isDarkMode = await JS.InvokeAsync<bool>("AdminDarkMode.get");
                if (isDarkMode) StateHasChanged();
            }
            catch { }
        }

        if (!triedLoadAvatar && string.IsNullOrEmpty(avatarUrl))
        {
            triedLoadAvatar = true;
            try
            {
                await LoadUserInfoAsync();
                StateHasChanged();
            }
            catch
            {
            }
        }
    }

    private async Task LoadUserInfoAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                var u = await AuthService.GetCurrentUserAsync();
                if (u != null)
                {
                    currentUser = u;
                    displayName = !string.IsNullOrEmpty(u.FirstName) 
                        ? $"{u.FirstName} {u.LastName}".Trim() 
                        : (!string.IsNullOrEmpty(u.DisplayName) ? u.DisplayName : u.Email ?? "Admin");

                    try
                    {
                        var mediaList = await MediaService.GetMediaForEntityAsync(u.Id, "User", "avatar");
                        var avatar = mediaList.FirstOrDefault();
                        if (avatar != null)
                        {
                            avatarUrl = MediaService.GetMediaUrl(avatar);
                        }
                    }
                    catch
                    {
                    }
                }
            }
        }
        catch
        {
        }
    }
}
