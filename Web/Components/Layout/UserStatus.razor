@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<div class="flex items-center justify-end">
    <AuthorizeView>
        <Authorized>
            <div class="relative">
                <button @onclick="ToggleDropdown"
                        @onclick:stopPropagation
                        type="button"
                        class="bf-dropdown-toggle z-50 flex items-center gap-2 text-gray-700 hover:text-gray-900 rounded-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-bf-primary focus:ring-offset-2">
                    @if (!string.IsNullOrEmpty(avatarUrl))
                    {
                        <img src="@avatarUrl" alt="User avatar" class="h-8 w-8 rounded-full object-cover" />
                    }
                    else
                    {
                        <div class="h-8 w-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-600">
                            <i class="bi bi-person-fill"></i>
                        </div>
                    }
                    <i class="bi bi-chevron-down text-sm"></i>
                </button>

                @if (isOpen)
                {
                    <div class="fixed inset-0 bf-dropdown-overlay" @onclick="CloseDropdown"></div>

                    <div class="absolute right-0 mt-2 w-56 bf-dropdown-menu rounded-lg border border-gray-200 py-1 z-50">
                        <button @onclick="NavigateToProfile" 
                                class="w-full flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition-all duration-200 text-left">
                            <i class="bi bi-person w-5 text-center"></i>
                            <span>@Localizer["Account"]</span>
                        </button>

                        <hr class="my-1 border-gray-200" />

                        <button @onclick="HandleLogout"
                                class="w-full flex items-center gap-3 px-4 py-3 text-red-600 hover:bg-red-50 transition-all duration-200 text-left">
                            <i class="bi bi-box-arrow-right w-5 text-center text-red-600"></i>
                            <span>@Localizer["Logout"]</span>
                        </button>
                    </div>
                }
            </div>
        </Authorized>
        <NotAuthorized>
            <a href="/admin/login"
               class="inline-flex items-center gap-2 px-4 py-2 bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-all duration-200 shadow-sm font-medium">
                <i class="bi bi-box-arrow-in-right"></i>
                <span>@Localizer["Login"]</span>
            </a>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private bool isOpen = false;
    [Parameter] public string? avatarUrl { get; set; }

    private void ToggleDropdown()
    {
        isOpen = !isOpen;
    }

    private void CloseDropdown()
    {
        if (isOpen)
        {
            isOpen = false;
            StateHasChanged();
        }
    }

    private void NavigateToProfile()
    {
        isOpen = false;
        Navigation.NavigateTo("/admin/account");
    }

    private void HandleLogout()
    {
        isOpen = false;
        Navigation.NavigateTo("/logout", forceLoad: true);
    }
}
