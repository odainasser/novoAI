@inherits LayoutComponentBase
@attribute [Authorize(Roles = Roles.Cashier)]
@using Microsoft.AspNetCore.Authorization
@using System.Globalization
@using Web.Components.Common
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IMediaService MediaService
@inject IShiftService ShiftService
@inject IWarehouseService WarehouseService
@inject IJSRuntime JS
@inject Web.Offline.OfflineNetworkMonitor OfflineNetwork
@inject Web.Offline.IOfflineSyncService OfflineSync
@implements IDisposable
@implements IAsyncDisposable

<div class="min-h-screen bg-gray-50" data-theme="@(isDarkMode ? "dark" : "light")">
    <!-- Top Navigation Bar -->
    <nav class="portal-header fixed top-0 left-0 right-0 z-50 h-16 border-b border-white/10 bg-[var(--bf-header-bg)]">
        <div class="px-4 lg:px-6 h-full">
            <div class="relative flex justify-between items-center h-full">
                <!-- Left: Logo -->
                <div class="flex items-center gap-3">
                    <a href="/cashier" class="flex items-center gap-2.5">
                        <img src="/logo.png" alt="Logo" class="h-9 w-auto" />
                    </a>
                    @if (!string.IsNullOrWhiteSpace(activeShiftStoreName))
                    {
                        <div class="hidden sm:flex items-center gap-3 px-3 py-1.5 rounded-lg text-xs font-medium text-white border border-white/25 bg-white/10">
                            <span class="inline-flex items-center gap-1.5">
                                <i class="bi bi-shop"></i>
                                <span>@Localizer["Store"]:</span>
                                <span class="font-semibold">@activeShiftStoreName</span>
                            </span>
                        </div>
                    }
                </div>

                <!-- Center: Quick Navigation -->
                <div class="hidden md:flex items-center rounded-xl p-1 gap-1 bg-white/15 border border-white/25 absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
                    <NavLink href="/cashier"
                             class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold text-white/80 hover:text-white transition-colors duration-150"
                             ActiveClass="!bg-[var(--bf-primary)] !text-[var(--bf-primary-contrast)] shadow-sm"
                             Match="NavLinkMatch.All">
                        <i class="bi bi-cart3 text-base"></i><span>@Localizer["POS"]</span>
                    </NavLink>
                    <NavLink href="/cashier/orders"
                             class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold text-white/80 hover:text-white transition-colors duration-150"
                             ActiveClass="!bg-[var(--bf-primary)] !text-[var(--bf-primary-contrast)] shadow-sm">
                        <i class="bi bi-bag-check text-base"></i><span>@Localizer["Orders"]</span>
                    </NavLink>
                    <NavLink href="/cashier/shifts"
                             class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold text-white/80 hover:text-white transition-colors duration-150"
                             ActiveClass="!bg-[var(--bf-primary)] !text-[var(--bf-primary-contrast)] shadow-sm">
                        <i class="bi bi-stopwatch text-base"></i><span>@Localizer["Shifts"]</span>
                    </NavLink>
                </div>

                <!-- Right: Actions + User Menu -->
                <div class="flex items-center gap-1 sm:gap-1.5">
                    <!-- Notifications Bell -->
                    <NotificationBell />

                    <!-- Dark Mode Toggle -->
                    <button @onclick="ToggleDarkMode"
                            class="header-icon-btn"
                            title="@(isDarkMode ? Localizer["LightMode"] : Localizer["DarkMode"])">
                        <i class="bi @(isDarkMode ? "bi-sun-fill" : "bi-moon-stars-fill") text-xl"></i>
                    </button>

                    <div class="header-separator hidden sm:block"></div>

                    <LanguageSelector Dark="false" />

                    <div class="header-separator"></div>

                    <AuthorizeView Context="auth">
                        <Authorized>
                            @if (auth.User.Identity?.IsAuthenticated == true)
                            {
                                <Dropdown Alignment="right" ToggleCss="bf-dropdown-toggle bf-dropdown-compact !text-white !border-0 !px-2 !py-1.5 !rounded-xl" ToggleStyle="">
                                    <ToggleContent>
                                        <div class="flex items-center gap-2.5 group cursor-pointer">
                                            @if (!string.IsNullOrEmpty(avatarUrl))
                                            {
                                                <img src="@avatarUrl" alt="User avatar" class="h-9 w-9 rounded-full object-cover ring-2 ring-white/50 transition-all duration-200 group-hover:ring-white/80 group-hover:scale-105" />
                                            }
                                            else
                                            {
                                                <div class="h-9 w-9 rounded-full flex items-center justify-center text-white text-sm font-bold bg-white/20 ring-2 ring-white/30 transition-all duration-200 group-hover:bg-white/30 group-hover:ring-white/50 group-hover:scale-105">
                                                    @(displayName.Length > 0 ? displayName[0].ToString().ToUpper() : "C")
                                                </div>
                                            }
                                            <div class="hidden sm:block text-left">
                                                <p class="text-sm font-semibold text-white leading-tight tracking-tight">@displayName</p>
                                                <p class="text-[11px] text-white/60 font-medium">@Localizer["Cashier"]</p>
                                            </div>
                                            <i class="bi bi-chevron-down text-[10px] text-white/50 transition-transform duration-200"></i>
                                        </div>
                                    </ToggleContent>
                                    <ChildContent>
                                        <div class="px-4 py-3 bg-gradient-to-br from-gray-50 to-white border-b border-gray-100">
                                            <div class="flex items-center gap-3">
                                                @if (!string.IsNullOrEmpty(avatarUrl))
                                                {
                                                    <img src="@avatarUrl" alt="" class="h-10 w-10 rounded-full object-cover ring-1 ring-gray-200" />
                                                }
                                                else
                                                {
                                                    <div class="h-10 w-10 rounded-full flex items-center justify-center text-white text-sm font-bold bg-[var(--bf-primary)]">
                                                        @(displayName.Length > 0 ? displayName[0].ToString().ToUpper() : "C")
                                                    </div>
                                                }
                                                <div class="min-w-0">
                                                    <p class="text-sm font-semibold text-gray-900 truncate">@displayName</p>
                                                    <p class="text-xs text-gray-500 truncate">@currentUser?.Email</p>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Mobile Navigation -->
                                        <div class="md:hidden border-b border-gray-100 py-1">
                                            <a href="/cashier" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors duration-150">
                                                <i class="bi bi-cart3 text-gray-400"></i>
                                                <span>@Localizer["POS"]</span>
                                            </a>
                                            <a href="/cashier/orders" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors duration-150">
                                                <i class="bi bi-receipt text-gray-400"></i>
                                                <span>@Localizer["Orders"]</span>
                                            </a>
                                        </div>

                                        <div class="py-1">
                                            <a href="/cashier/profile" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors duration-150">
                                                <i class="bi bi-person-circle text-gray-400"></i>
                                                <span>@Localizer["MyProfile"]</span>
                                            </a>
                                        </div>
                                        <div class="border-t border-gray-100"></div>
                                        <div class="py-1">
                                            <button @onclick="HandleLogoutClick"
                                                    class="w-full flex items-center gap-3 px-4 py-2.5 text-sm !text-red-600 hover:!bg-red-50 transition-colors duration-150">
                                                <i class="bi bi-box-arrow-right rtl:rotate-180 text-red-400"></i>
                                                <span>@Localizer["SignOut"]</span>
                                            </button>
                                        </div>
                                    </ChildContent>
                                </Dropdown>
                            }
                        </Authorized>
                        <NotAuthorized>
                            <a href="/login" class="px-4 py-2 text-sm text-bf-primary hover:opacity-80 font-medium">
                                @Localizer["SignIn"]
                            </a>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>
    </nav>

    <Web.Components.Common.OfflineIndicator @ref="offlineIndicator" />

    <!-- Main Content -->
    <main class="pt-16 min-h-screen flex flex-col">
        <div class="p-4 lg:p-6 flex-1 bg-gray-50">
            @Body
        </div>
    </main>
</div>

@if (showLogoutBlockedModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center" @onclick="CloseLogoutBlockedModal">
        <div class="bg-white rounded-xl shadow-lg max-w-md w-full mx-4 overflow-hidden" @onclick:stopPropagation>
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
                <div class="flex items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill bf-icon-warning text-xl"></i>
                    <h3 class="text-lg font-semibold text-gray-900">@Localizer["CannotSignOut"]</h3>
                </div>
                <button type="button" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors" @onclick="CloseLogoutBlockedModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="px-5 py-4">
                <p class="text-sm text-gray-700">@Localizer["EndShiftBeforeSignOut"]</p>
            </div>
            <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-gray-200">
                <button type="button" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" @onclick="CloseLogoutBlockedModal">
                    @Localizer["Close"]
                </button>
                <button type="button" class="px-4 py-2 text-sm font-medium bf-bg-warning-600 bf-hover-bg-warning-700 rounded-lg transition-colors" @onclick="GoToShifts">
                    <i class="bi bi-clock-history me-1"></i>
                    @Localizer["GoToShifts"]
                </button>
            </div>
        </div>
    </div>
}

<div id="blazor-error-ui" class="fixed bottom-0 left-0 right-0 bg-red-600 text-white p-4 shadow-lg hidden" data-nosnippet>
    <div class="flex items-center justify-between max-w-7xl mx-auto">
        <div class="flex items-center gap-3">
            <i class="bi bi-exclamation-triangle-fill text-xl"></i>
            <span>@Localizer["ErrorOccurred"]</span>
            <a href="." class="underline hover:no-underline">@Localizer["Reload"]</a>
        </div>
        <button class="text-white hover:text-gray-200 text-2xl" onclick="document.getElementById('blazor-error-ui').style.display='none'">&times;</button>
    </div>
</div>

@code {
    private UserDto currentUser = new();
    private string? avatarUrl;
    private string displayName = string.Empty;
    private bool triedLoadAvatar = false;
    private bool isDarkMode = false;
    private string? activeShiftStoreName;
    private bool showLogoutBlockedModal = false;
    private Web.Components.Common.OfflineIndicator? offlineIndicator;

    private async Task HandleLogoutClick()
    {
        try
        {
            var hasActive = await ShiftService.HasActiveShiftAsync();
            if (hasActive)
            {
                showLogoutBlockedModal = true;
                StateHasChanged();
                return;
            }
        }
        catch
        {
        }

        Navigation.NavigateTo("/logout", true);
    }

    private void CloseLogoutBlockedModal()
    {
        showLogoutBlockedModal = false;
    }

    private void GoToShifts()
    {
        showLogoutBlockedModal = false;
        Navigation.NavigateTo("/cashier/shifts");
    }

    private async Task ToggleDarkMode()
    {
        isDarkMode = !isDarkMode;
        await JS.InvokeVoidAsync("CashierDarkMode.set", isDarkMode);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadUserInfoAsync();
            await LoadActiveShiftBranchAsync();
            Navigation.LocationChanged += OnLocationChanged;
            await OfflineNetwork.AttachAsync(OnNetworkOnline, OnNetworkOffline);

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var relative = Navigation.ToBaseRelativePath(Navigation.Uri);

            if (user.Identity?.IsAuthenticated == true && !user.IsInRole(Roles.Cashier))
            {
                if (!string.IsNullOrEmpty(relative) &&
                    relative.StartsWith("cashier", StringComparison.OrdinalIgnoreCase))
                {
                    Navigation.NavigateTo("/admin", forceLoad: true);
                    return;
                }
            }

            // Cache stores/products/orders/shifts for the next offline session
            // and flush any queue items that survived a reload. The browser
            // 'online' event only fires on transitions, so reloading the page
            // while already online would otherwise leave pending items stuck.
            if (user.Identity?.IsAuthenticated == true && user.IsInRole(Roles.Cashier))
            {
                _ = Task.Run(async () =>
                {
                    try
                    {
                        // Flush first so any queued offline mutations are
                        // committed before we overwrite the local cache with
                        // server data. FlushQueueAsync already triggers a pull
                        // when something was sent, so we only need to fall
                        // back to a plain pull when the queue was empty.
                        if (await OfflineNetwork.IsOnlineAsync())
                        {
                            var result = await OfflineSync.FlushQueueAsync();
                            if (result.Flushed == 0)
                                await OfflineSync.PullAllAsync();
                        }
                        else
                        {
                            await OfflineSync.PullAllAsync();
                        }
                    }
                    catch { }
                });
            }
        }
        catch
        {
        }
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await InvokeAsync(async () =>
        {
            await LoadActiveShiftBranchAsync();
            StateHasChanged();
        });
    }

    private async Task LoadActiveShiftBranchAsync()
    {
        activeShiftStoreName = null;

        try
        {
            var res = await ShiftService.GetMyShiftsAsync(1, 100);
            var activeShift = res.Items.FirstOrDefault(s => s.Status == Web.Models.Enums.ShiftStatus.Active);
            if (activeShift?.WarehouseId is not Guid warehouseId)
                return;

            var isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
            activeShiftStoreName = NormalizeStoreName(isAr ? activeShift.WarehouseNameAr : activeShift.WarehouseNameEn);

            // Fall back to the cached warehouse list when the shift didn't
            // carry a name (e.g. shift was started offline before the cashier
            // visited StoreSelector). The OfflineWarehouseService serves this
            // from the offline `stores` cache, so it works without network.
            if (string.IsNullOrWhiteSpace(activeShiftStoreName))
            {
                var wh = await WarehouseService.GetWarehouseByIdAsync(warehouseId);
                activeShiftStoreName = NormalizeStoreName(isAr ? wh?.NameAr : wh?.NameEn);
            }
        }
        catch
        {
        }
    }

    private static string? NormalizeStoreName(string? storeName)
    {
        if (string.IsNullOrWhiteSpace(storeName))
            return storeName;

        var normalized = storeName.Trim();
        if (normalized.EndsWith(" - Store", StringComparison.OrdinalIgnoreCase))
            normalized = normalized[..^8].TrimEnd();

        return normalized;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                isDarkMode = await JS.InvokeAsync<bool>("CashierDarkMode.get");
                if (isDarkMode) StateHasChanged();
            }
            catch { }
        }

        if (!triedLoadAvatar && string.IsNullOrEmpty(avatarUrl))
        {
            triedLoadAvatar = true;
            try
            {
                await LoadUserInfoAsync();
                StateHasChanged();
            }
            catch
            {
            }
        }
    }

    private async Task LoadUserInfoAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                var u = await AuthService.GetCurrentUserAsync();
                if (u != null)
                {
                    currentUser = u;
                    displayName = !string.IsNullOrEmpty(u.FirstName)
                        ? $"{u.FirstName} {u.LastName}".Trim()
                        : (!string.IsNullOrEmpty(u.DisplayName) ? u.DisplayName : u.Email ?? "Cashier");

                    try
                    {
                        var mediaList = await MediaService.GetMediaForEntityAsync(u.Id, "User", "avatar");
                        var avatar = mediaList.FirstOrDefault();
                        if (avatar != null)
                        {
                            avatarUrl = MediaService.GetMediaUrl(avatar);
                        }
                    }
                    catch
                    {
                    }
                }
            }
        }
        catch
        {
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    public async ValueTask DisposeAsync()
    {
        try { await OfflineNetwork.DisposeAsync(); } catch { }
        Dispose();
    }

    private async Task OnNetworkOnline()
    {
        Console.WriteLine("[OfflineSync] browser online — flushing queue");
        if (offlineIndicator is not null)
        {
            try { await offlineIndicator.SetOnline(true); } catch { }
        }
        try { await OfflineSync.FlushQueueAsync(); } catch (Exception ex) { Console.WriteLine($"[OfflineSync] flush threw: {ex.Message}"); }
    }

    private async Task OnNetworkOffline()
    {
        Console.WriteLine("[OfflineSync] browser offline");
        if (offlineIndicator is not null)
        {
            try { await offlineIndicator.SetOnline(false); } catch { }
        }
    }
}
