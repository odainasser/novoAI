@using Web.Models.Inventory
@using System.Globalization
@inject IJsonStringLocalizer Localizer

@if (IsVisible && Adjustment is not null)
{
    var isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);

    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center" @onclick="HandleBackgroundClick">
        <div class="bg-white rounded-xl shadow-lg max-w-3xl w-full mx-4 max-h-[90vh] overflow-hidden flex flex-col" @onclick:stopPropagation>
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 flex-shrink-0">
                <div>
                    <h3 class="text-lg font-semibold text-gray-900">@Localizer["AdjustmentDetails"]</h3>
                    <p class="text-sm text-gray-500 font-mono">@Adjustment.AdjustmentNumber</p>
                </div>
                <button @onclick="Close" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="px-5 py-4 overflow-y-auto flex-1">
                <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-5">
                    <div class="p-3 bg-gray-50 rounded-lg">
                        <p class="text-xs text-gray-500 uppercase font-medium">@Localizer["Type"]</p>
                        <span class="font-medium text-sm">@Localizer[Adjustment.AdjustmentType]</span>
                    </div>
                    <div class="p-3 bg-gray-50 rounded-lg">
                        <p class="text-xs text-gray-500 uppercase font-medium">@Localizer["Status"]</p>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">@Adjustment.Status</span>
                    </div>
                    <div class="p-3 bg-gray-50 rounded-lg">
                        <p class="text-xs text-gray-500 uppercase font-medium">@Localizer["RequestedDate"]</p>
                        <span class="font-medium text-sm">@(Adjustment.RequestedDate?.ToString("yyyy-MM-dd") ?? Adjustment.CreatedAt.ToString("yyyy-MM-dd"))</span>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Adjustment.Explanation))
                {
                    <div class="p-3 bg-gray-50 rounded-lg mb-5">
                        <p class="text-xs text-gray-500 uppercase font-medium mb-1">@Localizer["Explanation"]</p>
                        <span class="text-sm">@Adjustment.Explanation</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Adjustment.JustificationImageUrl))
                {
                    <div class="p-3 bg-gray-50 rounded-lg mb-5">
                        <p class="text-xs text-gray-500 uppercase font-medium mb-2">@Localizer["JustificationImage"]</p>
                        <div class="border rounded-lg overflow-hidden bg-white flex items-center justify-center p-2" style="max-height: 360px;">
                            <img src="@Adjustment.JustificationImageUrl" alt="" class="max-h-full max-w-full object-contain" />
                        </div>
                    </div>
                }

                <h4 class="text-sm font-semibold text-gray-900 mb-2">@Localizer["Items"] (@Adjustment.Lines.Count)</h4>
                <div class="overflow-x-auto border border-gray-200 rounded-lg">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500 uppercase">@Localizer["Product"]</th>
                                <th class="px-3 py-2 text-end text-xs font-medium text-gray-500 uppercase">@Localizer["CurrentQty"]</th>
                                <th class="px-3 py-2 text-end text-xs font-medium text-gray-500 uppercase">@Localizer["AdjustmentQty"]</th>
                                <th class="px-3 py-2 text-end text-xs font-medium text-gray-500 uppercase">@Localizer["NewQty"]</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-100">
                            @foreach (var line in Adjustment.Lines)
                            {
                                <tr>
                                    <td class="px-3 py-2 text-sm">
                                        <div class="font-medium text-gray-900">@(isAr ? line.ProductNameAr : line.ProductNameEn)</div>
                                        <div class="text-xs text-gray-500 font-mono">@line.UnitBarcode</div>
                                    </td>
                                    <td class="px-3 py-2 text-sm text-end text-gray-700">@line.CurrentQuantity</td>
                                    <td class="px-3 py-2 text-sm text-end font-medium @(line.AdjustmentQuantity >= 0 ? "text-emerald-700" : "text-red-700")">
                                        @(line.AdjustmentQuantity > 0 ? "+" : "")@line.AdjustmentQuantity
                                    </td>
                                    <td class="px-3 py-2 text-sm text-end font-semibold text-gray-900">@line.NewQuantity</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="px-5 py-3 border-t border-gray-200 bg-gray-50 flex-shrink-0">
                <button @onclick="Close" class="ms-auto block px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-100">
                    @Localizer["Close"]
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public StockAdjustmentDto? Adjustment { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private async Task Close() => await OnClose.InvokeAsync();
    private async Task HandleBackgroundClick() => await OnClose.InvokeAsync();
}
