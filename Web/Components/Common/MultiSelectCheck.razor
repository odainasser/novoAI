@typeparam TItem
@typeparam TValue
@inject IJsonStringLocalizer Localizer

@* Generic multi-select rendered as a checkbox list. Mirrors SearchableDropdown's
   API (Items / DisplayText / ItemValue) but binds a List<TValue> via SelectedValues.
   An optional ExpandedTemplate renders extra content under each *checked* item
   (used by the assistant plan editor to show a tool's parameters inline). *@

<div class="@WrapperClass">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="block text-sm font-medium text-gray-700 mb-1.5">
            @Label
            @if (Required) { <span class="text-red-600">*</span> }
        </label>
    }
    <div class="border border-gray-300 rounded-lg overflow-hidden">
        @if (Searchable)
        {
            <div class="p-2 border-b border-gray-100">
                <div class="relative">
                    <i class="bi bi-search absolute start-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                    <input type="text" @bind="searchQuery" @bind:event="oninput"
                           placeholder="@Localizer["Search"]..."
                           class="w-full ps-8 pe-3 py-1.5 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-1 focus:ring-bf-primary focus:border-bf-primary" />
                </div>
            </div>
        }
        <div class="@ListClass overflow-y-auto divide-y divide-gray-100">
            @if (!Filtered.Any())
            {
                <div class="px-3 py-4 text-sm text-gray-400 text-center">@Localizer["NoDataFound"]</div>
            }
            else
            {
                @foreach (var item in Filtered)
                {
                    var val = ItemValue(item);
                    var isSel = IsSelected(val);
                    <div>
                        <label class="flex items-center gap-2 px-3 py-2 cursor-pointer hover:bg-gray-50">
                            <input type="checkbox" checked="@isSel"
                                   @onchange="e => Toggle(val, (bool)(e.Value ?? false))"
                                   class="w-4 h-4 rounded border-gray-300 text-bf-primary focus:ring-bf-primary cursor-pointer" />
                            <span class="text-sm text-gray-700 flex-1">@DisplayText(item)</span>
                        </label>
                        @if (isSel && ExpandedTemplate is not null)
                        {
                            <div class="border-t border-gray-100 bg-gray-50">
                                @ExpandedTemplate(item)
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IEnumerable<TItem> Items { get; set; } = Enumerable.Empty<TItem>();
    [Parameter, EditorRequired] public Func<TItem, string> DisplayText { get; set; } = default!;
    [Parameter, EditorRequired] public Func<TItem, TValue> ItemValue { get; set; } = default!;

    [Parameter] public List<TValue> SelectedValues { get; set; } = new();
    [Parameter] public EventCallback<List<TValue>> SelectedValuesChanged { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    [Parameter] public string? Label { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Searchable { get; set; }
    [Parameter] public string WrapperClass { get; set; } = "";
    [Parameter] public string ListClass { get; set; } = "max-h-48";

    /// <summary>Optional content rendered under a checked item (e.g. its parameters).</summary>
    [Parameter] public RenderFragment<TItem>? ExpandedTemplate { get; set; }

    private string searchQuery = "";

    private IEnumerable<TItem> Filtered =>
        string.IsNullOrWhiteSpace(searchQuery)
            ? Items
            : Items.Where(i => DisplayText(i).Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

    private bool IsSelected(TValue val) =>
        SelectedValues is not null && SelectedValues.Any(v => EqualityComparer<TValue>.Default.Equals(v, val));

    private async Task Toggle(TValue val, bool on)
    {
        var list = SelectedValues is null ? new List<TValue>() : new List<TValue>(SelectedValues);
        var idx = list.FindIndex(v => EqualityComparer<TValue>.Default.Equals(v, val));
        if (on) { if (idx < 0) list.Add(val); }
        else { if (idx >= 0) list.RemoveAt(idx); }

        SelectedValues = list;
        await SelectedValuesChanged.InvokeAsync(list);
        await OnChanged.InvokeAsync();
    }
}
