@using Web.Models.Orders
@using System.Globalization

<div class="mt-3 bg-white border border-gray-200 rounded-xl px-4 py-2 flex items-center divide-x divide-gray-100">
    <div class="flex items-center gap-2 flex-1 px-3 first:ps-0">
        <i class="bi bi-receipt-cutoff text-blue-500 text-sm"></i>
        <div>
            <p class="text-[10px] text-gray-400 leading-none">@Localizer["TodayOrders"]</p>
            <p class="text-sm font-bold text-gray-800 leading-tight">@Statistics.TodayOrders</p>
        </div>
    </div>
    <div class="flex items-center gap-2 flex-1 px-3">
        <i class="bi bi-currency-dollar text-green-500 text-sm"></i>
        <div>
            <p class="text-[10px] text-gray-400 leading-none">@Localizer["TodayRevenue"]</p>
            <p class="text-sm font-bold text-gray-800 leading-tight">@Statistics.TodayRevenue.ToString("N2", CultureInfo) @Localizer["CurrencyUnit"]</p>
        </div>
    </div>
    <div class="flex items-center gap-2 flex-1 px-3">
        <i class="bi bi-box-seam text-bf-primary text-sm"></i>
        <div>
            <p class="text-[10px] text-gray-400 leading-none">@Localizer["ItemsSold"]</p>
            <p class="text-sm font-bold text-gray-800 leading-tight">@Statistics.TodayItemsSold</p>
        </div>
    </div>
    <div class="flex items-center gap-2 flex-1 px-3">
        <i class="bi bi-clock-history text-orange-500 text-sm"></i>
        <div>
            <p class="text-[10px] text-gray-400 leading-none">@Localizer["LastSale"]</p>
            <p class="text-sm font-bold text-gray-800 leading-tight">@LastSaleTime</p>
        </div>
    </div>
</div>

@code {
    [Parameter] public OrderStatisticsDto Statistics { get; set; } = new();
    [Parameter] public string LastSaleTime { get; set; } = "--:--";
    [Parameter] public CultureInfo CultureInfo { get; set; } = default!;
}
