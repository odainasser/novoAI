@* Legacy wrapper that defers to the modern <Spinner /> component.
   New code should use <Spinner ... /> directly. *@
<Spinner Size="@SizeEnum" Color="@ColorEnum" Centered="@CenterByDefault" />

@code {
    /// <summary>Kept for backwards compatibility. Ignored when Size/Color params are set.</summary>
    [Parameter] public string SpinnerClass { get; set; } = "animate-spin h-10 w-10 text-bf-primary";

    /// <summary>Kept for backwards compatibility. Ignored when Size/Color params are set.</summary>
    [Parameter] public string WrapperClass { get; set; } = "flex justify-center items-center py-12";

    [Parameter] public Spinner.SpinnerSize? Size { get; set; }
    [Parameter] public Spinner.SpinnerColor? Color { get; set; }

    private Spinner.SpinnerSize SizeEnum => Size ?? Spinner.SpinnerSize.Lg;
    private Spinner.SpinnerColor ColorEnum => Color ?? Spinner.SpinnerColor.Primary;
    private bool CenterByDefault => WrapperClass?.Contains("justify-center") == true;
}
