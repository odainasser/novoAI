@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Web.Models.Offline
@using Web.Offline
@implements IDisposable
@inject OfflineNetworkMonitor Network
@inject IOfflineSyncService Sync
@inject IIndexedDbService Idb
@inject AuthenticationStateProvider AuthStateProvider

@if (showBanner)
{
    <div class="fixed top-16 left-0 right-0 z-40 flex justify-center pointer-events-none">
        <div class="pointer-events-auto mt-2 flex flex-col items-center gap-2 max-w-[min(95vw,640px)]">
            <button type="button"
                    @onclick="TogglePanel"
                    class="inline-flex items-center gap-3 px-4 py-2 rounded-full text-xs sm:text-sm font-medium shadow-md cursor-pointer hover:opacity-90 transition border @(isOnline ? "bf-bg-warning-100 bf-text-warning bf-border-warning" : "bf-bg-danger-100 bf-text-danger bf-border-danger")">
                @if (isOnline)
                {
                    <i class="bi bi-cloud-arrow-up"></i>
                    <span>@Localizer["OfflineSession"]</span>
                }
                else
                {
                    <i class="bi bi-wifi-off"></i>
                    <span>@Localizer["OfflineMode"]</span>
                }
                @if (pendingCount > 0)
                {
                    <span class="px-2 py-0.5 rounded-full text-[10px] sm:text-xs font-semibold bg-white/80 text-gray-800">
                        @pendingCount @Localizer["PendingSyncItems"]
                    </span>
                }
                @if (pendingCount > 0)
                {
                    <i class="bi bi-chevron-@(isPanelOpen ? "up" : "down") text-[10px] opacity-70"></i>
                }
            </button>

            @if (isPanelOpen && pendingCount > 0)
            {
                <div class="w-[min(95vw,640px)] bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden">
                    <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between bg-gray-50">
                        <div class="text-sm font-semibold text-gray-800">@Localizer["PendingSyncQueue"]</div>
                        <div class="flex items-center gap-2">
                            @if (isOnline)
                            {
                                <button type="button" @onclick="FlushNowAsync" disabled="@isFlushing"
                                        class="text-xs font-medium px-2.5 py-1 rounded-md bg-bf-primary text-white hover:opacity-90 transition disabled:opacity-50">
                                    @(isFlushing ? Localizer["Syncing"] : Localizer["SyncNow"])
                                </button>
                            }
                            <button type="button" @onclick="TogglePanel"
                                    class="text-xs text-gray-500 hover:text-gray-700 px-2 py-1">
                                @Localizer["Close"]
                            </button>
                        </div>
                    </div>

                    @if (pendingItems.Count == 0)
                    {
                        <div class="px-4 py-6 text-center text-sm text-gray-500">@Localizer["NoPendingItems"]</div>
                    }
                    else
                    {
                        <ul class="max-h-72 overflow-y-auto divide-y divide-gray-100 text-sm">
                            @foreach (var item in pendingItems)
                            {
                                <li class="px-4 py-2.5 flex items-start gap-3">
                                    <i class="@OpIcon(item.Op) text-base text-bf-primary mt-0.5"></i>
                                    <div class="flex-1 min-w-0">
                                        <div class="font-medium text-gray-900">@OpLabel(item.Op)</div>
                                        <div class="text-[11px] text-gray-500">
                                            @item.QueuedAtUtc.ToLocal().ToString("yyyy-MM-dd HH:mm")
                                            @if (item.Attempts > 0)
                                            {
                                                <span>· @item.Attempts @Localizer["Attempts"]</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.LastError))
                                        {
                                            <div class="text-[11px] text-red-600 truncate mt-0.5" title="@item.LastError">@item.LastError</div>
                                        }
                                    </div>
                                    <span class="text-[10px] text-gray-400 font-mono">#@item.Seq</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private bool isOnline = true;
    private bool isOfflineSession;
    private int pendingCount;
    private bool isPanelOpen;
    private bool isFlushing;
    private List<SyncQueueItem> pendingItems = new();
    private System.Threading.Timer? refreshTimer;

    private bool showBanner => !isOnline || isOfflineSession || pendingCount > 0;

    protected override async Task OnInitializedAsync()
    {
        isOnline = await Network.IsOnlineAsync();
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isOfflineSession = authState.User?.Claims.Any(c => c.Type == "offline_session" && c.Value == "1") == true;
        await RefreshPendingAsync();

        // Refresh queue depth every 30 seconds so the counter doesn't go stale
        // while the cashier is making sales in offline mode.
        refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await RefreshPendingAsync();
                if (isPanelOpen) await LoadPendingItemsAsync();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    public async Task SetOnline(bool online)
    {
        isOnline = online;
        await RefreshPendingAsync();
        if (isPanelOpen) await LoadPendingItemsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task TogglePanel()
    {
        isPanelOpen = !isPanelOpen;
        if (isPanelOpen) await LoadPendingItemsAsync();
    }

    private async Task FlushNowAsync()
    {
        if (isFlushing) return;
        isFlushing = true;
        try { await Sync.FlushQueueAsync(); } catch { }
        isFlushing = false;
        await RefreshPendingAsync();
        await LoadPendingItemsAsync();
    }

    private async Task RefreshPendingAsync()
    {
        try
        {
            pendingCount = await Sync.CountPendingAsync();
        }
        catch
        {
            pendingCount = 0;
        }
    }

    private async Task LoadPendingItemsAsync()
    {
        try
        {
            var all = await Idb.GetAllAsync<SyncQueueItem>(OfflineStores.SyncQueue);
            pendingItems = all
                .Where(i => i.Seq.HasValue)
                .OrderBy(i => i.Seq)
                .ToList();
        }
        catch
        {
            pendingItems = new List<SyncQueueItem>();
        }
    }

    private static string OpLabel(SyncQueueOpType op) => op switch
    {
        SyncQueueOpType.CreateOrder => "New order",
        SyncQueueOpType.PartialRefund => "Partial refund",
        SyncQueueOpType.StartShift => "Start shift",
        SyncQueueOpType.EndShift => "End shift",
        _ => op.ToString()
    };

    private static string OpIcon(SyncQueueOpType op) => op switch
    {
        SyncQueueOpType.CreateOrder => "bi bi-cart-plus",
        SyncQueueOpType.PartialRefund => "bi bi-arrow-counterclockwise",
        SyncQueueOpType.StartShift => "bi bi-play-circle",
        SyncQueueOpType.EndShift => "bi bi-stop-circle",
        _ => "bi bi-clock-history"
    };

    public void Dispose()
    {
        refreshTimer?.Dispose();
        refreshTimer = null;
    }
}
