@using Web.Models.Orders
@inject IJsonStringLocalizer Localizer

@if (IsVisible && Order != null)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50" @onclick="HandleBackdropClick">
        <div class="bg-white rounded-xl shadow-lg max-w-md w-full mx-4 overflow-hidden" @onclick:stopPropagation>
            <div class="px-5 py-6 text-center">
                <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="bi bi-check-lg text-green-600 text-3xl"></i>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-1">@Localizer["PaymentSuccessful"]</h3>
                <p class="text-sm text-gray-500">@Localizer["TransactionCompletedVia"] @Order.PaymentMethodName</p>
            </div>

            <div class="mx-5 mb-5 bg-gray-50 rounded-lg p-4">
                <div class="flex justify-between mb-2">
                    <span class="text-sm text-gray-500">@Localizer["ReceiptNumber"]</span>
                    <span class="text-sm font-mono font-semibold text-gray-900">@Order.OrderNumber</span>
                </div>
                <div class="flex justify-between mb-2">
                    <span class="text-sm text-gray-500">@Localizer["Items"]</span>
                    <span class="text-sm font-medium text-gray-900">@Order.ItemCount</span>
                </div>
                <div class="flex justify-between pt-2 border-t border-gray-200">
                    <span class="text-sm text-gray-500">@Localizer["TotalPaid"]</span>
                    <span class="text-base font-bold text-bf-primary">@Localizer.GetLocalizedCurrency(Order.Total)</span>
                </div>
            </div>

            <div class="flex items-center gap-2 px-5 py-4 border-t border-gray-200">
                <button @onclick="InvokePrint" class="flex-1 px-4 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors inline-flex items-center justify-center gap-2">
                    <i class="bi bi-printer"></i>
                    @Localizer["PrintReceipt"]
                </button>
                <button @onclick="InvokeNewSale" class="flex-1 px-4 py-2.5 text-sm font-medium bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-colors inline-flex items-center justify-center gap-2">
                    <i class="bi bi-plus-circle"></i>
                    @Localizer["NewSale"]
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public OrderDto? Order { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnPrint { get; set; }
    [Parameter] public EventCallback OnNewSale { get; set; }

    private async Task InvokePrint()
    {
        if (OnPrint.HasDelegate) await OnPrint.InvokeAsync();
    }

    private async Task InvokeNewSale()
    {
        if (OnNewSale.HasDelegate) await OnNewSale.InvokeAsync();
        if (OnClose.HasDelegate) await OnClose.InvokeAsync();
    }

    private async Task HandleBackdropClick()
    {
        if (OnClose.HasDelegate) await OnClose.InvokeAsync();
    }
}
