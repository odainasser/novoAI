@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using System.Globalization
@using Web.Models.Inventory
@using Web.Models.Warehouses
@using Web.Models.Categories
@using Web.Models.Units
@inject IStocktakeClientService StocktakeService
@inject IWarehouseService WarehouseService
@inject ICategoryService CategoryService
@inject IUnitService UnitService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer

@* Shared Stocktake tab used by both the Admin and Branch inventory sections.
   When BranchId is set the view is scoped to the branch warehouse and every
   API call carries the branchId for server-side validation. *@

<div class="flex justify-end mb-4">
    <AuthorizeView Policy="Permission:inventory.write">
        <Authorized>
            <button @onclick="OpenCreate" class="btn-primary-action">
                <i class="bi bi-plus-circle"></i>
                <span>@Localizer["CreateStocktake"]</span>
            </button>
        </Authorized>
    </AuthorizeView>
</div>

<!-- Filters -->
<div class="mb-6 bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
    <div class="flex flex-wrap items-center gap-3 p-4">
        <div class="flex-1 min-w-[200px]">
            <SearchInput @bind-Value="searchTerm" OnSearch="HandleSearch" Placeholder="@Localizer["SearchStocktakes"]" />
        </div>

        <button @onclick="() => showFiltersPanel = !showFiltersPanel"
                class="@($"inline-flex items-center gap-2 py-2 px-4 rounded-lg border transition-all duration-200 font-medium text-sm {(showFiltersPanel ? "bg-purple-50 border-purple-300 text-purple-700" : "bg-white border-gray-300 text-gray-700 hover:bg-gray-50")}")">
            <i class="bi bi-funnel"></i>
            <span>@Localizer["Filters"]</span>
            @if (ActiveFilterCount > 0)
            {
                <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-purple-600 rounded-full">@ActiveFilterCount</span>
            }
            <i class="@($"bi bi-chevron-{(showFiltersPanel ? "up" : "down")} text-xs")"></i>
        </button>

        @if (HasActiveFilters())
        {
            <button @onclick="ResetFilters" class="inline-flex items-center gap-2 py-2 px-4 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">
                <i class="bi bi-x-circle"></i>
                <span>@Localizer["ResetFilters"]</span>
            </button>
        }
    </div>

    @if (showFiltersPanel)
    {
        <div class="px-4 pb-4 pt-0 border-t border-gray-200">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 pt-4">
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Status"]</label>
                    <div class="relative">
                        <select @bind="filterStatus" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                            <option value="">@Localizer["All"]</option>
                            <option value="Draft">@Localizer["StocktakeStatusDraft"]</option>
                            <option value="InProgress">@Localizer["StocktakeStatusInProgress"]</option>
                            <option value="Completed">@Localizer["StocktakeStatusCompleted"]</option>
                            <option value="Approved">@Localizer["StocktakeStatusApproved"]</option>
                            <option value="Cancelled">@Localizer["StocktakeStatusCancelled"]</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">@Localizer["Type"]</label>
                    <div class="relative">
                        <select @bind="filterType" @bind:after="ApplyFilters" class="w-full appearance-none bg-white border border-gray-300 text-gray-700 py-2 px-3 pe-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-bf-primary text-sm">
                            <option value="">@Localizer["AllTypes"]</option>
                            <option value="Full">@Localizer["StocktakeTypeFull"]</option>
                            <option value="Cycle">@Localizer["StocktakeTypeCycle"]</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 end-0 flex items-center px-2 text-gray-400"><svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg></div>
                    </div>
                </div>
                @if (BranchId == null)
                {
                    <div>
                        <SearchableDropdown TItem="WarehouseDto"
                                            TValue="string"
                                            Items="warehouses"
                                            @bind-Value="filterWarehouseId"
                                            OnChanged="ApplyFilters"
                                            DisplayText="w => isAr ? w.NameAr : w.NameEn"
                                            SearchText='w => $"{w.NameEn} {w.NameAr}"'
                                            ItemValue="w => w.Id.ToString()"
                                            Label='@Localizer["Warehouse"]'
                                            Placeholder='@Localizer["AllWarehouses"]'
                                            Compact="true" />
                    </div>
                }
            </div>
        </div>
    }
</div>

@if (isLoading)
{
    <Spinner Size="Spinner.SpinnerSize.Lg" Centered="true" />
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="p-4 bf-bg-danger-50 border bf-border-danger rounded-lg flex items-start gap-3">
        <i class="bi bi-exclamation-triangle-fill bf-icon-danger text-lg mt-0.5"></i>
        <span class="bf-text-danger">@errorMessage</span>
    </div>
}
else if (!stocktakeList.Any())
{
    <div class="text-center py-12">
        <i class="bi bi-clipboard-check text-6xl text-gray-300 mb-4"></i>
        <p class="text-gray-500 text-lg">@Localizer["NoStocktakesFound"]</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["StocktakeNumber"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Warehouse"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Type"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Progress"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Date"]</th>
                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                    <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var st in stocktakeList)
                {
                    <tr class="hover:bg-gray-50 transition-colors duration-150">
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@st.StocktakeNumber</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@(isAr ? st.WarehouseNameAr : st.WarehouseNameEn)</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            @Localizer[st.Type == "Full" ? "StocktakeTypeFull" : "StocktakeTypeCycle"]
                            @if (st.Type == "Cycle" && !string.IsNullOrEmpty(st.ScopeCategoryNameEn))
                            {
                                <span class="text-xs text-gray-400 block">@(isAr ? st.ScopeCategoryNameAr : st.ScopeCategoryNameEn)</span>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            <span>@st.CountedLines / @st.TotalLines @Localizer["Counted"]</span>
                            @if (st.FlaggedLines > 0)
                            {
                                <span class="text-xs bf-text-warning-strong block">@st.FlaggedLines @Localizer["Discrepancies"]</span>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@st.CreatedAt.ToLocal().ToString("dd/MM/yyyy")</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <span class="px-2 py-1 text-xs font-medium rounded-full @StatusClass(st.Status)">@Localizer[StatusKey(st.Status)]</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                            @if (st.Status is "Draft" or "InProgress")
                            {
                                <AuthorizeView Policy="Permission:inventory.write">
                                    <Authorized>
                                        <button @onclick="() => OpenDetail(st.Id)" title="@Localizer["Count"]" class="text-bf-primary hover:opacity-80 me-2">
                                            <i class="bi bi-clipboard-data"></i>
                                        </button>
                                    </Authorized>
                                </AuthorizeView>
                            }
                            else if (st.Status == "Completed")
                            {
                                <button @onclick="() => OpenDetail(st.Id)" title="@Localizer["ReviewAndApprove"]" class="text-indigo-600 hover:text-indigo-900 me-2">
                                    <i class="bi bi-check2-square"></i>
                                </button>
                            }
                            else
                            {
                                <button @onclick="() => OpenDetail(st.Id)" title="@Localizer["View"]" class="text-indigo-600 hover:text-indigo-900 me-2">
                                    <i class="bi bi-eye"></i>
                                </button>
                            }
                            @if (st.Status is "Draft" or "InProgress" or "Completed")
                            {
                                <AuthorizeView Policy="Permission:inventory.write">
                                    <Authorized>
                                        <button @onclick="() => ConfirmCancel(st.Id)" title="@Localizer["Cancel"]" class="bf-text-danger bf-hover-text-danger-strong">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    </Authorized>
                                </AuthorizeView>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="@OnPageChanged" />
}

<!-- Cancel Confirm -->
<ConfirmModal IsVisible="@showCancelConfirm"
              Title="@Localizer["CancelStocktakeTitle"]"
              Message="@Localizer["CancelStocktakeMessage"]"
              OnConfirm="@HandleCancel"
              OnCancel="@(() => showCancelConfirm = false)"
              IsDanger="true" />

@* ===== Create Modal ===== *@
@if (showCreateModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center" @onclick="CloseCreate">
        <div class="bg-white rounded-xl shadow-lg max-w-3xl w-full mx-4 max-h-[90vh] overflow-hidden flex flex-col" @onclick:stopPropagation>
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 flex-shrink-0">
                <h3 class="text-lg font-semibold text-gray-900">@Localizer["CreateStocktake"]</h3>
                <button @onclick="CloseCreate" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="px-5 py-4 overflow-y-auto flex-1">
                <div class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["Warehouse"] *</label>
                            <select value="@createRequest.WarehouseId" @onchange="OnCreateWarehouseChanged" disabled="@(BranchId != null)"
                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary focus:border-transparent disabled:bg-gray-100">
                                <option value="@Guid.Empty">@Localizer["SelectWarehouse"]</option>
                                @foreach (var w in warehouses)
                                {
                                    <option value="@w.Id">@(isAr ? w.NameAr : w.NameEn)</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["Type"] *</label>
                            <select @bind="createRequest.Type" @bind:after="OnCreateTypeChanged" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary focus:border-transparent">
                                <option value="">@Localizer["SelectType"]</option>
                                <option value="Full">@Localizer["StocktakeTypeFull"]</option>
                                <option value="Cycle">@Localizer["StocktakeTypeCycle"]</option>
                            </select>
                        </div>
                    </div>

                    @if (createRequest.Type == "Cycle")
                    {
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["StocktakeScope"] *</label>
                            <select @bind="createRequest.ScopeType" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary focus:border-transparent">
                                <option value="Category">@Localizer["ScopeCategory"]</option>
                                <option value="Products">@Localizer["ScopeProducts"]</option>
                            </select>
                        </div>

                        @if (createRequest.ScopeType == "Category")
                        {
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["Category"] *</label>
                                <SearchableDropdown TItem="CategoryDto" TValue="Guid?"
                                                    Items="categories"
                                                    @bind-Value="createRequest.ScopeCategoryId"
                                                    DisplayText="c => isAr ? c.NameAr : c.NameEn"
                                                    SearchText='c => $"{c.NameEn} {c.NameAr}"'
                                                    ItemValue="c => (Guid?)c.Id"
                                                    Placeholder="@Localizer["SelectCategory"]"
                                                    Compact="true" />
                            </div>
                        }
                        else if (createRequest.ScopeType == "Products")
                        {
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["Products"] *</label>
                                <div class="flex items-end gap-2">
                                    <div class="flex-1">
                                        <SearchableDropdown TItem="UnitDto" TValue="Guid"
                                                            Items="selectableUnits"
                                                            @bind-Value="unitToAdd"
                                                            DisplayText="@(u => (isAr ? u.ProductNameAr : u.ProductNameEn) + " - " + (isAr ? u.UnitOfMeasureNameAr : u.UnitOfMeasureNameEn) + " (" + u.Quantity + ")")"
                                                            SearchText='@(u => $"{u.ProductNameEn} {u.ProductNameAr} {u.Barcode}")'
                                                            ItemValue="@(u => u.Id)"
                                                            Placeholder="@Localizer["SelectUnit"]"
                                                            Compact="true"
                                                            Clearable="false" />
                                    </div>
                                    <button @onclick="AddScopeUnit" disabled="@(unitToAdd == Guid.Empty)" class="px-3 py-2 bf-bg-success-600 bf-hover-bg-success-700 rounded-lg text-sm disabled:opacity-50">
                                        <i class="bi bi-plus"></i> @Localizer["AddItem"]
                                    </button>
                                </div>
                                @if (scopeUnits.Any())
                                {
                                    <div class="mt-2 flex flex-wrap gap-2">
                                        @foreach (var u in scopeUnits)
                                        {
                                            <span class="inline-flex items-center gap-1 px-2 py-1 bg-purple-100 text-purple-800 rounded-full text-xs">
                                                @(isAr ? u.ProductNameAr : u.ProductNameEn)
                                                <button @onclick="() => RemoveScopeUnit(u.Id)" class="bf-text-danger"><i class="bi bi-x"></i></button>
                                            </span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">@Localizer["Notes"]</label>
                        <textarea @bind="createRequest.Notes" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary focus:border-transparent"></textarea>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="mt-4 p-3 bf-bg-danger-50 border bf-border-danger rounded-lg bf-text-danger text-sm">
                        <i class="bi bi-exclamation-triangle me-1"></i> @modalError
                    </div>
                }
            </div>

            <div class="px-5 py-3 border-t border-gray-200 bg-gray-50 flex-shrink-0 flex justify-end gap-3">
                <button @onclick="CloseCreate" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 transition-colors">@Localizer["Cancel"]</button>
                <button @onclick="SaveCreate" disabled="@isSaving" class="px-4 py-2 text-sm font-medium bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-colors disabled:opacity-50 flex items-center justify-center gap-2">
                    @if (isSaving) { <Spinner Size="Spinner.SpinnerSize.Sm" /> }
                    <span>@Localizer["Create"]</span>
                </button>
            </div>
        </div>
    </div>
}

@* ===== Detail / Count / Review Modal ===== *@
@if (showDetailModal && current != null)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center" @onclick="CloseDetail">
        <div class="bg-white rounded-xl shadow-lg max-w-5xl w-full mx-4 max-h-[90vh] overflow-hidden flex flex-col" @onclick:stopPropagation>
            @{
                var isCounting = current.Status == "InProgress";
                var isReview = current.Status == "Completed";
                var isDraft = current.Status == "Draft";
            }
            <div class="flex items-start justify-between px-5 py-4 border-b border-gray-200 flex-shrink-0">
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 font-mono">@current.StocktakeNumber</h3>
                    <p class="text-sm text-gray-500 mt-0.5">
                        @(isAr ? current.WarehouseNameAr : current.WarehouseNameEn) ·
                        @Localizer[current.Type == "Full" ? "StocktakeTypeFull" : "StocktakeTypeCycle"] ·
                        <span class="px-2 py-0.5 text-xs font-medium rounded-full @StatusClass(current.Status)">@Localizer[StatusKey(current.Status)]</span>
                    </p>
                </div>
                <button @onclick="CloseDetail" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="px-5 py-4 overflow-y-auto flex-1">
                @if (isDraft)
                {
                    <div class="p-4 bg-blue-50 border border-blue-200 rounded-lg mb-4 flex items-center justify-between">
                        <span class="text-sm text-blue-800">@Localizer["StocktakeDraftHint"] (@current.TotalLines @Localizer["Items"])</span>
                        <AuthorizeView Policy="Permission:inventory.write">
                            <Authorized>
                                <button @onclick="StartCounting" disabled="@isSaving" class="px-4 py-2 bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 disabled:opacity-50 flex items-center gap-2">
                                    @if (isSaving) { <Spinner Size="Spinner.SpinnerSize.Sm" /> }
                                    <i class="bi bi-play-circle"></i> <span>@Localizer["StartCounting"]</span>
                                </button>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                }

                @if (isCounting)
                {
                    <div class="flex flex-wrap items-center gap-3 mb-4">
                        <div class="flex-1 min-w-[220px]">
                            <label class="block text-xs text-gray-500 mb-1">@Localizer["ScanBarcode"]</label>
                            <input @bind="barcodeInput" @bind:event="oninput" @onkeydown="OnBarcodeKeyDown"
                                   placeholder="@Localizer["ScanBarcodePlaceholder"]"
                                   class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-bf-primary" />
                        </div>
                        <label class="inline-flex items-center gap-2 text-sm text-gray-600 mt-5">
                            <input type="checkbox" @bind="showSystemQty" class="rounded" />
                            @Localizer["ShowSystemQuantity"]
                        </label>
                    </div>
                }

                <div class="overflow-x-auto border border-gray-200 rounded-lg">
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-3 py-2 text-start text-xs font-medium text-gray-500 uppercase">@Localizer["Unit"]</th>
                                @if (!isCounting || showSystemQty)
                                {
                                    <th class="px-3 py-2 text-end text-xs font-medium text-gray-500">@Localizer["SystemQuantity"]</th>
                                }
                                <th class="px-3 py-2 text-end text-xs font-medium text-gray-500">@Localizer["CountedQuantity"]</th>
                                @if (!isCounting)
                                {
                                    <th class="px-3 py-2 text-end text-xs font-medium text-gray-500">@Localizer["Difference"]</th>
                                }
                                @if (isReview)
                                {
                                    <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["AdjustmentType"]</th>
                                }
                                @if (current.Status == "Approved")
                                {
                                    <th class="px-3 py-2 text-start text-xs font-medium text-gray-500">@Localizer["Adjustment"]</th>
                                }
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @foreach (var line in current.Lines)
                            {
                                var lineId = line.Id;
                                <tr id="@($"stk-line-{lineId}")" class="@(highlightLineId == lineId ? "bg-yellow-50" : (line.Difference != 0 && !isCounting ? "bf-bg-warning-50" : ""))">
                                    <td class="px-3 py-2">
                                        <span class="font-medium">@(isAr ? line.ProductNameAr : line.ProductNameEn)</span>
                                        <div class="text-xs text-gray-500">@line.UnitBarcode · @(isAr ? line.UnitOfMeasureNameAr : line.UnitOfMeasureNameEn) (@line.UnitBaseQuantity)</div>
                                    </td>
                                    @if (!isCounting || showSystemQty)
                                    {
                                        <td class="px-3 py-2 text-end">@line.SystemQuantity</td>
                                    }
                                    <td class="px-3 py-2 text-end">
                                        @if (isCounting)
                                        {
                                            <input type="number" min="0" @bind="line.CountedQuantity"
                                                   class="w-24 border border-gray-300 rounded px-2 py-1 text-sm text-end" />
                                        }
                                        else
                                        {
                                            <span>@(line.CountedQuantity?.ToString() ?? "—")</span>
                                        }
                                    </td>
                                    @if (!isCounting)
                                    {
                                        <td class="px-3 py-2 text-end font-medium @(line.Difference == 0 ? "bf-text-success" : "bf-text-danger")">
                                            @(line.Difference > 0 ? "+" : "")@line.Difference
                                        </td>
                                    }
                                    @if (isReview)
                                    {
                                        <td class="px-3 py-2">
                                            @if (line.Difference < 0)
                                            {
                                                <select @bind="approveTypes[lineId]" class="border border-gray-300 rounded px-2 py-1 text-sm">
                                                    <option value="">@Localizer["SelectType"]</option>
                                                    <option value="Loss">@Localizer["Loss"]</option>
                                                    <option value="Theft">@Localizer["Theft"]</option>
                                                    <option value="Damage">@Localizer["Damage"]</option>
                                                    <option value="Expiry">@Localizer["Expiry"]</option>
                                                </select>
                                            }
                                            else if (line.Difference > 0)
                                            {
                                                <select @bind="approveTypes[lineId]" class="border border-gray-300 rounded px-2 py-1 text-sm">
                                                    <option value="">@Localizer["SelectType"]</option>
                                                    <option value="CorrectionAdd">@Localizer["CorrectionAdd"]</option>
                                                </select>
                                            }
                                            else
                                            {
                                                <span class="text-xs text-gray-400">@Localizer["Matched"]</span>
                                            }
                                        </td>
                                    }
                                    @if (current.Status == "Approved")
                                    {
                                        <td class="px-3 py-2">
                                            @if (!string.IsNullOrEmpty(line.GeneratedAdjustmentNumber))
                                            {
                                                <span class="text-xs">@Localizer[line.AdjustmentType ?? string.Empty] · @line.GeneratedAdjustmentNumber</span>
                                            }
                                            else
                                            {
                                                <span class="text-xs text-gray-400">@Localizer["Matched"]</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="mt-4 p-3 bf-bg-danger-50 border bf-border-danger rounded-lg bf-text-danger text-sm">
                        <i class="bi bi-exclamation-triangle me-1"></i> @modalError
                    </div>
                }
            </div>

            <div class="px-5 py-3 border-t border-gray-200 bg-gray-50 flex-shrink-0 flex justify-end gap-3">
                <button @onclick="CloseDetail" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 transition-colors">@Localizer["Close"]</button>

                @if (isCounting)
                {
                    <AuthorizeView Policy="Permission:inventory.write">
                        <Authorized>
                            <button @onclick="() => SaveCounts()" disabled="@isSaving" class="px-4 py-2 text-sm font-medium bg-white text-gray-800 border border-gray-300 rounded-lg hover:bg-gray-100 disabled:opacity-50 flex items-center gap-2 transition-colors">
                                @if (isSaving) { <Spinner Size="Spinner.SpinnerSize.Sm" /> }
                                <i class="bi bi-save"></i> <span>@Localizer["SaveCounts"]</span>
                            </button>
                            <button @onclick="CompleteCounting" disabled="@isSaving" class="px-4 py-2 text-sm font-medium bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 disabled:opacity-50 flex items-center gap-2 transition-colors">
                                <i class="bi bi-check2-all"></i> <span>@Localizer["CompleteCounting"]</span>
                            </button>
                        </Authorized>
                    </AuthorizeView>
                }
                else if (isReview)
                {
                    <AuthorizeView Policy="Permission:inventory.approve">
                        <Authorized>
                            <button @onclick="ApproveStocktake" disabled="@isSaving" class="px-4 py-2 text-sm font-medium bf-bg-success-600 text-white rounded-lg hover:bf-bg-success-700 disabled:opacity-50 flex items-center gap-2 transition-colors">
                                @if (isSaving) { <Spinner Size="Spinner.SpinnerSize.Sm" /> }
                                <i class="bi bi-check-circle"></i> <span>@Localizer["ApproveAndGenerate"]</span>
                            </button>
                        </Authorized>
                    </AuthorizeView>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid? BranchId { get; set; }

    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private string modalError = string.Empty;
    private bool isAr = false;
    private int pageIndex = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private int totalCount = 0;

    private List<WarehouseDto> warehouses = new();
    private List<CategoryDto> categories = new();
    private List<UnitDto> units = new();

    private string searchTerm = string.Empty;
    private string filterStatus = string.Empty;
    private string filterType = string.Empty;
    private string filterWarehouseId = string.Empty;
    private bool showFiltersPanel = false;

    private List<StocktakeDto> stocktakeList = new();

    // Create
    private bool showCreateModal = false;
    private CreateStocktakeRequest createRequest = new();
    private List<UnitDto> selectableUnits = new();
    private List<UnitDto> scopeUnits = new();
    private Guid unitToAdd = Guid.Empty;

    // Detail / count / review
    private bool showDetailModal = false;
    private StocktakeDto? current;
    private string barcodeInput = string.Empty;
    private bool showSystemQty = false;
    private Guid highlightLineId = Guid.Empty;
    private Dictionary<Guid, string> approveTypes = new();

    // Cancel
    private bool showCancelConfirm = false;
    private Guid itemToCancel = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        await LoadLookupData();
        await LoadData();
    }

    private async Task LoadLookupData()
    {
        try
        {
            var allWarehouses = (await WarehouseService.GetActiveWarehousesAsync()).ToList();
            warehouses = BranchId.HasValue
                ? allWarehouses.Where(w => w.BranchId == BranchId.Value).ToList()
                : allWarehouses;
            categories = (await CategoryService.GetAllCategoriesAsync(1, 500, isActive: true)).Items;
            units = (await UnitService.GetAllAsync(1, 500, isActive: true)).Items;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load lookup data: {ex.Message}");
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            Guid? warehouseId = Guid.TryParse(filterWarehouseId, out var wId) ? wId : null;
            var result = await StocktakeService.GetAllAsync(
                pageIndex, pageSize, searchTerm,
                string.IsNullOrEmpty(filterType) ? null : filterType,
                string.IsNullOrEmpty(filterStatus) ? null : filterStatus,
                warehouseId, null, null, BranchId);
            stocktakeList = result.Items;
            totalPages = result.TotalPages;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnPageChanged(int newPage) { pageIndex = newPage; await LoadData(); }
    private async Task HandleSearch(string value) { searchTerm = value; pageIndex = 1; await LoadData(); }
    private async Task ApplyFilters() { pageIndex = 1; await LoadData(); }

    private async Task ResetFilters()
    {
        searchTerm = filterStatus = filterType = filterWarehouseId = string.Empty;
        showFiltersPanel = false;
        pageIndex = 1;
        await LoadData();
    }

    private bool HasActiveFilters() =>
        !string.IsNullOrEmpty(filterStatus) || !string.IsNullOrEmpty(filterType) || !string.IsNullOrEmpty(filterWarehouseId);

    private int ActiveFilterCount
    {
        get
        {
            int c = 0;
            if (!string.IsNullOrEmpty(filterStatus)) c++;
            if (!string.IsNullOrEmpty(filterType)) c++;
            if (!string.IsNullOrEmpty(filterWarehouseId)) c++;
            return c;
        }
    }

    private static string StatusKey(string status) => status switch
    {
        "Draft" => "StocktakeStatusDraft",
        "InProgress" => "StocktakeStatusInProgress",
        "Completed" => "StocktakeStatusCompleted",
        "Approved" => "StocktakeStatusApproved",
        "Cancelled" => "StocktakeStatusCancelled",
        _ => status
    };

    private static string StatusClass(string status) => status switch
    {
        "Draft" => "bg-gray-100 text-gray-700",
        "InProgress" => "bf-bg-info-100 bf-text-info",
        "Completed" => "bf-bg-warning-100 bf-text-warning",
        "Approved" => "bf-bg-success-100 bf-text-success",
        "Cancelled" => "bf-bg-danger-50 bf-text-danger",
        _ => "bg-gray-100 text-gray-700"
    };

    // ===== Create =====
    private void OpenCreate()
    {
        createRequest = new CreateStocktakeRequest { Type = "Full", ScopeType = "All" };
        if (BranchId.HasValue && warehouses.Count > 0)
            createRequest.WarehouseId = warehouses[0].Id;
        scopeUnits = new();
        selectableUnits = new();
        unitToAdd = Guid.Empty;
        modalError = string.Empty;
        showCreateModal = true;
    }

    private void CloseCreate() { showCreateModal = false; modalError = string.Empty; }

    private void OnCreateTypeChanged()
    {
        if (createRequest.Type == "Full")
        {
            createRequest.ScopeType = "All";
        }
        else if (createRequest.Type == "Cycle" && (createRequest.ScopeType == "All" || string.IsNullOrEmpty(createRequest.ScopeType)))
        {
            createRequest.ScopeType = "Category";
        }
    }

    private void OnCreateWarehouseChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        createRequest.WarehouseId = string.IsNullOrEmpty(val) ? Guid.Empty : Guid.Parse(val);
        scopeUnits.Clear();
        selectableUnits = createRequest.WarehouseId == Guid.Empty ? new() : units;
    }

    private void AddScopeUnit()
    {
        if (unitToAdd == Guid.Empty) return;
        var u = units.FirstOrDefault(x => x.Id == unitToAdd);
        if (u != null && scopeUnits.All(x => x.Id != u.Id))
            scopeUnits.Add(u);
        unitToAdd = Guid.Empty;
    }

    private void RemoveScopeUnit(Guid id) => scopeUnits.RemoveAll(x => x.Id == id);

    private async Task SaveCreate()
    {
        isSaving = true;
        modalError = string.Empty;
        try
        {
            if (createRequest.ScopeType == "Products")
                createRequest.UnitIds = scopeUnits.Select(u => u.Id).ToList();

            await StocktakeService.CreateAsync(createRequest, BranchId);
            CloseCreate();
            await LoadData();
        }
        catch (Web.Services.ServerValidationException ex)
        {
            modalError = string.Join(" ", ex.Errors.Values.SelectMany(v => v).Select(e => Localizer[e]));
        }
        catch (Exception ex) { modalError = ex.Message; }
        finally { isSaving = false; }
    }

    // ===== Detail / count / review =====
    private async Task OpenDetail(Guid id)
    {
        modalError = string.Empty;
        barcodeInput = string.Empty;
        highlightLineId = Guid.Empty;
        current = await StocktakeService.GetByIdAsync(id, BranchId);
        if (current == null) return;
        showSystemQty = current.Status != "InProgress"; // blind count by default while counting
        approveTypes = BuildApproveTypes(current);
        showDetailModal = true;
    }

    private void CloseDetail() { showDetailModal = false; current = null; modalError = string.Empty; }

    // Positive differences (stock to add) have only one valid type, so pre-select CorrectionAdd —
    // the manager can still change it. Negative differences are left for the manager to pick.
    private static Dictionary<Guid, string> BuildApproveTypes(StocktakeDto stocktake)
        => stocktake.Lines.ToDictionary(
            l => l.Id,
            l => !string.IsNullOrEmpty(l.AdjustmentType) ? l.AdjustmentType
                 : l.Difference > 0 ? "CorrectionAdd"
                 : string.Empty);

    private async Task StartCounting()
    {
        if (current == null) return;
        isSaving = true;
        modalError = string.Empty;
        try
        {
            current = await StocktakeService.StartAsync(current.Id, BranchId);
            showSystemQty = false;
            await LoadData();
        }
        catch (Exception ex) { modalError = ex.Message; }
        finally { isSaving = false; }
    }

    private void OnBarcodeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter" || current == null) return;
        var code = barcodeInput.Trim();
        if (string.IsNullOrEmpty(code)) return;

        var line = current.Lines.FirstOrDefault(l =>
            string.Equals(l.UnitBarcode, code, StringComparison.OrdinalIgnoreCase));
        if (line != null)
        {
            line.CountedQuantity = (line.CountedQuantity ?? 0) + 1;
            highlightLineId = line.Id;
            modalError = string.Empty;
        }
        else
        {
            modalError = Localizer["BarcodeNotInScope"];
        }
        barcodeInput = string.Empty;
    }

    private async Task SaveCounts(bool reload = true)
    {
        if (current == null) return;
        isSaving = true;
        modalError = string.Empty;
        try
        {
            var req = new SaveStocktakeCountsRequest
            {
                Lines = current.Lines
                    .Where(l => l.CountedQuantity.HasValue)
                    .Select(l => new StocktakeCountLineRequest { LineId = l.Id, CountedQuantity = l.CountedQuantity!.Value, Notes = l.Notes })
                    .ToList()
            };
            if (req.Lines.Count > 0)
                current = await StocktakeService.SaveCountsAsync(current.Id, req, BranchId);
            if (reload) await LoadData();
        }
        catch (Exception ex) { modalError = ex.Message; }
        finally { isSaving = false; }
    }

    private async Task CompleteCounting()
    {
        if (current == null) return;
        isSaving = true;
        modalError = string.Empty;
        try
        {
            await SaveCounts(reload: false);          // persist latest counts first
            current = await StocktakeService.CompleteAsync(current.Id, BranchId);
            showSystemQty = true;
            approveTypes = BuildApproveTypes(current);
            await LoadData();
        }
        catch (Exception ex) { modalError = ex.Message; }
        finally { isSaving = false; }
    }

    private async Task ApproveStocktake()
    {
        if (current == null) return;
        modalError = string.Empty;

        // Every difference line must have a type chosen by the manager — none are auto-filled.
        var diffLines = current.Lines.Where(l => l.Difference != 0).ToList();
        if (diffLines.Any(l => string.IsNullOrEmpty(approveTypes.GetValueOrDefault(l.Id))))
        {
            modalError = Localizer["AssignAllDifferenceTypes"];
            return;
        }

        isSaving = true;
        try
        {
            var req = new ApproveStocktakeRequest
            {
                Lines = diffLines
                    .Select(l => new ApproveStocktakeLineRequest
                    {
                        LineId = l.Id,
                        AdjustmentType = approveTypes.GetValueOrDefault(l.Id)
                    })
                    .ToList()
            };
            current = await StocktakeService.ApproveAsync(current.Id, req, BranchId);
            await LoadData();
        }
        catch (Web.Services.ServerValidationException ex)
        {
            modalError = string.Join(" ", ex.Errors.Values.SelectMany(v => v).Select(e => Localizer[e]));
        }
        catch (Exception ex) { modalError = ex.Message; }
        finally { isSaving = false; }
    }

    // ===== Cancel =====
    private void ConfirmCancel(Guid id) { itemToCancel = id; showCancelConfirm = true; }

    private async Task HandleCancel()
    {
        showCancelConfirm = false;
        try
        {
            await StocktakeService.CancelAsync(itemToCancel, BranchId);
            if (current?.Id == itemToCancel) CloseDetail();
            await LoadData();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }
}
