@using Web.Models.Shifts
@using Web.Models.Enums
@inject IShiftService ShiftService
@inject IJsonStringLocalizer Localizer
@using System.Globalization

@if (IsVisible)
{
    var currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.ToLowerInvariant();
    var cultureInfo = currentCulture == "ar" ? new CultureInfo("ar-AE") : new CultureInfo("en-AE");

    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center" @onclick="HandleBackgroundClick">
        <div class="bg-white rounded-xl shadow-lg max-w-4xl w-full mx-4 max-h-[90vh] overflow-hidden flex flex-col" @onclick:stopPropagation>
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 flex-shrink-0">
                <h3 class="text-lg font-semibold text-gray-900">@CashierName @Localizer["Shifts"]</h3>
                <button @onclick="Close" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="px-5 py-4 overflow-y-auto flex-1">

            @if (isLoading)
            {
                <Spinner Size="Spinner.SpinnerSize.Md" Centered="true" />
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="p-4 bg-red-50 border border-red-200 rounded-lg flex items-start gap-3">
                    <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                    <span class="text-red-800">@errorMessage</span>
                </div>
            }
            else if (shifts == null || !shifts.Any())
            {
                <div class="text-center py-12">
                    <i class="bi bi-inbox text-4xl text-gray-300 mb-3 block"></i>
                    <p class="text-sm text-gray-500">@Localizer["NoShiftsFound"]</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto border border-gray-200 rounded-lg">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-start text-xs font-semibold text-gray-600 uppercase tracking-wider">@Localizer["StartTime"]</th>
                                <th class="px-4 py-3 text-start text-xs font-semibold text-gray-600 uppercase tracking-wider">@Localizer["EndTime"]</th>
                                <th class="px-4 py-3 text-start text-xs font-semibold text-gray-600 uppercase tracking-wider">@Localizer["TotalSales"]</th>
                                <th class="px-4 py-3 text-start text-xs font-semibold text-gray-600 uppercase tracking-wider">@Localizer["CashIn"]</th>
                                <th class="px-4 py-3 text-start text-xs font-semibold text-gray-600 uppercase tracking-wider">@Localizer["CashOut"]</th>
                                <th class="px-4 py-3 text-start text-xs font-semibold text-gray-600 uppercase tracking-wider">@Localizer["Status"]</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-100">
                            @foreach (var s in shifts)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    @{ var localStart = s.StartTime.ToLocal(); }
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500" title="@localStart.ToString("yyyy-MM-dd HH:mm:ss")">
                                        <div>@localStart.ToString("yyyy-MM-dd")</div>
                                        <div class="text-xs text-gray-400">@localStart.ToString("hh:mm:ss tt")</div>
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500">
                                        @if (s.EndTime.HasValue)
                                        {
                                            var localEnd = s.EndTime.Value.ToLocal();
                                            <div title="@localEnd.ToString("yyyy-MM-dd HH:mm:ss")">
                                                <div>@localEnd.ToString("yyyy-MM-dd")</div>
                                                <div class="text-xs text-gray-400">@localEnd.ToString("hh:mm:ss tt")</div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-gray-400">—</span>
                                        }
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900">@s.TotalSales.ToString("N2")</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-700">@s.CashIn.ToString("N2")</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-700">@s.CashOut.ToString("N2")</td>
                                    <td class="px-4 py-3 whitespace-nowrap">
                                        <span class="@GetShiftStatusBadgeClass(s.Status)">
                                            @Localizer[$"ShiftStatus_{s.Status}"]
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            }

            </div>

            <div class="flex items-center justify-between px-5 py-4 border-t border-gray-200 flex-shrink-0">
                <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="@OnPageChanged" Compact="true" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string? CashierName { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private List<ShiftDto> shifts = new();
    private bool isLoading = false;
    private string? errorMessage;
    private int pageIndex = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private int totalCount = 0;

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !string.IsNullOrEmpty(CashierName))
        {
            pageIndex = 1; // reset paging when opening for a new cashier
            await LoadShifts();
        }
    }

    private async Task LoadShifts()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            var result = await ShiftService.GetAllShiftsAsync(pageIndex, pageSize, null, CashierName);
            shifts = result.Items;
            totalPages = result.TotalPages;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            shifts = new List<ShiftDto>();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnPageChanged(int newPage)
    {
        pageIndex = newPage;
        await LoadShifts();
    }

    private void Close()
    {
        OnClose.InvokeAsync();
    }

    private void HandleBackgroundClick()
    {
        Close();
    }

    private string GetShiftStatusBadgeClass(ShiftStatus status)
    {
        return status switch
        {
            ShiftStatus.Active => "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800",
            ShiftStatus.Completed => "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800",
            _ => "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800"
        };
    }
}
