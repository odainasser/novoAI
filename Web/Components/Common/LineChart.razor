@using System.Globalization

@* Reusable SVG line chart component with RTL/LTR tooltip support *@

<div style="min-height: @(Height + 104)px;" class="flex flex-col justify-start">
@if (!Items.Any())
{
    <div class="flex flex-col items-center justify-center text-center" style="min-height: @(Height + 104)px;">
        <div class="h-12 w-12 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <i class="bi bi-graph-up text-gray-400 text-xl"></i>
        </div>
        <p class="text-gray-500 text-sm">@EmptyText</p>
    </div>
}
else
{
    var maxVal = Math.Max(1m, Items.Max(i => i.Value));
    var count = Items.Count;
    var paddingLeft = 60;
    var paddingRight = 24;
    var paddingTop = 32;
    var paddingBottom = 40;
    var chartWidth = Math.Max(count * PointSpacing, 400);
    var svgWidth = chartWidth + paddingLeft + paddingRight;
    var svgHeight = Height + paddingTop + paddingBottom;
    var chartHeight = Height;
    var gridLines = 4;
    const int tooltipWidth = 160;
    const int tooltipHeight = 40;

    // Build point coordinates
    var points = new List<(double X, double Y, int Index)>();
    for (var i = 0; i < count; i++)
    {
        var x = paddingLeft + (count > 1 ? (double)i / (count - 1) * chartWidth : chartWidth / 2.0);
        var y = paddingTop + chartHeight - (double)(Items[i].Value / maxVal) * chartHeight;
        points.Add((x, y, i));
    }

    // SVG polyline points string
    var polylinePoints = string.Join(" ", points.Select(p => $"{p.X.ToString("F1", CultureInfo.InvariantCulture)},{p.Y.ToString("F1", CultureInfo.InvariantCulture)}"));

    // Gradient polygon (fill area under line)
    var areaPoints = polylinePoints
        + $" {points.Last().X.ToString("F1", CultureInfo.InvariantCulture)},{(paddingTop + chartHeight).ToString("F1", CultureInfo.InvariantCulture)}"
        + $" {points.First().X.ToString("F1", CultureInfo.InvariantCulture)},{(paddingTop + chartHeight).ToString("F1", CultureInfo.InvariantCulture)}";

    <div style="overflow-x: auto; overflow-y: hidden;">
        <svg width="@svgWidth" height="@svgHeight" class="select-none" style="min-width: @(svgWidth)px;">
            <defs>
                <linearGradient id="line-chart-fill-@_instanceId" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" style="stop-color: @FillColor;" stop-opacity="0.25" />
                    <stop offset="100%" style="stop-color: @FillColor;" stop-opacity="0.02" />
                </linearGradient>
            </defs>

            @* Grid lines and Y-axis labels *@
            @for (var g = 0; g <= gridLines; g++)
            {
                var gy = paddingTop + (double)g / gridLines * chartHeight;
                var gridVal = maxVal - (maxVal * g / gridLines);
                var isBaseline = g == gridLines;
                <line class="@(isBaseline ? "chart-grid-baseline" : "chart-grid-line")"
                      x1="@paddingLeft" y1="@gy.ToString("F1", CultureInfo.InvariantCulture)"
                      x2="@(paddingLeft + chartWidth)" y2="@gy.ToString("F1", CultureInfo.InvariantCulture)"
                      stroke-width="1" stroke-dasharray="@(isBaseline ? "0" : "4,4")" />
                @((MarkupString)$"<text class='chart-axis-label-muted' x='{paddingLeft - 10}' y='{(gy + 4).ToString("F1", CultureInfo.InvariantCulture)}' text-anchor='end' font-size='11' font-weight='500' font-family='system-ui, sans-serif'>{FormatYLabel(gridVal)}</text>")
            }

            @* Area fill *@
            <polygon points="@areaPoints" fill="url(#line-chart-fill-@_instanceId)" />

            @* Line *@
            <polyline points="@polylinePoints" fill="none" stroke-width="2.5"
                      stroke-linecap="round" stroke-linejoin="round" style="stroke: @LineColor;" />

            @* Data points and X-axis labels *@
            @foreach (var pt in points)
            {
                var item = Items[pt.Index];
                var labelY = paddingTop + chartHeight + 24;

                // Clamp tooltip horizontally so it stays within svg bounds
                var rawTipX = pt.X - tooltipWidth / 2.0;
                var minTipX = paddingLeft - 8;
                var maxTipX = paddingLeft + chartWidth + paddingRight - tooltipWidth + 8;
                var tipX = Math.Min(Math.Max(rawTipX, minTipX), maxTipX);

                // Default tooltip above the dot; flip below if too close to the top
                var tipAboveY = pt.Y - tooltipHeight - 12;
                var tipY = tipAboveY < paddingTop - 4 ? pt.Y + 12 : tipAboveY;

                @* X-axis label *@
                @((MarkupString)$"<text class='chart-axis-label' x='{pt.X.ToString("F1", CultureInfo.InvariantCulture)}' y='{labelY}' text-anchor='middle' font-size='11' font-weight='600' font-family='system-ui, sans-serif'>{item.Label}</text>")

                @* Hover vertical guide line *@
                <line id="lc-guide-@(_instanceId)-@(pt.Index)"
                      x1="@pt.X.ToString("F1", CultureInfo.InvariantCulture)" y1="@paddingTop"
                      x2="@pt.X.ToString("F1", CultureInfo.InvariantCulture)" y2="@(paddingTop + chartHeight)"
                      stroke-width="1" stroke-dasharray="3,3" opacity="0"
                      style="stroke: @LineColor; transition: opacity 0.15s; pointer-events: none;" />

                @* Invisible hover area *@
                <rect x="@((pt.X - PointSpacing / 2.0).ToString("F1", CultureInfo.InvariantCulture))" y="@paddingTop"
                      width="@PointSpacing" height="@chartHeight" fill="transparent" class="cursor-pointer"
                      onmouseover="this.parentNode.querySelector('#lc-dot-@(_instanceId)-@(pt.Index)').setAttribute('r','6');this.parentNode.querySelector('#lc-tip-@(_instanceId)-@(pt.Index)').style.opacity='1';this.parentNode.querySelector('#lc-guide-@(_instanceId)-@(pt.Index)').setAttribute('opacity','0.5')"
                      onmouseout="this.parentNode.querySelector('#lc-dot-@(_instanceId)-@(pt.Index)').setAttribute('r','4');this.parentNode.querySelector('#lc-tip-@(_instanceId)-@(pt.Index)').style.opacity='0';this.parentNode.querySelector('#lc-guide-@(_instanceId)-@(pt.Index)').setAttribute('opacity','0')" />

                @* Dot *@
                <circle id="lc-dot-@(_instanceId)-@(pt.Index)"
                        cx="@pt.X.ToString("F1", CultureInfo.InvariantCulture)" cy="@pt.Y.ToString("F1", CultureInfo.InvariantCulture)"
                        r="4" fill="white" stroke-width="2.5"
                        style="stroke: @LineColor; transition: r 0.15s; pointer-events: none; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.1));" />

                @* Tooltip *@
                <foreignObject id="lc-tip-@(_instanceId)-@(pt.Index)"
                               x="@tipX.ToString("F1", CultureInfo.InvariantCulture)"
                               y="@tipY.ToString("F1", CultureInfo.InvariantCulture)"
                               width="@tooltipWidth" height="@tooltipHeight"
                               style="opacity:0; transition: opacity 0.15s; pointer-events: none; overflow: visible;">
                    <div xmlns="http://www.w3.org/1999/xhtml"
                         class="bg-gray-800 text-white text-xs rounded-lg px-2.5 py-1.5 shadow-md text-center whitespace-nowrap w-fit mx-auto">
                        @((MarkupString)item.Tooltip)
                    </div>
                </foreignObject>
            }
        </svg>
    </div>

    @if (LegendItems.Any())
    {
        <div class="flex items-center gap-4 mt-4 text-xs text-gray-500 flex-wrap">
            @foreach (var legend in LegendItems)
            {
                <div class="flex items-center gap-1.5">
                    <div class="w-3 h-3 rounded-sm" style="background-color: @legend.Color;"></div>
                    <span>@legend.Label</span>
                </div>
            }
        </div>
    }
}
</div>

@code {
    [Parameter] public List<LineChartItem> Items { get; set; } = new();
    [Parameter] public List<LineChartLegend> LegendItems { get; set; } = new();
    [Parameter] public int Height { get; set; } = 180;
    [Parameter] public int PointSpacing { get; set; } = 72;
    [Parameter] public string LineColor { get; set; } = "var(--bf-primary)";
    [Parameter] public string FillColor { get; set; } = "var(--bf-primary)";
    [Parameter] public string EmptyText { get; set; } = "No data available";

    private string _instanceId = Guid.NewGuid().ToString("N")[..8];

    private static string FormatYLabel(decimal val)
    {
        if (val >= 1_000_000) return (val / 1_000_000).ToString("0.#") + "M";
        if (val >= 1_000) return (val / 1_000).ToString("0.#") + "K";
        return val.ToString("0");
    }

    public class LineChartItem
    {
        public string Label { get; set; } = string.Empty;
        public decimal Value { get; set; }
        public string Tooltip { get; set; } = string.Empty;
    }

    public class LineChartLegend
    {
        public string Label { get; set; } = string.Empty;
        public string Color { get; set; } = "var(--bf-primary)";
    }
}
