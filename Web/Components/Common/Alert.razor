@* Reusable alert/message component *@
@if (!string.IsNullOrEmpty(Message))
{
    <div class="@GetAlertClass() mb-6 p-4 rounded-lg flex items-start gap-3">
        <i class="@GetIconClass() text-lg mt-0.5"></i>
        <div class="flex-1">
            <span class="@GetTextClass()">@Message</span>
            @if (Dismissible)
            {
                <button type="button" class="@GetDismissButtonClass()" @onclick="Dismiss">
                    <i class="bi bi-x-lg"></i>
                </button>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string? Message { get; set; }
    [Parameter] public AlertType Type { get; set; } = AlertType.Info;
    [Parameter] public bool Dismissible { get; set; } = true;
    [Parameter] public EventCallback OnDismiss { get; set; }

    private async Task Dismiss()
    {
        Message = null;
        await OnDismiss.InvokeAsync();
    }

    private string GetAlertClass() => Type switch
    {
        AlertType.Success => "bf-bg-success-50 border bf-border-success",
        AlertType.Error => "bf-bg-danger-50 border bf-border-danger",
        AlertType.Warning => "bf-bg-warning-50 border bf-border-warning",
        _ => "bf-bg-info-50 border bf-border-info"
    };

    private string GetIconClass() => Type switch
    {
        AlertType.Success => "bi bi-check-circle-fill bf-icon-success",
        AlertType.Error => "bi bi-exclamation-triangle-fill bf-icon-danger",
        AlertType.Warning => "bi bi-exclamation-triangle-fill bf-icon-warning",
        _ => "bi bi-info-circle-fill bf-text-info"
    };

    private string GetTextClass() => Type switch
    {
        AlertType.Success => "bf-text-success",
        AlertType.Error => "bf-text-danger",
        AlertType.Warning => "bf-text-warning",
        _ => "bf-text-info"
    };

    private string GetDismissButtonClass() => Type switch
    {
        AlertType.Success => "float-right bf-text-success bf-hover-text-success-strong",
        AlertType.Error => "float-right bf-text-danger bf-hover-text-danger-strong",
        AlertType.Warning => "float-right bf-text-warning bf-hover-text-warning-strong",
        _ => "float-right bf-text-info bf-hover-text-info-strong"
    };

    public enum AlertType
    {
        Success,
        Error,
        Warning,
        Info
    }
}
