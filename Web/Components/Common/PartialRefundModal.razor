@inject IJsonStringLocalizer Localizer
@using Web.Models.Orders

@if (IsVisible)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center">
        <div class="bg-white rounded-xl shadow-lg max-w-md w-full mx-4 overflow-hidden">
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">@Title</h3>
                <button type="button" @onclick="HandleCancel" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="px-5 py-4">
                <p class="text-sm text-gray-600 mb-4">@Message</p>

                @if (refundItems != null && refundItems.Any())
                {
                    <div class="max-h-60 overflow-y-auto border border-gray-200 rounded-lg">
                        @foreach (var it in refundItems)
                        {
                            <div class="flex items-center gap-3 px-3 py-2.5 hover:bg-gray-50 border-b border-gray-100 last:border-b-0">
                                <div class="flex-1 min-w-0">
                                    <div class="text-sm font-medium text-gray-900 truncate">@it.ProductName</div>
                                    <div class="text-xs text-gray-500 font-mono">@it.ProductCode</div>
                                </div>
                                <div class="w-24 flex-shrink-0">
                                    <input type="number" min="0" max="@it.Quantity" @bind="it.RefundQuantity" class="w-full border border-gray-300 rounded-lg px-2 py-1.5 text-sm focus:ring-2 focus:ring-bf-primary focus:border-transparent" />
                                    <div class="text-xs text-gray-500 mt-0.5">@Localizer["Available"]: @it.Quantity</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">@Localizer["RefundAmount"] <span class="text-red-500">*</span></label>
                        <input type="number" step="0.01" min="0" @bind="amountInput" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-bf-primary focus:border-transparent" />
                        @if (errorMessage != null)
                        {
                            <p class="text-red-600 text-xs mt-1">@errorMessage</p>
                        }
                    </div>
                }
            </div>

            <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-gray-200">
                <button @onclick="HandleCancel" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">@CancelText</button>
                <button @onclick="HandleConfirm" class="px-4 py-2 text-sm font-medium bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-colors">@ConfirmText</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public string ConfirmText { get; set; } = string.Empty;
    [Parameter] public string CancelText { get; set; } = string.Empty;
    [Parameter] public decimal MaxAmount { get; set; }
    public class RefundItemModel
    {
        public Guid OrderItemId { get; set; }
        public Guid ProductId { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public string ProductCode { get; set; } = string.Empty;
        public int Quantity { get; set; }
        public int RefundQuantity { get; set; }
    }

    [Parameter] public List<OrderItemDto>? OrderItems { get; set; }
    private List<RefundItemModel>? refundItems;

    protected override void OnParametersSet()
    {
        // Initialize backing list so bindings persist across renders
        if (OrderItems != null)
        {
            refundItems = OrderItems.Select(i => new RefundItemModel
            {
                OrderItemId = i.Id,
                ProductId = i.ProductId,
                ProductName = i.ProductNameEn,
                ProductCode = i.ProductCode,
                Quantity = i.Quantity,
                RefundQuantity = 0
            }).ToList();
        }
        else
        {
            refundItems = null;
        }
    }

    [Parameter] public EventCallback<decimal> OnConfirm { get; set; }
    [Parameter] public EventCallback<List<PartialRefundItemRequest>> OnConfirmItems { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private decimal amountInput;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(Title)) Title = Localizer["PartialRefund"];
        if (string.IsNullOrEmpty(Message)) Message = Localizer["PartialRefundMessage"];
        if (string.IsNullOrEmpty(ConfirmText)) ConfirmText = Localizer["Confirm"];
        if (string.IsNullOrEmpty(CancelText)) CancelText = Localizer["Cancel"];
        amountInput = MaxAmount;
    }

    private async Task HandleConfirm()
    {
        errorMessage = null;
        if (refundItems != null && refundItems.Any())
        {
            var selected = refundItems.Where(i => i.RefundQuantity > 0).ToList();
            if (!selected.Any())
            {
                errorMessage = Localizer["InvalidAmount"];
                return;
            }

            // Validate quantities
            foreach (var s in selected)
            {
                if (s.RefundQuantity < 0 || s.RefundQuantity > s.Quantity)
                {
                    errorMessage = Localizer["InvalidAmount"];
                    return;
                }
            }

            if (OnConfirmItems.HasDelegate)
            {
                var payload = selected.Select(s => new PartialRefundItemRequest { OrderItemId = s.OrderItemId, Quantity = s.RefundQuantity }).ToList();
                await OnConfirmItems.InvokeAsync(payload);
                return;
            }
        }

        if (amountInput <= 0)
        {
            errorMessage = Localizer["InvalidAmount"];
            return;
        }
        if (amountInput > MaxAmount)
        {
            errorMessage = string.Format(Localizer["AmountExceedsTotal"], MaxAmount);
            return;
        }

        await OnConfirm.InvokeAsync(amountInput);
    }

    private async Task HandleCancel()
    {
        await OnCancel.InvokeAsync();
    }
}
