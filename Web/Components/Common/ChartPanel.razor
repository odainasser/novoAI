@* Reusable card panel for charts — includes title, icon, loading/empty states, optional filter, and action link *@

<div class="bg-white rounded-xl shadow-sm border border-gray-100">
    <div class="p-5 border-b border-gray-100">
        <div class="flex items-center justify-between gap-3 flex-wrap">
            <h3 class="font-semibold text-gray-900 flex items-center gap-2">
                @if (!string.IsNullOrEmpty(Icon))
                {
                    <i class="bi bi-@Icon @IconColorClass"></i>
                }
                @Title
            </h3>
            <div class="flex items-center gap-3">
                @if (HeaderActions != null)
                {
                    @HeaderActions
                }
                @if (!string.IsNullOrEmpty(ActionText) && !string.IsNullOrEmpty(ActionUrl))
                {
                    <a href="@ActionUrl" class="text-sm text-purple-600 hover:text-purple-700 font-medium flex items-center gap-1">
                        @ActionText
                        <i class="bi bi-arrow-right rtl:rotate-180"></i>
                    </a>
                }
            </div>
        </div>
        @if (FilterActions != null)
        {
            <div class="mt-3 pt-3 border-t border-gray-50">
                @FilterActions
            </div>
        }
    </div>
    <div class="p-5">
        @if (IsLoading)
        {
            <div class="flex items-center justify-center py-10">
                <Spinner Size="Spinner.SpinnerSize.Md" />
            </div>
        }
        else
        {
            @ChildContent
        }
    </div>
</div>

@code {
    /// <summary>Panel title text.</summary>
    [Parameter] public string Title { get; set; } = string.Empty;

    /// <summary>Bootstrap icon name (without "bi-" prefix).</summary>
    [Parameter] public string? Icon { get; set; }

    /// <summary>Tailwind color class for the icon (e.g. "text-purple-600").</summary>
    [Parameter] public string IconColorClass { get; set; } = "text-purple-600";

    /// <summary>Whether the panel is in loading state.</summary>
    [Parameter] public bool IsLoading { get; set; }

    /// <summary>Tailwind color class for the loading spinner.</summary>
    [Parameter] public string SpinnerColorClass { get; set; } = "text-purple-500";

    /// <summary>Action link text shown in header.</summary>
    [Parameter] public string? ActionText { get; set; }

    /// <summary>Action link URL.</summary>
    [Parameter] public string? ActionUrl { get; set; }

    /// <summary>Additional header actions (e.g. filter dropdowns) rendered before the action link.</summary>
    [Parameter] public RenderFragment? HeaderActions { get; set; }

    /// <summary>Filter controls rendered in a separate row below the title.</summary>
    [Parameter] public RenderFragment? FilterActions { get; set; }

    /// <summary>Main content rendered when not loading.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
