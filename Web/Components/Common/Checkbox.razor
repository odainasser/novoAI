@using System.Linq.Expressions

<div class="@ContainerClass">
    <div class="flex items-center">
        <input id="@Id" 
               type="checkbox" 
               checked="@Value" 
               disabled="@Disabled"
               @onchange="HandleChange"
               class="@ComputedInputClass" 
               @attributes="AdditionalAttributes" />
        
        @if (!string.IsNullOrEmpty(Label) || ChildContent != null)
        {
            <label for="@Id" class="@ComputedLabelClass">
                @if (!string.IsNullOrEmpty(Label))
                {
                    <span class="text-gray-900">@Label</span>
                }
                else
                {
                    @ChildContent
                }
            </label>
        }
    </div>
    @if (ValidationFor != null)
    {
        <div class="mt-1">
            <ValidationMessage For="@ValidationFor" class="text-sm text-red-600" />
        </div>
    }
</div>

@code {
    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    [Parameter] public Expression<Func<bool>>? ValidationFor { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string Id { get; set; } = "checkbox-" + Guid.NewGuid().ToString("N");
    [Parameter] public string Class { get; set; } = "";
    [Parameter] public string ContainerClass { get; set; } = "";
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedInputClass => $"h-4 w-4 text-purple-600 border-gray-300 rounded focus:ring-purple-500 transition duration-150 ease-in-out disabled:opacity-50 cursor-pointer {Class}";
    private string ComputedLabelClass => $"ms-2 block text-sm select-none cursor-pointer {(Disabled ? "opacity-50 cursor-not-allowed" : "")}";

    private async Task HandleChange(ChangeEventArgs e)
    {
        if (Disabled) return;
        var newValue = (bool)(e.Value ?? false);
        if (Value != newValue)
        {
            Value = newValue;
            await ValueChanged.InvokeAsync(newValue);
        }
    }
}
