@using Web.Models.Shifts
@using Web.Models.Cashiers
@inject IJsonStringLocalizer Localizer
@inject ICashierManagementService CashierManagementService

@if (IsVisible)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center" @onclick="OnCancelClicked">
        <div class="bg-white rounded-xl shadow-lg max-w-md w-full mx-4 overflow-hidden" @onclick:stopPropagation>
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">@Localizer["StartShift"]</h3>
                <button type="button" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors" @onclick="OnCancelClicked">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <EditForm Model="model" OnValidSubmit="HandleValidSubmit">
                <LocalizedDataAnnotationsValidator />
                <ServerValidator @ref="serverValidator" />

                <div class="px-5 py-4 space-y-4">
                    @if (assignedStores.Count > 1)
                    {
                        <div>
                            <SearchableDropdown TItem="AssignedWarehouseDto"
                                                TValue="Guid?"
                                                Items="assignedStores"
                                                @bind-Value="selectedWarehouseId"
                                                DisplayText="s => isAr ? s.NameAr : s.NameEn"
                                                SearchText='s => $"{s.NameEn} {s.NameAr}"'
                                                ItemValue="s => (Guid?)s.Id"
                                                Label='@Localizer["Store"]'
                                                Required="true"
                                                Clearable="false" />
                        </div>
                    }
                    else if (assignedStores.Count == 1)
                    {
                        <div class="flex items-center gap-2 px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-700">
                            <i class="bi bi-shop text-gray-400"></i>
                            <span>@(isAr ? assignedStores[0].NameAr : assignedStores[0].NameEn)</span>
                        </div>
                    }
                    else if (storesLoaded)
                    {
                        <div class="p-3 bf-bg-warning-50 border bf-border-warning rounded-lg text-sm bf-text-warning flex items-center gap-2">
                            <i class="bi bi-exclamation-triangle flex-shrink-0"></i>
                            <span>@Localizer["NoStoresAssigned"]</span>
                        </div>
                    }

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">@Localizer["CashIn"] <span class="text-red-500">*</span></label>
                        <InputNumber @bind-Value="model.CashIn" step="0.01" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all" />
                        <ValidationMessage For="() => model.CashIn" class="text-red-600 text-xs mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">@Localizer["Comments"]</label>
                        <InputTextArea @bind-Value="model.Comments" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-bf-primary focus:border-transparent transition-all" />
                    </div>

                    @if (!string.IsNullOrEmpty(switchError))
                    {
                        <div class="p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700 flex items-center gap-2">
                            <i class="bi bi-exclamation-circle flex-shrink-0"></i>
                            <span>@switchError</span>
                        </div>
                    }
                </div>

                <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-gray-200">
                    <button type="button" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" @onclick="OnCancelClicked">@Localizer["Cancel"]</button>
                    <button type="submit" disabled="@(isSubmitting || assignedStores.Count == 0)" class="px-4 py-2 text-sm font-medium bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-all disabled:opacity-50 inline-flex items-center gap-2">
                        @if (isSubmitting)
                        {
                            <Spinner Size="Spinner.SpinnerSize.Xs" Color="Spinner.SpinnerColor.White" />
                        }
                        @Localizer["StartShiftShort"]
                    </button>
                </div>
            </EditForm>

        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback<StartShiftRequest> OnStart { get; set; }

    private StartShiftModel model = new();
    private ServerValidator? serverValidator;

    private List<AssignedWarehouseDto> assignedStores = new();
    private Guid? selectedWarehouseId;
    private Guid? currentWarehouseId;
    private bool isAr = false;
    private bool isSubmitting = false;
    private string? switchError;
    private bool storesLoaded = false;

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !storesLoaded)
        {
            storesLoaded = true;
            isAr = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.ToLowerInvariant() == "ar";
            try
            {
                var profile = await CashierManagementService.GetCurrentCashierProfileAsync();
                if (profile != null)
                {
                    assignedStores = profile.AssignedWarehouses;
                    currentWarehouseId = profile.WarehouseId;
                    selectedWarehouseId = profile.WarehouseId;
                }
            }
            catch { }
        }
        if (!IsVisible)
        {
            storesLoaded = false;
        }
    }

    public void DisplayErrors(IDictionary<string, string[]> errors)
    {
        serverValidator?.DisplayErrors(errors);
    }

    public void Reset()
    {
        model = new StartShiftModel();
        switchError = null;
        storesLoaded = false;
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        switchError = null;

        try
        {
            // Switch store first if the cashier selected a different one
            if (selectedWarehouseId.HasValue && selectedWarehouseId != currentWarehouseId)
            {
                await CashierManagementService.SwitchMyStoreAsync(selectedWarehouseId.Value);
                currentWarehouseId = selectedWarehouseId;
            }

            var req = new StartShiftRequest { CashIn = model.CashIn, Comments = model.Comments };
            if (OnStart.HasDelegate)
            {
                await OnStart.InvokeAsync(req);
            }
        }
        catch (Exception ex)
        {
            switchError = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task OnCancelClicked()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }

    private class StartShiftModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "CashInRequired")]
        [System.ComponentModel.DataAnnotations.Range(0, double.MaxValue, ErrorMessage = "CashInMustBeNonNegative")]
        public decimal CashIn { get; set; }

        public string? Comments { get; set; }
    }
}
