@code {
    // When set, the assistant is hard-locked to this branch (Branch Panel). The
    // active branch id is sent with every request so the backend scopes answers
    // to the branch's warehouses and refuses cross-branch / company-wide data.
    [Parameter] public Guid? ScopeBranchId { get; set; }

    private bool isOpen;
    private bool isMaximized;
    private bool isTyping;

    // ── Report-answer modal ──────────────────────────────────────────
    private bool showReportModal;
    private bool reportSubmitting;
    private bool reportDone;
    private string reportError = string.Empty;
    private string reportFeedback = string.Empty;
    private string reportAnswerText = string.Empty;
    private string reportQuestionText = string.Empty;
    private bool isCooldown;
    private string inputText = string.Empty;
    private string? currentUserId;
    private ElementReference bodyRef;

    private readonly List<ChatDisplayMessage> displayMessages = new();
    private List<AssistantMessage> conversationHistory = new();

    private CancellationTokenSource? currentRequestCts;

    private string[] suggestions = Array.Empty<string>();

    // Tracks which scope the current conversation was loaded for, so switching
    // branches reloads that branch's own chat history instead of mixing them.
    private bool scopeLoaded;
    private Guid? loadedScope;

    private record ChatDisplayMessage(string Text, bool IsUser, DateTime Time);

    private string StorageKey => ScopeBranchId.HasValue
        ? $"ai-chat-history-{currentUserId}-branch-{ScopeBranchId}"
        : $"ai-chat-history-{currentUserId}";

    protected override async Task OnParametersSetAsync()
    {
        // Re-initialise only on the first render or when the active branch changes.
        if (scopeLoaded && loadedScope == ScopeBranchId)
            return;

        scopeLoaded = true;
        loadedScope = ScopeBranchId;

        displayMessages.Clear();
        conversationHistory = new();

        suggestions = ScopeBranchId.HasValue
            ? new[]
            {
                Localizer["AiSuggestBranchOrders"],
                Localizer["AiSuggestBranchLowStock"]
            }
            : new[]
            {
                Localizer["AiSuggestDashboard"],
                Localizer["AiSuggestTodaySales"],
                Localizer["AiSuggestLowStock"],
                Localizer["AiSuggestRevenue"]
            };

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (currentUserId is not null)
                await LoadHistoryFromStorageAsync();
        }
        catch { }

        if (displayMessages.Count == 0)
        {
            displayMessages.Add(new ChatDisplayMessage(
                ScopeBranchId.HasValue ? Localizer["AiChatWelcomeBranch"] : Localizer["AiChatWelcome"],
                false, DateTime.Now));
        }
    }

    private void ToggleOpen()
    {
        isOpen = !isOpen;
    }

    private void ToggleMaximize()
    {
        isMaximized = !isMaximized;
    }

    private void OpenReport(ChatDisplayMessage botMsg)
    {
        reportAnswerText = botMsg.Text;
        reportQuestionText = FindQuestionFor(botMsg);
        reportFeedback = string.Empty;
        reportError = string.Empty;
        reportDone = false;
        reportSubmitting = false;
        showReportModal = true;
    }

    // The question is the most recent user message before this bot answer.
    private string FindQuestionFor(ChatDisplayMessage botMsg)
    {
        var idx = displayMessages.IndexOf(botMsg);
        if (idx < 0) idx = displayMessages.Count - 1;
        for (var i = idx - 1; i >= 0; i--)
            if (displayMessages[i].IsUser) return displayMessages[i].Text;
        return string.Empty;
    }

    private void CloseReport() => showReportModal = false;

    private async Task SubmitReport()
    {
        if (reportSubmitting) return;
        reportSubmitting = true;
        reportError = string.Empty;
        try
        {
            await AssistantService.ReportAsync(new AssistantReportRequest
            {
                Question = reportQuestionText,
                Answer = reportAnswerText,
                Feedback = string.IsNullOrWhiteSpace(reportFeedback) ? null : reportFeedback.Trim(),
                Locale = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName,
                BranchId = ScopeBranchId
            });
            reportDone = true;
        }
        catch
        {
            reportError = Localizer["ReportFailed"];
        }
        finally
        {
            reportSubmitting = false;
        }
    }

    private async Task StartResize(Microsoft.AspNetCore.Components.Web.PointerEventArgs e)
    {
        var isRtl = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName
            .Equals("ar", StringComparison.OrdinalIgnoreCase);
        try { await JS.InvokeVoidAsync("AiChatResizer.start", e.ClientX, isMaximized, isRtl); }
        catch { }
    }

    private async Task SendSuggestion(string text)
    {
        inputText = text;
        await HandleSendAsync();
    }

    private async Task OnInputKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isTyping && !isCooldown && !string.IsNullOrWhiteSpace(inputText))
            await HandleSendAsync();
    }

    private void StopRequest()
    {
        try { currentRequestCts?.Cancel(); }
        catch { }
    }

    private async Task HandleSendAsync()
    {
        var question = inputText.Trim();
        if (string.IsNullOrEmpty(question) || isTyping || isCooldown)
            return;

        inputText = string.Empty;
        displayMessages.Add(new ChatDisplayMessage(question, true, DateTime.Now));
        isTyping = true;

        currentRequestCts?.Dispose();
        currentRequestCts = new CancellationTokenSource();
        var ct = currentRequestCts.Token;

        StateHasChanged();
        await ScrollToBottomAsync();

        try
        {
            var locale = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
            var request = new AssistantRequest
            {
                Question = question,
                History = conversationHistory,
                Locale = locale,
                BranchId = ScopeBranchId
            };

            var response = await AssistantService.AskAsync(request, ct);

            conversationHistory = response.History;
            displayMessages.Add(new ChatDisplayMessage(response.Answer, false, DateTime.Now));

            await SaveHistoryToStorageAsync();
        }
        catch (OperationCanceledException)
        {
            displayMessages.Add(new ChatDisplayMessage(
                Localizer["AiChatStopped"], false, DateTime.Now));
        }
        catch (Exception)
        {
            displayMessages.Add(new ChatDisplayMessage(
                Localizer["AiChatErrorGeneric"], false, DateTime.Now));
        }
        finally
        {
            isTyping = false;
            currentRequestCts?.Dispose();
            currentRequestCts = null;
            StateHasChanged();
            await ScrollToBottomAsync();
        }
    }

    private async void StartCooldown()
    {
        isCooldown = true;
        StateHasChanged();
        await Task.Delay(3000);
        isCooldown = false;
        StateHasChanged();
    }

    private async Task ClearConversation()
    {
        displayMessages.Clear();
        conversationHistory.Clear();
        displayMessages.Add(new ChatDisplayMessage(
            ScopeBranchId.HasValue ? Localizer["AiChatWelcomeBranch"] : Localizer["AiChatWelcome"],
            false, DateTime.Now));

        if (currentUserId is not null)
        {
            try { await LocalStorage.RemoveItemAsync(StorageKey); }
            catch { }
        }
    }

    private async Task CopyToClipboard(string text)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
        }
        catch { }
    }

    private async Task ScrollToBottomAsync()
    {
        try
        {
            await Task.Delay(50);
            await JS.InvokeVoidAsync("eval", "document.querySelector('.ai-chat-body')?.scrollTo({top:999999,behavior:'smooth'})");
        }
        catch { }
    }

    private static string FormatMarkdown(string text)
    {
        if (string.IsNullOrEmpty(text)) return string.Empty;

        var html = System.Net.WebUtility.HtmlEncode(text);

        // Bold: **text**
        html = Regex.Replace(html, @"\*\*(.+?)\*\*", "<strong>$1</strong>");

        // Inline code: `text`
        html = Regex.Replace(html, @"`(.+?)`", "<code>$1</code>");

        // Unordered list items: lines starting with - or *
        html = Regex.Replace(html, @"(?m)^[\-\*]\s+(.+)$", "<li>$1</li>");
        html = Regex.Replace(html, @"(<li>.*?</li>(\s*<li>.*?</li>)*)", "<ul>$1</ul>");

        // Numbered list items
        html = Regex.Replace(html, @"(?m)^\d+\.\s+(.+)$", "<li>$1</li>");

        // Line breaks
        html = html.Replace("\n", "<br/>");

        // Clean up double <br/> inside lists
        html = html.Replace("<br/><li>", "<li>");
        html = html.Replace("</li><br/>", "</li>");
        html = html.Replace("<br/><ul>", "<ul>");
        html = html.Replace("</ul><br/>", "</ul>");

        return html;
    }

    // ── localStorage persistence ────────────────────────────────────

    private async Task SaveHistoryToStorageAsync()
    {
        if (currentUserId is null) return;
        try
        {
            var toSave = displayMessages
                .Select(m => new StoredMessage(m.Text, m.IsUser, m.Time))
                .ToList();
            await LocalStorage.SetItemAsync(StorageKey, toSave);
        }
        catch { }
    }

    private async Task LoadHistoryFromStorageAsync()
    {
        if (currentUserId is null) return;
        try
        {
            var stored = await LocalStorage.GetItemAsync<List<StoredMessage>>(StorageKey);
            if (stored is { Count: > 0 })
            {
                foreach (var m in stored)
                    displayMessages.Add(new ChatDisplayMessage(m.Text, m.IsUser, m.Time));

                conversationHistory = stored
                    .Select(m => new AssistantMessage
                    {
                        Role = m.IsUser ? "user" : "assistant",
                        Content = m.Text
                    })
                    .ToList();
            }
        }
        catch { }
    }

    private record StoredMessage(string Text, bool IsUser, DateTime Time);
}
