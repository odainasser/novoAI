@using System.Globalization
@using System.Text.RegularExpressions
@using Web.Models.Assistant
@inject IAssistantClientService AssistantService
@inject IJsonStringLocalizer Localizer
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<div class="ai-chat-widget @(isOpen && isMaximized ? "maximized" : "")">
    @if (!isOpen)
    {
        <button type="button"
                class="ai-chat-fab"
                @onclick="ToggleOpen"
                title="@Localizer["AskAIAssistant"]">
            <i class="bi bi-stars"></i>
            <span class="ai-chat-fab-pulse"></span>
        </button>
    }
    else
    {
        <div class="ai-chat-panel @(isMaximized ? "maximized" : "")">
            <!-- Resize handle (drag the inner edge to widen) -->
            <div class="ai-chat-resizer" @onpointerdown="StartResize" title="@Localizer["DragToResize"]"></div>
            <!-- Header -->
            <div class="ai-chat-header">
                <div class="flex items-center gap-3">
                    <div class="ai-chat-avatar">
                        <i class="bi bi-robot"></i>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-white leading-tight">@Localizer["AiAssistant"]</p>
                        <p class="text-[11px] text-white/70 flex items-center gap-1">
                            <span class="ai-chat-dot"></span>
                            @Localizer["OnlineNow"]
                        </p>
                    </div>
                </div>
                <div class="flex items-center gap-1">
                    <button type="button" class="ai-chat-header-btn" @onclick="ClearConversation" title="@Localizer["Clear"]">
                        <i class="bi bi-trash3"></i>
                    </button>
                    <button type="button" class="ai-chat-header-btn" @onclick="ToggleMaximize"
                            title="@(isMaximized ? Localizer["Minimize"] : Localizer["Maximize"])">
                        <i class="bi @(isMaximized ? "bi-fullscreen-exit" : "bi-arrows-fullscreen")"></i>
                    </button>
                    <button type="button" class="ai-chat-header-btn" @onclick="ToggleOpen" title="@Localizer["Close"]">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>

            <!-- Messages -->
            <div class="ai-chat-body" @ref="bodyRef">
                @foreach (var msg in displayMessages)
                {
                    <div class="@(msg.IsUser ? "ai-msg-user" : "ai-msg-bot")">
                        @if (!msg.IsUser)
                        {
                            <div class="ai-msg-avatar">
                                <i class="bi bi-robot"></i>
                            </div>
                        }
                        <div class="ai-msg-bubble">
                            @if (msg.IsUser)
                            {
                                <p class="text-sm whitespace-pre-line">@msg.Text</p>
                            }
                            else
                            {
                                <div class="ai-msg-content text-sm">@((MarkupString)FormatMarkdown(msg.Text))</div>
                                <div class="ai-msg-actions">
                                    <button type="button" class="ai-msg-action" @onclick="() => CopyToClipboard(msg.Text)" title="@Localizer["Copy"]">
                                        <i class="bi bi-clipboard"></i>
                                    </button>
                                    <button type="button" class="ai-msg-action" @onclick="() => OpenReport(msg)" title="@Localizer["ReportAnswer"]">
                                        <i class="bi bi-flag"></i>
                                    </button>
                                </div>
                            }
                            <span class="ai-msg-time">@msg.Time.ToString("HH:mm")</span>
                        </div>
                    </div>
                }

                @if (isTyping)
                {
                    <div class="ai-msg-bot">
                        <div class="ai-msg-avatar">
                            <i class="bi bi-robot"></i>
                        </div>
                        <div class="ai-msg-bubble">
                            <div class="ai-typing">
                                <span></span><span></span><span></span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Quick suggestions -->
            @if (displayMessages.Count <= 1 && !isTyping)
            {
                <div class="ai-chat-suggestions">
                    @foreach (var s in suggestions)
                    {
                        <button type="button" class="ai-chat-chip" @onclick="() => SendSuggestion(s)">
                            <i class="bi bi-lightning-charge"></i>
                            @s
                        </button>
                    }
                </div>
            }

            <!-- Input -->
            <div class="ai-chat-input">
                <input type="text"
                       placeholder="@Localizer["AskAnything"]"
                       @bind="inputText"
                       @bind:event="oninput"
                       @onkeydown="OnInputKeyDown"
                       class="ai-chat-textbox" />
                @if (isTyping)
                {
                    <button type="button"
                            class="ai-chat-stop"
                            @onclick="StopRequest"
                            title="@Localizer["StopGeneration"]">
                        <i class="bi bi-stop-fill"></i>
                    </button>
                }
                else
                {
                    <button type="button"
                            class="ai-chat-send"
                            @onclick="HandleSendAsync"
                            disabled="@(isCooldown || string.IsNullOrWhiteSpace(inputText))">
                        <i class="bi bi-send-fill"></i>
                    </button>
                }
            </div>
        </div>
    }

    @* ── Report-answer modal (optional feedback) ─────────────────────── *@
    @if (showReportModal)
    {
        <div class="ai-report-overlay" @onclick="CloseReport">
            <div class="ai-report-card" @onclick:stopPropagation>
                <div class="ai-report-head">
                    <h3 class="flex items-center gap-2 text-sm font-semibold">
                        <i class="bi bi-flag"></i> @Localizer["ReportAnswer"]
                    </h3>
                    <button type="button" class="ai-report-x" @onclick="CloseReport" title="@Localizer["Close"]">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                @if (reportDone)
                {
                    <div class="ai-report-body">
                        <div class="flex flex-col items-center text-center py-4 gap-2">
                            <i class="bi bi-check-circle-fill text-3xl bf-icon-success"></i>
                            <p class="text-sm font-medium">@Localizer["ReportSubmitted"]</p>
                            <p class="text-xs ai-report-muted">@Localizer["ReportThanks"]</p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="ai-report-body">
                        <div class="ai-report-snippet">@reportAnswerText</div>
                        <label class="block text-xs font-medium ai-report-muted mb-1">@Localizer["FeedbackOptional"]</label>
                        <textarea class="ai-report-textarea" rows="3"
                                  placeholder="@Localizer["ReportFeedbackPlaceholder"]"
                                  @bind="reportFeedback" @bind:event="oninput"></textarea>
                        @if (!string.IsNullOrEmpty(reportError))
                        {
                            <div class="mt-2 text-xs bf-text-danger flex items-center gap-1">
                                <i class="bi bi-exclamation-circle"></i> <span>@reportError</span>
                            </div>
                        }
                    </div>
                    <div class="ai-report-foot">
                        <button type="button" class="ai-report-btn-cancel" @onclick="CloseReport">@Localizer["Cancel"]</button>
                        <button type="button" class="ai-report-btn-submit" @onclick="SubmitReport" disabled="@reportSubmitting">
                            @if (reportSubmitting)
                            {
                                <Spinner Size="Spinner.SpinnerSize.Sm" Color="Spinner.SpinnerColor.White" />
                            }
                            <span>@Localizer["SubmitReport"]</span>
                        </button>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
    .ai-chat-widget {
        position: fixed;
        bottom: 6vh;
        inset-inline-end: 2vw;
        z-index: 1050;
        font-size: clamp(0.8rem, 0.7rem + 0.35vw, 1rem);
    }

    .ai-chat-fab {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.5em;
        padding: 0.85em 1.3em;
        background: linear-gradient(135deg, var(--bf-primary) 0%, var(--bf-primary-dark) 100%);
        color: white;
        border: none;
        border-radius: 999em;
        box-shadow: 0 0.5em 1.5em rgba(5, 150, 105, 0.35);
        cursor: pointer;
        font-weight: 600;
        font-size: 1em;
        transition: transform .15s ease, box-shadow .15s ease;
    }
    .ai-chat-fab:hover {
        transform: translateY(-12.5%);
        box-shadow: 0 0.75em 1.75em rgba(5, 150, 105, 0.45);
    }
    .ai-chat-fab i { font-size: 1.25em; }
    .ai-chat-fab-pulse {
        position: absolute;
        inset-inline-end: -0.15em;
        top: -0.15em;
        width: 0.85em; height: 0.85em;
        border-radius: 50%;
        background: var(--bf-primary-500);
        box-shadow: 0 0 0 0 rgba(16,185,129,.7);
        animation: aiPulse 1.8s infinite;
    }
    @@keyframes aiPulse {
        0%   { box-shadow: 0 0 0 0 rgba(16,185,129,.7); }
        70%  { box-shadow: 0 0 0 0.7em rgba(16,185,129,0); }
        100% { box-shadow: 0 0 0 0 rgba(16,185,129,0); }
    }

    .ai-chat-panel {
        position: relative;
        width: var(--ai-chat-float-w, clamp(18rem, 30vw, 26rem));
        max-width: 96vw;
        height: clamp(24rem, 65vh, 36rem);
        max-height: 85vh;
        background: white;
        border-radius: 1em;
        box-shadow: 0 1.25em 3em rgba(0,0,0,.2);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        animation: aiSlideUp .2s ease-out;
    }

    /* Drag handle on the inner (start) edge — drag toward the page to widen. */
    .ai-chat-resizer {
        position: absolute;
        inset-inline-start: 0;
        top: 0;
        bottom: 0;
        width: 7px;
        cursor: ew-resize;
        z-index: 5;
        background: transparent;
        transition: background .15s ease;
        touch-action: none;
    }
    .ai-chat-resizer:hover,
    .ai-chat-resizer:active { background: var(--bf-primary-200); }
    @@keyframes aiSlideUp {
        from { opacity: 0; transform: translateY(0.75em); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Maximized: docked side rail on the end edge, mirroring the ──
       ── left navigation menu. It sits BELOW the full-width global  ──
       ── header (which bridges over it, exactly like the left menu) ──
       ── and reserves space so the content + footer reflow beside   ──
       ── it — nothing is overlaid, so no high z-index is needed. */
    :root { --ai-dock-w: clamp(20rem, 28vw, 28rem); }

    .ai-chat-widget.maximized {
        top: 4rem;                 /* below the fixed global header (h-16) */
        bottom: 0;
        inset-inline-start: auto;
        inset-inline-end: 0;
        z-index: 40;               /* same band as the sidebar, under the header */
    }
    .ai-chat-panel.maximized {
        width: var(--ai-dock-w);
        max-width: 100vw;
        height: 100%;
        max-height: none;
        border-radius: 0;
        border-inline-start: 1px solid #e5e7eb;
        box-shadow: none;
        animation: aiSlideIn .2s ease-out;
    }
    /* Match the chat header height to the layout header (h-16 = 4rem). */
    .ai-chat-panel.maximized .ai-chat-header {
        height: 4rem;
        padding-top: 0;
        padding-bottom: 0;
    }
    @@keyframes aiSlideIn {
        from { opacity: 0; transform: translateX(1.5em); }
        to   { opacity: 1; transform: translateX(0); }
    }
    [dir="rtl"] .ai-chat-panel.maximized {
        animation: aiSlideInRtl .2s ease-out;
    }
    @@keyframes aiSlideInRtl {
        from { opacity: 0; transform: translateX(-1.5em); }
        to   { opacity: 1; transform: translateX(0); }
    }

    /* Reserve space on the end side so the content + footer reflow beside
       the rail (like main's start-margin reserves space for the left menu).
       The global header stays full-width and bridges over the rail.
       Only on large screens; on smaller viewports the panel is full-width. */
    @@media (min-width: 64rem) {
        body:has(.ai-chat-widget.maximized) main {
            padding-inline-end: var(--ai-dock-w);
        }
    }
    @@media (max-width: 63.999rem) {
        .ai-chat-panel.maximized { width: 100vw; border-inline-start: none; }
    }

    .ai-chat-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1em 1.1em;
        background: linear-gradient(135deg, var(--bf-primary) 0%, var(--bf-primary-dark) 100%);
        color: white;
    }
    .ai-chat-avatar {
        width: 2.5em; height: 2.5em;
        border-radius: 50%;
        background: rgba(255,255,255,.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1em;
    }
    .ai-chat-dot {
        width: 0.55em; height: 0.55em;
        border-radius: 50%;
        background: var(--bf-primary-500);
        display: inline-block;
    }
    .ai-chat-header-btn {
        width: 2.2em; height: 2.2em;
        border-radius: 0.5em;
        border: none;
        background: rgba(255,255,255,.15);
        color: white;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: background .15s ease;
        font-size: 1em;
    }
    .ai-chat-header-btn:hover { background: rgba(255,255,255,.28); }

    .ai-chat-body {
        flex: 1;
        overflow-y: auto;
        padding: 1em;
        background: #f9fafb;
        display: flex;
        flex-direction: column;
        gap: 0.75em;
    }

    .ai-msg-bot, .ai-msg-user {
        display: flex;
        gap: 0.5em;
        max-width: 90%;
    }
    .ai-msg-bot { align-self: flex-start; }
    .ai-msg-user { align-self: flex-end; flex-direction: row-reverse; }

    .ai-msg-avatar {
        width: 2em; height: 2em;
        flex-shrink: 0;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--bf-primary) 0%, var(--bf-primary-dark) 100%);
        color: white;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.85em;
    }
    .ai-msg-bubble {
        background: white;
        border: 1px solid #e5e7eb;
        padding: 0.65em 0.85em;
        border-radius: 1em;
        border-top-left-radius: 0.25em;
        color: #1f2937;
        position: relative;
        min-width: 0;
        font-size: 1em;
    }
    .ai-msg-user .ai-msg-bubble {
        background: linear-gradient(135deg, var(--bf-primary) 0%, var(--bf-primary-dark) 100%);
        color: white;
        border: none;
        border-radius: 1em;
        border-top-right-radius: 0.25em;
    }
    .ai-msg-time {
        display: block;
        margin-top: 0.3em;
        font-size: 0.7em;
        opacity: .55;
    }

    .ai-msg-content { line-height: 1.5; }
    .ai-msg-content strong { font-weight: 600; }
    .ai-msg-content code {
        background: #f3f4f6;
        padding: 0.1em 0.35em;
        border-radius: 0.25em;
        font-size: 0.9em;
    }
    .ai-msg-content ul, .ai-msg-content ol {
        margin: 0.4em 0;
        padding-inline-start: 1.2em;
    }
    .ai-msg-content li { margin: 0.15em 0; }

    .ai-msg-copy {
        position: absolute;
        top: 0.4em;
        inset-inline-end: 0.4em;
        width: 1.8em; height: 1.8em;
        border-radius: 0.35em;
        border: none;
        background: rgba(0,0,0,.05);
        color: #6b7280;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        font-size: 0.8em;
        transition: background .15s ease;
    }
    .ai-msg-bubble:hover .ai-msg-copy { display: flex; }
    .ai-msg-copy:hover { background: rgba(0,0,0,.1); }

    .ai-typing { display: inline-flex; gap: 0.25em; padding: 0.15em 0; }
    .ai-typing span {
        width: 0.5em; height: 0.5em;
        border-radius: 50%;
        background: #9ca3af;
        animation: aiDot 1.2s infinite ease-in-out;
    }
    .ai-typing span:nth-child(2) { animation-delay: .15s; }
    .ai-typing span:nth-child(3) { animation-delay: .3s; }
    @@keyframes aiDot {
        0%, 60%, 100% { transform: translateY(0); opacity: .5; }
        30%           { transform: translateY(-30%); opacity: 1; }
    }

    .ai-chat-suggestions {
        padding: 0.55em 0.85em;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4em;
        border-top: 1px solid #e5e7eb;
        background: white;
    }
    .ai-chat-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.3em;
        padding: 0.4em 0.7em;
        font-size: 0.85em;
        color: var(--bf-primary-700);
        background: var(--bf-primary-50);
        border: 1px solid var(--bf-primary-200);
        border-radius: 999em;
        cursor: pointer;
        transition: background .15s ease;
    }
    .ai-chat-chip:hover { background: var(--bf-primary-100); }

    .ai-chat-input {
        display: flex;
        align-items: center;
        gap: 0.5em;
        padding: 0.65em 0.85em;
        border-top: 1px solid #e5e7eb;
        background: white;
    }
    .ai-chat-textbox {
        flex: 1;
        min-width: 0;
        padding: 0.65em 1em;
        border: 1px solid #e5e7eb;
        border-radius: 999em;
        background: #f9fafb;
        font-size: 1em;
        outline: none;
        transition: border-color .15s ease, background .15s ease;
    }
    .ai-chat-textbox:focus {
        border-color: var(--bf-primary);
        background: white;
    }
    .ai-chat-send {
        width: 2.75em; height: 2.75em;
        flex-shrink: 0;
        border-radius: 50%;
        border: none;
        background: linear-gradient(135deg, var(--bf-primary) 0%, var(--bf-primary-dark) 100%);
        color: white;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: opacity .15s ease;
        font-size: 1em;
    }
    .ai-chat-send:disabled { opacity: .4; cursor: not-allowed; }

    [dir="rtl"] .ai-chat-send i { transform: scaleX(-1); }

    .ai-chat-stop {
        width: 2.75em; height: 2.75em;
        flex-shrink: 0;
        border-radius: 50%;
        border: none;
        background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
        color: white;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 1em;
        animation: aiStopPulse 1.5s infinite;
        box-shadow: 0 0.25em 0.75em rgba(220, 38, 38, 0.4);
    }
    .ai-chat-stop:hover {
        background: linear-gradient(135deg, #b91c1c 0%, #991b1b 100%);
    }
    @@keyframes aiStopPulse {
        0%, 100% { transform: scale(1); }
        50%      { transform: scale(1.05); }
    }

    @@media (max-width: 30rem) {
        .ai-chat-fab-label { display: none; }
        .ai-chat-fab { padding: 0.85em; }
        .ai-chat-panel {
            width: calc(100vw - 1.5rem);
            height: calc(100vh - 8rem);
        }
    }

    /* ── Dark mode ── (surface/border/text aligned with the app dark theme;
       the brand-gradient header, avatars and user bubble stay as-is) */
    [data-theme="dark"] .ai-chat-panel {
        background: #1a2235;
        color: #e2e8f0;
    }
    [data-theme="dark"] .ai-chat-panel.maximized {
        border-inline-start-color: #334155;
    }
    [data-theme="dark"] .ai-chat-body {
        background: #0f172a;
    }
    [data-theme="dark"] .ai-msg-bubble {
        background: #1e293b;
        border-color: #334155;
        color: #e2e8f0;
    }
    [data-theme="dark"] .ai-msg-content code {
        background: #334155;
        color: #e2e8f0;
    }
    [data-theme="dark"] .ai-msg-copy {
        background: rgba(255,255,255,.08);
        color: #cbd5e1;
    }
    [data-theme="dark"] .ai-msg-copy:hover {
        background: rgba(255,255,255,.16);
    }
    [data-theme="dark"] .ai-chat-suggestions,
    [data-theme="dark"] .ai-chat-input {
        background: #1a2235;
        border-top-color: #334155;
    }
    [data-theme="dark"] .ai-chat-textbox {
        background: #0f172a;
        border-color: #334155;
        color: #e2e8f0;
    }
    [data-theme="dark"] .ai-chat-textbox::placeholder { color: #64748b; }
    [data-theme="dark"] .ai-chat-textbox:focus {
        background: #0f172a;
        border-color: var(--bf-primary);
    }
    [data-theme="dark"] .ai-chat-chip {
        background: rgba(16,185,129,.15);
        border-color: rgba(16,185,129,.35);
        color: #34d399;
    }
    [data-theme="dark"] .ai-chat-chip:hover { background: rgba(16,185,129,.25); }
    [data-theme="dark"] .ai-typing span { background: #64748b; }
    [data-theme="dark"] .ai-chat-resizer:hover,
    [data-theme="dark"] .ai-chat-resizer:active { background: rgba(16,185,129,.35); }

    /* ── Bot message actions (copy / report) ── */
    .ai-msg-actions {
        position: absolute;
        top: 0.4em;
        inset-inline-end: 0.4em;
        display: none;
        gap: 0.2em;
    }
    .ai-msg-bubble:hover .ai-msg-actions { display: flex; }
    .ai-msg-action {
        width: 1.8em; height: 1.8em;
        border-radius: 0.35em;
        border: none;
        background: rgba(0,0,0,.05);
        color: #6b7280;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.8em;
        transition: background .15s ease, color .15s ease;
    }
    .ai-msg-action:hover { background: rgba(0,0,0,.1); }

    /* ── Report-answer modal ── */
    .ai-report-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.5);
        z-index: 1100;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }
    .ai-report-card {
        background: #fff;
        color: #1f2937;
        width: 100%;
        max-width: 30rem;
        border-radius: 0.9em;
        box-shadow: 0 1.25em 3em rgba(0,0,0,.25);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        max-height: 85vh;
        animation: aiSlideUp .15s ease-out;
    }
    .ai-report-head {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.9em 1.1em;
        background: linear-gradient(135deg, var(--bf-primary) 0%, var(--bf-primary-dark) 100%);
        color: #fff;
    }
    .ai-report-x {
        width: 1.9em; height: 1.9em; border-radius: 0.4em; border: none;
        background: rgba(255,255,255,.15); color: #fff; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
    }
    .ai-report-x:hover { background: rgba(255,255,255,.28); }
    .ai-report-body { padding: 1em 1.1em; overflow-y: auto; }
    .ai-report-muted { color: #6b7280; }
    .ai-report-snippet {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
