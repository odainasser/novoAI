@using Web.Models.UserLogs
@using System.Globalization
@inject IUserLogService LogService
@inject IUserManagementService UserService
@inject IJsonStringLocalizer Localizer

@if (IsVisible)
{
    var cultureInfo = CultureInfo.CurrentUICulture.Name.StartsWith("ar") ? new CultureInfo("ar-AE") : new CultureInfo("en-AE");

    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm overflow-y-auto h-full w-full z-50 flex items-center justify-center" @onclick="HandleBackgroundClick">
        <div class="bg-white rounded-xl shadow-lg max-w-4xl w-full mx-4 max-h-[90vh] overflow-hidden flex flex-col" @onclick:stopPropagation>
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 flex-shrink-0">
                <div>
                    @if (UserId.HasValue && string.IsNullOrEmpty(EntityName))
                    {
                        <h3 class="text-lg font-semibold text-gray-900">@Localizer["UserLogs"]</h3>
                        <p class="text-sm text-gray-500">@Localizer["ShowingLogsFor"] <strong>@(userDisplayName ?? UserId.ToString())</strong></p>
                    }
                    else if (!string.IsNullOrEmpty(EntityName))
                    {
                        var url = GetEntityUrl(EntityName, EntityId);
                        <h3 class="text-lg font-semibold text-gray-900">@Localizer["Logs"]</h3>
                        if (!string.IsNullOrEmpty(url))
                        {
                            <p class="text-sm text-gray-500">@Localizer["ShowingLogsFor"] <a href="@url" class="font-semibold text-bf-primary hover:underline">@Localizer[$"Entity_{EntityName}"]</a></p>
                        }
                        else
                        {
                            <p class="text-sm text-gray-500">@Localizer["ShowingLogsFor"] <strong>@Localizer[$"Entity_{EntityName}"]</strong></p>
                        }
                    }
                    else
                    {
                        <h3 class="text-lg font-semibold text-gray-900">@Localizer["AuditLogs"]</h3>
                    }
                </div>
                <button @onclick="Close" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="px-5 py-4 overflow-y-auto flex-1">

            @if (isLoading)
            {
                <Spinner Size="Spinner.SpinnerSize.Md" Centered="true" />
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="p-4 bg-red-50 border border-red-200 rounded-lg flex items-start gap-3">
                    <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                    <span class="text-red-800">@errorMessage</span>
                </div>
            }
            else if (logs == null || !logs.Any())
            {
                <div class="text-center py-12">
                    <i class="bi bi-inbox text-4xl text-gray-300 mb-3 block"></i>
                    <p class="text-sm text-gray-500">@Localizer["NoLogsFound"]</p>
                </div>
            }
            else
            {
                <div class="border border-gray-200 rounded-lg overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["DateTime"]</th>
                                    @if (UserId.HasValue && string.IsNullOrEmpty(EntityName))
                                    {
                                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Action"]</th>
                                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Entity"]</th>
                                    }
                                    else
                                    {
                                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["User"]</th>
                                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Action"]</th>
                                        <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Entity"]</th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                @foreach (var log in logs)
                                {
                                    <tr class="hover:bg-gray-50 transition-colors duration-150">
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@log.Timestamp.ToLocal().ToString("yyyy-MM-dd HH:mm")</td>
                                        @if (UserId.HasValue && string.IsNullOrEmpty(EntityName))
                                        {
                                            <td class="px-6 py-4 whitespace-nowrap text-sm"><span class="@GetActionBadgeClass(log.Action)">@Localizer[$"Action_{log.Action}"]</span></td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                @if (!string.IsNullOrEmpty(log.EntityName))
                                                {
                                                    var url = GetEntityUrl(log.EntityName, log.EntityId);
                                                    var localizedEntityName = Localizer[$"Entity_{log.EntityName}"];
                                                    if (!string.IsNullOrEmpty(log.EntityId) && !string.IsNullOrEmpty(url))
                                                    {
                                                        <a class="text-blue-600 hover:underline" href="@url" target="_blank" rel="noopener noreferrer">@localizedEntityName</a>
                                                    }
                                                    else
                                                    {
                                                        <span>@localizedEntityName</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-gray-400">-</span>
                                                }
                                            </td>
                                        }
                                        else
                                        {
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <div class="text-sm font-medium text-gray-900">
                                                    @if (log.UserId != Guid.Empty)
                                                    {
                                                        <a href="/admin/users/edit/@log.UserId" class="text-bf-primary hover:underline">@log.UserName</a>
                                                    }
                                                    else
                                                    {
                                                        @log.UserName
                                                    }
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm"><span class="@GetActionBadgeClass(log.Action)">@Localizer[$"Action_{log.Action}"]</span></td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                @if (!string.IsNullOrEmpty(log.EntityName))
                                                {
                                                    var url = GetEntityUrl(log.EntityName, log.EntityId);
                                                    var localizedEntityName = Localizer[$"Entity_{log.EntityName}"];
                                                    if (!string.IsNullOrEmpty(log.EntityId) && !string.IsNullOrEmpty(url))
                                                    {
                                                        <a class="text-blue-600 hover:underline" href="@url" target="_blank" rel="noopener noreferrer">@localizedEntityName</a>
                                                    }
                                                    else
                                                    {
                                                        <span>@localizedEntityName</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-gray-400">-</span>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            }

            </div>

            <div class="flex items-center justify-between px-5 py-4 border-t border-gray-200 flex-shrink-0">
                <div class="flex items-center gap-3">
                    <label class="text-sm text-gray-600">@Localizer["PageSize"]</label>
                    <select @onchange="OnPageSizeChanged" class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-bf-primary focus:border-transparent">
                        <option value="10" selected="@(pageSize==10)">10</option>
                        <option value="25" selected="@(pageSize==25)">25</option>
                        <option value="50" selected="@(pageSize==50)">50</option>
                    </select>
                </div>
                <div class="flex items-center gap-2">
                    <Pagination PageIndex="@pageIndex" TotalPages="@totalPages" TotalCount="@totalCount" PageSize="@pageSize" OnPageChanged="@OnPageChanged" Compact="true" />
                    <button @onclick="Close" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">@Localizer["Close"]</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public Guid? UserId { get; set; }
    [Parameter] public string? EntityName { get; set; }
    [Parameter] public string? EntityId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private List<UserLogDto> logs = new();
    private bool isLoading = false;
    private string? errorMessage;
    private int pageIndex = 1;
    private int pageSize = 10; // show 10 records per page in modal
    private int totalPages = 1;
    private int totalCount = 0;
    private string? userDisplayName;

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible)
        {
            // reset paging whenever modal opens or filter changes
            pageIndex = 1;
            await LoadLogs();
        }
    }

    private async Task LoadLogs()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            var result = await LogService.GetLogsAsync(pageIndex, pageSize, UserId, EntityName, EntityId);
            logs = result.Items;
            totalPages = result.TotalPages;
            totalCount = result.TotalCount;

            if (UserId.HasValue)
            {
                userDisplayName = logs.FirstOrDefault()?.UserName;
                if (string.IsNullOrWhiteSpace(userDisplayName))
                {
                    var user = await UserService.GetUserByIdAsync(UserId.Value);
                    if (user != null) userDisplayName = !string.IsNullOrWhiteSpace(user.FullName) ? user.FullName : user.Email;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            logs = new List<UserLogDto>();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void Close()
    {
        OnClose.InvokeAsync();
    }

    private async Task OnPageChanged(int newPage)
    {
        pageIndex = newPage;
        await LoadLogs();
    }

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e?.Value?.ToString(), out var newSize) && newSize > 0)
        {
            pageSize = newSize;
            pageIndex = 1;
            await LoadLogs();
        }
    }

    private void HandleBackgroundClick()
    {
        Close();
    }

    private string GetActionBadgeClass(string action)
    {
        if (string.IsNullOrEmpty(action))
            return "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800";

        switch (action.Trim().ToLowerInvariant())
        {
            case "created":
                return "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800";
            case "updated":
                return "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800";
            case "deleted":
                return "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800";
            default:
                return "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800";
        }
    }


    private string? GetEntityUrl(string? entityName, string? entityId)
    {
        if (string.IsNullOrWhiteSpace(entityName) || string.IsNullOrWhiteSpace(entityId))
            return null;

        var name = entityName.Trim().ToLowerInvariant();

        return name switch
        {
            "user" or "users" => $"/admin/users/edit/{entityId}",
            "role" or "roles" => $"/admin/roles/edit/{entityId}",
            "lookup" or "lookups" => $"/admin/lookups/edit/{entityId}",
            "category" or "categories" => $"/admin/categories/edit/{entityId}",
            "product" or "products" => $"/admin/products/edit/{entityId}",
            "unit" or "units" => $"/admin/catalog/units/edit/{entityId}",
            "promotion" or "promotions" => $"/admin/promotions/edit/{entityId}",
            "supplier" or "suppliers" => $"/admin/suppliers/edit/{entityId}",
            "warehouse" or "warehouses" => $"/admin/warehouses/edit/{entityId}",
            "terminal" or "terminals" => $"/admin/terminals/edit/{entityId}",
            "cashier" or "cashiers" => $"/admin/users/edit/{entityId}",
            "branch" or "branches" => $"/admin/branches/edit/{entityId}",
            "order" or "orders" => "/admin/orders",
            "shift" or "shifts" => "/admin/shifts",
            "goodsreceivingnote" or "goodsreceiving" or "grn" => $"/admin/inventory/grn?id={entityId}",
            "stockadjustment" => $"/admin/inventory/adjustments?id={entityId}",
            "stocktransfer" => $"/admin/inventory/transfers?id={entityId}",
            _ => null
        };
    }
}
