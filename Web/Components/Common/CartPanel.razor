@using Web.Models.Products
@using Web.Models.Orders
@typeparam TCartItem

<div class="flex-1 overflow-y-auto px-3 py-3 bg-gray-50">
    @if (!CartItems.Any())
    {
        <div class="flex flex-col items-center justify-center h-full text-center p-6">
            <div class="w-24 h-24 rounded-2xl bf-bg-info-50 border bf-border-info flex items-center justify-center mb-4">
                <i class="bi bi-cart3 text-4xl bf-text-info"></i>
            </div>
            <p class="text-sm font-semibold text-gray-700">@Localizer["CartEmpty"]</p>
            <p class="text-xs text-gray-400 mt-1">@Localizer["SelectItemsToAdd"]</p>
        </div>
    }
    else
    {
        <div class="space-y-2">
            @foreach (var rawItem in CartItems)
            {
                var item = GetDynamic(rawItem);
                <div class="group bg-white rounded-xl border border-gray-200 px-3 py-2.5 hover:border-emerald-300 hover:shadow-sm transition-all duration-150">
                    <!-- Row 1: Name + Remove -->
                    <div class="flex items-start justify-between gap-2">
                        <p class="font-semibold text-gray-900 text-sm leading-snug truncate">@(IsAr ? item.Product.NameAr : item.Product.NameEn)</p>
                        <button @onclick="() => OnRemoveItem.InvokeAsync(rawItem)"
                                title="@Localizer["Remove"]"
                                class="shrink-0 w-6 h-6 flex items-center justify-center text-gray-300 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all opacity-60 group-hover:opacity-100 focus:opacity-100">
                            <i class="bi bi-x-lg text-[11px]"></i>
                        </button>
                    </div>

                    <!-- Row 2: Badges -->
                    @if (item.SelectedUnit != null || item.HasDiscount)
                    {
                        <div class="flex flex-wrap items-center gap-1.5 mt-1.5">
                            @if (item.SelectedUnit != null)
                            {
                                <span class="text-[10px] bf-bg-info-50 bf-text-info px-2 py-0.5 rounded-md font-semibold border bf-border-info">
                                    @(IsAr ? item.SelectedUnit.UnitOfMeasureNameAr : item.SelectedUnit.UnitOfMeasureNameEn)
                                </span>
                            }
                            @if (item.HasDiscount)
                            {
                                <span class="text-[10px] bg-red-50 text-red-600 px-2 py-0.5 rounded-md font-semibold border border-red-100 inline-flex items-center gap-1">
                                    <i class="bi bi-tag-fill"></i>@Localizer["OnPromotion"]
                                </span>
                            }
                        </div>
                    }

                    <!-- Row 3: Unit price · Stepper · Line total -->
                    <div class="flex items-center justify-between gap-3 mt-2.5">
                        <!-- Unit price -->
                        <div class="text-[11px] text-gray-500 font-medium min-w-0">
                            @if (item.HasDiscount)
                            {
                                <div class="flex items-center gap-1.5">
                                    <span class="line-through text-gray-400">@item.OriginalUnitPrice.ToString("N2", CultureInfo)</span>
                                    <span class="bf-text-info font-bold">@item.UnitPrice.ToString("N2", CultureInfo)</span>
                                    <span class="text-gray-400">/ @Localizer["Each"]</span>
                                </div>
                            }
                            else
                            {
                                <span>@item.UnitPrice.ToString("N2", CultureInfo) @Localizer["CurrencyUnit"] / @Localizer["Each"]</span>
                            }
                        </div>

                        <div class="flex items-center gap-3 shrink-0">
                            <!-- Quantity stepper -->
                            <div class="flex items-center h-9 rounded-lg border border-gray-200 bg-gray-50 overflow-hidden shrink-0">
                                <button @onclick="() => OnDecreaseQuantity.InvokeAsync(rawItem)"
                                        class="w-8 h-full flex items-center justify-center text-gray-500 hover:bg-bf-primary hover:text-bf-primary-contrast transition-colors">
                                    <i class="bi bi-dash text-base"></i>
                                </button>
                                <input type="number" min="1"
                                       value="@item.Quantity"
                                       @onchange="e => OnSetQuantity.InvokeAsync((rawItem, e.Value?.ToString()))"
                                       class="w-10 h-full text-center font-bold text-[13px] text-gray-900 bg-white border-x border-gray-200 p-0 focus:outline-none focus:ring-1 focus:ring-bf-primary [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
                                <button @onclick="() => OnIncreaseQuantity.InvokeAsync(rawItem)"
                                        class="w-8 h-full flex items-center justify-center text-gray-500 hover:bg-bf-primary hover:text-bf-primary-contrast transition-colors">
                                    <i class="bi bi-plus text-base"></i>
                                </button>
                            </div>

                            <!-- Line total -->
                            <div class="text-end min-w-[4.5rem]">
                                @if (item.HasDiscount)
                                {
                                    <span class="block text-[10px] text-gray-400 line-through leading-none">@item.OriginalTotal.ToString("N2", CultureInfo)</span>
                                    <span class="block font-extrabold text-sm bf-text-info leading-tight">@item.Total.ToString("N2", CultureInfo) <span class="text-[10px] font-semibold text-gray-400">@Localizer["CurrencyUnit"]</span></span>
                                }
                                else
                                {
                                    <span class="font-extrabold text-sm text-gray-900">@item.Total.ToString("N2", CultureInfo) <span class="text-[10px] font-semibold text-gray-400">@Localizer["CurrencyUnit"]</span></span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Cart Summary -->
<div class="border-t border-gray-200 bg-white px-4 pt-3 pb-4">
    <div class="space-y-2 mb-3">
        <div class="flex justify-between text-sm">
            <span class="text-gray-500">@Localizer["SubtotalItems", TotalItems]</span>
            <span class="font-semibold text-gray-700">@Subtotal.ToString("N2", CultureInfo) @Localizer["CurrencyUnit"]</span>
        </div>
        @if (TotalDiscount > 0)
        {
            <div class="flex justify-between text-sm bf-text-info">
                <span class="flex items-center gap-1.5">
                    <i class="bi bi-tag-fill"></i>
                    @Localizer["Discount"]
                </span>
                <span class="font-semibold">-@TotalDiscount.ToString("N2", CultureInfo) @Localizer["CurrencyUnit"]</span>
            </div>
        }
        <div class="flex justify-between text-sm">
            <span class="text-gray-500">@Localizer["VAT"]</span>
            <span class="font-semibold text-gray-700">@Vat.ToString("N2", CultureInfo) @Localizer["CurrencyUnit"]</span>
        </div>
    </div>

    <!-- Total -->
    <div class="flex justify-between items-center rounded-xl bf-bg-info-50 border bf-border-info px-4 py-3 mb-3">
        <span class="text-gray-900 font-bold text-base">@Localizer["Total"]</span>
        <span class="bf-text-info font-extrabold text-2xl tracking-tight">@Total.ToString("N2", CultureInfo) <span class="text-sm font-bold">@Localizer["CurrencyUnit"]</span></span>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="mb-3 p-2.5 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm flex items-center gap-2">
            <i class="bi bi-exclamation-circle-fill shrink-0"></i>
            <span>@ErrorMessage</span>
        </div>
    }

    @PaymentContent
</div>

@code {
    [Parameter] public IEnumerable<TCartItem> CartItems { get; set; } = Array.Empty<TCartItem>();
    [Parameter] public bool IsAr { get; set; }
    [Parameter] public System.Globalization.CultureInfo CultureInfo { get; set; } = default!;
    [Parameter] public int TotalItems { get; set; }
    [Parameter] public decimal Subtotal { get; set; }
    [Parameter] public decimal TotalDiscount { get; set; }
    [Parameter] public decimal Vat { get; set; }
    [Parameter] public decimal Total { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }

    [Parameter] public RenderFragment PaymentContent { get; set; } = default!;

    [Parameter] public EventCallback<TCartItem> OnIncreaseQuantity { get; set; }
    [Parameter] public EventCallback<TCartItem> OnDecreaseQuantity { get; set; }
    [Parameter] public EventCallback<(TCartItem Item, string? Value)> OnSetQuantity { get; set; }
    [Parameter] public EventCallback<TCartItem> OnRemoveItem { get; set; }

    // Use reflection or interface pattern dynamically since we need to render specific properties,
    // but the actual object Type will carry through to WebAssembly to prevent runtime exceptions.
    // Or simpler, let Blazor infer properties by casting within the loop.
    private dynamic GetDynamic(TCartItem item) => item!;
}
